<% layout('/layout/boilerplate') -%>
<style>
  .tape-id-success {
    border: 2px solid #28a745 !important;
    background-color: #f3fff6;
    color: #155724;
    font-weight: 600;
  }
  .tape-id-error {
    border: 2px solid #dc3545 !important;
    background-color: #fff5f5;
    color: #721c24;
    font-weight: 600;
  }
  input[readonly] { background: #f1f5f9; cursor: not-allowed; }
</style>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <form
    class="needs-validation"
    action="/fairtech/tape-binding/edit/<%= binding._id %>"
    method="post"
    onsubmit="return validateBeforeSubmit()"
    autocomplete="off"
    novalidate
  >
    <input type="hidden" name="returnTo" value="<%= returnTo || '' %>" />
    <input type="hidden" name="tapeId" id="resolved-tape-id" value="<%= binding.tapeId?._id || '' %>" />

    <div class="span-full form-heading">
      <h1>Edit Tape Binding</h1>
    </div>

    <!-- ================= USER INFO (READ-ONLY) ================= -->
    <div class="span-full form-subheading">
      <h1>User Information</h1>
    </div>

    <div class="span-seven">
      <label>Tape ID</label>
      <input type="text" id="tape-id-display" class="form-control input-tag"
        value="<%= binding.tapeId?.tapeProductId || 'N/A' %>" readonly />
    </div>
    <div class="span-six">
      <label>Client Name</label>
      <input type="text" class="form-control input-tag" value="<%= binding.userId?.clientName || '' %>" readonly />
    </div>
    <div class="span-six">
      <label>User Name</label>
      <input type="text" class="form-control input-tag" value="<%= binding.userId?.userName || '' %>" readonly />
    </div>
    <div class="span-six">
      <label>User Contact</label>
      <input type="text" class="form-control input-tag" value="<%= binding.userId?.userContact || '' %>" readonly />
    </div>
    <div class="span-seven">
      <label>Location</label>
      <input type="text" class="form-control input-tag" value="<%= binding.userId?.userLocation || '' %>" readonly />
    </div>

    <!-- ================= TAPE SPECIFICATIONS ================= -->
    <div class="span-full form-subheading" style="display: flex; justify-content: space-between; align-items: center;">
      <h1>Tape Specifications</h1>
      <button type="button" id="reset-specs-btn" style="padding: 4px 12px; border-radius: 4px; background-color: #dc3545; color: white; border: none; cursor: pointer; font-size: 14px;">Reset</button>
    </div>

    <div class="span-five">
      <label>Paper Code</label>
      <select name="tapePaperCode" id="tape-paper-code" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% paperCodes?.forEach(pc => { %>
          <option value="<%= pc %>"><%= pc %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-five">
      <label>Paper Type</label>
      <select name="tapePaperType" id="tape-paper-type" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% paperTypes?.forEach(pt => { %>
          <option value="<%= pt %>"><%= pt %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-four">
      <label>GSM</label>
      <select name="tapeGsm" id="tape-gsm" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% gsms?.forEach(g => { %>
          <option value="<%= g %>"><%= g %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-four">
      <label>Width</label>
      <select name="tapeWidth" id="tape-width" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% widths?.forEach(w => { %>
          <option value="<%= w %>"><%= w %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-five">
      <label>MTRS</label>
      <select name="tapeMtrs" id="tape-mtrs" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% mtrsList?.forEach(m => { %>
          <option value="<%= m %>"><%= m %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-five">
      <label>Core ID</label>
      <select name="tapeCoreId" id="tape-core-id" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% coreIds?.forEach(c => { %>
          <option value="<%= c %>"><%= c %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-four">
      <label>Finish</label>
      <select name="tapeFinish" id="tape-finish" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Search</option>
        <% finishes?.forEach(f => { %>
          <option value="<%= f %>"><%= f %></option>
        <% }) %>
      </select>
    </div>

    <!-- ================= CLIENT SPECIFICATIONS ================= -->
    <div class="span-full form-subheading">
      <h1>Client Specifications</h1>
    </div>

    <div class="span-five">
      <label>Client Paper Code</label>
      <input type="text" id="tape-client-paper-code" name="tapeClientPaperCode" class="form-control"
        value="<%= binding.tapeClientPaperCode %>" required />
    </div>
    <div class="span-five">
      <label>Client GSM</label>
      <input type="text" id="tape-client-gsm" name="clientTapeGsm" class="form-control"
        value="<%= binding.clientTapeGsm %>" required />
    </div>
    <div class="span-five">
      <label>Client Item Type</label>
      <input type="text" id="item-client-item-type" name="itemClientItemType" class="form-control"
        value="<%= binding.itemClientItemType || '' %>" />
    </div>
    <div class="span-five">
      <label>MTRS Delivered</label>
      <input type="text" name="tapeMtrsDel" class="form-control"
        value="<%= binding.tapeMtrsDel %>" required />
    </div>
    <div class="span-six">
      <label>Rate Per Roll</label>
      <input type="text" id="tape-rate-per-roll" name="tapeRatePerRoll" class="form-control"
        value="<%= binding.tapeRatePerRoll %>" required />
    </div>
    <div class="span-six">
      <label>Sales sq mtrs Cost</label>
      <input type="text" id="tape-sale-cost" name="tapeSaleCost" class="form-control"
        value="<%= binding.tapeSaleCost %>" tabindex="-1" required readonly />
    </div>

    <!-- ================= PRICING & ORDER TERMS ================= -->
    <div class="span-full form-subheading">
      <h1>Pricing & Order Terms</h1>
    </div>

    <div class="span-seven">
      <label>Minimum Order QTY</label>
      <input type="text" id="tape-min-qty" name="tapeMinQty" class="form-control"
        value="<%= binding.tapeMinQty %>" required />
    </div>
    <div class="span-six">
      <label>Order QTY</label>
      <input type="text" id="tape-odr-qty" name="tapeOdrQty" class="form-control"
        value="<%= binding.tapeOdrQty %>" required />
    </div>
    <div class="span-seven">
      <label>Repeat Order Freq</label>
      <input type="text" name="tapeOdrFreq" class="form-control"
        value="<%= binding.tapeOdrFreq || '' %>" required />
    </div>
    <div class="span-six">
      <label>CR</label>
      <input type="text" name="tapeCreditTerm" class="form-control"
        value="<%= binding.tapeCreditTerm || '' %>" required />
    </div>
    <div class="span-six">
      <label>Status</label>
      <select name="status" class="form-control select-tag" required>
        <option value="ACTIVE" <%= binding.status === "ACTIVE" ? "selected" : "" %>>ACTIVE</option>
        <option value="INACTIVE" <%= binding.status === "INACTIVE" ? "selected" : "" %>>INACTIVE</option>
      </select>
    </div>

    <!-- ================= BUTTONS ================= -->
    <div class="span-full btn-grp" style="flex-direction: row-reverse;">
      <button class="submit-btn" type="submit">Update Tape Binding</button>
      <button type="button" id="cancelBtn">Cancel</button>
    </div>
  </form>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const CURRENT = {
    tapePaperCode: "<%= binding.tapeId?.tapePaperCode || '' %>",
    tapePaperType: "<%= binding.tapeId?.tapePaperType || '' %>",
    tapeGsm:       "<%= binding.tapeId?.tapeGsm || '' %>",
    tapeWidth:     "<%= binding.tapeId?.tapeWidth || '' %>",
    tapeMtrs:      "<%= binding.tapeId?.tapeMtrs || '' %>",
    tapeCoreId:    "<%= binding.tapeId?.tapeCoreId || '' %>",
    tapeFinish:    "<%= binding.tapeId?.tapeFinish || '' %>",
  };

  const tapeFields = [
    "tape-paper-code",
    "tape-paper-type",
    "tape-gsm",
    "tape-width",
    "tape-mtrs",
    "tape-core-id",
    "tape-finish",
  ];

  const fieldToApiKey = {
    "tape-paper-code": "paperCodes",
    "tape-paper-type": "paperTypes",
    "tape-gsm":        "gsms",
    "tape-width":      "widths",
    "tape-mtrs":       "mtrsList",
    "tape-core-id":    "coreIds",
    "tape-finish":     "finishes",
  };

  const fieldToParam = {
    "tape-paper-code": "tapePaperCode",
    "tape-paper-type": "tapePaperType",
    "tape-gsm":        "tapeGsm",
    "tape-width":      "tapeWidth",
    "tape-mtrs":       "tapeMtrs",
    "tape-core-id":    "tapeCoreId",
    "tape-finish":     "tapeFinish",
  };

  const tapeIdInput   = document.getElementById("resolved-tape-id");
  const tapeIdDisplay = document.getElementById("tape-id-display");
  const rateInput     = document.getElementById("tape-rate-per-roll");
  const saleCostInput = document.getElementById("tape-sale-cost");

  /* ── Choices init ── */
  const specChoices = {};
  tapeFields.forEach(id => {
    const el = document.getElementById(id);
    if (el) specChoices[id] = new Choices(el, { searchEnabled: true, shouldSort: false, itemSelectText: "" });
  });

  /* ── Rate calc ── */
  function calcSaleCost() {
    const width = Number(document.getElementById("tape-width")?.value) || 0;
    const mtrs  = Number(document.getElementById("tape-mtrs")?.value)  || 0;
    const rate  = Number(rateInput?.value) || 0;
    if (!width || !mtrs || !rate) { saleCostInput.value = ""; return; }
    saleCostInput.value = (rate / ((width * mtrs) / 1000)).toFixed(4);
  }

  rateInput?.addEventListener("input", calcSaleCost);

  /* ── Smart filter ── */
  async function filterSpecs(changedFieldId) {
    const params = new URLSearchParams();
    tapeFields.forEach(id => {
      const el = document.getElementById(id);
      if (el && el.value) params.set(fieldToParam[id], el.value);
    });

    try {
      const res  = await fetch(`/fairtech/form/tape-binding/filter-specs?${params}`);
      const data = await res.json();
      if (!data) return;

      const autoSelected = [];
      tapeFields.forEach(id => {
        if (id === changedFieldId) return;
        const inst = specChoices[id];
        if (!inst) return;
        const filteredValues = data[fieldToApiKey[id]] || [];
        const currentValue   = document.getElementById(id)?.value || "";

        const newChoices = filteredValues.map(v => ({
          value: String(v), label: String(v), selected: String(v) === currentValue,
        }));

        if (changedFieldId !== "reset-all" && filteredValues.length === 1 && !currentValue) {
          newChoices[0].selected = true;
          autoSelected.push(id);
        }

        inst.clearStore();
        inst.setChoices(
          [{ value: "", label: "Search", disabled: true, selected: !newChoices.some(c => c.selected) }, ...newChoices],
          "value", "label", true
        );

        if (currentValue && filteredValues.map(String).includes(currentValue)) {
          inst.setChoiceByValue(currentValue);
        } else if (changedFieldId !== "reset-all" && filteredValues.length === 1 && !currentValue) {
          inst.setChoiceByValue(String(filteredValues[0]));
        }
      });

      if (autoSelected.length) await filterSpecs(autoSelected[0]);
    } catch (err) {
      console.error("Filter specs error:", err);
    }
  }

  /* ── Resolve tape ── */
  async function resolveTape() {
    const values = {};
    for (const id of tapeFields) {
      const el = document.getElementById(id);
      if (!el || !el.value) {
        tapeIdInput.value = "";
        tapeIdDisplay.value = "— select all specs —";
        tapeIdDisplay.className = "form-control input-tag";
        return;
      }
      values[id] = el.value;
    }

    const params = new URLSearchParams({
      tapePaperCode: values["tape-paper-code"],
      tapePaperType: values["tape-paper-type"],
      tapeGsm:       values["tape-gsm"],
      tapeWidth:     values["tape-width"],
      tapeMtrs:      values["tape-mtrs"],
      tapeCoreId:    values["tape-core-id"],
      tapeFinish:    values["tape-finish"],
    });

    try {
      const res = await fetch(`/fairtech/form/tape-binding/resolve-tape?${params}`);
      if (!res.ok) {
        tapeIdInput.value  = "";
        tapeIdDisplay.value = "No matching tape found";
        tapeIdDisplay.className = "form-control input-tag tape-id-error";
        return;
      }
      const data = await res.json();
      tapeIdInput.value  = data.tapeId;
      tapeIdDisplay.value = data.tapeProductId;
      tapeIdDisplay.className = "form-control input-tag tape-id-success";
      calcSaleCost();
    } catch (err) {
      console.error("Resolve tape error:", err);
    }
  }

  /* ── Spec change handler ── */
  tapeFields.forEach(id => {
    document.getElementById(id)?.addEventListener("change", async () => {
      await filterSpecs(id);
      await resolveTape();
    });
  });

  /* ── Reset ── */
  document.getElementById("reset-specs-btn").addEventListener("click", async () => {
    tapeFields.forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = "";
      specChoices[id]?.setChoiceByValue("");
    });
    tapeIdInput.value  = "";
    tapeIdDisplay.value = "";
    tapeIdDisplay.className = "form-control input-tag";
    await filterSpecs("reset-all");
  });

  /* ── Cancel ── */
  document.getElementById("cancelBtn").addEventListener("click", () => window.history.back());

  /* ── Init: prefill dropdowns with current binding specs ── */
  (async () => {
    // First pass — populate all lists unfiltered
    await filterSpecs("init-none");

    // Set each field to the current binding value
    for (const [id, paramKey] of Object.entries(fieldToParam)) {
      const val = CURRENT[paramKey];
      if (val && specChoices[id]) specChoices[id].setChoiceByValue(String(val));
    }

    // Cascade-filter with all values set
    await filterSpecs("init-none");

    // Re-apply values in case cascade cleared any
    for (const [id, paramKey] of Object.entries(fieldToParam)) {
      const val = CURRENT[paramKey];
      if (val && specChoices[id]) specChoices[id].setChoiceByValue(String(val));
    }

    await resolveTape();
  })();
});

function validateBeforeSubmit() {
  const tapeId = document.getElementById("resolved-tape-id").value;
  if (!tapeId) {
    showToast("Please select valid tape specifications.", "error");
    return false;
  }
  const minQty = Number(document.getElementById("tape-min-qty")?.value);
  const odrQty = Number(document.getElementById("tape-odr-qty")?.value);
  if (minQty >= odrQty) {
    showToast("Order Quantity must be greater than Minimum Order Quantity", "error");
    return false;
  }
  return true;
}
</script>
