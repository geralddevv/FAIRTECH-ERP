<% layout('/layout/boilerplate') -%>

<style>
  .kv-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border: 1.5px solid #e6eaf2;
    border-radius: 10px;
    overflow: hidden;
  }
  .kv-table tr:last-child td {
    border-bottom: none;
  }
  .kv-table td {
    padding: 11px 14px;
    border-bottom: 1px solid #e6eaf2;
    font-size: 14px;
    vertical-align: middle;
  }
  .kv-table td.kv-label {
    width: 16.66%;
    color: #5a6586;
    font-weight: 600;
    background: #f8fbff;
    border-right: 1.5px solid #e6eaf2;
    white-space: nowrap;
  }
  .kv-table td.kv-value {
    width: 16.66%;
    color: #1f2a44;
    font-weight: 500;
    border-right: 1.5px solid #e6eaf2;
  }
  .kv-table tr > td:last-child {
    border-right: none;
  }
  .kv-table thead th {
    background: #044a78;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    padding: 11px 14px;
    text-align: left;
  }
</style>

<div class="main-content">
  <form
    class="needs-validation"
    action="/fairtech/vendor-item/edit/tape/<%= binding._id %>"
    method="post"
    autocomplete="off"
    novalidate
  >
    <input type="hidden" name="returnTo" value="<%= returnTo || '' %>" />

    <div
      class="span-full form-subheading gap"
      style="display: flex; justify-content: space-between; align-items: center"
    >
      <h1 style="margin: 0">Edit Vendor Tape Binding</h1>
    </div>

    <%
      // The binding's own location can be missing on older records -- fall
      // back to the vendor user's location the same way the old <select>
      // effectively did (defaulting to the only/first option when nothing
      // matched binding.location).
      const displayLocation = binding.location || (userLocations || [])[0] || '';
    %>
    <input type="hidden" name="location" value="<%= displayLocation %>" />
    <%
      const kvPairs = [
        ["Tape ID", binding.tapeId?.tapeProductId || 'N/A'],
        ["Vendor Name", binding.vendorUserId?.vendorName || 'N/A'],
        ["Vendor User", binding.vendorUserId?.userName || 'N/A'],
        ["Location", displayLocation || 'N/A'],
        ["Paper Code", binding.tapeId?.tapePaperCode || 'N/A'],
        ["Paper Type", binding.tapeId?.tapePaperType || 'N/A'],
        ["GSM", binding.tapeId?.tapeGsm || 'N/A'],
        ["Width", binding.tapeId?.tapeWidth || 'N/A'],
        ["MTRS", binding.tapeId?.tapeMtrs || 'N/A'],
        ["Core ID", binding.tapeId?.tapeCoreId || 'N/A'],
        ["Finish", binding.tapeId?.tapeFinish || 'N/A'],
      ];
      const perRow = 3;
      const kvRows = [];
      for (let i = 0; i < kvPairs.length; i += perRow) {
        kvRows.push(kvPairs.slice(i, i + perRow));
      }
    %>
    <div class="span-full">
      <table class="kv-table">
        <thead>
          <tr><th colspan="6">Tape Specifications</th></tr>
        </thead>
        <tbody>
          <% kvRows.forEach(row => { %>
            <tr>
              <% row.forEach(([label, value]) => { %>
                <td class="kv-label"><%= label %></td>
                <td class="kv-value"><%= value %></td>
              <% }) %>
              <% for (let i = row.length; i < perRow; i++) { %>
                <td class="kv-label"></td>
                <td class="kv-value"></td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="span-full form-subheading">
      <h1>Vendor Overrides</h1>
    </div>

    <div class="span-six">
      <label>Vendor Paper Code</label>
      <input
        type="text"
        name="vendorTapePaperCode"
        class="form-control"
        value="<%= binding.vendorTapePaperCode %>"
        required
      />
    </div>

    <div class="span-six">
      <label>Vendor Paper Type</label>
      <input
        type="text"
        name="vendorTapePaperType"
        class="form-control"
        value="<%= binding.vendorTapePaperType %>"
        required
      />
    </div>

    <div class="span-six">
      <label>Vendor GSM</label>
      <input type="number" name="vendorTapeGsm" class="form-control" value="<%= binding.vendorTapeGsm %>" required />
    </div>

    <div class="span-six">
      <label>MSQ</label>
      <input type="number" name="tapeMinQty" class="form-control" value="<%= binding.tapeMinQty %>" min="0" required />
    </div>

    <div class="span-eight">
      <label>Rate</label>
      <input type="number" name="tapeRatePerRoll" class="form-control" value="<%= binding.tapeRatePerRoll %>" step="0.01" min="0" />
    </div>

    <div class="span-full btn-grp" style="flex-direction: row-reverse">
      <button class="submit-btn" type="submit">Update Vendor Tape Binding</button>
      <button type="button" id="cancelBtn">Cancel</button>
    </div>
  </form>
</div>

<script>
  const form = document.querySelector("form");
  const submitBtn = form.querySelector('button[type="submit"]');
  const returnTo = <%- safeJson(returnTo || "") %>;

  document.getElementById("cancelBtn").addEventListener("click", () => {
    if (returnTo) {
      window.location.href = returnTo;
      return;
    }
    window.history.back();
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    submitBtn.disabled = true;

    try {
      const res = await fetch(form.action, {
        method: "POST",
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      });
      const data = await res.json();

      if (!res.ok || !data?.success) {
        submitBtn.disabled = false;
        if (window.showToast) window.showToast(data?.message || "Failed to update vendor binding", true);
        return;
      }

      window.location.href = data.redirect || returnTo || "/fairtech/vendor/coordinator/view";
    } catch (err) {
      console.error(err);
      submitBtn.disabled = false;
      if (window.showToast) window.showToast("Failed to update vendor binding", true);
    }
  });
</script>
