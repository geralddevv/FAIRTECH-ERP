<% layout('/layout/boilerplate') -%>
<style>
  input[readonly], select[disabled] { background: #f1f5f9; cursor: not-allowed; }
</style>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <form
    class="needs-validation"
    action="/fairtech/tape/edit/<%= tape._id %>"
    method="post"
    autocomplete="off"
    novalidate
  >
    <div class="span-full form-heading">
      <h1>Tape Master</h1>
    </div>

    <div class="span-four">
      <label>Product ID</label>
      <input type="text" class="form-control input-tag" value="<%= tape.tapeProductId %>" readonly />
    </div>
    <div class="span-four">
      <label>Paper Code</label>
      <input type="text" class="form-control" value="<%= tape.tapePaperCode %>" readonly />
    </div>
    <div class="span-four">
      <label>Paper Type</label>
      <input type="text" class="form-control" value="<%= tape.tapePaperType %>" readonly />
    </div>
    <div class="span-three">
      <label>GSM</label>
      <input type="text" class="form-control" value="<%= tape.tapeGsm %>" readonly />
    </div>
    <div class="span-three">
      <label>Width</label>
      <input type="text" class="form-control" value="<%= tape.tapeWidth %>" readonly />
    </div>
    <div class="span-four">
      <label>Adhesive GSM</label>
      <input type="text" class="form-control" value="<%= tape.tapeAdhesiveGsm %>" readonly />
    </div>
    <div class="span-three">
      <label>MTRS</label>
      <input type="text" class="form-control" value="<%= tape.tapeMtrs %>" readonly />
    </div>
    <div class="span-three">
      <label>Core ID</label>
      <input type="text" class="form-control" value="<%= tape.tapeCoreId %>" readonly />
    </div>
    <div class="span-three">
      <label>Finish</label>
      <input type="text" class="form-control" value="<%= tape.tapeFinish %>" readonly />
    </div>

    <div class="span-five">
      <label>Status</label>
      <select name="status" class="form-control select-tag" required>
        <option value="ACTIVE" <%= (tape.status || "ACTIVE") === "ACTIVE" ? "selected" : "" %>>ACTIVE</option>
        <option value="INACTIVE" <%= tape.status === "INACTIVE" ? "selected" : "" %>>INACTIVE</option>
      </select>
    </div>

    <div class="span-full btn-grp" style="flex-direction: row-reverse;">
      <button class="submit-btn" type="submit">Update Status</button>
      <button type="button" id="cancelBtn">Cancel</button>
    </div>
  </form>
</div>

<script>
  document.getElementById("cancelBtn").addEventListener("click", () => {
    window.location.href = "/fairtech/tape/profile/<%= tape._id %>";
  });
</script>
