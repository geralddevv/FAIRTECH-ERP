<% layout('/layout/boilerplate') -%>

<div class="contain" style="flex-direction: column; padding: 10px; gap: 14px;">
  <style>
    .ap-card {
      width: 100%;
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      overflow: hidden;
    }
    .ap-table-wrap { overflow-x: auto; }
    .ap-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .ap-table th, .ap-table td { padding: 9px 14px; border-bottom: 1px solid #e5e7eb; border-right: 1px solid #e5e7eb; text-align: left; white-space: nowrap; }
    .ap-table tr > *:last-child { border-right: none; }
    .ap-table th { background: #f8fafc; color: #044a78; font-weight: 700; }
    .ap-table td { color: #1f2a44; font-weight: 600; }
    .ap-table tbody tr { cursor: pointer; }
    .ap-table tbody tr:hover { background: #fbfdff; }

    .mq-count-badge {
      display: inline-block;
      min-width: 22px;
      padding: 2px 8px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      text-align: center;
    }
    .mq-count-badge.has-pending { background: #fff8e1; color: #7a5b00; border: 1px solid #f0c36d; }
    .mq-count-badge.empty { background: #f1f5f9; color: #94a3b8; border: 1px solid #e2e8f0; }
  </style>

  <div class="indi-head">
    <h1>Machine Queues</h1>
  </div>

  <div class="ap-card">
    <div class="ap-table-wrap">
      <table class="ap-table">
        <thead>
          <tr>
            <th>Machine Name</th>
            <th>Type</th>
            <th>Location</th>
            <th>Pending Orders</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach((row) => { %>
            <tr onclick="window.location.href='/fairtech/machine/<%= row._id %>/queue'">
              <td><%= row.machineName %></td>
              <td><%= row.machineType %></td>
              <td><%= row.locationName %></td>
              <td>
                <span class="mq-count-badge <%= row.pendingCount > 0 ? 'has-pending' : 'empty' %>">
                  <%= row.pendingCount %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
