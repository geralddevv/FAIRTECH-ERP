<% layout('/layout/boilerplate') %>

<%
  const jc = prefill || {};
  const ref = jc.productionReference || {};
  const isEmpty = (v) => v === undefined || v === null || (typeof v === "string" && v.trim() === "") || v === "—";
  const dash = (v) => (isEmpty(v) ? "—" : v);
  const fmtQty = (v) => (Number.isFinite(Number(v)) && v !== "" && v != null)
    ? Number(v).toLocaleString("en-IN")
    : dash(v);
  const today = new Date();
  const dateDay = String(today.getDate()).padStart(2, "0");
  const dateMonth = String(today.getMonth() + 1).padStart(2, "0");
  const dateYear = today.getFullYear();
  const dateInputValue = `${dateYear}-${dateMonth}-${dateDay}`;
  const dateDisplayValue = `${dateDay}/${dateMonth}/${dateYear}`;
%>

<style>
  .jc-info-wrap {
    border: 2px solid #044a78;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(4,74,120,0.08);
  }
  .jc-info-table {
    width: 100%;
    border-collapse: collapse;
    background: #ffffff;
    table-layout: fixed;
  }
  .jc-info-table th,
  .jc-info-table td {
    padding: 8px 12px;
    border-bottom: 1px solid #e2e8f0;
    border-right: 1px solid #e2e8f0;
    text-align: left;
    vertical-align: middle;
  }
  .jc-info-table tr > *:last-child {
    border-right: none;
  }
  .jc-info-table tr:last-child > * {
    border-bottom: none;
  }
  .jc-info-table th {
    width: 12%;
    background: #f0f7ff;
    color: #03365a;
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
  }
  .jc-info-table td {
    color: #1f2a44;
    font-size: 13px;
    font-weight: 600;
    word-break: break-word;
  }
  .jc-info-section {
    background: #044a78 !important;
    color: #ffffff !important;
    text-align: left !important;
    letter-spacing: 0.02em;
  }
  .jc-ref-row {
    display: flex;
  }
  .jc-ref-item {
    flex: 1;
    display: flex;
    align-items: center;
    border-right: 1px solid #e2e8f0;
  }
  .jc-ref-item:last-child {
    border-right: none;
  }
  .jc-ref-label {
    background: #f0f7ff;
    color: #03365a;
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
    padding: 8px 12px;
  }
  .jc-ref-value {
    color: #1f2a44;
    font-size: 13px;
    font-weight: 600;
    word-break: break-word;
    padding: 8px 12px;
    flex: 1;
  }

  .jc-log-table {
    width: 100%;
    border-collapse: collapse;
    background: #ffffff;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(4,74,120,0.08);
  }
  .jc-log-table th {
    background: #044a78;
    color: #ffffff;
    font-size: 13px;
    font-weight: 600;
    padding: 9px 10px;
    text-align: center;
    letter-spacing: 0.02em;
    border-right: 1px solid rgba(255,255,255,0.25);
  }
  .jc-log-table th:last-child {
    border-right: none;
  }

  /* Toggled as a class rather than an inline style so the element keeps its
     own display value (flex for the headings) when shown again. */
  .jc-hidden { display: none !important; }

  /* .span-full (common.css) sets flex-direction: column + align-items:
     flex-start, which pins the button to the left and makes justify-content
     act on the vertical axis. Restate the axis explicitly so it centres, and
     drop the inherited border/padding -- it's a lone button, not a panel. */
  .jc-start-prod-wrap {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    border: none;
    padding: 6px 0;
  }

  .jc-log-table td {
    padding: 6px 8px;
    border-bottom: 1px solid #e2e8f0;
    border-right: 1px solid #e2e8f0;
    vertical-align: middle;
  }
  .jc-log-table td:last-child {
    border-right: none;
  }
  .jc-log-table tr:last-child td {
    border-bottom: none;
  }
  .jc-log-table input.form-control {
    padding: 6px 8px !important;
    font-size: 13px !important;
    height: auto !important;
    min-width: 0;
  }

  /* The punched time takes the dash's place, so the slot is sized for the
     widest one ("12:59 PM") from the start -- otherwise the cell reflows the
     moment Start is pressed and the button beside it changes size under the
     operator's finger. Tabular figures keep it steady between times too. */
  .jc-log-table .js-start-display,
  .jc-log-table .js-stop-display,
  .jc-log-table .log-start-display,
  .jc-log-table .log-stop-display {
    display: inline-block;
    min-width: 62px;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }

  /* The rolls picked for this job — a plain column table rather than the
     label/value grid the panels above use, since every roll repeats the same
     set of fields. */
  .jc-roll-table {
    width: 100%;
    border-collapse: collapse;
    background: #ffffff;
    table-layout: fixed;
  }
  .jc-roll-table th {
    background: #f0f7ff;
    color: #03365a;
    font-size: 12px;
    font-weight: 700;
    text-align: left;
    padding: 7px 12px;
    border-bottom: 1px solid #e2e8f0;
    border-right: 1px solid #e2e8f0;
    white-space: nowrap;
  }
  .jc-roll-table td {
    color: #1f2a44;
    font-size: 13px;
    font-weight: 600;
    padding: 7px 12px;
    border-bottom: 1px solid #e2e8f0;
    border-right: 1px solid #e2e8f0;
    word-break: break-word;
  }
  .jc-roll-table th:last-child,
  .jc-roll-table td:last-child { border-right: none; }
  .jc-roll-table tr:last-child td { border-bottom: none; }
  .jc-no-rolls {
    padding: 10px 12px;
    font-size: 13px;
    font-weight: 600;
    color: #92400e;
    background: #fffbeb;
  }

  .jc-readonly {
    background: #f0f7ff !important;
    color: #044a78 !important;
    font-weight: 700 !important;
    cursor: default !important;
  }

  /* ---------------- Mobile (operators fill this in on a phone) ----------------
     Every table here is wider than a phone, so each one collapses to stacked
     label/value rows. Cells carry data-label (static ones in the markup above,
     the Job Setting / Production Log rows from their JS templates) and it is
     rendered as the leading label via ::before. Desktop is untouched. */
  @media screen and (max-width: 768px) {
    /* Info panel — three label/value pairs per row become one pair per line. */
    .jc-info-table { table-layout: auto; }
    .jc-info-table tbody { display: block; }
    .jc-info-table tr { display: flex; flex-wrap: wrap; }
    .jc-info-table th,
    .jc-info-table td { display: block; padding: 7px 10px; }
    .jc-info-table th { flex: 0 0 34%; width: auto; font-size: 12px; }
    .jc-info-table td { flex: 1 1 60%; font-size: 12.5px; border-right: none; }
    /* The filler cell that pads the last row out to six columns. */
    .jc-info-table th:empty,
    .jc-info-table td:empty { display: none; }
    .jc-info-table .jc-info-section,
    .jc-info-table td[colspan] { flex: 1 1 100%; }

    .jc-ref-row { flex-direction: column; }
    .jc-ref-item { border-right: none; border-bottom: 1px solid #e2e8f0; }
    .jc-ref-item:last-child { border-bottom: none; }
    .jc-ref-label { flex: 0 0 34%; padding: 7px 10px; font-size: 12px; }
    .jc-ref-value { padding: 7px 10px; font-size: 12.5px; }

    /* Allocated Paper — one card per roll. */
    .jc-roll-table { table-layout: auto; }
    .jc-roll-table thead { display: none; }
    .jc-roll-table tbody,
    .jc-roll-table tr,
    .jc-roll-table td { display: block; width: 100%; }
    .jc-roll-table tbody tr { border-bottom: 2px solid #044a78; }
    .jc-roll-table tbody tr:last-child { border-bottom: none; }
    .jc-roll-table td {
      display: flex; align-items: center; gap: 10px;
      padding: 6px 10px; border-right: none; font-size: 12.5px;
      text-align: left !important;
    }
    .jc-roll-table td::before {
      content: attr(data-label);
      flex: 0 0 34%; color: #5a6586; font-weight: 700; font-size: 12px;
    }
    .jc-roll-table td:first-child { background: #f0f7ff; color: #03365a; font-weight: 700; }

    /* Job Setting + Production Log — one card per entry, inputs full width so
       nothing has to be reached by scrolling sideways. */
    .jc-log-table thead { display: none; }
    .jc-log-table tbody,
    .jc-log-table tfoot,
    .jc-log-table tr,
    .jc-log-table td { display: block; width: 100%; }
    .jc-log-table tbody tr {
      display: flex; flex-wrap: wrap; width: auto;
      border: 1px solid #cbd5e1; border-radius: 8px; overflow: hidden; margin-bottom: 10px;
    }
    .jc-log-table tbody tr:last-child { margin-bottom: 0; }
    /* Each cell takes its own line by default. */
    .jc-log-table tbody td { flex: 1 1 100%; }
    /* Top line is the row number and the roll it belongs to: the number sits in
       a fixed badge like the "#" column on desktop (its label would say nothing
       the position doesn't), and Roll ID takes whatever is left. */
    .jc-log-table tbody td[data-label="Row"] {
      flex: 0 0 44px; justify-content: center;
      border-right: 1px solid #cbd5e1;
      /* The card clips with overflow:hidden, but the tinted badge sits in the
         corner -- rounding it to match keeps the fill from squaring off the
         card's top-left. */
      border-radius: 7px 0 0 0;
    }
    /* Rule under the first line, separating "which roll" from the readings
       taken against it. */
    .jc-log-table tbody td[data-label="Row"],
    .jc-log-table tbody td[data-label="Roll ID"] { border-bottom: 1px solid #cbd5e1; }
    .jc-log-table tbody td[data-label="Row"]::before { content: none; }
    /* 60% is picked the same way as the 40% below: it fits beside the badge but
       leaves too little for Mtrs to join the line, so the card breaks after
       Roll ID. An auto basis would inherit the cell's width:100% and push Roll
       ID onto a line of its own. */
    .jc-log-table tbody td[data-label="Roll ID"] { flex: 1 1 60%; }
    .jc-log-table tbody td[data-label="Roll ID"]::before { flex: 0 0 auto; }
    /* Except Mtrs, which shares a line with the Start/Stop button it arms —
       they're one action ("enter the meters, then hit go"), so splitting them
       across two lines makes the operator hunt for the button. Two lines, not
       one: Mtrs+Start, then Mtrs+Stop. The 40% basis is what forces the break —
       two cells fit (80%) but never three (120%) — and flex-grow then shares
       the line out evenly. A zero basis would let all four sit on one line.
       The button cell drops its label: the ▶ / ■ icon already says which it
       is, and the space is better spent on the tap target. */
    .jc-log-table tbody td[data-label="Mtrs"],
    .jc-log-table tbody td[data-label="Start"],
    .jc-log-table tbody td[data-label="Stop"] { flex: 1 1 40%; }
    .jc-log-table tbody td[data-label="Mtrs"] { border-right: 1px solid #cbd5e1; }
    .jc-log-table tbody td[data-label="Mtrs"]::before { flex: 0 0 auto; }
    .jc-log-table tbody td[data-label="Start"]::before,
    .jc-log-table tbody td[data-label="Stop"]::before { content: none; }
    .jc-log-table td {
      display: flex; align-items: center; gap: 10px;
      padding: 7px 10px; border-right: none; min-width: 0 !important;
      white-space: normal !important; text-align: left !important;
    }
    .jc-log-table td::before {
      content: attr(data-label);
      flex: 0 0 34%; color: #5a6586; font-weight: 700; font-size: 12px;
    }
    .jc-log-table td:not([data-label])::before { content: none; }
    .jc-log-table tbody td:first-child { background: #f0f7ff; }
    .jc-log-table tbody td:last-child { border-bottom: none; }
    /* Beats the inline width:90px on the Roll ID input. */
    .jc-log-table input.form-control { width: 100% !important; flex: 1 1 auto; }
    /* Tap targets: the Start/Stop buttons stretch across whatever the label and
       the recorded time leave free, so they're hard to miss with gloves on.
       The inline width/height on the buttons needs !important to beat. */
    .jc-log-table .js-start-btn,
    .jc-log-table .js-stop-btn,
    .jc-log-table .log-start-btn,
    .jc-log-table .log-stop-btn {
      flex: 1 1 auto;
      width: auto !important;
      height: 38px !important;
      font-size: 15px !important;
    }
    /* The "—" / recorded time sits between the label and the button. */
    .jc-log-table .js-start-display,
    .jc-log-table .js-stop-display,
    .jc-log-table .log-start-display,
    .jc-log-table .log-stop-display { flex: 0 0 auto; margin-right: 0 !important; }

    /* Totals: "Total" heads the block on its own line, with the two figures
       side by side underneath. Qualified with .jc-log-table throughout -- a
       bare .jc-total-row loses to the `.jc-log-table tr { display: block }`
       above on specificity, which is what kept these two stacked. */
    .jc-log-table .jc-total-row {
      display: flex; flex-wrap: wrap; width: auto;
      border-radius: 8px; overflow: hidden; margin-top: 10px;
    }
    .jc-log-table .jc-total-row .jc-total-label {
      flex: 1 1 100%; width: auto; text-align: left !important;
      border-bottom: 1px solid rgba(255, 255, 255, 0.25);
    }
    .jc-log-table .jc-total-row td {
      flex: 1 1 0; width: auto; min-width: 0;
      flex-direction: column; align-items: stretch; gap: 4px;
    }
    .jc-log-table .jc-total-row td::before { color: #ffffff; flex: 0 0 auto; }

    /* The row-count steppers sit beside their heading; let them drop below it
       rather than squeezing the title. */
    .form-subheading { flex-wrap: wrap; }
  }
</style>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px">
  <form
    action="/fairtech/machine/jobcard/form"
    method="POST"
    class="needs-validation"
    autocomplete="off"
    novalidate
  >
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="hidden" name="pendingId" value="<%= pendingId %>" />
    <input type="hidden" name="machineId" value="<%= machine ? machine._id : '' %>" />
    <input type="hidden" name="date" value="<%= dateInputValue %>" />
    <input type="hidden" name="machineNo" value="<%= machine ? machine.machineName : '' %>" />
    <input type="hidden" name="lotNo" value="<%= isEmpty(jc.lotNo) ? '' : jc.lotNo %>" />
    <input type="hidden" name="quantity" value="<%= isEmpty(jc.quantity) ? '' : jc.quantity %>" />
    <input type="hidden" name="productId" value="<%= isEmpty(jc.productId) ? '' : jc.productId %>" />
    <input type="hidden" name="labelWidth" value="<%= isEmpty(jc.labelWidth) ? '' : jc.labelWidth %>" />
    <input type="hidden" name="labelHeight" value="<%= isEmpty(jc.labelHeight) ? '' : jc.labelHeight %>" />
    <input type="hidden" name="rolls" value="<%= isEmpty(jc.rolls) ? '' : jc.rolls %>" />
    <input type="hidden" name="paperSize" value="<%= isEmpty(ref.paperSize || jc.paperSize) ? '' : (ref.paperSize || jc.paperSize) %>" />
    <input type="hidden" name="paperType" value="<%= isEmpty(ref.paperType || jc.paperType) ? '' : (ref.paperType || jc.paperType) %>" />
    <input type="hidden" name="paperCode" value="<%= isEmpty(ref.paperCode || jc.paperCode) ? '' : (ref.paperCode || jc.paperCode) %>" />
    <input type="hidden" name="dieNo" value="<%= isEmpty(ref.die || jc.dieNo) ? '' : (ref.die || jc.dieNo) %>" />
    <input type="hidden" name="operatorName" value="<%= isEmpty(jc.operatorName) ? '' : jc.operatorName %>" />
    <input type="hidden" name="helperName" value="<%= isEmpty(jc.helperName) ? '' : jc.helperName %>" />

    <div class="span-full form-heading">
      <h1>Production Entry</h1>
    </div>

    <div class="span-full jc-info-wrap">
      <table class="jc-info-table">
        <tbody>
          <tr>
            <th>Date</th><td><%= dateDisplayValue %></td>
            <th>Lot No</th><td><%= dash(jc.lotNo) %></td>
            <th>Quantity</th><td><%= fmtQty(jc.quantity) %></td>
          </tr>
          <tr>
            <th>Label ID</th><td><%= dash(jc.productId) %></td>
            <th>Width</th><td><%= dash(jc.labelWidth) %></td>
            <th>Height</th><td><%= dash(jc.labelHeight) %></td>
          </tr>
          <tr>
            <th>No. of Rolls</th><td><%= dash(jc.rolls) %></td>
            <th>Paper Size</th><td><%= dash(jc.paperSize) %></td>
            <th>Family</th><td><%= dash(jc.paperType) %></td>
          </tr>
          <tr>
            <th>Paper Code</th><td><%= dash(jc.paperCode) %></td>
            <th>Machine</th><td><%= dash(machine ? machine.machineName : "") %></td>
            <th></th><td></td>
          </tr>
          <tr>
            <th colspan="6" class="jc-info-section">Die Details</th>
          </tr>
          <tr>
            <td colspan="6" style="padding: 0;">
              <div class="jc-ref-row">
                <div class="jc-ref-item"><span class="jc-ref-label">Die No</span><span class="jc-ref-value"><%= dash(ref.dieNo || jc.dieNo) %></span></div>
                <div class="jc-ref-item"><span class="jc-ref-label">Die</span><span class="jc-ref-value"><%= dash(ref.dieDetails) %></span></div>
                <div class="jc-ref-item"><span class="jc-ref-label">Running Meters</span><span class="jc-ref-value"><%= dash(ref.runningMeters) %></span></div>
                <div class="jc-ref-item"><span class="jc-ref-label">Paper Code</span><span class="jc-ref-value"><%= dash(ref.paperCode) %></span></div>
                <div class="jc-ref-item"><span class="jc-ref-label">Family</span><span class="jc-ref-value"><%= dash(ref.paperType) %></span></div>
                <div class="jc-ref-item"><span class="jc-ref-label">Paper Size</span><span class="jc-ref-value"><%= dash(ref.paperSize) %></span></div>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Allocated Paper — one row per roll ticked on the Assign Production
         form. The rolls come from PendingProduction.allottedRollIds, so jobs
         assigned before those were recorded fall back to the notice below.
         Only what differs per roll is listed; the family, vendor, paper code
         and size are the same for every roll and are already stated in the
         Die Details panel above. -->
    <% const allocRolls = jc.allottedRollDetails || []; %>
    <div class="span-full form-subheading">
      <h1>Allocated Paper</h1>
    </div>

    <div class="span-full jc-info-wrap">
      <% if (allocRolls.length) { %>
        <table class="jc-roll-table">
          <thead>
            <tr>
              <th style="width:44px; text-align:center;">#</th>
              <th>Roll No</th>
              <th>Running Mtrs</th>
              <th>Location</th>
            </tr>
          </thead>
          <tbody>
            <% allocRolls.forEach((r, i) => { %>
              <tr>
                <td style="text-align:center;" data-label="#"><%= i + 1 %></td>
                <td data-label="Roll No"><%= dash(r.rollNo) %></td>
                <td data-label="Running Mtrs"><%= fmtQty(r.paperMtrs) %></td>
                <td data-label="Location"><%= dash(r.location) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="jc-no-rolls">
          No rolls recorded for this job — pick them in the Rolls section of Assign Production.
        </div>
      <% } %>
    </div>

    <!-- Job Setting Table -->
    <div class="span-full form-subheading" style="display: flex; align-items: center; gap: 12px;">
      <h1>Job Setting</h1>
      <div style="display: inline-flex; align-items: center; gap: 6px; margin-left: 10px;">
        <button type="button" id="jsMinus" style="width: 30px; height: 30px; border: 1px solid #044A78; background: white; color: #044A78; border-radius: 4px; font-size: 18px; line-height: 1; cursor: pointer;">-</button>
        <input type="text" id="jsCount" style="width: 56px; height: 30px; text-align: center; border: 1px solid #044A78; border-radius: 4px; font-size: 14px;" class="form-control" value="1" readonly />
        <button type="button" id="jsPlus" style="width: 30px; height: 30px; border: 1px solid #044A78; background: white; color: #044A78; border-radius: 4px; font-size: 18px; line-height: 1; cursor: pointer;">+</button>
      </div>
    </div>

    <div class="span-full">
      <table class="jc-log-table">
        <thead>
          <tr>
            <th style="width:36px; text-align:center;">#</th>
            <th style="width:90px;">Roll ID</th>
            <th>Mtrs</th>
            <th style="text-align:center;">Start</th>
            <th>Mtrs</th>
            <th style="text-align:center;">Stop</th>
          </tr>
        </thead>
        <tbody id="jsTableBody">
          <!-- rows injected by JS -->
        </tbody>
      </table>
    </div>

    <!-- Appears only once every Job Setting row has both Start and Stop
         recorded; clicking it reveals the Production Log below. -->
    <div class="span-full jc-start-prod-wrap jc-hidden" id="startProdWrap">
      <button type="button" id="startProdBtn"
        style="display:inline-flex; align-items:center; gap:8px; padding:10px 26px; border:none; border-radius:6px; background:#10b981; color:#fff; font-size:14px; font-weight:600; cursor:pointer;">
        <i class="fa-solid fa-play"></i> Start Production
      </button>
    </div>

    <!-- Production Log Table -->
    <div class="span-full form-subheading jc-hidden" id="prodLogHead" style="display: flex; align-items: center; gap: 12px;">
      <h1>Production Log</h1>
      <div style="display: inline-flex; align-items: center; gap: 6px; margin-left: 10px;">
        <button type="button" id="logMinus" style="width: 30px; height: 30px; border: 1px solid #044A78; background: white; color: #044A78; border-radius: 4px; font-size: 18px; line-height: 1; cursor: pointer;">-</button>
        <input type="text" id="logCount" style="width: 56px; height: 30px; text-align: center; border: 1px solid #044A78; border-radius: 4px; font-size: 14px;" class="form-control" value="1" readonly />
        <button type="button" id="logPlus" style="width: 30px; height: 30px; border: 1px solid #044A78; background: white; color: #044A78; border-radius: 4px; font-size: 18px; line-height: 1; cursor: pointer;">+</button>
      </div>
    </div>

    <div class="span-full jc-hidden" id="prodLogBody">
      <table class="jc-log-table">
        <thead>
          <tr>
            <th style="width:36px; text-align:center;">#</th>
            <th style="width:90px;">Roll ID</th>
            <th>Mtrs</th>
            <th style="text-align:center;">Start</th>
            <th>Mtrs</th>
            <th style="text-align:center;">Stop</th>
          </tr>
        </thead>
        <tbody id="logTableBody">
          <!-- rows injected by JS -->
        </tbody>
        <tfoot>
          <!-- Both figures are derived from the rows above (see recalcLogTotals)
               -- readonly, so they can't drift from the readings they came
               from. -->
          <tr class="jc-total-row" style="background: #044a78;">
            <td class="jc-total-label" style="text-align:center; font-size:12px; font-weight:700; color:#ffffff; white-space:nowrap; padding: 6px 8px;">Total</td>
            <td colspan="3" style="padding: 6px 8px" data-label="RM">
              <input type="text" name="totalMeter" class="form-control jc-readonly" readonly
                     placeholder="RM" style="padding:6px 8px !important; font-size:13px !important; height:auto !important;" />
            </td>
            <td colspan="2" style="padding: 6px 8px" data-label="SQ Mtrs">
              <input type="text" name="sqMtr" class="form-control jc-readonly" readonly
                     placeholder="SQ Mtrs" style="padding:6px 8px !important; font-size:13px !important; height:auto !important;" />
            </td>
          </tr>
        </tfoot>
      </table>
    </div>

    <div class="btn-grp span-full jc-hidden" id="saveBtnWrap">
      <button type="submit">Save Production Entry</button>
    </div>
  </form>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    /* ── Die selector ── */
    const dieSelect = document.getElementById("dieNo");
    if (dieSelect) {
      new Choices(dieSelect, { searchEnabled: true, shouldSort: false, itemSelectText: "" });
    }

    /* Paper Size/Type/Code are plain free-text inputs with native <datalist>
       suggestions (see the "Row 4" markup above) -- no JS wiring needed. */

    /* ── Row gating (shared by Job Setting and Production Log) ──
       An entry row unlocks left to right: naming the roll opens the start
       Mtrs, the start Mtrs arms Start and opens the stop Mtrs, the stop Mtrs
       arms Stop. Clearing a field re-locks and wipes everything downstream of
       it, so a row can never end up holding a stop reading for a roll that was
       never named. Both tables build identical rows apart from the js-/log-
       class prefix, hence the prefix argument. */
    const filled = (el) => Boolean(el && String(el.value).trim() !== "");

    // readonly, not disabled: the server zips the Job Setting / Production Log
    // rows together by position (see POST /machine/jobcard/form), and a
    // disabled field posts nothing at all -- one locked cell would shift every
    // later row's readings onto the wrong roll.
    function setInputLocked(input, locked) {
      if (!input) return;
      input.readOnly = locked;
      input.style.background = locked ? "#f1f5f9" : "";
      input.style.cursor = locked ? "not-allowed" : "";
      if (locked) input.value = "";
    }

    function setBtnArmed(btn, armed, color) {
      if (!btn) return;
      btn.disabled = !armed;
      btn.style.background = armed ? color : "#d1d5db";
      btn.style.cursor = armed ? "pointer" : "not-allowed";
    }

    function syncRowGating(row, p) {
      if (!row) return;
      const rollId = row.querySelector(`.${p}-roll-id`);
      const mtrs1  = row.querySelector(`.${p}-mtrs1`);
      const mtrs2  = row.querySelector(`.${p}-mtrs2`);
      // A time already punched is a fact about the run -- leave that half of
      // the row alone rather than re-arming a button that's been used or
      // wiping the reading it was taken against.
      const started = filled(row.querySelector(`.${p}-start-input`));
      const stopped = filled(row.querySelector(`.${p}-stop-input`));

      if (!started) {
        setInputLocked(mtrs1, !filled(rollId));
        setBtnArmed(row.querySelector(`.${p}-start-btn`), filled(mtrs1), "#10b981");
      }
      if (!stopped) {
        setInputLocked(mtrs2, !filled(mtrs1));
        setBtnArmed(row.querySelector(`.${p}-stop-btn`), filled(mtrs2), "#ef4444");
      }
    }

    /* ── Job Setting dynamic rows ── */
    const jsBody  = document.getElementById("jsTableBody");
    const jsCount = document.getElementById("jsCount");
    const jsPlus  = document.getElementById("jsPlus");
    const jsMinus = document.getElementById("jsMinus");

    function jsRenumber() {
      Array.from(jsBody.rows).forEach((row, i) => { row.cells[0].textContent = i + 1; });
      jsCount.value = jsBody.rows.length;
    }

    function createJsRow() {
      const tr = document.createElement("tr");
      // data-label feeds the mobile card layout (see the @media block above);
      // it is ignored on desktop, where the <thead> supplies the headings.
      tr.innerHTML = `
        <td style="text-align:center; font-weight:600; color:#03365a; background:#f0f7ff;" data-label="Row"></td>
        <td data-label="Roll ID"><input type="text" name="jsRollId" class="form-control js-roll-id" placeholder="Roll ID" style="width:90px;" /></td>
        <td data-label="Mtrs"><input type="number" name="jsMtrs1" class="form-control js-mtrs1" placeholder="Mtrs" min="0" step="any" required /></td>
        <td style="text-align:center; white-space:nowrap; min-width:110px;" data-label="Start">
          <span class="js-start-display" style="font-size:12px; font-weight:700; color:#03365a; margin-right:4px;">—</span>
          <input type="hidden" name="jsStart" class="js-start-input" />
          <button type="button" class="js-start-btn" disabled
            style="width:32px; height:26px; padding:0; font-size:12px; border:none; border-radius:4px; cursor:not-allowed; background:#d1d5db; color:white; display:inline-flex; align-items:center; justify-content:center; flex-shrink:0;">
            <i class="fa-solid fa-play"></i>
          </button>
        </td>
        <td data-label="Mtrs"><input type="number" name="jsMtrs2" class="form-control js-mtrs2" placeholder="Mtrs" min="0" step="any" /></td>
        <td style="text-align:center; white-space:nowrap; min-width:110px;" data-label="Stop">
          <span class="js-stop-display" style="font-size:12px; font-weight:700; color:#dc2626; margin-right:4px;">—</span>
          <input type="hidden" name="jsStop" class="js-stop-input" />
          <button type="button" class="js-stop-btn" disabled
            style="width:32px; height:26px; padding:0; font-size:12px; border:none; border-radius:4px; cursor:not-allowed; background:#d1d5db; color:white; display:inline-flex; align-items:center; justify-content:center; flex-shrink:0;">
            <i class="fa-solid fa-stop"></i>
          </button>
        </td>`;
      syncRowGating(tr, "js");
      return tr;
    }

    jsBody.addEventListener("input", (e) => {
      syncRowGating(e.target.closest("tr"), "js");
    });

    jsBody.addEventListener("click", (e) => {
      const startBtn = e.target.closest(".js-start-btn");
      if (startBtn && !startBtn.disabled) {
        const row = startBtn.closest("tr");
        const time = nowHHMM();
        row.querySelector(".js-start-input").value = time;
        row.querySelector(".js-start-display").textContent = time;
        startBtn.disabled = true;
        startBtn.innerHTML = '<i class="fa-solid fa-check"></i>';
        startBtn.style.background = "#6b7280";
        startBtn.style.cursor = "default";
        refreshStartProdBtn();
        return;
      }
      const stopBtn = e.target.closest(".js-stop-btn");
      if (stopBtn && !stopBtn.disabled) {
        const row = stopBtn.closest("tr");
        const time = nowHHMM();
        row.querySelector(".js-stop-input").value = time;
        row.querySelector(".js-stop-display").textContent = time;
        stopBtn.disabled = true;
        stopBtn.innerHTML = '<i class="fa-solid fa-check"></i>';
        stopBtn.style.background = "#6b7280";
        stopBtn.style.cursor = "default";
        refreshStartProdBtn();
      }
    });

    /* ── Start Production gate ── */
    const startProdWrap = document.getElementById("startProdWrap");
    const startProdBtn  = document.getElementById("startProdBtn");
    const prodLogHead   = document.getElementById("prodLogHead");
    const prodLogBody   = document.getElementById("prodLogBody");
    const saveBtnWrap   = document.getElementById("saveBtnWrap");
    let productionStarted = false;

    // Every Job Setting row must have both a Start and a Stop time before
    // production can begin. Once the log is open it stays open, so adding a
    // fresh setting row later doesn't yank it away mid-entry.
    function jobSettingComplete() {
      const rows = Array.from(jsBody.rows);
      if (!rows.length) return false;
      return rows.every((row) => {
        const start = row.querySelector(".js-start-input");
        const stop  = row.querySelector(".js-stop-input");
        return start && stop && start.value.trim() !== "" && stop.value.trim() !== "";
      });
    }

    function refreshStartProdBtn() {
      if (productionStarted) return;
      startProdWrap.classList.toggle("jc-hidden", !jobSettingComplete());
    }

    startProdBtn.addEventListener("click", () => {
      productionStarted = true;
      startProdWrap.classList.add("jc-hidden");
      prodLogHead.classList.remove("jc-hidden");
      prodLogBody.classList.remove("jc-hidden");
      saveBtnWrap.classList.remove("jc-hidden");
      prodLogHead.scrollIntoView({ behavior: "smooth", block: "nearest" });
    });

    jsPlus.addEventListener("click", () => { jsBody.appendChild(createJsRow()); jsRenumber(); refreshStartProdBtn(); });
    jsMinus.addEventListener("click", () => { if (jsBody.rows.length > 1) { jsBody.removeChild(jsBody.lastElementChild); jsRenumber(); refreshStartProdBtn(); } });
    jsBody.appendChild(createJsRow());
    jsRenumber();
    refreshStartProdBtn();

    /* ── Production Log dynamic rows ── */
    const logBody   = document.getElementById("logTableBody");
    const logCount  = document.getElementById("logCount");
    const logPlus   = document.getElementById("logPlus");
    const logMinus  = document.getElementById("logMinus");

    function renumber() {
      Array.from(logBody.rows).forEach((row, i) => {
        row.cells[0].textContent = i + 1;
      });
      logCount.value = logBody.rows.length;
    }

    function createLogRow() {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td style="text-align:center; font-weight:600; color:#03365a; background:#f0f7ff;" data-label="Row"></td>
        <td data-label="Roll ID"><input type="text" name="rollId" class="form-control log-roll-id" placeholder="Roll ID" style="width:90px;" /></td>
        <td data-label="Mtrs"><input type="number" name="logMtrs1" class="form-control log-mtrs1" placeholder="Mtrs" min="0" step="any" /></td>
        <td style="text-align:center; white-space:nowrap; min-width:110px;" data-label="Start">
          <span class="log-start-display" style="font-size:12px; font-weight:700; color:#03365a; margin-right:4px;">—</span>
          <input type="hidden" name="logStart" class="log-start-input" />
          <button type="button" class="log-start-btn" disabled
            style="width:32px; height:26px; padding:0; font-size:12px; border:none; border-radius:4px; cursor:not-allowed; background:#d1d5db; color:white; display:inline-flex; align-items:center; justify-content:center; flex-shrink:0;">
            <i class="fa-solid fa-play"></i>
          </button>
        </td>
        <td data-label="Mtrs"><input type="number" name="logMtrs2" class="form-control log-mtrs2" placeholder="Mtrs" min="0" step="any" /></td>
        <td style="text-align:center; white-space:nowrap; min-width:110px;" data-label="Stop">
          <span class="log-stop-display" style="font-size:12px; font-weight:700; color:#dc2626; margin-right:4px;">—</span>
          <input type="hidden" name="logStop" class="log-stop-input" />
          <button type="button" class="log-stop-btn" disabled
            style="width:32px; height:26px; padding:0; font-size:12px; border:none; border-radius:4px; cursor:not-allowed; background:#d1d5db; color:white; display:inline-flex; align-items:center; justify-content:center; flex-shrink:0;">
            <i class="fa-solid fa-stop"></i>
          </button>
        </td>`;
      syncRowGating(tr, "log");
      return tr;
    }

    function nowHHMM() {
      const d = new Date();
      let h = d.getHours();
      const m = String(d.getMinutes()).padStart(2,"0");
      const ampm = h >= 12 ? "PM" : "AM";
      h = h % 12 || 12;
      return `${h}:${m} ${ampm}`;
    }

    /* ── Production Log totals ──
       Running metres for a row is what the counter moved by: stop reading minus
       start reading. The total is those added up, and the sheet area follows
       from it and the paper size this job runs on. Both are derived, never
       typed, so they can't disagree with the rows above. */
    const totalMeterInput = document.querySelector('input[name="totalMeter"]');
    const sqMtrInput = document.querySelector('input[name="sqMtr"]');
    const paperSizeVal = Number(document.querySelector('input[name="paperSize"]')?.value) || 0;
    const round2 = (n) => String(Math.round(n * 100) / 100);

    function recalcLogTotals() {
      let runningMtrs = 0;
      Array.from(logBody.rows).forEach((row) => {
        const from = parseFloat(row.querySelector(".log-mtrs1")?.value);
        const to = parseFloat(row.querySelector(".log-mtrs2")?.value);
        // Only a completed, forward-running pair contributes -- a half-filled
        // row, or a stop reading below its start, isn't a length yet.
        if (Number.isFinite(from) && Number.isFinite(to) && to > from) runningMtrs += to - from;
      });

      if (totalMeterInput) totalMeterInput.value = runningMtrs ? round2(runningMtrs) : "";
      if (sqMtrInput) sqMtrInput.value = runningMtrs ? round2(paperSizeVal * (runningMtrs / 100)) : "";
    }

    logBody.addEventListener("input", (e) => {
      syncRowGating(e.target.closest("tr"), "log");
      recalcLogTotals();
    });

    logBody.addEventListener("click", (e) => {
      const startBtn = e.target.closest(".log-start-btn");
      if (startBtn && !startBtn.disabled) {
        const row = startBtn.closest("tr");
        const time = nowHHMM();
        row.querySelector(".log-start-input").value = time;
        row.querySelector(".log-start-display").textContent = time;
        startBtn.disabled = true;
        startBtn.innerHTML = '<i class="fa-solid fa-check"></i>';
        startBtn.style.background = "#6b7280";
        startBtn.style.cursor = "default";
        return;
      }
      const stopBtn = e.target.closest(".log-stop-btn");
      if (stopBtn && !stopBtn.disabled) {
        const row = stopBtn.closest("tr");
        const time = nowHHMM();
        row.querySelector(".log-stop-input").value = time;
        row.querySelector(".log-stop-display").textContent = time;
        stopBtn.disabled = true;
        stopBtn.innerHTML = '<i class="fa-solid fa-check"></i>';
        stopBtn.style.background = "#6b7280";
        stopBtn.style.cursor = "default";
      }
    });

    logPlus.addEventListener("click", () => {
      logBody.appendChild(createLogRow());
      renumber();
      recalcLogTotals();
    });

    logMinus.addEventListener("click", () => {
      if (logBody.rows.length > 1) {
        logBody.removeChild(logBody.lastElementChild);
        renumber();
        recalcLogTotals();
      }
    });

    logBody.appendChild(createLogRow());
    renumber();
    recalcLogTotals();

    /* ── Draft autosave ──
       A shift's readings can't be re-keyed from memory, so nothing typed here
       should be able to vanish: the phone locking, the session expiring, or the
       connection dropping on submit would otherwise take the lot. Every change
       is mirrored into localStorage and put back when the page returns.

       The draft deliberately survives submitting -- a POST that never lands is
       exactly when it's wanted. It is cleared from the other end instead: a
       save that actually reached the server redirects to the job card view with
       ?saved=<pendingId>, and that page drops this key. */
    const DRAFT_KEY = `jc-draft:${document.querySelector('input[name="pendingId"]')?.value || "new"}`;

    // Private browsing and full quotas both throw on localStorage; autosave is
    // a safety net, so it fails quiet rather than breaking data entry.
    function readDraft() {
      try { return JSON.parse(localStorage.getItem(DRAFT_KEY) || "null"); } catch (e) { return null; }
    }
    function writeDraft(draft) {
      try { localStorage.setItem(DRAFT_KEY, JSON.stringify(draft)); } catch (e) { /* ignore */ }
    }
    function dropDraft() {
      try { localStorage.removeItem(DRAFT_KEY); } catch (e) { /* ignore */ }
    }

    const readRows = (body, p) => Array.from(body.rows).map((row) => ({
      rollId: row.querySelector(`.${p}-roll-id`)?.value || "",
      mtrs1: row.querySelector(`.${p}-mtrs1`)?.value || "",
      start: row.querySelector(`.${p}-start-input`)?.value || "",
      mtrs2: row.querySelector(`.${p}-mtrs2`)?.value || "",
      stop: row.querySelector(`.${p}-stop-input`)?.value || "",
    }));

    const anyEntry = (rows) => rows.some((r) => r.rollId || r.mtrs1 || r.mtrs2 || r.start || r.stop);

    function saveDraft() {
      const draft = {
        jsRows: readRows(jsBody, "js"),
        logRows: readRows(logBody, "log"),
        productionStarted,
        savedAt: Date.now(),
      };
      // An untouched form isn't worth keeping -- and storing it would mean
      // every visit left a draft behind to be restored over.
      if (!anyEntry(draft.jsRows) && !anyEntry(draft.logRows)) { dropDraft(); return; }
      writeDraft(draft);
    }

    let draftTimer = null;
    function scheduleSave() { clearTimeout(draftTimer); draftTimer = setTimeout(saveDraft, 400); }

    // Puts a recorded time back exactly as the click handler left it: button
    // spent, showing a tick, with the time beside it.
    function markPunched(btn, display, input, time) {
      if (!btn || !input || !time) return;
      input.value = time;
      if (display) display.textContent = time;
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-check"></i>';
      btn.style.background = "#6b7280";
      btn.style.cursor = "default";
    }

    function applyRows(body, p, rows, makeRow, renumberFn) {
      while (body.rows.length < rows.length) body.appendChild(makeRow());
      while (body.rows.length > rows.length && body.rows.length > 1) body.removeChild(body.lastElementChild);
      rows.forEach((data, i) => {
        const row = body.rows[i];
        if (!row) return;
        // Written before the gating is re-run: a field is still locked from
        // when the row was built, and a locked field refuses to hold a value.
        const put = (sel, value) => {
          const el = row.querySelector(sel);
          if (!el) return;
          el.readOnly = false;
          el.value = value;
        };
        put(`.${p}-roll-id`, data.rollId);
        put(`.${p}-mtrs1`, data.mtrs1);
        put(`.${p}-mtrs2`, data.mtrs2);
        markPunched(
          row.querySelector(`.${p}-start-btn`),
          row.querySelector(`.${p}-start-display`),
          row.querySelector(`.${p}-start-input`),
          data.start,
        );
        markPunched(
          row.querySelector(`.${p}-stop-btn`),
          row.querySelector(`.${p}-stop-display`),
          row.querySelector(`.${p}-stop-input`),
          data.stop,
        );
        syncRowGating(row, p);
      });
      renumberFn();
    }

    function restoreDraft() {
      const draft = readDraft();
      if (!draft) return;

      if (Array.isArray(draft.jsRows) && draft.jsRows.length) {
        applyRows(jsBody, "js", draft.jsRows, createJsRow, jsRenumber);
      }
      if (Array.isArray(draft.logRows) && draft.logRows.length) {
        applyRows(logBody, "log", draft.logRows, createLogRow, renumber);
      }
      if (draft.productionStarted) {
        productionStarted = true;
        startProdWrap.classList.add("jc-hidden");
        prodLogHead.classList.remove("jc-hidden");
        prodLogBody.classList.remove("jc-hidden");
        saveBtnWrap.classList.remove("jc-hidden");
      }
      refreshStartProdBtn();
      recalcLogTotals();
      if (typeof showToast === "function") showToast("Restored your unsaved entry", "success");
    }

    const jcForm = document.querySelector("form.needs-validation");
    if (jcForm) {
      // click covers what typing doesn't: the Start/Stop punches, the row
      // steppers and Start Production all change state without an input event.
      ["input", "change", "click"].forEach((evt) => jcForm.addEventListener(evt, scheduleSave));
      jcForm.addEventListener("submit", () => { clearTimeout(draftTimer); saveDraft(); });
    }
    // Backgrounding a tab on mobile can end it outright -- flush rather than
    // wait out the debounce.
    window.addEventListener("pagehide", () => { clearTimeout(draftTimer); saveDraft(); });

    restoreDraft();
  });
</script>

<% if (notification && notification.length) { %>
<script>
  const jcFlash = <%- safeJson(notification[0]) %>;
  const jcFlashType = /failed|not found|error/i.test(String(jcFlash)) ? "error" : "success";
  const showJcFlash = () => {
    if (typeof hideStaticToast === "function") hideStaticToast();
    if (typeof showToast === "function") showToast(jcFlash, jcFlashType);
  };
  document.readyState === "loading"
    ? document.addEventListener("DOMContentLoaded", showJcFlash, { once: true })
    : showJcFlash();
</script>
<% } %>
