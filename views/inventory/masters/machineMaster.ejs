<% layout('/layout/boilerplate') %>

<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />
<link href="https://unpkg.com/tabulator-tables@5.6.2/dist/css/tabulator_modern.min.css" rel="stylesheet" />

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <style>
    .header-action-btn {
      background-color: #f0f0f0;
      color: #044a78;
      padding: 2px 14px;
      font-size: 14px;
      font-weight: 500;
      border: none;
      cursor: pointer;
      border-radius: 0.5rem;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      transition: all 0.2s ease-in-out;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .header-action-btn:hover { background-color: #e4e4e4; }
    #machine-table { width: auto; }
    .loc-btn {
      padding: 3px 8px; border: none; border-radius: 4px;
      cursor: pointer; font-size: 12px; color: #fff; transition: opacity 0.15s;
    }
    .loc-btn:hover { opacity: 0.85; }
    .dialog-header {
      background: #044A78; padding: 18px 22px;
      display: flex; align-items: center; justify-content: space-between;
      border-radius: 14px 14px 0 0;
    }
    .dialog-header h2 { margin: 0; font-size: 1.05rem; font-weight: 700; color: #fff; }
    .dialog-close-btn {
      background: none; border: none; color: #fff; font-size: 20px;
      cursor: pointer; line-height: 1; padding: 0 2px; opacity: 0.8; transition: opacity 0.15s;
    }
    .dialog-close-btn:hover { opacity: 1; }
    .dialog-body { padding: 24px; background: #fff; border-radius: 0 0 14px 14px; }
    .dialog-field-label { display: block; font-size: 13px; font-weight: 600; color: #475569; margin-bottom: 8px; }
    .dialog-field-group { margin-bottom: 16px; }
    .dialog-error { color: #ef4444; font-size: 12px; margin-top: 5px; display: none; }
    .dialog-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; }
    .dialog-choices .choices__inner {
      border-radius: 10px !important; border: 1.5px solid #e2e8f0 !important;
      background-color: #f8fafc; font-size: 14px; min-height: 44px;
      display: flex; align-items: center;
    }
    .dialog-choices .choices__list--single { padding: 6px 10px; }
    .dialog-choices .choices__placeholder { opacity: 0.55; }
    .dialog-choices .choices__list--dropdown { z-index: 99999; }
    .dialog-choices .choices__input--cloned { padding: 10px 10px !important; font-size: 14px !important; min-height: 38px !important; }
  </style>

  <div class="indi-head">
    <h1>Machine Master</h1>
    <div style="display: flex; gap: 10px; align-items: center">
      <button class="header-action-btn" onclick="openAddDialog()">
        <i class="fa-solid fa-plus" style="margin-right: 4px"></i> Machine
      </button>
    </div>
  </div>

  <div class="table-spinner"><div class="spinner-circle"></div></div>
  <div id="machine-table" class="tabulator tabulator-modern"></div>
</div>

<!-- ============ ADD MACHINE DIALOG ============ -->
<div class="logout-modal" id="addDialog" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="addDialogTitle"
    style="width: min(440px, 95vw); padding: 0; border-radius: 14px; border: none;">
    <div class="dialog-header">
      <h2 id="addDialogTitle">Add Machine</h2>
      <button class="dialog-close-btn" type="button" onclick="closeAddDialog()" aria-label="Close">×</button>
    </div>
    <div class="dialog-body">
      <div class="dialog-field-group dialog-choices">
        <label class="dialog-field-label" for="addLocationSelect">Location</label>
        <select id="addLocationSelect"><option value="">Select Location</option></select>
      </div>
      <div class="dialog-field-group dialog-choices">
        <label class="dialog-field-label" for="addMachineTypeSelect">Machine Family</label>
        <select id="addMachineTypeSelect">
          <option value="">Select Type</option>
          <option value="Flatbed">Flatbed</option>
          <option value="Rotary">Rotary</option>
          <option value="Flexo">Flexo</option>
          <option value="Slitting">Slitting</option>
          <option value="Micro Slitter">Micro Slitter</option>
          <option value="Sheet Cutter">Sheet Cutter</option>
          <option value="Coating">Coating</option>
        </select>
      </div>
      <div class="dialog-field-group">
        <label class="dialog-field-label" for="addMachineInput">Machine Name</label>
        <input type="text" id="addMachineInput" class="form-control premium-input"
          placeholder="Enter machine name" autocomplete="off" maxlength="100" />
      </div>
      <div id="addMachineError" class="dialog-error"></div>
      <div class="dialog-actions">
        <button class="logout-btn" type="button" onclick="closeAddDialog()">Cancel</button>
        <button class="logout-btn primary" type="button" id="addSubmitBtn" onclick="submitAdd()">Save Machine</button>
      </div>
    </div>
  </div>
</div>

<!-- ============ EDIT MACHINE DIALOG ============ -->
<div class="logout-modal" id="editDialog" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="editDialogTitle"
    style="width: min(440px, 95vw); padding: 0; border-radius: 14px; border: none;">
    <div class="dialog-header">
      <h2 id="editDialogTitle">Edit Machine</h2>
      <button class="dialog-close-btn" type="button" onclick="closeEditDialog()" aria-label="Close">×</button>
    </div>
    <div class="dialog-body">
      <div class="dialog-field-group dialog-choices">
        <label class="dialog-field-label" for="editLocationSelect">Location</label>
        <select id="editLocationSelect"><option value="">Select Location</option></select>
      </div>
      <div class="dialog-field-group dialog-choices">
        <label class="dialog-field-label" for="editMachineTypeSelect">Machine Family</label>
        <select id="editMachineTypeSelect">
          <option value="">Select Type</option>
          <option value="Flatbed">Flatbed</option>
          <option value="Rotary">Rotary</option>
          <option value="Flexo">Flexo</option>
          <option value="Slitting">Slitting</option>
          <option value="Micro Slitter">Micro Slitter</option>
          <option value="Sheet Cutter">Sheet Cutter</option>
          <option value="Coating">Coating</option>
        </select>
      </div>
      <div class="dialog-field-group">
        <label class="dialog-field-label" for="editMachineInput">Machine Name</label>
        <input type="text" id="editMachineInput" class="form-control premium-input"
          placeholder="Enter machine name" autocomplete="off" maxlength="100" />
      </div>
      <div id="editMachineError" class="dialog-error"></div>
      <div class="dialog-actions">
        <button class="logout-btn" type="button" onclick="closeEditDialog()">Cancel</button>
        <button class="logout-btn primary" type="button" id="editSubmitBtn" onclick="submitEdit()">Update Machine</button>
      </div>
    </div>
  </div>
</div>

<!-- ============ DELETE CONFIRMATION DIALOG ============ -->
<div class="logout-modal" id="deleteDialog" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteDialogTitle"
    style="width: min(400px, 95vw);">
    <h2 class="logout-title" id="deleteDialogTitle">
      <i class="fa-solid fa-triangle-exclamation" style="color: #ef4444; margin-right: 8px;"></i>Delete Machine?
    </h2>
    <p class="logout-text">
      Are you sure you want to delete <strong id="deleteMachineName"></strong>
      <span id="deleteMachineLocLabel"></span>? This action cannot be undone.
    </p>
    <div class="logout-actions">
      <button class="logout-btn" type="button" onclick="closeDeleteDialog()">Cancel</button>
      <button class="logout-btn" type="button" id="deleteConfirmBtn" onclick="submitDelete()"
        style="background: #ef4444; color: #fff; border-color: #ef4444;">Yes, Delete</button>
    </div>
  </div>
</div>

<script id="machines-data"  type="application/json"><%- safeJson(machines) %></script>
<script id="locations-data" type="application/json"><%- safeJson(locations) %></script>
<script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
<script>
  const locationsData = JSON.parse(document.getElementById("locations-data").textContent);
  const rawMachines   = JSON.parse(document.getElementById("machines-data").textContent);

  const tableData = rawMachines.map(m => ({
    _id:          String(m._id),
    machineName:  m.machineName,
    locationName: m.location?.locationName || "—",
    locationId:   m.location?._id ? String(m.location._id) : "",
    machineType:  m.machineType || "",
  }));

  const withTextFilter = col => ({ headerFilter: "input", headerFilterPlaceholder: "Search", ...col });

  new Tabulator("#machine-table", {
    data:             tableData,
    height:           "auto",
    responsiveLayout: false,
    movableColumns:   true,
    placeholder:      "No machines added yet.",
    columns: [
      {
        title: "Actions", field: "_id", width: 90, hozAlign: "center", headerSort: false,
        formatter(cell) {
          const m    = cell.getRow().getData();
          const wrap = document.createElement("div");
          wrap.style.cssText = "display:flex;gap:5px;justify-content:center;";

          const editBtn = document.createElement("button");
          editBtn.className = "loc-btn";
          editBtn.style.background = "#e67e22";
          editBtn.title = "Edit";
          editBtn.innerHTML = '<i class="fa-solid fa-pen-to-square"></i>';
          editBtn.addEventListener("click", () => openEditDialog(m._id, m.machineName, m.locationId, m.machineType));

          const delBtn = document.createElement("button");
          delBtn.className = "loc-btn";
          delBtn.style.background = "#d9534f";
          delBtn.title = "Delete";
          delBtn.innerHTML = '<i class="fa-solid fa-trash"></i>';
          delBtn.addEventListener("click", () => openDeleteDialog(m._id, m.machineName, m.locationName));

          wrap.appendChild(editBtn);
          wrap.appendChild(delBtn);
          return wrap;
        },
      },
      withTextFilter({ title: "Machine Name", field: "machineName", minWidth: 180, sorter: "string" }),
      withTextFilter({ title: "Location",     field: "locationName", minWidth: 160, sorter: "string" }),
      {
        title: "Type", field: "machineType", width: 130, hozAlign: "center", sorter: "string",
        formatter: cell => cell.getValue() || "—",
        headerFilter: "select",
        headerFilterParams: { values: { "": "All", Flatbed: "Flatbed", Rotary: "Rotary", Flexo: "Flexo", Slitting: "Slitting", "Micro Slitter": "Micro Slitter", "Sheet Cutter": "Sheet Cutter", Coating: "Coating" } },
      },
    ],
  });

  /* ─────────────────────────────────────────
     Dialog helpers
  ───────────────────────────────────────── */
  const CHOICES_CONFIG      = { searchEnabled: true,  shouldSort: false, itemSelectText: "", searchPlaceholderValue: "Search location..." };
  const TYPE_CHOICES_CONFIG = { searchEnabled: false, shouldSort: false, itemSelectText: "" };
  const MACHINE_TYPES       = ["Flatbed", "Rotary", "Flexo", "Slitting", "Micro Slitter", "Sheet Cutter", "Coating"];

  function buildChoices(selectId, selectedId) {
    const sel = document.getElementById(selectId);
    sel.innerHTML = '<option value="">Select Location</option>' +
      locationsData.map(loc =>
        `<option value="${loc._id}"${String(loc._id) === String(selectedId) ? " selected" : ""}>${loc.locationName}</option>`
      ).join("");
    return new Choices(sel, CHOICES_CONFIG);
  }

  function buildTypeChoices(selectId, selectedType) {
    const sel = document.getElementById(selectId);
    sel.innerHTML = '<option value="">Select Type</option>' +
      MACHINE_TYPES.map(t =>
        `<option value="${t}"${t === selectedType ? " selected" : ""}>${t}</option>`
      ).join("");
    return new Choices(sel, TYPE_CHOICES_CONFIG);
  }

  function openModal(id)  { const d = document.getElementById(id); d.classList.add("show");    d.setAttribute("aria-hidden", "false"); }
  function closeModal(id) { const d = document.getElementById(id); d.classList.remove("show"); d.setAttribute("aria-hidden", "true");  }
  function showError(elId, msg) { const el = document.getElementById(elId); el.textContent = msg; el.style.display = "block"; }
  function hideError(elId)      { document.getElementById(elId).style.display = "none"; }
  function setLoading(btnId, loading) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.disabled = loading;
    btn.style.opacity = loading ? "0.7" : "";
  }

  ["addDialog", "editDialog", "deleteDialog"].forEach(id => {
    document.getElementById(id).addEventListener("click", function (e) {
      if (e.target === this) closeModal(id);
    });
  });
  document.addEventListener("keydown", e => {
    if (e.key !== "Escape") return;
    ["addDialog", "editDialog", "deleteDialog"].forEach(id => {
      if (document.getElementById(id).classList.contains("show")) closeModal(id);
    });
  });

  /* ─── ADD ─── */
  let addChoices = null, addTypeChoices = null;

  function openAddDialog() {
    if (addChoices)     { addChoices.destroy();     addChoices = null; }
    if (addTypeChoices) { addTypeChoices.destroy(); addTypeChoices = null; }
    addChoices     = buildChoices("addLocationSelect", "");
    addTypeChoices = buildTypeChoices("addMachineTypeSelect", "");
    document.getElementById("addMachineInput").value = "";
    hideError("addMachineError");
    openModal("addDialog");
    setTimeout(() => document.getElementById("addMachineInput").focus(), 60);
  }
  function closeAddDialog() { closeModal("addDialog"); }

  document.getElementById("addMachineInput").addEventListener("keydown", e => { if (e.key === "Enter") submitAdd(); });

  async function submitAdd() {
    const locationId  = document.getElementById("addLocationSelect").value;
    const machineType = document.getElementById("addMachineTypeSelect").value;
    const machineName = document.getElementById("addMachineInput").value.trim();
    if (!locationId)  { showError("addMachineError", "Please select a location.");     return; }
    if (!machineType) { showError("addMachineError", "Please select a machine type."); return; }
    if (!machineName) { showError("addMachineError", "Machine name is required.");     return; }
    hideError("addMachineError");
    setLoading("addSubmitBtn", true);
    try {
      const res  = await fetch("/fairtech/form/machine", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ machineName, locationId, machineType }),
      });
      const data = await res.json();
      if (data.success) { window.location.href = data.redirect || "/fairtech/form/machine"; }
      else              { showError("addMachineError", data.message || "Failed to add machine."); }
    } catch { showError("addMachineError", "Server error. Please try again."); }
    finally  { setLoading("addSubmitBtn", false); }
  }

  /* ─── EDIT ─── */
  let editId = null, editChoices = null, editTypeChoices = null;

  function openEditDialog(id, name, locId, machineType) {
    editId = id;
    if (editChoices)     { editChoices.destroy();     editChoices = null; }
    if (editTypeChoices) { editTypeChoices.destroy(); editTypeChoices = null; }
    editChoices     = buildChoices("editLocationSelect", locId);
    editTypeChoices = buildTypeChoices("editMachineTypeSelect", machineType || "");
    document.getElementById("editMachineInput").value = name;
    hideError("editMachineError");
    openModal("editDialog");
    setTimeout(() => { const inp = document.getElementById("editMachineInput"); inp.focus(); inp.select(); }, 60);
  }
  function closeEditDialog() { closeModal("editDialog"); editId = null; }

  document.getElementById("editMachineInput").addEventListener("keydown", e => { if (e.key === "Enter") submitEdit(); });

  async function submitEdit() {
    const locationId  = document.getElementById("editLocationSelect").value;
    const machineType = document.getElementById("editMachineTypeSelect").value;
    const machineName = document.getElementById("editMachineInput").value.trim();
    if (!locationId)  { showError("editMachineError", "Please select a location.");     return; }
    if (!machineType) { showError("editMachineError", "Please select a machine type."); return; }
    if (!machineName) { showError("editMachineError", "Machine name is required.");     return; }
    if (!editId)      return;
    hideError("editMachineError");
    setLoading("editSubmitBtn", true);
    try {
      const res  = await fetch(`/fairtech/api/machines/${editId}`, {
        method: "PUT", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ machineName, locationId, machineType }),
      });
      const data = await res.json();
      if (data.success) { window.location.reload(); }
      else              { showError("editMachineError", data.message || "Failed to update machine."); }
    } catch { showError("editMachineError", "Server error. Please try again."); }
    finally  { setLoading("editSubmitBtn", false); }
  }

  /* ─── DELETE ─── */
  let deleteId = null;

  function openDeleteDialog(id, name, locName) {
    deleteId = id;
    document.getElementById("deleteMachineName").textContent = name;
    document.getElementById("deleteMachineLocLabel").textContent = locName ? ` at ${locName}` : "";
    openModal("deleteDialog");
  }
  function closeDeleteDialog() { closeModal("deleteDialog"); deleteId = null; }

  async function submitDelete() {
    if (!deleteId) return;
    setLoading("deleteConfirmBtn", true);
    try {
      const res  = await fetch(`/fairtech/api/machines/${deleteId}`, { method: "DELETE" });
      const data = await res.json();
      if (data.success) { window.location.reload(); }
      else              { closeDeleteDialog(); alert(data.message || "Failed to delete machine."); }
    } catch { closeDeleteDialog(); alert("Error deleting machine."); }
    finally  { setLoading("deleteConfirmBtn", false); }
  }
</script>
