<% layout('/layout/boilerplate') -%>

<div class="contain mq-page" style="flex-direction: column; padding: 10px; gap: 14px;">
  <style>
    .mq-head h1 { font-size: 20px; color: #fff; margin: 0; }
    .mq-head .mq-sub { font-size: 13px; color: rgba(255, 255, 255, 0.85); margin-top: 2px; }

    .ap-card {
      width: 100%;
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      overflow: hidden;
    }
    .ap-card-title {
      background: #044a78;
      color: #fff; font-size: 14px; font-weight: 600; letter-spacing: 0.2px;
      padding: 9px 16px; display: flex; align-items: center; justify-content: space-between; gap: 10px;
    }

    .ap-table-wrap { overflow-x: auto; }
    .ap-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .ap-table th, .ap-table td { padding: 9px 14px; border-bottom: 1px solid #e5e7eb; border-right: 1px solid #e5e7eb; text-align: left; white-space: nowrap; }
    .ap-table tr > *:last-child { border-right: none; }
    .ap-table th { background: #f8fafc; color: #044a78; font-weight: 700; }
    .ap-table td { color: #1f2a44; font-weight: 600; }
    .ap-table tbody tr:hover { background: #fbfdff; }

    .ap-notice {
      background: #fff8e1; border: 1px solid #f0c36d; color: #7a5b00; border-radius: 8px;
      padding: 10px 14px; font-size: 13px; display: flex; align-items: center; gap: 8px;
    }

    .mq-start-btn {
      display: inline-flex; align-items: center; gap: 6px; background: #10b981; color: #fff;
      border: none; border-radius: 6px; padding: 6px 12px; font-size: 12.5px; font-weight: 600;
      cursor: pointer; text-decoration: none; white-space: nowrap; transition: opacity 0.2s;
    }
    .mq-start-btn:hover { opacity: 0.85; }

    .ap-table tbody tr.mq-row-match { background: #dcfce7; }
    .ap-table tbody tr.mq-row-match:hover { background: #bbf7d0; }
    .ap-table tbody tr.mq-row-short { background: #fee2e2; }
    .ap-table tbody tr.mq-row-short:hover { background: #fecaca; }

    .mq-rolls-cell {
      cursor: pointer; color: #044a78; text-decoration: underline; text-decoration-style: dotted;
      text-underline-offset: 3px;
    }
    .mq-rolls-cell:hover { color: #023654; }

    .dialog-header {
      background: #044A78; padding: 18px 22px;
      display: flex; align-items: center; justify-content: space-between;
      border-radius: 14px 14px 0 0;
    }
    .dialog-header h2 { margin: 0; font-size: 1.05rem; font-weight: 700; color: #fff; }
    .dialog-close-btn {
      background: none; border: none; color: #fff; font-size: 20px;
      cursor: pointer; line-height: 1; padding: 0 2px; opacity: 0.8; transition: opacity 0.15s;
    }
    .dialog-close-btn:hover { opacity: 1; }
    .dialog-body { padding: 20px 22px; background: #fff; border-radius: 0 0 14px 14px; }
    .rd-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .rd-table th, .rd-table td { padding: 8px 10px; border-bottom: 1px solid #e5e7eb; text-align: left; }
    .rd-table th { width: 42%; color: #5a6586; font-weight: 600; }
    .rd-table td { color: #1f2a44; font-weight: 700; }
    .rd-table tr:last-child th, .rd-table tr:last-child td { border-bottom: none; }

    /* ---------- Mobile (operators work this page on a phone) ----------
       Twelve columns can't be read on a 360px screen even with a scroller, so
       each order becomes its own card: the <th> text is repeated per cell from
       data-label and the row's status colour still tints the whole card. */
    @media screen and (max-width: 768px) {
      .mq-page { height: auto; min-height: 100%; padding: 8px; gap: 10px; }
      .mq-head { padding: 0.5rem 0.7rem; }
      .mq-head h1 { font-size: 17px; }
      .mq-head .mq-sub { font-size: 12px; }
      .ap-card-title { font-size: 13px; padding: 8px 12px; }

      .ap-table-wrap { overflow-x: visible; }
      .ap-table thead { display: none; }
      .ap-table, .ap-table tbody, .ap-table tr, .ap-table td { display: block; width: 100%; }
      .ap-table tbody tr {
        border: 1px solid #dbe3ec; border-radius: 8px; overflow: hidden; margin: 10px;
        width: auto;
      }
      .ap-table td {
        display: flex; align-items: center; gap: 10px;
        padding: 7px 12px; border-right: none; white-space: normal; font-size: 13px;
      }
      .ap-table td::before {
        content: attr(data-label);
        flex: 0 0 42%; min-width: 0;
        color: #5a6586; font-weight: 700; font-size: 12px;
      }
      .ap-table td:last-child { border-bottom: none; justify-content: center; padding: 10px 12px; }
      .ap-table td:last-child::before { content: none; }
      .mq-start-btn { width: 100%; justify-content: center; padding: 11px 12px; font-size: 14px; }

      .dialog-header { padding: 14px 16px; }
      .dialog-body { padding: 14px 16px; }
      .rd-table th, .rd-table td { padding: 7px 6px; font-size: 12.5px; }
    }
  </style>

  <div class="indi-head mq-head">
    <div>
      <h1><%= machine.machineName %></h1>
      <div class="mq-sub">
        <%= machine.machineType || "—" %><% if (machine.location && machine.location.locationName) { %> / <%= machine.location.locationName %><% } %>
      </div>
    </div>
  </div>

  <div class="ap-card">
    <div class="ap-card-title">
      <span><i class="fa-solid fa-layer-group"></i> Pending List</span>
      <span><%= rows.length %> order<%= rows.length === 1 ? "" : "s" %></span>
    </div>

    <% if (rows.length === 0) { %>
      <div style="padding: 14px 16px;">
        <div class="ap-notice">
          <i class="fa-solid fa-circle-info"></i>
          No orders currently assigned to this machine.
        </div>
      </div>
    <% } else { %>
      <div class="ap-table-wrap">
        <table class="ap-table">
          <thead>
            <tr>
              <th>Lot No</th>
              <th>Product ID</th>
              <th>Width</th>
              <th>Height</th>
              <th>Die</th>
              <th>Paper Type</th>
              <th>Paper Code</th>
              <th>Paper Size</th>
              <th>Required Rolls</th>
              <th>Allotted Rolls</th>
              <th>Balance Rolls</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach((row) => { %>
              <tr class="<%= row.rollsStatus === 'match' ? 'mq-row-match' : row.rollsStatus === 'short' ? 'mq-row-short' : '' %>">
                <td data-label="Lot No"><%= row.lotNo %></td>
                <td data-label="Product ID"><%= row.productId %></td>
                <td data-label="Width"><%= row.labelWidth %></td>
                <td data-label="Height"><%= row.labelHeight %></td>
                <td data-label="Die"><%= row.dieNo %></td>
                <td data-label="Paper Type"><%= row.paperType %></td>
                <td data-label="Paper Code"><%= row.paperCode %></td>
                <td data-label="Paper Size"><%= row.paperSize %></td>
                <td data-label="Required Rolls"><%= row.rolls %></td>
                <td class="mq-rolls-cell" data-label="Allotted Rolls" data-id="<%= row._id %>" onclick="openRollDetails(this.dataset.id)" title="View roll allotment details"><%= row.allottedRolls %></td>
                <td data-label="Balance Rolls"><%= row.balanceRolls %></td>
                <td>
                  <a href="/fairtech/machine/jobcard/form?pendingId=<%= row._id %>" class="mq-start-btn" title="Initiate Production">
                    <i class="fa-solid fa-play"></i> Initiate Production
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<!-- ============ ROLL ALLOTMENT DETAILS DIALOG ============ -->
<div class="logout-modal" id="rollDetailsDialog" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="rollDetailsTitle"
    style="width: min(480px, 95vw); padding: 0; border-radius: 14px; border: none;">
    <div class="dialog-header">
      <h2 id="rollDetailsTitle">Roll Allotment Details</h2>
      <button class="dialog-close-btn" type="button" onclick="closeModal('rollDetailsDialog')" aria-label="Close">×</button>
    </div>
    <div class="dialog-body" id="rollDetailsBody"></div>
  </div>
</div>

<script id="queue-rows-data" type="application/json"><%- safeJson(rows) %></script>
<script>
  const QUEUE_ROWS = JSON.parse(document.getElementById("queue-rows-data").textContent);

  function openModal(id)  { const d = document.getElementById(id); d.classList.add("show");    d.setAttribute("aria-hidden", "false"); }
  function closeModal(id) { const d = document.getElementById(id); d.classList.remove("show"); d.setAttribute("aria-hidden", "true");  }

  function dash(v) { return v === undefined || v === null || v === "" ? "—" : v; }

  function openRollDetails(id) {
    const row = QUEUE_ROWS.find((r) => r._id === id);
    if (!row) return;
    const ref = row.productionReference || {};

    const statusLabel = row.rollsStatus === "match" ? "Fully allotted"
      : row.rollsStatus === "short" ? "Short allotted"
      : row.rollsStatus === "over" ? "Over allotted"
      : "—";
    const statusColor = row.rollsStatus === "match" ? "#16a34a"
      : row.rollsStatus === "short" ? "#dc2626"
      : row.rollsStatus === "over" ? "#d97706"
      : "#1f2a44";

    const pairs = [
      ["Lot No", dash(row.lotNo)],
      ["Product ID", dash(row.productId)],
      ["Die", dash(ref.die || row.dieNo)],
      ["Running Meters", dash(ref.runningMeters)],
      ["Paper Code", dash(ref.paperCode || row.paperCode)],
      ["Paper Type", dash(ref.paperType || row.paperType)],
      ["Paper Size", dash(ref.paperSize || row.paperSize)],
      ["GSM", dash(ref.gsm)],
      ["Quantity", dash(row.quantity)],
      ["Required Rolls", dash(row.rolls)],
      ["Allotted Rolls", dash(row.allottedRolls)],
      ["Balance Rolls", dash(row.balanceRolls)],
      ["Operator", dash(row.operatorName)],
      ["Helper", dash(row.helperName)],
    ];

    const rowsHtml = pairs.map(([k, v]) => `<tr><th>${k}</th><td>${v}</td></tr>`).join("")
      + `<tr><th>Status</th><td><span style="color:${statusColor};">${statusLabel}</span></td></tr>`;

    document.getElementById("rollDetailsBody").innerHTML = `<table class="rd-table"><tbody>${rowsHtml}</tbody></table>`;
    openModal("rollDetailsDialog");
  }

  document.getElementById("rollDetailsDialog").addEventListener("click", (e) => {
    if (e.target.id === "rollDetailsDialog") closeModal("rollDetailsDialog");
  });
</script>
