<% layout('/layout/boilerplate') %>

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <style>
    .header-action-btn {
      background-color: #f0f0f0;
      color: #044a78;
      padding: 2px 14px;
      font-size: 14px;
      font-weight: 500;
      border: none;
      cursor: pointer;
      border-radius: 0.5rem;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      transition: all 0.2s ease-in-out;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .header-action-btn:hover {
      background-color: #e4e4e4;
    }
    .location-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 12px;
    }
    .location-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      font-weight: 600;
      font-size: 14px;
      color: #03365a;
      transition: box-shadow 0.15s ease;
    }
    .location-card:hover {
      box-shadow: 0 2px 8px rgba(4, 74, 120, 0.1);
    }
    .location-card-name {
      flex: 1;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .location-actions {
      display: flex;
      gap: 5px;
      flex-shrink: 0;
      margin-left: 10px;
    }
    .loc-btn {
      padding: 3px 8px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 12px;
      color: #fff;
      transition: opacity 0.15s;
    }
    .loc-btn:hover {
      opacity: 0.85;
    }
    .dialog-header {
      background: #044A78;
      padding: 18px 22px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .dialog-header h2 {
      margin: 0;
      font-size: 1.05rem;
      font-weight: 700;
      color: #fff;
    }
    .dialog-close-btn {
      background: none;
      border: none;
      color: #fff;
      font-size: 20px;
      cursor: pointer;
      line-height: 1;
      padding: 0 2px;
      opacity: 0.8;
      transition: opacity 0.15s;
    }
    .dialog-close-btn:hover {
      opacity: 1;
    }
    .dialog-body {
      padding: 24px;
      background: #fff;
    }
    .dialog-field-label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #475569;
      margin-bottom: 8px;
    }
    .dialog-error {
      color: #ef4444;
      font-size: 12px;
      margin-top: 5px;
      display: none;
    }
    .dialog-actions {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 20px;
    }
  </style>

  <div class="indi-head">
    <h1>Location Master</h1>
    <div style="display: flex; gap: 10px; align-items: center">
      <button class="header-action-btn" onclick="openAddDialog()">
        <i class="fa-solid fa-plus" style="margin-right: 4px"></i> Location
      </button>
    </div>
  </div>

  <div style="padding: 4px 0;">
    <% if (locations && locations.length > 0) { %>
      <div class="location-grid">
        <% locations.forEach(loc => { %>
          <div class="location-card">
            <span class="location-card-name"><%= loc.locationName %></span>
            <div class="location-actions">
              <button
                class="loc-btn"
                style="background: #e67e22;"
                data-loc-id="<%= loc._id %>"
                data-loc-name="<%= loc.locationName %>"
                onclick="openEditDialog(this.dataset.locId, this.dataset.locName)"
                title="Edit Location">
                <i class="fa-solid fa-pen-to-square"></i>
              </button>
              <button
                class="loc-btn"
                style="background: #d9534f;"
                data-loc-id="<%= loc._id %>"
                data-loc-name="<%= loc.locationName %>"
                onclick="openDeleteDialog(this.dataset.locId, this.dataset.locName)"
                title="Delete Location">
                <i class="fa-solid fa-trash"></i>
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div style="text-align: center; padding: 40px 20px; color: #6b7280;">
        <i class="fa-solid fa-location-dot" style="font-size: 36px; color: #cbd5e1; margin-bottom: 12px;"></i>
        <p style="font-size: 14px; margin: 0;">No locations added yet. Click <strong>+ Location</strong> to add one.</p>
      </div>
    <% } %>
  </div>
</div>

<!-- ============ ADD LOCATION DIALOG ============ -->
<div class="logout-modal" id="addDialog" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="addDialogTitle"
    style="width: min(420px, 95vw); padding: 0; border-radius: 14px; overflow: hidden;">
    <div class="dialog-header">
      <h2 id="addDialogTitle">Add Location</h2>
      <button class="dialog-close-btn" type="button" onclick="closeAddDialog()" aria-label="Close">×</button>
    </div>
    <div class="dialog-body">
      <label class="dialog-field-label" for="addLocationInput">Location Name</label>
      <input
        type="text"
        id="addLocationInput"
        class="form-control premium-input"
        placeholder="Enter location name"
        autocomplete="off"
        maxlength="100"
      />
      <div id="addLocationError" class="dialog-error"></div>
      <div class="dialog-actions">
        <button class="logout-btn" type="button" onclick="closeAddDialog()">Cancel</button>
        <button class="logout-btn primary" type="button" id="addSubmitBtn" onclick="submitAdd()">Save Location</button>
      </div>
    </div>
  </div>
</div>

<!-- ============ EDIT LOCATION DIALOG ============ -->
<div class="logout-modal" id="editDialog" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="editDialogTitle"
    style="width: min(420px, 95vw); padding: 0; border-radius: 14px; overflow: hidden;">
    <div class="dialog-header">
      <h2 id="editDialogTitle">Edit Location</h2>
      <button class="dialog-close-btn" type="button" onclick="closeEditDialog()" aria-label="Close">×</button>
    </div>
    <div class="dialog-body">
      <label class="dialog-field-label" for="editLocationInput">Location Name</label>
      <input
        type="text"
        id="editLocationInput"
        class="form-control premium-input"
        placeholder="Enter location name"
        autocomplete="off"
        maxlength="100"
      />
      <div id="editLocationError" class="dialog-error"></div>
      <div class="dialog-actions">
        <button class="logout-btn" type="button" onclick="closeEditDialog()">Cancel</button>
        <button class="logout-btn primary" type="button" id="editSubmitBtn" onclick="submitEdit()">Update Location</button>
      </div>
    </div>
  </div>
</div>

<!-- ============ DELETE CONFIRMATION DIALOG ============ -->
<div class="logout-modal" id="deleteDialog" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteDialogTitle"
    style="width: min(400px, 95vw);">
    <h2 class="logout-title" id="deleteDialogTitle">
      <i class="fa-solid fa-triangle-exclamation" style="color: #ef4444; margin-right: 8px;"></i>Delete Location?
    </h2>
    <p class="logout-text">
      Are you sure you want to delete <strong id="deleteLocName"></strong>? This action cannot be undone.
    </p>
    <div class="logout-actions">
      <button class="logout-btn" type="button" onclick="closeDeleteDialog()">Cancel</button>
      <button
        class="logout-btn"
        type="button"
        id="deleteConfirmBtn"
        onclick="submitDelete()"
        style="background: #ef4444; color: #fff; border-color: #ef4444;">
        Yes, Delete
      </button>
    </div>
  </div>
</div>

<script>
  // ---- Helpers ----
  function openModal(id) {
    const d = document.getElementById(id);
    d.classList.add("show");
    d.setAttribute("aria-hidden", "false");
  }
  function closeModal(id) {
    const d = document.getElementById(id);
    d.classList.remove("show");
    d.setAttribute("aria-hidden", "true");
  }
  function showError(elId, msg) {
    const el = document.getElementById(elId);
    el.textContent = msg;
    el.style.display = "block";
  }
  function hideError(elId) {
    document.getElementById(elId).style.display = "none";
  }
  function setLoading(btnId, loading) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.disabled = loading;
    btn.style.opacity = loading ? "0.7" : "";
  }

  // Dismiss on backdrop click
  ["addDialog", "editDialog", "deleteDialog"].forEach(id => {
    document.getElementById(id).addEventListener("click", function (e) {
      if (e.target === this) closeModal(id);
    });
  });

  // Dismiss on ESC
  document.addEventListener("keydown", e => {
    if (e.key !== "Escape") return;
    ["addDialog", "editDialog", "deleteDialog"].forEach(id => {
      if (document.getElementById(id).classList.contains("show")) closeModal(id);
    });
  });

  // ---- ADD ----
  function openAddDialog() {
    document.getElementById("addLocationInput").value = "";
    hideError("addLocationError");
    openModal("addDialog");
    setTimeout(() => document.getElementById("addLocationInput").focus(), 60);
  }
  function closeAddDialog() {
    closeModal("addDialog");
  }

  document.getElementById("addLocationInput").addEventListener("keydown", e => {
    if (e.key === "Enter") submitAdd();
  });

  async function submitAdd() {
    const name = document.getElementById("addLocationInput").value.trim();
    if (!name) {
      showError("addLocationError", "Location name is required.");
      return;
    }
    hideError("addLocationError");
    setLoading("addSubmitBtn", true);
    try {
      const res = await fetch("/fairtech/form/location", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ locationName: name }),
      });
      const data = await res.json();
      if (data.success) {
        window.location.href = data.redirect || "/fairtech/form/location";
      } else {
        showError("addLocationError", data.message || "Failed to add location.");
      }
    } catch {
      showError("addLocationError", "Server error. Please try again.");
    } finally {
      setLoading("addSubmitBtn", false);
    }
  }

  // ---- EDIT ----
  let editId = null;

  function openEditDialog(id, name) {
    editId = id;
    document.getElementById("editLocationInput").value = name;
    hideError("editLocationError");
    openModal("editDialog");
    setTimeout(() => {
      const inp = document.getElementById("editLocationInput");
      inp.focus();
      inp.select();
    }, 60);
  }
  function closeEditDialog() {
    closeModal("editDialog");
    editId = null;
  }

  document.getElementById("editLocationInput").addEventListener("keydown", e => {
    if (e.key === "Enter") submitEdit();
  });

  async function submitEdit() {
    const name = document.getElementById("editLocationInput").value.trim();
    if (!name) {
      showError("editLocationError", "Location name is required.");
      return;
    }
    if (!editId) return;
    hideError("editLocationError");
    setLoading("editSubmitBtn", true);
    try {
      const res = await fetch(`/fairtech/api/locations/${editId}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ locationName: name }),
      });
      const data = await res.json();
      if (data.success) {
        window.location.reload();
      } else {
        showError("editLocationError", data.message || "Failed to update location.");
      }
    } catch {
      showError("editLocationError", "Server error. Please try again.");
    } finally {
      setLoading("editSubmitBtn", false);
    }
  }

  // ---- DELETE ----
  let deleteId = null;

  function openDeleteDialog(id, name) {
    deleteId = id;
    document.getElementById("deleteLocName").textContent = name;
    openModal("deleteDialog");
  }
  function closeDeleteDialog() {
    closeModal("deleteDialog");
    deleteId = null;
  }

  async function submitDelete() {
    if (!deleteId) return;
    setLoading("deleteConfirmBtn", true);
    try {
      const res = await fetch(`/fairtech/api/locations/${deleteId}`, {
        method: "DELETE",
      });
      const data = await res.json();
      if (data.success) {
        window.location.reload();
      } else {
        closeDeleteDialog();
        alert(data.message || "Failed to delete location.");
      }
    } catch {
      closeDeleteDialog();
      alert("Error deleting location.");
    } finally {
      setLoading("deleteConfirmBtn", false);
    }
  }
</script>
