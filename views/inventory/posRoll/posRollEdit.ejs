<% layout('/layout/boilerplate') -%>
<style>
  input[readonly] { background: #f1f5f9; cursor: not-allowed; }
</style>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <form
    class="needs-validation"
    action="/fairtech/pos-roll/edit/<%= posRoll._id %>"
    method="post"
    autocomplete="off"
    novalidate
  >
    <div class="span-full form-heading">
      <h1>POS Roll Master</h1>
    </div>

    <div class="span-five">
      <label>Product ID</label>
      <input type="text" class="form-control input-tag" value="<%= posRoll.posProductId %>" readonly />
    </div>
    <div class="span-four">
      <label>Paper Code</label>
      <input type="text" class="form-control" value="<%= posRoll.posPaperCode %>" readonly />
    </div>
    <div class="span-four">
      <label>Paper Type</label>
      <input type="text" class="form-control" value="<%= posRoll.posPaperType %>" readonly />
    </div>
    <div class="span-four">
      <label>Color</label>
      <input type="text" class="form-control" value="<%= posRoll.posColor %>" readonly />
    </div>
    <div class="span-four">
      <label>GSM</label>
      <input type="text" class="form-control" value="<%= posRoll.posGsm %>" readonly />
    </div>
    <div class="span-four">
      <label>Width</label>
      <input type="text" class="form-control" value="<%= posRoll.posWidth %>" readonly />
    </div>
    <div class="span-four">
      <label>MTRS</label>
      <input type="text" class="form-control" value="<%= posRoll.posMtrs %>" readonly />
    </div>
    <div class="span-three">
      <label>Core ID</label>
      <input type="text" class="form-control" value="<%= posRoll.posCoreId %>" readonly />
    </div>

    <div class="span-five">
      <label>Status</label>
      <select name="status" class="form-control select-tag" required>
        <option value="ACTIVE" <%= (posRoll.status || "ACTIVE") === "ACTIVE" ? "selected" : "" %>>ACTIVE</option>
        <option value="INACTIVE" <%= posRoll.status === "INACTIVE" ? "selected" : "" %>>INACTIVE</option>
      </select>
    </div>

    <div class="span-full btn-grp" style="flex-direction: row-reverse;">
      <button class="submit-btn" type="submit">Update Status</button>
      <button type="button" id="cancelBtn">Cancel</button>
    </div>
  </form>
</div>

<script>
  document.getElementById("cancelBtn").addEventListener("click", () => {
    window.location.href = "/fairtech/pos-roll/profile/<%= posRoll._id %>";
  });
</script>
