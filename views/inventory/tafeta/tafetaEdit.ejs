<% layout('/layout/boilerplate') -%>
<style>
  input[readonly] { background: #f1f5f9; cursor: not-allowed; }
</style>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <form
    class="needs-validation"
    action="/fairtech/tafeta/edit/<%= tafeta._id %>"
    method="post"
    autocomplete="off"
    novalidate
  >
    <div class="span-full form-heading">
      <h1>Tafeta Master</h1>
    </div>

    <div class="span-five">
      <label>Product ID</label>
      <input type="text" class="form-control input-tag" value="<%= tafeta.tafetaProductId %>" readonly />
    </div>
    <div class="span-six">
      <label>Material Code</label>
      <input type="text" class="form-control" value="<%= tafeta.tafetaMaterialCode %>" readonly />
    </div>
    <div class="span-six">
      <label>Material Type</label>
      <input type="text" class="form-control" value="<%= tafeta.tafetaMaterialType %>" readonly />
    </div>
    <div class="span-five">
      <label>Color</label>
      <input type="text" class="form-control" value="<%= tafeta.tafetaColor %>" readonly />
    </div>
    <div class="span-five">
      <label>GSM</label>
      <input type="text" class="form-control" value="<%= tafeta.tafetaGsm %>" readonly />
    </div>
    <div class="span-five">
      <label>Width</label>
      <input type="text" class="form-control" value="<%= tafeta.tafetaWidth %>" readonly />
    </div>
    <div class="span-seven">
      <label>MTRS</label>
      <input type="text" class="form-control" value="<%= tafeta.tafetaMtrs %>" readonly />
    </div>
    <div class="span-six">
      <label>Core Length</label>
      <input type="text" class="form-control" value="<%= tafeta.tafetaCoreLen %>" readonly />
    </div>
    <div class="span-six">
      <label>Notch</label>
      <input type="text" class="form-control" value="<%= tafeta.tafetaNotch %>" readonly />
    </div>
    <div class="span-six">
      <label>Core ID</label>
      <input type="text" class="form-control" value="<%= tafeta.tafetaCoreId %>" readonly />
    </div>

    <div class="span-seven">
      <label>Status</label>
      <select name="status" class="form-control select-tag" required>
        <option value="ACTIVE" <%= (tafeta.status || "ACTIVE") === "ACTIVE" ? "selected" : "" %>>ACTIVE</option>
        <option value="INACTIVE" <%= tafeta.status === "INACTIVE" ? "selected" : "" %>>INACTIVE</option>
      </select>
    </div>

    <div class="span-full btn-grp" style="flex-direction: row-reverse;">
      <button class="submit-btn" type="submit">Update Status</button>
      <button type="button" id="cancelBtn">Cancel</button>
    </div>
  </form>
</div>

<script>
  document.getElementById("cancelBtn").addEventListener("click", () => {
    window.location.href = "/fairtech/tafeta/profile/<%= tafeta._id %>";
  });
</script>
