<% layout('/layout/boilerplate') %>

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <style>
    .header-action-btn {
      background-color: #f0f0f0;
      color: #044a78;
      padding: 2px 14px;
      font-size: 14px;
      font-weight: 500;
      border: none;
      cursor: pointer;
      border-radius: 0.5rem;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      transition: all 0.2s ease-in-out;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .header-action-btn:hover {
      background-color: #e4e4e4;
    }
    .machine-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 12px;
    }
    .machine-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      transition: box-shadow 0.15s ease;
    }
    .machine-card:hover {
      box-shadow: 0 2px 8px rgba(4, 74, 120, 0.1);
    }
    .machine-card-info {
      flex: 1;
      min-width: 0;
    }
    .machine-card-name {
      font-weight: 600;
      font-size: 14px;
      color: #03365a;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .machine-card-location {
      font-size: 13px;
      font-weight: 600;
      color: #475569;
      margin-top: 3px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .machine-card-location i {
      font-size: 11px;
      margin-right: 4px;
      color: #044a78;
    }
    .machine-actions {
      display: flex;
      gap: 5px;
      flex-shrink: 0;
      margin-left: 10px;
    }
    .loc-btn {
      padding: 3px 8px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 12px;
      color: #fff;
      transition: opacity 0.15s;
    }
    .loc-btn:hover {
      opacity: 0.85;
    }
    .dialog-header {
      background: #044A78;
      padding: 18px 22px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-radius: 14px 14px 0 0;
    }
    .dialog-header h2 {
      margin: 0;
      font-size: 1.05rem;
      font-weight: 700;
      color: #fff;
    }
    .dialog-close-btn {
      background: none;
      border: none;
      color: #fff;
      font-size: 20px;
      cursor: pointer;
      line-height: 1;
      padding: 0 2px;
      opacity: 0.8;
      transition: opacity 0.15s;
    }
    .dialog-close-btn:hover {
      opacity: 1;
    }
    .dialog-body {
      padding: 24px;
      background: #fff;
      border-radius: 0 0 14px 14px;
    }
    .dialog-field-label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #475569;
      margin-bottom: 8px;
    }
    .dialog-field-group {
      margin-bottom: 16px;
    }
    .dialog-error {
      color: #ef4444;
      font-size: 12px;
      margin-top: 5px;
      display: none;
    }
    .dialog-actions {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 20px;
    }
    .dialog-choices .choices__inner {
      border-radius: 10px !important;
      border: 1.5px solid #e2e8f0 !important;
      background-color: #f8fafc;
      font-size: 14px;
      min-height: 44px;
      display: flex;
      align-items: center;
    }
    .dialog-choices .choices__list--single {
      padding: 6px 10px;
    }
    .dialog-choices .choices__placeholder {
      opacity: 0.55;
    }
    .dialog-choices .choices__list--dropdown {
      z-index: 99999;
    }
    .dialog-choices .choices__input--cloned {
      padding: 10px 10px !important;
      font-size: 14px !important;
      min-height: 38px !important;
    }
  </style>

  <div class="indi-head">
    <h1>Machine Master</h1>
    <div style="display: flex; gap: 10px; align-items: center">
      <button class="header-action-btn" onclick="openAddDialog()">
        <i class="fa-solid fa-plus" style="margin-right: 4px"></i> Machine
      </button>
    </div>
  </div>

  <div style="padding: 4px 0;">
    <% if (machines && machines.length > 0) { %>
      <div class="machine-grid">
        <% machines.forEach(m => { %>
          <div class="machine-card">
            <div class="machine-card-info">
              <div class="machine-card-name"><%= m.machineName %></div>
              <div class="machine-card-location">
                <i class="fa-solid fa-location-dot"></i><%= m.location?.locationName || '—' %>
              </div>
            </div>
            <div class="machine-actions">
              <button
                class="loc-btn"
                style="background: #e67e22;"
                data-id="<%= m._id %>"
                data-name="<%= m.machineName %>"
                data-loc-id="<%= m.location?._id || '' %>"
                onclick="openEditDialog(this.dataset.id, this.dataset.name, this.dataset.locId)"
                title="Edit Machine">
                <i class="fa-solid fa-pen-to-square"></i>
              </button>
              <button
                class="loc-btn"
                style="background: #d9534f;"
                data-id="<%= m._id %>"
                data-name="<%= m.machineName %>"
                data-loc-name="<%= m.location?.locationName || '' %>"
                onclick="openDeleteDialog(this.dataset.id, this.dataset.name, this.dataset.locName)"
                title="Delete Machine">
                <i class="fa-solid fa-trash"></i>
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div style="text-align: center; padding: 40px 20px; color: #6b7280;">
        <i class="fa-solid fa-gears" style="font-size: 36px; color: #cbd5e1; margin-bottom: 12px;"></i>
        <p style="font-size: 14px; margin: 0;">No machines added yet. Click <strong>+ Machine</strong> to add one.</p>
      </div>
    <% } %>
  </div>
</div>

<!-- ============ ADD MACHINE DIALOG ============ -->
<div class="logout-modal" id="addDialog" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="addDialogTitle"
    style="width: min(440px, 95vw); padding: 0; border-radius: 14px; border: none;">
    <div class="dialog-header">
      <h2 id="addDialogTitle">Add Machine</h2>
      <button class="dialog-close-btn" type="button" onclick="closeAddDialog()" aria-label="Close">×</button>
    </div>
    <div class="dialog-body">
      <div class="dialog-field-group dialog-choices">
        <label class="dialog-field-label" for="addLocationSelect">Location</label>
        <select id="addLocationSelect">
          <option value="">Select Location</option>
        </select>
      </div>
      <div class="dialog-field-group">
        <label class="dialog-field-label" for="addMachineInput">Machine Name</label>
        <input
          type="text"
          id="addMachineInput"
          class="form-control premium-input"
          placeholder="Enter machine name"
          autocomplete="off"
          maxlength="100"
        />
      </div>
      <div id="addMachineError" class="dialog-error"></div>
      <div class="dialog-actions">
        <button class="logout-btn" type="button" onclick="closeAddDialog()">Cancel</button>
        <button class="logout-btn primary" type="button" id="addSubmitBtn" onclick="submitAdd()">Save Machine</button>
      </div>
    </div>
  </div>
</div>

<!-- ============ EDIT MACHINE DIALOG ============ -->
<div class="logout-modal" id="editDialog" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="editDialogTitle"
    style="width: min(440px, 95vw); padding: 0; border-radius: 14px; border: none;">
    <div class="dialog-header">
      <h2 id="editDialogTitle">Edit Machine</h2>
      <button class="dialog-close-btn" type="button" onclick="closeEditDialog()" aria-label="Close">×</button>
    </div>
    <div class="dialog-body">
      <div class="dialog-field-group dialog-choices">
        <label class="dialog-field-label" for="editLocationSelect">Location</label>
        <select id="editLocationSelect">
          <option value="">Select Location</option>
        </select>
      </div>
      <div class="dialog-field-group">
        <label class="dialog-field-label" for="editMachineInput">Machine Name</label>
        <input
          type="text"
          id="editMachineInput"
          class="form-control premium-input"
          placeholder="Enter machine name"
          autocomplete="off"
          maxlength="100"
        />
      </div>
      <div id="editMachineError" class="dialog-error"></div>
      <div class="dialog-actions">
        <button class="logout-btn" type="button" onclick="closeEditDialog()">Cancel</button>
        <button class="logout-btn primary" type="button" id="editSubmitBtn" onclick="submitEdit()">Update Machine</button>
      </div>
    </div>
  </div>
</div>

<!-- ============ DELETE CONFIRMATION DIALOG ============ -->
<div class="logout-modal" id="deleteDialog" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteDialogTitle"
    style="width: min(400px, 95vw);">
    <h2 class="logout-title" id="deleteDialogTitle">
      <i class="fa-solid fa-triangle-exclamation" style="color: #ef4444; margin-right: 8px;"></i>Delete Machine?
    </h2>
    <p class="logout-text">
      Are you sure you want to delete <strong id="deleteMachineName"></strong>
      <span id="deleteMachineLocLabel"></span>? This action cannot be undone.
    </p>
    <div class="logout-actions">
      <button class="logout-btn" type="button" onclick="closeDeleteDialog()">Cancel</button>
      <button
        class="logout-btn"
        type="button"
        id="deleteConfirmBtn"
        onclick="submitDelete()"
        style="background: #ef4444; color: #fff; border-color: #ef4444;">
        Yes, Delete
      </button>
    </div>
  </div>
</div>

<script id="locations-data" type="application/json"><%- safeJson(locations) %></script>
<script>
  const locationsData = JSON.parse(document.getElementById("locations-data").textContent);

  const CHOICES_CONFIG = { searchEnabled: true, shouldSort: false, itemSelectText: "", searchPlaceholderValue: "Search location..." };

  function buildChoices(selectId, selectedId) {
    const sel = document.getElementById(selectId);
    sel.innerHTML = '<option value="">Select Location</option>' +
      locationsData.map(loc =>
        `<option value="${loc._id}"${String(loc._id) === String(selectedId) ? " selected" : ""}>${loc.locationName}</option>`
      ).join("");
    return new Choices(sel, CHOICES_CONFIG);
  }

  // ---- Helpers ----
  function openModal(id) {
    const d = document.getElementById(id);
    d.classList.add("show");
    d.setAttribute("aria-hidden", "false");
  }
  function closeModal(id) {
    const d = document.getElementById(id);
    d.classList.remove("show");
    d.setAttribute("aria-hidden", "true");
  }
  function showError(elId, msg) {
    const el = document.getElementById(elId);
    el.textContent = msg;
    el.style.display = "block";
  }
  function hideError(elId) {
    document.getElementById(elId).style.display = "none";
  }
  function setLoading(btnId, loading) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.disabled = loading;
    btn.style.opacity = loading ? "0.7" : "";
  }

  // Close on backdrop click
  ["addDialog", "editDialog", "deleteDialog"].forEach(id => {
    document.getElementById(id).addEventListener("click", function (e) {
      if (e.target === this) closeModal(id);
    });
  });

  // Close on ESC
  document.addEventListener("keydown", e => {
    if (e.key !== "Escape") return;
    ["addDialog", "editDialog", "deleteDialog"].forEach(id => {
      if (document.getElementById(id).classList.contains("show")) closeModal(id);
    });
  });

  // ---- ADD ----
  let addChoices = null;

  function openAddDialog() {
    if (addChoices) { addChoices.destroy(); addChoices = null; }
    addChoices = buildChoices("addLocationSelect", "");
    document.getElementById("addMachineInput").value = "";
    hideError("addMachineError");
    openModal("addDialog");
    setTimeout(() => document.getElementById("addMachineInput").focus(), 60);
  }
  function closeAddDialog() {
    closeModal("addDialog");
  }

  document.getElementById("addMachineInput").addEventListener("keydown", e => {
    if (e.key === "Enter") submitAdd();
  });

  async function submitAdd() {
    const locationId = document.getElementById("addLocationSelect").value;
    const machineName = document.getElementById("addMachineInput").value.trim();
    if (!locationId) {
      showError("addMachineError", "Please select a location.");
      return;
    }
    if (!machineName) {
      showError("addMachineError", "Machine name is required.");
      return;
    }
    hideError("addMachineError");
    setLoading("addSubmitBtn", true);
    try {
      const res = await fetch("/fairtech/form/machine", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ machineName, locationId }),
      });
      const data = await res.json();
      if (data.success) {
        window.location.href = data.redirect || "/fairtech/form/machine";
      } else {
        showError("addMachineError", data.message || "Failed to add machine.");
      }
    } catch {
      showError("addMachineError", "Server error. Please try again.");
    } finally {
      setLoading("addSubmitBtn", false);
    }
  }

  // ---- EDIT ----
  let editId = null;
  let editChoices = null;

  function openEditDialog(id, name, locId) {
    editId = id;
    if (editChoices) { editChoices.destroy(); editChoices = null; }
    editChoices = buildChoices("editLocationSelect", locId);
    document.getElementById("editMachineInput").value = name;
    hideError("editMachineError");
    openModal("editDialog");
    setTimeout(() => {
      const inp = document.getElementById("editMachineInput");
      inp.focus();
      inp.select();
    }, 60);
  }
  function closeEditDialog() {
    closeModal("editDialog");
    editId = null;
  }

  document.getElementById("editMachineInput").addEventListener("keydown", e => {
    if (e.key === "Enter") submitEdit();
  });

  async function submitEdit() {
    const locationId = document.getElementById("editLocationSelect").value;
    const machineName = document.getElementById("editMachineInput").value.trim();
    if (!locationId) {
      showError("editMachineError", "Please select a location.");
      return;
    }
    if (!machineName) {
      showError("editMachineError", "Machine name is required.");
      return;
    }
    if (!editId) return;
    hideError("editMachineError");
    setLoading("editSubmitBtn", true);
    try {
      const res = await fetch(`/fairtech/api/machines/${editId}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ machineName, locationId }),
      });
      const data = await res.json();
      if (data.success) {
        window.location.reload();
      } else {
        showError("editMachineError", data.message || "Failed to update machine.");
      }
    } catch {
      showError("editMachineError", "Server error. Please try again.");
    } finally {
      setLoading("editSubmitBtn", false);
    }
  }

  // ---- DELETE ----
  let deleteId = null;

  function openDeleteDialog(id, name, locName) {
    deleteId = id;
    document.getElementById("deleteMachineName").textContent = name;
    const locLabel = document.getElementById("deleteMachineLocLabel");
    locLabel.textContent = locName ? ` at ${locName}` : "";
    openModal("deleteDialog");
  }
  function closeDeleteDialog() {
    closeModal("deleteDialog");
    deleteId = null;
  }

  async function submitDelete() {
    if (!deleteId) return;
    setLoading("deleteConfirmBtn", true);
    try {
      const res = await fetch(`/fairtech/api/machines/${deleteId}`, {
        method: "DELETE",
      });
      const data = await res.json();
      if (data.success) {
        window.location.reload();
      } else {
        closeDeleteDialog();
        alert(data.message || "Failed to delete machine.");
      }
    } catch {
      closeDeleteDialog();
      alert("Error deleting machine.");
    } finally {
      setLoading("deleteConfirmBtn", false);
    }
  }
</script>
