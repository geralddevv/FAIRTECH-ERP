<% layout('/layout/boilerplate') %>

<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />

<style>
  .order-highlight {
    padding: 0.3rem 0.85rem;
    border-radius: 0.35rem;
    font-weight: 600;
    font-size: 1.15rem;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.5);
    background-color: rgba(255, 255, 255, 0.12);
    margin-left: 8px;
    display: inline-block;
  }
  .order-highlight.active { background-color: rgba(255, 255, 255, 0.18); }
  .order-highlight.filtered { background-color: rgba(16, 185, 129, 0.22); border-color: rgba(255, 255, 255, 0.65); }
</style>

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <div class="indi-head">
    <h1>
      Pending Color Label Orders
      <span id="total-value-display" class="order-highlight active">Total: ₹0.00</span>
      <span id="filtered-value-display" class="order-highlight filtered" style="display: none">Filtered: ₹0.00</span>
    </h1>
    <div class="download-btns" style="display: flex; gap: 10px; align-items: center">
      <div class="download-selector" id="downloadSelector">
        <button class="download-selector__trigger">
          <span><i class="fa-solid fa-file-arrow-down"></i><span class="download-typo">Download</span></span>
          <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
        </button>
        <div class="download-selector__menu" id="downloads">
          <span class="download-selector__option" id="download-pdf"><i class="fas fa-file-pdf download-selector__option-icon"></i><span>PDF</span></span>
          <span class="download-selector__option" id="download-xlsx"><i class="fas fa-file-excel download-selector__option-icon"></i><span>Excel</span></span>
        </div>
      </div>
    </div>
  </div>

  <div class="table-spinner"><div class="spinner-circle"></div></div>
  <div id="master-table" class="tabulator tabulator-modern"></div>
</div>

<script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script id="order-data" type="application/json"><%- safeJson(orders || []) %></script>
<script>
  const orderData = JSON.parse(document.getElementById("order-data").textContent);
  const enrichedOrderData = orderData.map((row) => ({
    ...row,
    valueAmount: Math.max((Number(row.quantity) || 0) - (Number(row.dispatchedQuantity) || 0), 0) * (Number(row.orderRate) || 0),
  }));

  let customDialog, dialogMessage, dialogYes, dialogNo, cancelReasonWrap, cancelReasonInput;
  let currentConfirmCallback = null;

  document.addEventListener("DOMContentLoaded", () => {
    customDialog = document.getElementById("custom-confirm-dialog");
    dialogMessage = document.getElementById("custom-dialog-message");
    dialogYes = document.getElementById("custom-dialog-yes");
    dialogNo = document.getElementById("custom-dialog-no");
    cancelReasonWrap = document.getElementById("cancel-reason-wrap");
    cancelReasonInput = document.getElementById("cancel-reason-input");

    dialogYes.addEventListener("click", () => {
      if (cancelReasonWrap.style.display !== "none") {
        if (!cancelReasonInput.value.trim()) {
          cancelReasonInput.style.borderColor = "#ef4444";
          cancelReasonInput.placeholder = "Please provide a reason...";
          cancelReasonInput.focus();
          return;
        }
      }
      if (currentConfirmCallback) currentConfirmCallback();
      closeCustomDialog();
    });
    dialogNo.addEventListener("click", closeCustomDialog);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && customDialog.style.display === "flex") {
        if (e.target !== cancelReasonInput) { e.preventDefault(); dialogYes.click(); }
      }
    });
  });

  function showCustomConfirm(message, onConfirm, showReason = false) {
    dialogMessage.textContent = message;
    currentConfirmCallback = onConfirm;
    cancelReasonWrap.style.display = showReason ? "block" : "none";
    cancelReasonInput.value = "";
    cancelReasonInput.style.borderColor = "#d1d5db";
    customDialog.style.display = "flex";
    setTimeout(() => { if (showReason) cancelReasonInput.focus(); else dialogYes.focus(); }, 10);
  }

  function closeCustomDialog() {
    customDialog.style.display = "none";
    currentConfirmCallback = null;
    cancelReasonInput.value = "";
  }

  function escapeHtml(value) {
    return String(value ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
  }

  function formatDate(value) {
    if (!value) return "N/A";
    const date = new Date(value);
    return isNaN(date.getTime()) ? "N/A" : date.toLocaleDateString("en-IN", { year: "numeric", month: "short", day: "2-digit" });
  }

  window.requestCancel = function (orderId) {
    dialogYes.style.background = "#ef4444";
    dialogYes.textContent = "Yes, Cancel Order";
    showCustomConfirm("Are you sure you want to CANCEL this order? This cannot be undone.", () => {
      const form = document.createElement("form");
      form.method = "POST";
      form.action = "/fairtech/sales/order/status";
      [["orderId", orderId], ["status", "CANCELLED"], ["cancelReason", cancelReasonInput.value.trim()]].forEach(([n, v]) => {
        const i = document.createElement("input"); i.type = "hidden"; i.name = n; i.value = v; form.appendChild(i);
      });
      const csrf = document.createElement("input"); csrf.type = "hidden"; csrf.name = "_csrf";
      csrf.value = document.querySelector('meta[name="csrf-token"]')?.content; form.appendChild(csrf);
      document.body.appendChild(form); form.submit();
    }, true);
  };

  window.checkCreateOrder = function (url) {
    dialogYes.style.background = "#10b981";
    dialogYes.textContent = "Yes, Proceed Order";
    showCustomConfirm("Are you sure you want to proceed with this order?", () => { window.location.href = url; }, false);
  };

  const table = new Tabulator("#master-table", {
    data: enrichedOrderData,
    responsiveLayout: false,
    movableColumns: true,
    placeholder: "No pending color label orders found",
    initialSort: [{ column: "createdAt", dir: "asc" }],
    columns: [
      {
        title: "Actions",
        hozAlign: "center",
        headerSort: false,
        width: 120,
        formatter: (cell) => {
          const row = cell.getRow().getData();
          const client = encodeURIComponent(row.clientName || "");
          const confirmUrl = `/fairtech/sales/order/confirm?orderId=${row._id}&type=COLOR_LABEL&client=${client}`;
          const editUrl = `/fairtech/sales/order?orderId=${row._id}&type=COLOR_LABEL&client=${client}`;
          return `
            <div style="display:flex; gap:6px; justify-content:center; align-items:center; white-space:nowrap;">
              <a href="javascript:void(0)" onclick="checkCreateOrder('${confirmUrl}')"
                style="height:24px; padding:2px 10px; background:#10b981; color:white; border:none; border-radius:4px; cursor:pointer; font-size:11px; text-decoration:none; display:inline-flex; align-items:center; gap:4px; font-weight:600;"
                onmouseover="this.style.background='#059669'" onmouseout="this.style.background='#10b981'" title="Dispatch">
                <i class="fa-solid fa-truck-moving"></i>
              </a>
              <button onclick="requestCancel('${row._id}')"
                style="height:24px; padding:2px 10px; background:#ef4444; color:white; border:none; border-radius:4px; cursor:pointer; font-size:12px; font-weight:600;"
                onmouseover="this.style.background='#dc2626'" onmouseout="this.style.background='#ef4444'" title="Cancel Order">
                <i class="fa-solid fa-xmark"></i>
              </button>
              <a href="${editUrl}"
                style="height:24px; padding:2px 10px; background:#3b82f6; color:white; border:none; border-radius:4px; cursor:pointer; font-size:11px; text-decoration:none; display:inline-flex; align-items:center; gap:4px; font-weight:600;"
                onmouseover="this.style.background='#2563eb'" onmouseout="this.style.background='#3b82f6'" title="Edit Order">
                <i class="fa-solid fa-pencil"></i>
              </a>
            </div>`;
        },
      },
      { title: "Date", field: "createdAt", width: 105, headerFilter: "input", headerFilterPlaceholder: "Search", formatter: (cell) => new Date(cell.getValue()).toLocaleDateString("en-IN") },
      { title: "Client", field: "clientName", width: 200, headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "User", field: "userName", width: 150, headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "Product ID", field: "productId", width: 130, headerFilter: "input", headerFilterPlaceholder: "Search", formatter: (cell) => `<span style="color:#044A78; font-weight:600;">${escapeHtml(cell.getValue())}</span>` },
      { title: "Width", field: "labelWidth", hozAlign: "center", width: 75, headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "Height", field: "labelHeight", hozAlign: "center", width: 75, headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "Qty", field: "quantity", hozAlign: "center", width: 70, headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "Sent", field: "dispatchedQuantity", hozAlign: "center", width: 65, formatter: (cell) => cell.getValue() || "" },
      {
        title: "Bal",
        field: "balance",
        hozAlign: "center",
        width: 65,
        formatter: (cell) => {
          const row = cell.getRow().getData();
          const bal = Math.max((Number(row.quantity) || 0) - (Number(row.dispatchedQuantity) || 0), 0);
          return `<span style="font-weight:700; color:#044A78;">${bal}</span>`;
        },
      },
      {
        title: "Rate (₹)",
        field: "orderRate",
        hozAlign: "right",
        width: 90,
        formatter: (cell) => {
          const val = cell.getValue();
          if (val == null || val === "") return `<span style="color:#9ca3af;">—</span>`;
          return `<span style="font-weight:600; color:#0f766e;">₹${Number(val).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>`;
        },
      },
      {
        title: "Value (₹)",
        field: "valueAmount",
        hozAlign: "right",
        width: 110,
        sorter: (a, b) => Number(a || 0) - Number(b || 0),
        formatter: (cell) => {
          const value = Number(cell.getValue()) || 0;
          if (value === 0) return `<span style="color:#9ca3af;">—</span>`;
          return `<span style="font-weight:700; color:#044A78;">₹${value.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>`;
        },
      },
      { title: "PO Number", field: "poNumber", width: 130, headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "Est. Delivery", field: "estimatedDate", width: 120, headerFilter: "input", headerFilterPlaceholder: "Search", formatter: (cell) => formatDate(cell.getValue()) },
      { title: "Remarks", field: "remarks", headerFilter: "input", headerFilterPlaceholder: "Search" },
    ],
  });

  const grandTotal = enrichedOrderData.reduce((sum, row) => sum + (Number(row.valueAmount) || 0), 0);
  function formatINR(v) { return "₹" + v.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
  const totalDisplay = document.getElementById("total-value-display");
  if (totalDisplay) totalDisplay.textContent = "Total: " + formatINR(grandTotal);

  table.on("dataFiltered", function (filters, rows) {
    const filteredEl = document.getElementById("filtered-value-display");
    if (!filteredEl) return;
    const isFiltered = filters && filters.length > 0;
    if (!isFiltered) { filteredEl.style.display = "none"; return; }
    let total = 0;
    rows.forEach((row) => { total += Number(row.getData().valueAmount) || 0; });
    filteredEl.textContent = "Filtered: " + formatINR(total);
    filteredEl.style.display = "inline-block";
  });

  const selector = document.getElementById("downloadSelector");
  selector.querySelector(".download-selector__trigger").addEventListener("click", (e) => { e.stopPropagation(); selector.classList.toggle("download-selector--active"); });
  document.addEventListener("click", () => selector.classList.remove("download-selector--active"));
  document.getElementById("download-pdf").addEventListener("click", () => { table.download("pdf", "pending_color_label_orders.pdf", { orientation: "landscape", title: "Pending Color Label Orders" }); selector.classList.remove("download-selector--active"); });
  document.getElementById("download-xlsx").addEventListener("click", () => { table.download("xlsx", "pending_color_label_orders.xlsx", { sheetName: "ColorLabelOrders" }); selector.classList.remove("download-selector--active"); });
</script>

<!-- Custom Confirm Dialog -->
<div id="custom-confirm-dialog" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center;">
  <div style="background:white; border-radius:8px; width:440px; max-width:90%; box-shadow:0 4px 15px rgba(0,0,0,0.2); overflow:hidden; animation:popIn 0.2s ease-out;">
    <div style="padding:25px 20px; text-align:center;">
      <p id="custom-dialog-message" style="margin:0; color:#333; font-size:16px; line-height:1.5;">Are you sure?</p>
      <div id="cancel-reason-wrap" style="display:none; margin-top:15px; text-align:left;">
        <label for="cancel-reason-input" style="font-size:14px; font-weight:600; color:#374151; margin-bottom:6px; display:block;">Reason for Cancellation <span style="color:#ef4444">*</span></label>
        <textarea id="cancel-reason-input" rows="3" placeholder="Enter reason for cancellation..." style="width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; resize:none; font-family:inherit; box-sizing:border-box;"></textarea>
      </div>
    </div>
    <div style="padding:15px 20px; background:#f9fafb; display:flex; justify-content:flex-end; gap:10px; border-top:1px solid #e5e7eb;">
      <button id="custom-dialog-no" style="padding:8px 16px; border:1px solid #d1d5db; background:white; color:#374151; border-radius:6px; cursor:pointer; font-weight:500;">Go Back</button>
      <button id="custom-dialog-yes" style="padding:8px 16px; border:none; background:#ef4444; color:white; border-radius:6px; cursor:pointer; font-weight:500;">Yes, Cancel Order</button>
    </div>
  </div>
</div>

<style>
  @keyframes popIn { 0% { transform: scale(0.9); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
  #custom-dialog-no:hover { background: #f3f4f6; }
  #custom-dialog-yes:hover { opacity: 0.9; }
  #cancel-reason-input:focus { outline: none; border-color: #044a78; box-shadow: 0 0 0 2px rgba(26,26,46,0.1); }
</style>
