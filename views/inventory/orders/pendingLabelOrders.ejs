<% layout('/layout/boilerplate') %>

<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />

<style>
  .order-highlight {
    padding: 0.3rem 0.85rem;
    border-radius: 0.35rem;
    font-weight: 600;
    font-size: 1.15rem;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.5);
    background-color: rgba(255, 255, 255, 0.12);
    margin-left: 8px;
    display: inline-block;
  }
  .order-highlight.active { background-color: rgba(255, 255, 255, 0.18); }
  .order-highlight.filtered { background-color: rgba(16, 185, 129, 0.22); border-color: rgba(255, 255, 255, 0.65); }
</style>

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <div class="indi-head">
    <h1 style="display: flex; align-items: center; flex-wrap: wrap; flex: 1; min-width: 0; margin-right: 16px">
      <span>Pending Label Orders</span>
      <span id="label-total-display" class="order-highlight active">Plain Labels: ₹0.00</span>
      <span id="filtered-value-display" class="order-highlight filtered" style="display: none">Filtered: ₹0.00</span>
      <span style="margin-left: auto; display: flex; align-items: center; flex-wrap: wrap">
        <span id="color-label-value-display" class="order-highlight">Color Labels: ₹0.00</span>
        <span id="pending-items-value-display" class="order-highlight">Pending Items: ₹0.00</span>
        <span id="total-value-display" class="order-highlight">Total: ₹0.00</span>
      </span>
    </h1>
    <div class="download-btns" style="display: flex; gap: 10px; align-items: center">
      <div class="download-selector" id="downloadSelector">
        <button class="download-selector__trigger">
          <span><i class="fa-solid fa-file-arrow-down"></i><span class="download-typo">Download</span></span>
          <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
        </button>
        <div class="download-selector__menu" id="downloads">
          <span class="download-selector__option" id="download-pdf"><i class="fas fa-file-pdf download-selector__option-icon"></i><span>PDF</span></span>
          <span class="download-selector__option" id="download-xlsx"><i class="fas fa-file-excel download-selector__option-icon"></i><span>Excel</span></span>
        </div>
      </div>
    </div>
  </div>

  <div class="table-spinner"><div class="spinner-circle"></div></div>
  <div id="master-table" class="tabulator tabulator-modern"></div>
</div>

<script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script id="order-data" type="application/json"><%- safeJson(orders || []) %></script>
<script id="cross-totals-data" type="application/json">
  <%- safeJson({ colorLabelTotal: colorLabelTotal || 0, pendingItemsTotal: pendingItemsTotal || 0 }) %>
</script>
<script>
  const orderData = JSON.parse(document.getElementById("order-data").textContent);
  const crossTotals = JSON.parse(document.getElementById("cross-totals-data").textContent);
  const enrichedOrderData = orderData.map((row) => ({
    ...row,
    valueAmount: Math.max((Number(row.quantity) || 0) - (Number(row.dispatchedQuantity) || 0), 0) * (Number(row.orderRate) || 0),
  }));

  let customDialog, dialogMessage, dialogYes, dialogNo, cancelReasonWrap, cancelReasonInput;
  let detailsDialog, detailsBody;
  let currentConfirmCallback = null;

  document.addEventListener("DOMContentLoaded", () => {
    customDialog = document.getElementById("custom-confirm-dialog");
    dialogMessage = document.getElementById("custom-dialog-message");
    dialogYes = document.getElementById("custom-dialog-yes");
    dialogNo = document.getElementById("custom-dialog-no");
    cancelReasonWrap = document.getElementById("cancel-reason-wrap");
    cancelReasonInput = document.getElementById("cancel-reason-input");
    detailsDialog = document.getElementById("pending-order-details-dialog");
    detailsBody = document.getElementById("pending-order-details-body");
    if (detailsDialog) {
      detailsDialog.addEventListener("click", (e) => { if (e.target === detailsDialog) closeOrderDetailsDialog(); });
    }

    dialogYes.addEventListener("click", () => {
      if (cancelReasonWrap.style.display !== "none") {
        if (!cancelReasonInput.value.trim()) {
          cancelReasonInput.style.borderColor = "#ef4444";
          cancelReasonInput.placeholder = "Please provide a reason...";
          cancelReasonInput.focus();
          return;
        }
      }
      if (currentConfirmCallback) currentConfirmCallback();
      closeCustomDialog();
    });
    dialogNo.addEventListener("click", closeCustomDialog);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && customDialog.style.display === "flex") {
        if (e.target !== cancelReasonInput) { e.preventDefault(); dialogYes.click(); }
      }
    });
  });

  function showCustomConfirm(message, onConfirm, showReason = false) {
    dialogMessage.textContent = message;
    currentConfirmCallback = onConfirm;
    cancelReasonWrap.style.display = showReason ? "block" : "none";
    cancelReasonInput.value = "";
    cancelReasonInput.style.borderColor = "#d1d5db";
    customDialog.style.display = "flex";
    setTimeout(() => { if (showReason) cancelReasonInput.focus(); else dialogYes.focus(); }, 10);
  }

  function closeCustomDialog() {
    customDialog.style.display = "none";
    currentConfirmCallback = null;
    cancelReasonInput.value = "";
  }

  function escapeHtml(value) {
    return String(value ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
  }

  function formatDate(value) {
    if (!value) return "N/A";
    const date = new Date(value);
    return isNaN(date.getTime()) ? "N/A" : date.toLocaleDateString("en-IN", { year: "numeric", month: "short", day: "2-digit" });
  }

  // Group integers with Indian-style commas so large quantities read easily.
  function formatQty(value) {
    const n = Number(value);
    return Number.isFinite(n) ? n.toLocaleString("en-IN") : (value ?? "");
  }

  function closeOrderDetailsDialog() {
    if (detailsDialog) detailsDialog.style.display = "none";
  }

  window.viewPendingOrder = function (orderId) {
    const order = orderData.find((row) => String(row._id) === String(orderId));
    if (!order || !detailsDialog || !detailsBody) return;

    const client = order.clientName || "N/A";
    const user = order.userName || "N/A";
    const productId = order.productId || "N/A";
    const jobType = order.jobType || "N/A";
    const size = (order.labelWidth && order.labelHeight) ? `${order.labelWidth} × ${order.labelHeight}` : "N/A";
    const instructions = order.instructions || "—";
    const poNumber = order.poNumber || "N/A";
    const remarks = order.remarks || "—";
    const qty = Number(order.quantity) || 0;
    const dispatched = Number(order.dispatchedQuantity) || 0;
    const remaining = Math.max(qty - dispatched, 0);
    const orderRate = order.orderRate != null ? `₹${Number(order.orderRate).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 3 })}` : "N/A";

    detailsBody.innerHTML = `
      <div style="position:relative;background:#fff;border-radius:18px;box-shadow:0 18px 42px rgba(4,74,120,0.14);overflow:hidden;">
        <div style="max-height:calc(100vh - 48px);overflow-y:auto;scrollbar-width:thin;scrollbar-color:#044a78 #f0f2f5;">
          <div style="display:flex;justify-content:space-between;gap:16px;align-items:flex-start;padding:26px 26px 24px;background:radial-gradient(circle at top right,rgba(255,255,255,0.16),transparent 34%),linear-gradient(135deg,#044a78 0%,#03365a 100%);color:#fff;">
            <div>
              <h1 style="margin:0;font-size:22px;font-weight:700;">${escapeHtml(productId)}</h1>
              <div style="margin-top:4px;font-size:13px;opacity:0.82;">${escapeHtml(client)} | ${escapeHtml(user)}</div>
            </div>
            <div style="display:inline-flex;align-items:center;gap:10px;">
              <span style="display:inline-flex;align-items:center;gap:8px;padding:9px 14px;border-radius:999px;background:rgba(255,255,255,0.14);border:1px solid rgba(255,255,255,0.18);color:#fff;font-weight:700;font-size:13px;pointer-events:none;">
                <i class="fa-solid fa-tag"></i> LABEL
              </span>
              <button type="button" onclick="closeOrderDetailsDialog()" style="display:inline-flex;align-items:center;gap:8px;padding:9px 14px;border-radius:999px;background:rgba(255,255,255,0.14);border:1px solid rgba(255,255,255,0.18);color:#fff;font-weight:700;font-size:13px;cursor:pointer;" aria-label="Close">
                <i class="fa-solid fa-xmark"></i>
              </button>
            </div>
          </div>
          <div style="padding:22px 26px 26px;">
            <h3 style="margin:0 0 12px;color:#044a78;font-size:15px;font-weight:700;">Order Details</h3>
            <table style="width:100%;border-collapse:collapse;border:1px solid #e6eaf2;border-radius:12px;overflow:hidden;font-size:13px;">
              <thead><tr><th style="background:#f4f7ff;color:#044a78;font-weight:700;padding:9px 14px;text-align:left;width:38%;">Field</th><th style="background:#f4f7ff;color:#044a78;font-weight:700;padding:9px 14px;text-align:left;">Value</th></tr></thead>
              <tbody>
                <tr><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;color:#5a6586;font-weight:600;">Product ID</td><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;font-weight:700;color:#1f2a44;">${escapeHtml(productId)}</td></tr>
                <tr><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;color:#5a6586;font-weight:600;">Job Type</td><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;font-weight:700;color:#1f2a44;">${escapeHtml(jobType)}</td></tr>
                <tr><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;color:#5a6586;font-weight:600;">Size</td><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;font-weight:700;color:#1f2a44;">${escapeHtml(size)}</td></tr>
                <tr><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;color:#5a6586;font-weight:600;">Instructions</td><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;font-weight:700;color:#1f2a44;">${escapeHtml(instructions)}</td></tr>
                <tr><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;color:#5a6586;font-weight:600;">Client</td><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;font-weight:700;color:#1f2a44;">${escapeHtml(client)}</td></tr>
                <tr><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;color:#5a6586;font-weight:600;">User</td><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;font-weight:700;color:#1f2a44;">${escapeHtml(user)}</td></tr>
                <tr><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;color:#5a6586;font-weight:600;">PO Number</td><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;font-weight:700;color:#1f2a44;">${escapeHtml(poNumber)}</td></tr>
                <tr><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;color:#5a6586;font-weight:600;">Quantity</td><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;font-weight:700;color:#1f2a44;">${formatQty(qty)}</td></tr>
                <tr><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;color:#5a6586;font-weight:600;">Dispatched</td><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;font-weight:700;color:#1f2a44;">${formatQty(dispatched)}</td></tr>
                <tr><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;color:#5a6586;font-weight:600;">Remaining</td><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;font-weight:700;color:#044a78;">${formatQty(remaining)}</td></tr>
                <tr><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;color:#5a6586;font-weight:600;">Order Rate</td><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;font-weight:700;color:#0f766e;">${escapeHtml(orderRate)}</td></tr>
                <tr><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;color:#5a6586;font-weight:600;">Est. Delivery</td><td style="padding:8px 14px;border-bottom:1px solid #e6eaf2;font-weight:700;color:#1f2a44;">${formatDate(order.estimatedDate)}</td></tr>
                <tr><td style="padding:8px 14px;color:#5a6586;font-weight:600;">Remarks</td><td style="padding:8px 14px;font-weight:700;color:#1f2a44;white-space:pre-wrap;">${escapeHtml(remarks)}</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>`;

    detailsDialog.style.display = "flex";
  };

  window.requestCancel = function (orderId) {
    dialogYes.style.background = "#ef4444";
    dialogYes.textContent = "Yes, Cancel Order";
    showCustomConfirm("Are you sure you want to CANCEL this order? This cannot be undone.", () => {
      const form = document.createElement("form");
      form.method = "POST";
      form.action = "/fairtech/sales/order/status";
      [["orderId", orderId], ["status", "CANCELLED"], ["cancelReason", cancelReasonInput.value.trim()]].forEach(([n, v]) => {
        const i = document.createElement("input"); i.type = "hidden"; i.name = n; i.value = v; form.appendChild(i);
      });
      const csrf = document.createElement("input"); csrf.type = "hidden"; csrf.name = "_csrf";
      csrf.value = document.querySelector('meta[name="csrf-token"]')?.content; form.appendChild(csrf);
      document.body.appendChild(form); form.submit();
    }, true);
  };

  window.checkCreateOrder = function (url) {
    dialogYes.style.background = "#10b981";
    dialogYes.textContent = "Yes, Proceed Order";
    showCustomConfirm("Are you sure you want to proceed with this order?", () => { window.location.href = url; }, false);
  };

  const table = new Tabulator("#master-table", {
    data: enrichedOrderData,
    responsiveLayout: false,
    movableColumns: true,
    placeholder: "No pending label orders found",
    initialSort: [{ column: "poDate", dir: "asc" }],
    columns: [
      {
        title: "Actions",
        hozAlign: "center",
        headerSort: false,
        width: 185,
        formatter: (cell) => {
          const row = cell.getRow().getData();
          const client = encodeURIComponent(row.clientName || "");
          const confirmUrl = `/fairtech/sales/order/confirm?orderId=${row._id}&type=LABEL&client=${client}`;
          const editUrl = `/fairtech/sales/order?orderId=${row._id}&type=LABEL&client=${client}`;
          return `
            <div style="display:flex; gap:6px; justify-content:center; align-items:center; white-space:nowrap;">
              <button onclick="viewPendingOrder('${row._id}')"
                style="height:24px; padding:2px 10px; background:#111827; color:white; border:none; border-radius:4px; cursor:pointer; font-size:11px; display:inline-flex; align-items:center; gap:4px; font-weight:600;"
                onmouseover="this.style.background='#374151'" onmouseout="this.style.background='#111827'" title="View Details">
                <i class="fa-solid fa-eye"></i>
              </button>
              <a href="javascript:void(0)" onclick="checkCreateOrder('${confirmUrl}')"
                style="height:24px; padding:2px 10px; background:#10b981; color:white; border:none; border-radius:4px; cursor:pointer; font-size:11px; text-decoration:none; display:inline-flex; align-items:center; gap:4px; font-weight:600;"
                onmouseover="this.style.background='#059669'" onmouseout="this.style.background='#10b981'" title="Dispatch">
                <i class="fa-solid fa-truck-moving"></i>
              </a>
              <button onclick="requestCancel('${row._id}')"
                style="height:24px; padding:2px 10px; background:#ef4444; color:white; border:none; border-radius:4px; cursor:pointer; font-size:12px; font-weight:600;"
                onmouseover="this.style.background='#dc2626'" onmouseout="this.style.background='#ef4444'" title="Cancel Order">
                <i class="fa-solid fa-xmark"></i>
              </button>
              <a href="${editUrl}"
                style="height:24px; padding:2px 10px; background:#3b82f6; color:white; border:none; border-radius:4px; cursor:pointer; font-size:11px; text-decoration:none; display:inline-flex; align-items:center; gap:4px; font-weight:600;"
                onmouseover="this.style.background='#2563eb'" onmouseout="this.style.background='#3b82f6'" title="Edit Order">
                <i class="fa-solid fa-pencil"></i>
              </a>
            </div>`;
        },
      },
      { title: "Date", field: "poDate", width: 105, headerFilter: "input", headerFilterPlaceholder: "Search",
        sorter: (a, b, aRow, bRow) => {
          const aDate = new Date(a || aRow.getData().createdAt).getTime() || 0;
          const bDate = new Date(b || bRow.getData().createdAt).getTime() || 0;
          return aDate - bDate;
        },
        formatter: (cell) => {
          const raw = cell.getValue() || cell.getRow().getData().createdAt;
          if (!raw) return "N/A";
          const d = new Date(raw);
          if (isNaN(d.getTime())) return "N/A";
          return `${String(d.getDate()).padStart(2, "0")}/${String(d.getMonth() + 1).padStart(2, "0")}/${d.getFullYear()}`;
        }},
      { title: "PO No", field: "poNumber", width: 120, headerFilter: "input", headerFilterPlaceholder: "Search",
        formatter: (cell) => {
          const val = cell.getValue();
          return val == null || val === "" ? `<span style="color:#9ca3af;">—</span>` : escapeHtml(val);
        }},
      { title: "Client", field: "clientName", width: 200, headerFilter: "input", headerFilterPlaceholder: "Search" },
      {
        title: "Client Type",
        field: "clientType",
        width: 110,
        hozAlign: "center",
        headerFilter: "list",
        headerFilterParams: { values: { "": "All", DEALER: "Dealer", CLIENT: "Client" } },
        headerFilterPlaceholder: "All",
        formatter: (cell) => {
          const val = String(cell.getValue() || "").toUpperCase();
          if (!val) return "";
          const isDealer = val === "DEALER";
          const color = isDealer ? "#dc2626" : "#059669";
          return `<span style="color:${color}; font-weight:700;">${val}</span>`;
        },
      },
      { title: "User", field: "userName", width: 150, headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "Product ID", field: "productId", width: 130, headerFilter: "input", headerFilterPlaceholder: "Search", formatter: (cell) => `<span style="color:#044A78; font-weight:600;">${escapeHtml(cell.getValue())}</span>` },
      { title: "Job Type", field: "jobType", width: 90, hozAlign: "center", headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "Width", field: "labelWidth", hozAlign: "center", width: 75, headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "Height", field: "labelHeight", hozAlign: "center", width: 75, headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "Instructions", field: "instructions", width: 130, headerFilter: "input", headerFilterPlaceholder: "Search" },
      { title: "Qty", field: "quantity", hozAlign: "center", width: 80, headerFilter: "input", headerFilterPlaceholder: "Search", formatter: (cell) => formatQty(cell.getValue()) },
      { title: "Sent", field: "dispatchedQuantity", hozAlign: "center", width: 75, formatter: (cell) => (Number(cell.getValue()) ? formatQty(cell.getValue()) : "") },
      {
        title: "Bal",
        field: "balance",
        hozAlign: "center",
        width: 65,
        formatter: (cell) => {
          const row = cell.getRow().getData();
          const bal = Math.max((Number(row.quantity) || 0) - (Number(row.dispatchedQuantity) || 0), 0);
          return `<span style="font-weight:700; color:#044A78;">${formatQty(bal)}</span>`;
        },
      },
      {
        title: "Rate (₹)",
        field: "orderRate",
        hozAlign: "right",
        width: 90,
        formatter: (cell) => {
          const val = cell.getValue();
          if (val == null || val === "") return `<span style="color:#9ca3af;">—</span>`;
          return `<span style="font-weight:600; color:#0f766e;">₹${Number(val).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 3 })}</span>`;
        },
      },
      {
        title: "Value (₹)",
        field: "valueAmount",
        hozAlign: "right",
        width: 110,
        sorter: (a, b) => Number(a || 0) - Number(b || 0),
        formatter: (cell) => {
          const value = Number(cell.getValue()) || 0;
          if (value === 0) return `<span style="color:#9ca3af;">—</span>`;
          return `<span style="font-weight:700; color:#044A78;">₹${value.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>`;
        },
      },
      { title: "Est. Delivery", field: "estimatedDate", width: 120, headerFilter: "input", headerFilterPlaceholder: "Search", formatter: (cell) => formatDate(cell.getValue()) },
      { title: "Remarks", field: "remarks", headerFilter: "input", headerFilterPlaceholder: "Search" },
    ],
  });

  const labelTotal = enrichedOrderData.reduce((sum, row) => sum + (Number(row.valueAmount) || 0), 0);
  const colorLabelTotal = Number(crossTotals.colorLabelTotal) || 0;
  const pendingItemsTotal = Number(crossTotals.pendingItemsTotal) || 0;
  // Grand total = this page's own Plain Labels value + Color Labels + the
  // Tape/POS/Tafeta/TTR pending orders total (those live on their own pages).
  const grandTotal = labelTotal + colorLabelTotal + pendingItemsTotal;
  function formatINR(v) { return "₹" + v.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
  const labelTotalDisplay = document.getElementById("label-total-display");
  if (labelTotalDisplay) labelTotalDisplay.textContent = "Plain Labels: " + formatINR(labelTotal);
  const colorLabelDisplay = document.getElementById("color-label-value-display");
  if (colorLabelDisplay) colorLabelDisplay.textContent = "Color Labels: " + formatINR(colorLabelTotal);
  const pendingItemsDisplay = document.getElementById("pending-items-value-display");
  if (pendingItemsDisplay) pendingItemsDisplay.textContent = "Pending Items: " + formatINR(pendingItemsTotal);
  const totalDisplay = document.getElementById("total-value-display");
  if (totalDisplay) totalDisplay.textContent = "Total: " + formatINR(grandTotal);

  table.on("dataFiltered", function (filters, rows) {
    const filteredEl = document.getElementById("filtered-value-display");
    if (!filteredEl) return;
    const isFiltered = filters && filters.length > 0;
    if (!isFiltered) { filteredEl.style.display = "none"; return; }
    let total = 0;
    rows.forEach((row) => { total += Number(row.getData().valueAmount) || 0; });
    filteredEl.textContent = "Filtered: " + formatINR(total);
    filteredEl.style.display = "inline-block";
  });

  const selector = document.getElementById("downloadSelector");
  selector.querySelector(".download-selector__trigger").addEventListener("click", (e) => { e.stopPropagation(); selector.classList.toggle("download-selector--active"); });
  document.addEventListener("click", () => selector.classList.remove("download-selector--active"));
  document.getElementById("download-pdf").addEventListener("click", () => { table.download("pdf", "pending_label_orders.pdf", { orientation: "landscape", title: "Pending Label Orders" }); selector.classList.remove("download-selector--active"); });
  document.getElementById("download-xlsx").addEventListener("click", () => { table.download("xlsx", "pending_label_orders.xlsx", { sheetName: "PendingLabelOrders" }); selector.classList.remove("download-selector--active"); });
</script>

<!-- Custom Confirm Dialog -->
<div id="custom-confirm-dialog" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center;">
  <div style="background:white; border-radius:8px; width:440px; max-width:90%; box-shadow:0 4px 15px rgba(0,0,0,0.2); overflow:hidden; animation:popIn 0.2s ease-out;">
    <div style="padding:25px 20px; text-align:center;">
      <p id="custom-dialog-message" style="margin:0; color:#333; font-size:16px; line-height:1.5;">Are you sure?</p>
      <div id="cancel-reason-wrap" style="display:none; margin-top:15px; text-align:left;">
        <label for="cancel-reason-input" style="font-size:14px; font-weight:600; color:#374151; margin-bottom:6px; display:block;">Reason for Cancellation <span style="color:#ef4444">*</span></label>
        <textarea id="cancel-reason-input" rows="3" placeholder="Enter reason for cancellation..." style="width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; resize:none; font-family:inherit; box-sizing:border-box;"></textarea>
      </div>
    </div>
    <div style="padding:15px 20px; background:#f9fafb; display:flex; justify-content:flex-end; gap:10px; border-top:1px solid #e5e7eb;">
      <button id="custom-dialog-no" style="padding:8px 16px; border:1px solid #d1d5db; background:white; color:#374151; border-radius:6px; cursor:pointer; font-weight:500;">Go Back</button>
      <button id="custom-dialog-yes" style="padding:8px 16px; border:none; background:#ef4444; color:white; border-radius:6px; cursor:pointer; font-weight:500;">Yes, Cancel Order</button>
    </div>
  </div>
</div>

<style>
  @keyframes popIn { 0% { transform: scale(0.9); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
  #custom-dialog-no:hover { background: #f3f4f6; }
  #custom-dialog-yes:hover { opacity: 0.9; }
  #cancel-reason-input:focus { outline: none; border-color: #044a78; box-shadow: 0 0 0 2px rgba(26,26,46,0.1); }
</style>

<!-- Order Details Dialog -->
<div id="pending-order-details-dialog" style="display:none; position:fixed; inset:0; background:rgba(15,23,42,0.54); z-index:10000; justify-content:center; align-items:center; padding:24px; backdrop-filter:blur(6px);">
  <div id="pending-order-details-body" style="width:min(640px,100%); animation:detailsPopIn 0.2s ease-out;"></div>
</div>
<style>
  @keyframes detailsPopIn { 0% { transform:scale(0.96); opacity:0; } 100% { transform:scale(1); opacity:1; } }
</style>
