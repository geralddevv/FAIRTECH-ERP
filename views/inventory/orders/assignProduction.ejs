<% layout('/layout/boilerplate') -%>

<%
  const pp = pendingProduction;
  const item = pp.itemId || {};
  const owner = pp.userId || {};
  const isEmpty = (v) => v === undefined || v === null || (typeof v === "string" && v.trim() === "");
  const dash = (v) => (isEmpty(v) ? "—" : v);
  const fmtDate = (v) => {
    if (!v) return "—";
    const d = new Date(v);
    if (isNaN(d)) return "—";
    return String(d.getDate()).padStart(2, "0") + "/" + String(d.getMonth() + 1).padStart(2, "0") + "/" + d.getFullYear();
  };
  const balance = Math.max((Number(pp.quantity) || 0) - (Number(pp.dispatchedQuantity) || 0), 0);
  const fmtQty = (v) => (Number.isFinite(Number(v)) && v !== '' && v != null)
    ? Number(v).toLocaleString('en-IN')
    : (v || '—');
%>

<div class="contain" style="flex-direction: column; padding: 10px; gap: 14px;">
  <style>
    .ap-head h1 { font-size: 20px; color: #fff; margin: 0; }
    .ap-head .ap-sub { font-size: 13px; color: rgba(255, 255, 255, 0.85); margin-top: 2px; }

    .ap-card {
      width: 100%;
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      /* Not overflow:hidden -- the Die select's Choices.js dropdown lives
         inside this card and needs to overflow it (its own header's rounded
         top corners are handled directly on .ap-card-title below instead). */
      overflow: visible;
    }
    .ap-card-title {
      background: #044a78;
      color: #fff; font-size: 14px; font-weight: 600; letter-spacing: 0.2px;
      padding: 9px 16px; display: flex; align-items: center; justify-content: space-between; gap: 10px;
      border-radius: 9px 9px 0 0;
    }
    .ap-card-title select {
      font-size: 12.5px; padding: 5px 10px; border-radius: 6px; border: none; color: #044a78; font-weight: 600; cursor: pointer;
    }
    .ap-card .choices__list--dropdown {
      z-index: 60;
    }
    /* The Die select's Choices.js box was rendering shorter than the plain
       text inputs beside it (common.css zeroes out .choices__inner's
       min-height/padding for compactness elsewhere) -- match their height
       here specifically. */
    #die-field-wrap .choices__inner {
      min-height: 2.3rem;
      padding: 0.375rem 0.5rem;
      display: flex;
      align-items: center;
    }
    #die-field-wrap .choices__list--single {
      padding: 0;
    }
    /* The in-dropdown search box (.choices__input) was rendering with no
       padding -- force it explicitly since something in the cascade is
       stripping the default Choices.js 10px. */
    #die-field-wrap .choices__input {
      padding: 10px !important;
      box-sizing: border-box !important;
    }

    .ap-table-wrap { overflow-x: auto; border: 1px solid #e5e7eb; border-radius: 8px; }
    .ap-table { width: 100%; border-collapse: collapse; font-size: 13px; table-layout: fixed; }
    .ap-table th, .ap-table td { padding: 8px 14px; border-bottom: 1px solid #e5e7eb; border-right: 1px solid #e5e7eb; text-align: left; }
    .ap-table tr > *:last-child { border-right: none; }
    .ap-table th { background: #f8fafc; color: #044a78; font-weight: 700; white-space: nowrap; width: 10%; }
    .ap-table td { color: #1f2a44; font-weight: 600; word-break: break-word; }

    .ap-notice {
      background: #fff8e1; border: 1px solid #f0c36d; color: #7a5b00; border-radius: 8px;
      padding: 10px 14px; font-size: 13px; display: flex; align-items: center; gap: 8px;
    }

    /* Semi Finished / Finished stock strips -- same visual language (icons,
       colours, weights) as the stock bar on the Sales Order form, see
       views/inventory/orders/salesOrderForm.ejs. */
    /* The two stock cards sit side by side on one row, dropping to stacked
       only when there's genuinely no width for it. */
    .ap-stock-pair { display: flex; gap: 14px; align-items: stretch; width: 100%; }
    .ap-stock-pair > .ap-card { flex: 1 1 0; min-width: 0; }
    @media (max-width: 900px) {
      .ap-stock-pair { flex-direction: column; }
    }
    /* nowrap + scroll rather than wrapping, so the three figures always read as
       a single line -- same treatment as the Sales Order stock bar. */
    .ap-stock-row {
      display: flex; align-items: center; gap: 26px; flex-wrap: nowrap;
      padding: 12px 16px; overflow-x: auto;
    }
    .ap-stock-stat {
      display: flex; align-items: baseline; gap: 6px; font-size: 16px; font-weight: 700;
      white-space: nowrap;
    }
    .ap-stock-stat .ap-stock-unit { font-size: 11.5px; font-weight: 500; color: #6b7280; }
    .ap-stock-available { color: #044a78; }
    .ap-stock-allotted { color: #d97706; }
    .ap-stock-balance { color: #059669; }
    .ap-stock-balance.is-negative { color: #ef4444; }
    .ap-card-title .ap-card-note { font-size: 12px; font-weight: 500; opacity: 0.85; }

    /* Paper stock readout at the end of the Paper Selection row -- figures,
       not inputs, so they don't read as something you can type into. */
    /* Two-up stat panel. Every property .span-dual would otherwise impose
       (flex column, 10px padding, 18px/500 type, flex-start alignment) is
       restated here, so the panel doesn't inherit layout meant for
       label-above-input boxes. align-content centres it against the taller
       input fields sharing its row. */
    .ap-paper-stock {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      align-items: center;
      align-content: center;
      gap: 0;
      padding: 8px 14px;
      font-size: inherit;
      font-weight: 400;
    }
    .ap-paper-stat { display: flex; flex-direction: column; gap: 5px; padding: 0 14px; min-width: 0; }
    .ap-paper-stat:first-child { padding-left: 0; }
    .ap-paper-stat:last-child { padding-right: 0; }
    .ap-paper-stat + .ap-paper-stat { border-left: 1px solid #e2e8f0; }
    .ap-paper-stat-label {
      font-size: 11px; font-weight: 600; letter-spacing: 0.6px; text-transform: uppercase;
      color: #64748b; white-space: nowrap; line-height: 1;
    }
    .ap-paper-stat-figure { display: flex; align-items: baseline; gap: 5px; white-space: nowrap; }
    .ap-paper-stat-value { font-size: 20px; font-weight: 700; line-height: 1.15; }
    .ap-paper-stat-unit { font-size: 11px; font-weight: 500; color: #94a3b8; }

    /* Rolls listing -- reuses .ap-table/.ap-table-wrap from this page, with
       auto column widths since .ap-table fixes th to 10% for its key/value use. */
    .roll-table { table-layout: auto; }
    .roll-table th { width: auto; font-size: 12.5px; }
    .roll-table td { font-size: 13.5px; }
    /* Whole row is the hit area, so no-select stops a click from highlighting
       the cell text instead of reading as a tick. */
    .roll-table tbody tr { cursor: pointer; user-select: none; }
    .roll-table tbody tr:hover { background: #eff6ff; }
    .roll-table .roll-check-cell { width: 56px; text-align: center; }
    /* Roll No and Running Mtrs hug each other on the left; the trailing filler
       soaks up the rest of the width so the row stays fully clickable. */
    .roll-table th:not(.roll-fill), .roll-table td:not(.roll-fill) { white-space: nowrap; width: 1%; }
    .roll-table .roll-fill { width: 100%; border-right: none; }
    .roll-table input[type="checkbox"] {
      width: 20px; height: 20px; margin: 0; vertical-align: middle;
      cursor: pointer; accent-color: #044a78;
    }
    /* Rolls already ticked for another job on a machine aren't listed at all --
       nobody can pick them, so they'd only be noise. How many were left out is
       reported by this tag in the Rolls header instead. */
    .roll-allotted-note {
      display: inline-block; padding: 2px 10px; border-radius: 10px;
      background: #fde68a; color: #78350f;
      font-size: 11.5px; font-weight: 600; white-space: nowrap;
    }
    /* An author `display` beats the UA sheet's [hidden] rule, so restate it. */
    .roll-allotted-note[hidden] { display: none; }
    /* Rows locked out because the rolls already ticked cover the requirement. */
    .roll-table tbody tr.roll-locked,
    .roll-table tbody tr.roll-locked:hover { background: #f8fafc; cursor: not-allowed; }
    .roll-table tbody tr.roll-locked td { color: #94a3b8; }
    .roll-table tbody tr.roll-locked input[type="checkbox"] { cursor: not-allowed; }

    /* Running-metre budget in the Rolls header: what the run needs, what the
       ticked rolls add up to, and what's left over once the job is done.
       .form-subheading is the dark primary-colour bar, so every colour here is
       light-on-dark -- the slate/navy palette used elsewhere on this page
       disappears against it. */
    /* Extra left margin (on top of the header's 12px gap) so the figures read as
       a separate group rather than running on from the "Rolls / Available" title. */
    .roll-mtr-stats { display: flex; align-items: center; margin-left: 22px; }
    .roll-mtr-stat {
      display: flex; align-items: baseline; gap: 5px;
      padding: 0 14px; white-space: nowrap; line-height: 1;
    }
    .roll-mtr-stat:first-child { padding-left: 0; }
    .roll-mtr-stat:last-child { padding-right: 0; }
    .roll-mtr-stat + .roll-mtr-stat { border-left: 1px solid rgba(255, 255, 255, 0.35); }
    .roll-mtr-label {
      font-size: 11px; font-weight: 600; letter-spacing: 0.6px;
      text-transform: uppercase; color: rgba(255, 255, 255, 0.75);
    }
    .roll-mtr-value { font-size: 16px; font-weight: 700; color: #fff; }
    .roll-mtr-unit { font-size: 11px; font-weight: 500; color: rgba(255, 255, 255, 0.65); }
    #roll-mtr-selected { color: #fcd34d; }
    #roll-mtr-selected.is-met { color: #6ee7b7; }
    #roll-mtr-balance { color: #6ee7b7; }
    #roll-mtr-balance.is-negative { color: #fca5a5; }

    .ap-form-card {
      width: 100%; background: #fff; border-radius: 10px;
      border: 1px solid #e2e8f0; padding: 16px 18px; display: flex; flex-direction: column; gap: 14px;
    }
    .ap-form-title { display: flex; align-items: center; gap: 8px; font-size: 15px; font-weight: 700; color: #044a78; }
    .ap-form-field { max-width: 460px; display: flex; flex-direction: column; gap: 6px; }
    .ap-form-field label { font-size: 13px; font-weight: 600; color: #374151; }
    .ap-submit-btn {
      align-self: flex-start; background: #044a78; color: #fff; border: none; border-radius: 8px;
      padding: 10px 22px; font-size: 14.5px; font-weight: 600; cursor: pointer; transition: opacity 0.2s;
    }
    .ap-submit-btn:hover { opacity: 0.88; }

    /* Auto-generated read-only field (e.g. Lot No) */
    .jc-readonly {
      background: #f0f7ff !important;
      color: #044a78 !important;
      font-weight: 700 !important;
      cursor: default !important;
    }

    /* Inputs & selects inside span-* boxes on this page need explicit padding
       because the global * { padding: 0 } reset in common.css strips Bootstrap's
       .form-control padding when the elements live outside a real <form> tag.
       Values match the label master form (common.css .form-control baseline). */
    .span-three input.form-control, .span-four input.form-control, .span-five input.form-control,
    .span-six input.form-control, .span-seven input.form-control, .span-eight input.form-control,
    .span-dual input.form-control,
    .span-three input.input-tag, .span-four input.input-tag, .span-five input.input-tag,
    .span-six input.input-tag, .span-seven input.input-tag, .span-eight input.input-tag,
    .span-dual input.input-tag {
      padding: 0.375rem 0.5rem !important;
      font-size: 1rem !important;
      height: auto !important;
      width: 100%;
    }
    .span-three select.form-control, .span-four select.form-control, .span-five select.form-control,
    .span-six select.form-control, .span-seven select.form-control, .span-eight select.form-control,
    .span-dual select.form-control,
    .span-three select.select-tag, .span-four select.select-tag, .span-five select.select-tag,
    .span-six select.select-tag, .span-seven select.select-tag, .span-eight select.select-tag,
    .span-dual select.select-tag {
      padding: 0.375rem 0.5rem !important;
      font-size: 1rem !important;
      height: auto !important;
      width: 100%;
    }
    /* Choices.js wrappers inside any span-* box */
    .span-three .choices__inner, .span-four .choices__inner, .span-five .choices__inner,
    .span-six .choices__inner, .span-seven .choices__inner, .span-eight .choices__inner,
    .span-dual .choices__inner {
      min-height: 2.3rem;
      padding: 0.375rem 0.5rem !important;
      display: flex;
      align-items: center;
    }
    .span-three .choices__list--single, .span-four .choices__list--single,
    .span-five .choices__list--single, .span-six .choices__list--single,
    .span-seven .choices__list--single, .span-eight .choices__list--single,
    .span-dual .choices__list--single {
      padding: 0;
    }
    /* Force the assign form to use the same 32-col grid so Machine / Operator /
       Helper render in a single row (ap-form-card sets flex which stacks them). */
    #assign-form {
      display: grid !important;
      grid-template-columns: repeat(32, 1fr);
      gap: 1rem;
    }
  </style>

  <div class="indi-head ap-head" style="display:flex; align-items:center; justify-content:space-between; gap:14px;">
    <div>
      <h1>Assign Production</h1>
      <div class="ap-sub">
        <%= dash(owner.clientName || item.clientName) %><% if (owner.userName || item.userName) { %> / <%= owner.userName || item.userName %><% } %>
      </div>
    </div>
    <div style="text-align:right; color:#fff; line-height:1.4;">
      <div style="font-size:17px; font-weight:600;">Date: <%= fmtDate(new Date()) %></div>
      <div style="font-size:22px; font-weight:700;">Lot No: <%= previewLotNo %></div>
    </div>
  </div>

  <div class="ap-card">
    <div class="ap-card-title"><span><i class="fa-solid fa-tag"></i> Order Details</span></div>
    <div class="ap-table-wrap">
      <table class="ap-table">
        <tbody>
          <tr>
            <th>PO Number</th><td><%= dash(pp.poNumber) %></td>
            <th>PO Date</th><td><%= fmtDate(poDate) %></td>
            <th>Est. Delivery</th><td><%= fmtDate(pp.estimatedDate) %></td>
          </tr>
          <tr>
            <th>Product ID</th><td><%= dash(item.productId) %></td>
            <th>Width</th><td><%= dash(item.labelWidth) %></td>
            <th>Height</th><td><%= dash(item.labelHeight) %></td>
          </tr>
          <tr>
            <th>Quantity</th><td><%= fmtQty(pp.quantity) %></td>
            <th>Dispatched</th><td><%= fmtQty(pp.dispatchedQuantity || 0) %></td>
            <th>Balance</th><td><%= fmtQty(balance) %></td>
          </tr>
          <tr>
            <th>Job Name</th><td><%= dash(item.jobName) %></td>
            <th>Family</th><td><%= dash(item.labelFamily) %></td>
            <th>Remarks</th><td><%= dash(pp.remarks) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <%
    // Semi finished = printed rolls before slitting, counted in rolls; finished
    // = the slit product, counted in labels. Rolls are only ever produced whole,
    // so a job needing 1.2 rolls is run as 2 and the 0.8 left over is semi
    // finished stock a later order for the same spec can draw on.
    const ps = (typeof productionStock !== 'undefined' && productionStock) ? productionStock : null;
    const psEmptyStock = { available: 0, allotted: 0, balance: 0 };
    const psSemi = (ps && ps.semiFinished) ? ps.semiFinished : psEmptyStock;
    const psFinished = (ps && ps.finished) ? ps.finished : psEmptyStock;
  %>

  <div class="ap-stock-pair">
  <div class="ap-card">
    <div class="ap-card-title">
      <span><i class="fa-solid fa-layer-group"></i> Semi Finished Stock</span>
      <span class="ap-card-note">Before slitting</span>
    </div>
    <div class="ap-stock-row">
      <div class="ap-stock-stat ap-stock-available" title="Rolls on hand for this item">
        <i class="fa-solid fa-box-open"></i> Available:
        <span><%= fmtQty(psSemi.available) %></span>
        <span class="ap-stock-unit">rolls</span>
      </div>
      <div class="ap-stock-stat ap-stock-allotted" title="Rolls already committed to a job">
        <i class="fa-regular fa-clock"></i> Allotted:
        <span><%= fmtQty(psSemi.allotted) %></span>
        <span class="ap-stock-unit">rolls</span>
      </div>
      <div class="ap-stock-stat ap-stock-balance<%= Number(psSemi.balance) < 0 ? ' is-negative' : '' %>" title="Rolls free to use">
        <i class="fa-solid fa-scale-balanced"></i> Balance:
        <span><%= fmtQty(psSemi.balance) %></span>
        <span class="ap-stock-unit">rolls</span>
      </div>
    </div>
  </div>

  <div class="ap-card">
    <div class="ap-card-title">
      <span><i class="fa-solid fa-boxes-stacked"></i> Finished Stock</span>
      <span class="ap-card-note">After slitting</span>
    </div>
    <div class="ap-stock-row">
      <div class="ap-stock-stat ap-stock-available" title="Labels on hand for this item">
        <i class="fa-solid fa-box-open"></i> Available:
        <span><%= fmtQty(psFinished.available) %></span>
        <span class="ap-stock-unit">labels</span>
      </div>
      <div class="ap-stock-stat ap-stock-allotted" title="Labels already committed">
        <i class="fa-regular fa-clock"></i> Allotted:
        <span><%= fmtQty(psFinished.allotted) %></span>
        <span class="ap-stock-unit">labels</span>
      </div>
      <div class="ap-stock-stat ap-stock-balance<%= Number(psFinished.balance) < 0 ? ' is-negative' : '' %>" title="Labels free to use">
        <i class="fa-solid fa-scale-balanced"></i> Balance:
        <span><%= fmtQty(psFinished.balance) %></span>
        <span class="ap-stock-unit">labels</span>
      </div>
    </div>
  </div>
  </div>

  <%
    const apPrefillDieNo = (item && item.dieNo && item.dieNo !== '—') ? item.dieNo : '';
    // Compute bound dies from candidates (same logic as Production Reference card).
    // Only show dies actually linked to this order via a Production Binding;
    // fall back to the full master list only when no binding exists yet.
    const apBoundDies = [];
    const apSeenDieIds = new Set();
    candidates.forEach((c) => {
      if (!c.die) return;
      const sid = String(c.die._id);
      if (apSeenDieIds.has(sid)) return;
      apSeenDieIds.add(sid);
      apBoundDies.push(c.die);
    });
    const apDieOptions = apBoundDies;
  %>

  <div class="ap-card" style="overflow: visible;">
    <div class="ap-card-title">
      <span><i class="fa-solid fa-clipboard-list"></i> Production Details</span>
    </div>
    <div style="display: grid; grid-template-columns: repeat(32, 1fr); gap: 1rem; padding: 1rem; border: none; border-radius: 0; background: transparent;">

      <div class="span-three" style="display: none;">
        <label for="jcd-date">Date</label>
        <input type="date" id="jcd-date" name="date" form="assign-form" class="form-control input-tag"
               value="<%= new Date().toISOString().slice(0,10) %>" required />
      </div>

      <div class="span-three" style="display: none;">
        <label for="jcd-lot-no">Lot No</label>
        <input type="text" id="jcd-lot-no" name="lotNo" form="assign-form" class="form-control input-tag jc-readonly"
               value="<%= previewLotNo %>" readonly />
      </div>

      <div class="span-three" style="display: none;">
        <label for="jcd-quantity">Quantity</label>
        <input type="text" id="jcd-quantity" class="form-control input-tag"
               value="<%= pp.quantity ? fmtQty(pp.quantity) : '' %>" placeholder="Enter quantity"
               oninput="this.nextElementSibling.value=this.value.replace(/,/g,'')" />
        <input type="hidden" name="jcdQuantity" form="assign-form" value="<%= pp.quantity || '' %>" />
      </div>

      <div class="span-four" style="display: none;">
        <label for="jcd-product-id">Product ID</label>
        <input type="text" id="jcd-product-id" name="productId" form="assign-form" class="form-control input-tag"
               value="<%= dash(item.productId) !== '—' ? item.productId : '' %>" placeholder="Enter product ID" />
      </div>

      <div class="span-three" style="display: none;">
        <label for="jcd-width">Width</label>
        <input type="text" id="jcd-width" name="labelWidth" form="assign-form" class="form-control input-tag"
               value="<%= dash(item.labelWidth) !== '—' ? item.labelWidth : '' %>" placeholder="Width" />
      </div>

      <div class="span-three" style="display: none;">
        <label for="jcd-height">Height</label>
        <input type="text" id="jcd-height" name="labelHeight" form="assign-form" class="form-control input-tag"
               value="<%= dash(item.labelHeight) !== '—' ? item.labelHeight : '' %>" placeholder="Height" />
      </div>

      <div class="span-full form-subheading" style="grid-column: 1 / -1; margin: 0;">
        <h1>Paper Details</h1>
      </div>

      <!-- Read-only: this is the bound spec from the Production Binding, shown
           for reference. The paper actually used for the run is picked in the
           Paper Selection row on the assign form below. -->
      <div class="span-five" style="grid-column: span 4;">
        <label for="jcd-paper-type">Family</label>
        <input type="text" id="jcd-paper-type" name="jcdPaperType" form="assign-form" class="form-control input-tag jc-readonly"
               placeholder="Family" autocomplete="off" readonly value="<%= candidates[0]?.prodPaperFamily || candidates[0]?.prodPaperType || item.labelFamily || item.paperType || '' %>" />
      </div>

      <div class="span-five" style="grid-column: span 8;">
        <label for="jcd-vendor-name">Vendor Name</label>
        <input type="text" id="jcd-vendor-name" name="jcdVendorName" form="assign-form" class="form-control input-tag jc-readonly"
               value="<%= candidates[0]?.prodVendorName || '' %>" placeholder="Vendor name" autocomplete="off" readonly />
      </div>

      <div class="span-five" style="grid-column: span 4;">
        <label for="jcd-paper-code">Paper Code</label>
        <input type="text" id="jcd-paper-code" name="jcdPaperCode" form="assign-form" class="form-control input-tag jc-readonly"
               placeholder="Paper code" autocomplete="off" readonly value="<%= candidates[0]?.prodPaperCode || '' %>" />
      </div>

      <div class="span-five" style="grid-column: span 4;">
        <label for="jcd-paper-size">Paper Size</label>
        <input type="text" id="jcd-paper-size" name="jcdPaperSize" form="assign-form" class="form-control input-tag jc-readonly"
               placeholder="Paper size" readonly value="<%= candidates[0]?.prodPaperSize || '' %>" />
      </div>

      <div class="span-five" style="grid-column: span 6;">
        <label for="jcd-running-mtrs">Running Mtrs</label>
        <input type="text" id="jcd-running-mtrs" class="form-control input-tag jc-readonly"
               placeholder="Select a die" readonly />
      </div>

      <div class="span-five" style="grid-column: span 6;">
        <label for="jcd-rolls">~ No. of Rolls <span style="font-weight:400; font-size:11px; color:#6b7280;">(for <%= fmtQty(balance) %> labels)</span></label>
        <input type="text" id="jcd-rolls" name="rolls" form="assign-form" class="form-control input-tag jc-readonly"
               placeholder="Select a die" readonly />
      </div>

    </div>
  </div>

  <div class="ap-card">
    <div class="ap-card-title">
      <span><i class="fa-solid fa-industry"></i> Die Details</span>
    </div>
    <div style="padding: 4px 0 0 0;">
      <% if (candidates.length === 0) { %>
      <div class="ap-notice" style="margin: 10px 16px 0;">
        <i class="fa-solid fa-circle-info"></i>
        No production binding found for this client/label — select a die and paper below to continue.
      </div>
      <% } %>
      <%
        const firstCandidate = candidates[0] || {};
        const boundDies = [];
        const seenDieIds = new Set();
        candidates.forEach((c) => {
          if (!c.die) return;
          const dieIdStr = String(c.die._id);
          if (seenDieIds.has(dieIdStr)) return;
          seenDieIds.add(dieIdStr);
          boundDies.push(c.die);
        });
        const dieOptions = boundDies.length ? boundDies : (dies || []);
        const dieLabel = (d) => [
          (d.dieWidth != null && d.dieHeight != null) ? `${d.dieWidth} x ${d.dieHeight}` : '',
          d.dieTotalUps != null ? `${d.dieTotalUps}ups` : '',
          d.dieType || '',
        ].filter(Boolean).join(' - ');
      %>
      <div style="display: grid; grid-template-columns: repeat(32, 1fr); gap: 1rem; padding: 1rem; border: none; border-radius: 0; background: transparent;">
        <div class="span-five" id="die-field-wrap">
          <label for="manual-die-select">Die</label>
          <select id="manual-die-select" name="dieId" form="assign-form" class="form-control select-tag">
            <option value="" disabled hidden>Select die</option>
            <% dieOptions.forEach(d => { %>
              <option value="<%= d._id %>"
                      data-across="<%= d.dieFlatAcross || '' %>"
                      data-repgap="<%= d.dieFlatrepGap || '' %>"
                      data-dieno="<%= d.dieDieNo || '' %>"
                      data-width="<%= d.dieWidth || '' %>"
                      data-height="<%= d.dieHeight || '' %>"
                      data-acrossgap="<%= d.dieFlatAcrossGap || '' %>"
                      data-down="<%= d.dieFlatDown || '' %>"
                      data-totalups="<%= d.dieTotalUps || '' %>"
                      <%= (dieOptions.length === 1 || (firstCandidate.die && String(firstCandidate.die._id) === String(d._id))) ? 'selected' : '' %>><%= dieLabel(d) %></option>
            <% }) %>
          </select>
        </div>
        <!-- Still submitted to the backend (ProductionBinding paper spec) but no
             longer shown in this card -- kept in sync with the visible "Paper
             Details" fields above (jcd-paper-code / jcd-paper-type / jcd-paper-size). -->
        <div style="display:none;">
          <input type="text" id="manual-paper-code" name="paperCode" form="assign-form" value="<%= firstCandidate.prodPaperCode || '' %>" />
          <datalist id="manual-paper-code-options">
            <% [...new Set((papers || []).map(p => p.prodCode).filter(Boolean))].forEach(pc => { %><option value="<%= pc %>"></option><% }) %>
          </datalist>
          <input type="text" id="manual-paper-type" name="paperFamily" form="assign-form" value="<%= firstCandidate.prodPaperFamily || firstCandidate.prodPaperType || item.labelFamily || item.paperType || '' %>" />
          <datalist id="manual-paper-type-options">
            <% [...new Set((papers || []).map(p => p.family).filter(Boolean))].forEach(pt => { %><option value="<%= pt %>"></option><% }) %>
          </datalist>
          <input type="text" id="manual-paper-gsm" name="paperGsm" form="assign-form" value="<%= firstCandidate.prodPaperGsm || '' %>" />
          <input type="text" id="manual-paper-size" name="paperSize" form="assign-form" value="<%= firstCandidate.prodPaperSize || '' %>" />
          <input type="text" id="manual-vendor-name" name="vendorName" form="assign-form" value="<%= firstCandidate.prodVendorName || '' %>" />
        </div>

        <div class="span-three">
          <label for="die-detail-no">Die No</label>
          <input type="text" id="die-detail-no" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
        <div class="span-three">
          <label for="die-detail-width">Width</label>
          <input type="text" id="die-detail-width" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
        <div class="span-three">
          <label for="die-detail-height">Height</label>
          <input type="text" id="die-detail-height" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
        <div class="span-four">
          <label for="die-detail-across-ups">Across Ups</label>
          <input type="text" id="die-detail-across-ups" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
        <div class="span-four">
          <label for="die-detail-across-gap">Across Gap</label>
          <input type="text" id="die-detail-across-gap" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
        <div class="span-three">
          <label for="die-detail-down-ups">Down Ups</label>
          <input type="text" id="die-detail-down-ups" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
        <div class="span-four">
          <label for="die-detail-repeat-gap">Repeat Gap</label>
          <input type="text" id="die-detail-repeat-gap" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
        <div class="span-three">
          <label for="die-detail-total-ups">Total Ups</label>
          <input type="text" id="die-detail-total-ups" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
      </div>
      <div style="padding: 0 1rem 1rem;" id="reference-body-wrap">
        <div id="reference-body" class="ap-table-wrap"></div>
        <div id="no-die-notice" class="ap-notice" style="display: none;">
          <i class="fa-solid fa-triangle-exclamation"></i>
          Select a die to see which machines are eligible.
        </div>
        <div id="no-machine-notice" class="ap-notice" style="display: none;">
          <i class="fa-solid fa-triangle-exclamation"></i>
          No machines are bound to this die yet — add a Machine Binding first.
        </div>
      </div>
    </div>
  </div>

  <form id="assign-form" class="ap-form-card needs-validation" action="/fairtech/labels/production/assign/<%= pp._id %>" method="post" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <div class="span-dual" style="grid-column: span 11;">
      <label for="machine-select">Machine</label>
      <select id="machine-select" name="machineId" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Select Machine</option>
      </select>
    </div>

    <div class="span-dual" style="grid-column: span 11;">
      <label for="operator-select">Operator</label>
      <select id="operator-select" name="operatorId" class="form-control select-tag">
        <option value="" selected>Select Operator</option>
        <% operatorEmployees.forEach((emp) => { %>
          <option value="<%= emp._id %>" data-profilecode="<%= emp.empProfileCode || '' %>"><%= emp.empName %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-dual" style="grid-column: span 10;">
      <label for="helper-select">Helper</label>
      <select id="helper-select" name="helperId" class="form-control select-tag">
        <option value="" selected>Select Helper</option>
        <% helperEmployees.forEach((emp) => { %>
          <option value="<%= emp._id %>" data-profilecode="<%= emp.empProfileCode || '' %>"><%= emp.empName %></option>
        <% }) %>
      </select>
    </div>

    <!-- Paper actually used for this run. Pre-filled from the bound spec shown
         read-only above and editable here, so the run's paper can differ from
         what the Production Binding has on file. These drive the hidden paper
         inputs that are submitted. -->
    <div class="span-full form-subheading" style="grid-column: 1 / -1; margin: 0;">
      <h1>Paper Selection</h1>
    </div>

    <%
      const psk = (typeof paperStock !== 'undefined' && paperStock) ? paperStock : { available: null, allotted: null, balance: null };
      const pskDash = (v) => (v === null || v === undefined ? '—' : fmtQty(v));
    %>

    <div class="span-dual" style="grid-column: span 5;">
      <label for="sel-paper-type">Family</label>
      <input type="text" id="sel-paper-type" class="form-control input-tag"
             placeholder="Family" autocomplete="off"
             value="<%= candidates[0]?.prodPaperFamily || candidates[0]?.prodPaperType || item.labelFamily || item.paperType || '' %>" />
    </div>

    <div class="span-dual" style="grid-column: span 7;">
      <label for="sel-vendor-name">Vendor Name</label>
      <input type="text" id="sel-vendor-name" class="form-control input-tag"
             placeholder="Vendor name" autocomplete="off"
             value="<%= candidates[0]?.prodVendorName || '' %>" />
    </div>

    <div class="span-dual" style="grid-column: span 6;">
      <label for="sel-paper-code">Paper Code</label>
      <input type="text" id="sel-paper-code" class="form-control input-tag"
             placeholder="Paper code" autocomplete="off"
             value="<%= candidates[0]?.prodPaperCode || '' %>" />
    </div>

    <div class="span-dual" style="grid-column: span 4;">
      <label for="sel-paper-size">Paper Size</label>
      <input type="text" id="sel-paper-size" class="form-control input-tag"
             placeholder="Paper size" autocomplete="off"
             value="<%= candidates[0]?.prodPaperSize || '' %>" />
    </div>

    <!-- Stock for the exact vendor + code + size above. Read-only figures, not
         inputs -- computed server-side and re-queried when those fields change.
         Balance = available minus rolls committed to other assigned jobs; the
         tooltip spells out the subtraction. -->
    <div class="span-dual ap-paper-stock" style="grid-column: span 10;">
      <div class="ap-paper-stat">
        <span class="ap-paper-stat-label">Stock Available</span>
        <span class="ap-paper-stat-figure">
          <span class="ap-paper-stat-value ap-stock-available" id="sel-stock-available"><%= pskDash(psk.available) %></span>
          <span class="ap-paper-stat-unit">rolls</span>
        </span>
      </div>
      <div class="ap-paper-stat">
        <span class="ap-paper-stat-label">Allotted</span>
        <span class="ap-paper-stat-figure">
          <span class="ap-paper-stat-value ap-stock-allotted" id="sel-stock-allotted"
                title="Rolls allotted to other jobs already assigned to a machine"><%= pskDash(psk.allotted) %></span>
          <span class="ap-paper-stat-unit">rolls</span>
        </span>
      </div>
      <div class="ap-paper-stat">
        <span class="ap-paper-stat-label">Balance</span>
        <span class="ap-paper-stat-figure">
          <span class="ap-paper-stat-value ap-stock-balance<%= Number(psk.balance) < 0 ? ' is-negative' : '' %>"
                id="sel-stock-balance"
                title="<%= psk.allotted ? `${fmtQty(psk.available)} available − ${fmtQty(psk.allotted)} allotted` : 'Nothing allotted to other assigned jobs' %>"><%= pskDash(psk.balance) %></span>
          <span class="ap-paper-stat-unit">rolls</span>
        </span>
      </div>
    </div>

    <!-- Every pickable roll in stock for the paper + size above, listed with its
         own details -- one row per stock entry, since the same roll no can
         arrive more than once. Rolls allotted to another assigned job are left
         out (their count shows in the header tag). Tick the ones this run uses;
         only the stock row ids are submitted (as selectedRolls) since size/mtrs
         are properties of the roll and the server can read them back
         authoritatively. -->
    <div class="span-full form-subheading" style="grid-column: 1 / -1; margin: 0; display: flex; flex-direction: row; flex-wrap: wrap; align-items: center; gap: 12px;">
      <h1>Rolls</h1>
      <span class="roll-allotted-note" id="roll-allotted-note" hidden></span>
      <!-- Running-metre budget for this run: what the job needs, what the
           ticked rolls add up to, and what is left over once it has been run. -->
      <div class="roll-mtr-stats">
        <div class="roll-mtr-stat" title="Running metres this job needs">
          <span class="roll-mtr-label">Required</span>
          <span class="roll-mtr-value" id="roll-mtr-required">—</span>
          <span class="roll-mtr-unit">m</span>
        </div>
        <div class="roll-mtr-stat" title="Running metres on the rolls ticked below">
          <span class="roll-mtr-label">Selected</span>
          <span class="roll-mtr-value" id="roll-mtr-selected">0</span>
          <span class="roll-mtr-unit">m</span>
        </div>
        <div class="roll-mtr-stat" title="Running metres left over once this job has been run">
          <span class="roll-mtr-label">Balance</span>
          <span class="roll-mtr-value" id="roll-mtr-balance">—</span>
          <span class="roll-mtr-unit">m</span>
        </div>
      </div>
    </div>

    <div id="roll-details" style="grid-column: 1 / -1;"></div>

    <div class="btn-grp span-full">
      <button type="submit">Assign &amp; Continue to Confirm</button>
    </div>
  </form>
</div>

<script id="candidates-data" type="application/json"><%- safeJson(candidates) %></script>
<script id="all-machines-data" type="application/json"><%- safeJson(allMachines) %></script>
<script src="/js/choices.min.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const CANDIDATES = JSON.parse(document.getElementById("candidates-data").textContent);
    const ALL_MACHINES = JSON.parse(document.getElementById("all-machines-data").textContent);
    const manualDieSelect = document.getElementById("manual-die-select");

    const machineSelectEl = document.getElementById("machine-select");
    const referenceBody = document.getElementById("reference-body");
    const candidateSelect = document.getElementById("candidate-select");
    const noMachineNotice = document.getElementById("no-machine-notice");
    const noDieNotice = document.getElementById("no-die-notice");
    const submitBtn = document.querySelector(".ap-submit-btn");

    // A die must be bound before a machine can be assigned — toggles the
    // machine select + submit button together so the form can't be forced.
    function setAssignable(allowed) {
      machineSelectEl.disabled = !allowed;
      if (submitBtn) {
        submitBtn.disabled = !allowed;
        submitBtn.style.opacity = allowed ? "1" : "0.5";
        submitBtn.style.cursor = allowed ? "pointer" : "not-allowed";
      }
    }

    const machineChoices = new Choices(machineSelectEl, { searchEnabled: true, shouldSort: false, itemSelectText: "" });
    const operatorSelectEl = document.getElementById("operator-select");
    const helperSelectEl = document.getElementById("helper-select");
    const operatorChoices = new Choices(operatorSelectEl, { searchEnabled: true, shouldSort: false, itemSelectText: "" });
    const helperChoices = new Choices(helperSelectEl, { searchEnabled: true, shouldSort: false, itemSelectText: "" });

    // Each Operator/Helper's Profile Code mirrors the Machine name they run
    // (e.g. Machine "R1" <-> Employee Profile Code "R1") -- picking a machine
    // auto-selects whichever operator/helper shares that code. If the newly
    // picked machine has no matching operator/helper, clear back to the
    // placeholder instead of leaving the previous machine's pick behind.
    function autoFillByMachineCode(machineName, selectEl, choicesInstance) {
      const wanted = (machineName || "").trim().toUpperCase();
      const match = wanted
        ? Array.from(selectEl.options).find(
            (o) => o.dataset.profilecode && o.dataset.profilecode.trim().toUpperCase() === wanted,
          )
        : null;
      choicesInstance.setChoiceByValue(match ? match.value : "");
    }

    machineSelectEl.addEventListener("change", function () {
      const machine = ALL_MACHINES.find((m) => String(m._id) === String(this.value));
      autoFillByMachineCode(machine?.machineName, operatorSelectEl, operatorChoices);
      autoFillByMachineCode(machine?.machineName, helperSelectEl, helperChoices);
    });

    const machineLabel = (m) => `${m.machineName} — ${m.location?.locationName || "?"} (${m.machineType})`;

    function setMachineOptions(machines) {
      const options = machines.map((m) => ({ value: m._id, label: machineLabel(m) }));
      machineChoices.clearStore();
      machineChoices.setChoices(
        [{ value: "", label: "Select Machine", disabled: true, selected: true }, ...options],
        "value", "label", true,
      );
    }

    function dash(v) {
      return v === undefined || v === null || v === "" ? "—" : v;
    }

    // Renders label/value pairs as a real table, 3 pairs (6 cells) per row —
    // matches the .pcd-table / .diff-table convention used elsewhere in the app.
    function kvTable(pairs) {
      const perRow = 3;
      let rows = "";
      for (let i = 0; i < pairs.length; i += perRow) {
        const chunk = pairs.slice(i, i + perRow);
        while (chunk.length < perRow) chunk.push(["", ""]);
        rows += "<tr>" + chunk.map(([k, v]) => (k === "" ? "<th></th><td></td>" : `<th>${k}</th><td>${dash(v)}</td>`)).join("") + "</tr>";
      }
      return `<table class="ap-table"><tbody>${rows}</tbody></table>`;
    }

    function renderReference(candidate) {
      if (!candidate) {
        referenceBody.innerHTML = "";
        return;
      }
      // Die/Paper themselves are shown as the editable fields above now --
      // this table is just supplementary context (block/vendor) for whichever
      // candidate is currently applied.
      const pairs = [];
      if (candidate.block) {
        const b = candidate.block;
        pairs.push(
          ["Block No", b.blockNo],
          ["Block Machine Type / No", `${dash(b.blockMachineType)} / ${dash(b.blockMachineNo)}`],
          ["Front / Back Color", `${dash(b.blockFrontColor)} / ${dash(b.blockBackColor)}`],
        );
      }
      referenceBody.innerHTML = pairs.length ? kvTable(pairs) : "";
    }

    // Use a matching candidate's machineIds (named-machine fallback bindings)
    // for whichever die is picked; a manually picked die with no matching
    // Production Binding has no eligible machines to narrow down to.
    function computeEligibleMachines(dieId) {
      const matchingCandidate = CANDIDATES.find((c) => c.die && String(c.die._id) === String(dieId));
      if (matchingCandidate) {
        return ALL_MACHINES.filter((m) => matchingCandidate.machineIds.includes(String(m._id)));
      }
      return [];
    }

    // No. of Rolls: repeat length x = (Label Height + Label Gap, mm) / 1000
    // (metres per repeat down the web); a standard roll holds 1000m of
    // running length, so capacity-per-roll = (1000 / x) x Across Ups labels.
    // Rolls needed = remaining order balance / capacity-per-roll, rounded UP.
    const STANDARD_ROLL_METERS = 1000;
    const balanceQty = <%= balance %>;
    const labelHeightMm = <%= Number(item.labelHeight) || 0 %>;
    const labelGapMm = <%= Number(item.labelGap) || 0 %>;
    // Fallback family when a matching Production Binding exists but its own
    // paper-family fields were never filled in -- mirrors the server-rendered
    // initial value so applyCandidate() doesn't clobber it with a blank.
    const ITEM_LABEL_FAMILY = <%- JSON.stringify(item.labelFamily || item.paperType || "") %>;
    const rollsInput = document.getElementById("jcd-rolls");
    const runningMtrsInput = document.getElementById("jcd-running-mtrs");
    function updateRolls(dieId) {
      if (!rollsInput) return;
      const option = dieId ? manualDieSelect.querySelector(`option[value="${dieId}"]`) : null;
      const across = Number(option?.dataset.across);
      const repeatLengthM = (labelHeightMm + labelGapMm) / 1000;
      if (!option || !across || !balanceQty || !repeatLengthM) {
        rollsInput.value = "";
        if (runningMtrsInput) runningMtrsInput.value = "";
        syncRollSelection();
        return;
      }
      const capacityPerRoll = (STANDARD_ROLL_METERS / repeatLengthM) * across;
      const rawRolls = balanceQty / capacityPerRoll;
      rollsInput.value = String(Math.ceil(rawRolls));
      if (runningMtrsInput) runningMtrsInput.value = String(Math.round(rawRolls * 1000));
      // Running Mtrs is the "Required" figure the roll picker budgets against.
      syncRollSelection();
    }

    const dieDetailFields = {
      no: document.getElementById("die-detail-no"),
      width: document.getElementById("die-detail-width"),
      height: document.getElementById("die-detail-height"),
      acrossUps: document.getElementById("die-detail-across-ups"),
      acrossGap: document.getElementById("die-detail-across-gap"),
      downUps: document.getElementById("die-detail-down-ups"),
      repeatGap: document.getElementById("die-detail-repeat-gap"),
      totalUps: document.getElementById("die-detail-total-ups"),
    };
    function updateDieDetails(dieId) {
      const option = dieId ? manualDieSelect?.querySelector(`option[value="${dieId}"]`) : null;
      dieDetailFields.no.value = option?.dataset.dieno || "";
      dieDetailFields.width.value = option?.dataset.width || "";
      dieDetailFields.height.value = option?.dataset.height || "";
      dieDetailFields.acrossUps.value = option?.dataset.across || "";
      dieDetailFields.acrossGap.value = option?.dataset.acrossgap || "";
      dieDetailFields.downUps.value = option?.dataset.down || "";
      dieDetailFields.repeatGap.value = option?.dataset.repgap || "";
      dieDetailFields.totalUps.value = option?.dataset.totalups || "";
    }

    function applyDie(dieId) {
      updateRolls(dieId);
      updateDieDetails(dieId);

      if (!dieId) {
        setMachineOptions([]);
        if (noMachineNotice) noMachineNotice.style.display = "none";
        if (noDieNotice) noDieNotice.style.display = "flex";
        setAssignable(false);
        return;
      }
      if (noDieNotice) noDieNotice.style.display = "none";

      const eligible = computeEligibleMachines(dieId);
      setMachineOptions(eligible);
      if (noMachineNotice) noMachineNotice.style.display = eligible.length ? "none" : "flex";
      setAssignable(eligible.length > 0);
    }

    // Pre-fills the editable Die/Paper fields from a candidate for convenience
    // -- the operator can still change any of them before submitting.
    function applyCandidate(candidateId) {
      const candidate = CANDIDATES.find((c) => String(c._id) === String(candidateId)) || CANDIDATES[0];
      renderReference(candidate);

      const dieId = candidate?.die ? String(candidate.die._id) : "";
      if (manualDieChoices && dieId) {
        manualDieChoices.setChoiceByValue(dieId);
      } else if (manualDieSelect) {
        manualDieSelect.value = dieId;
      }
      const candidateFamily = candidate?.prodPaperFamily || candidate?.prodPaperType || ITEM_LABEL_FAMILY;
      document.getElementById("manual-paper-code").value = candidate?.prodPaperCode || "";
      document.getElementById("manual-paper-type").value = candidateFamily;
      document.getElementById("manual-paper-gsm").value = candidate?.prodPaperGsm || "";
      document.getElementById("manual-paper-size").value = candidate?.prodPaperSize || "";
      document.getElementById("manual-vendor-name").value = candidate?.prodVendorName || "";
      document.getElementById("jcd-vendor-name").value = candidate?.prodVendorName || "";
      document.getElementById("jcd-paper-type").value = candidateFamily;
      document.getElementById("jcd-paper-code").value = candidate?.prodPaperCode || "";
      document.getElementById("jcd-paper-size").value = candidate?.prodPaperSize || "";
      // Keep the editable Paper Selection copy in step with the bound spec,
      // otherwise switching candidate would move the hidden submitted fields
      // while the row below still showed the previous candidate's paper.
      document.getElementById("sel-vendor-name").value = candidate?.prodVendorName || "";
      document.getElementById("sel-paper-type").value = candidateFamily;
      document.getElementById("sel-paper-code").value = candidate?.prodPaperCode || "";
      document.getElementById("sel-paper-size").value = candidate?.prodPaperSize || "";

      applyDie(dieId);
    }

    let manualDieChoices = null;
    if (manualDieSelect) {
      manualDieChoices = new Choices(manualDieSelect, { searchEnabled: true, shouldSort: false, itemSelectText: "" });
      manualDieSelect.addEventListener("change", function () { applyDie(this.value); });
    }

    // Paper Selection row -- the paper actually used for this run. Pre-filled
    // from the bound spec and editable, so whatever is typed here is what gets
    // submitted (and synced onto the Production Binding), overriding the
    // read-only Paper Details above.
    const SEL_PAPER_FIELDS = [
      ["sel-paper-type", "manual-paper-type"],
      ["sel-paper-code", "manual-paper-code"],
      ["sel-paper-size", "manual-paper-size"],
      ["sel-vendor-name", "manual-vendor-name"],
    ];
    SEL_PAPER_FIELDS.forEach(([visibleId, hiddenId]) => {
      const visible = document.getElementById(visibleId);
      const hidden = document.getElementById(hiddenId);
      if (!visible || !hidden) return;
      hidden.value = visible.value;
      visible.addEventListener("input", () => { hidden.value = visible.value; });
    });

    // Paper stock figures follow whatever paper is named above. Rendered
    // server-side for the initial bound spec, then re-queried on edit --
    // debounced so typing a paper code doesn't fire a request per keystroke.
    const stockAvailableEl = document.getElementById("sel-stock-available");
    const stockAllottedEl = document.getElementById("sel-stock-allotted");
    const stockBalanceEl = document.getElementById("sel-stock-balance");
    const PENDING_ID = <%- JSON.stringify(String(pp._id)) %>;

    function refreshPaperStock() {
      if (!stockAvailableEl || !stockBalanceEl) return;
      const params = new URLSearchParams({
        vendorName: document.getElementById("sel-vendor-name")?.value || "",
        prodCode: document.getElementById("sel-paper-code")?.value || "",
        paperSize: document.getElementById("sel-paper-size")?.value || "",
        excludeId: PENDING_ID,
      });
      fetch(`/fairtech/labels/production/paper-stock?${params}`)
        .then((r) => r.json())
        .then(({ available, allotted, balance, rolls }) => {
          const show = (v) => (v === null || v === undefined ? "—" : Number(v).toLocaleString("en-IN"));
          stockAvailableEl.textContent = show(available);
          if (stockAllottedEl) stockAllottedEl.textContent = show(allotted);
          stockBalanceEl.textContent = show(balance);
          stockBalanceEl.classList.toggle("is-negative", Number(balance) < 0);
          stockBalanceEl.title = allotted
            ? `${show(available)} available − ${show(allotted)} allotted`
            : "Nothing allotted to other assigned jobs";
          // The Rolls section offers whatever is on the floor for this paper
          // and size, so its options have to follow the same lookup.
          AVAILABLE_ROLLS = Array.isArray(rolls) ? rolls : [];
          renderRollRows();
        })
        .catch(() => {
          stockAvailableEl.textContent = "—";
          stockBalanceEl.textContent = "—";
          stockBalanceEl.classList.remove("is-negative");
          stockBalanceEl.title = "";
        });
    }

    let paperStockTimer = null;
    ["sel-vendor-name", "sel-paper-code", "sel-paper-size"].forEach((id) => {
      document.getElementById(id)?.addEventListener("input", () => {
        clearTimeout(paperStockTimer);
        paperStockTimer = setTimeout(refreshPaperStock, 350);
      });
    });

    // Rolls section -- every pickable roll in stock for the paper + size above,
    // listed with its own details. Nothing is typed: you tick the rolls this run
    // uses. One row per stock entry, so a roll no that arrived twice shows twice
    // (its location and mtrs tell them apart). Rolls already allotted to another
    // assigned job are filtered out, so the row count is Stock Available minus
    // those -- the header tag says how many were left out.
    // What posts (selectedRolls) is the stock row id, not the roll no -- roll
    // numbers repeat, ids don't -- and size/mtrs belong to the roll, so the
    // server reads those back from stock rather than trusting the page.
    // Re-rendered by refreshPaperStock() when the paper changes, with existing
    // ticks carried over.
    let AVAILABLE_ROLLS = <%- safeJson((typeof paperStock !== 'undefined' && paperStock && paperStock.rolls) ? paperStock.rolls : []) %>;
    // Rolls this order already had allotted (when re-opening an assigned order to
    // edit it) -- pre-ticked on the first render, then cleared so later paper
    // changes fall back to carrying over whatever is ticked in the DOM.
    let INITIAL_ROLL_IDS = <%- safeJson((pendingProduction.allottedRollIds || []).map(String)) %>;
    const rollsContainer = document.getElementById("roll-details");
    const allottedNoteEl = document.getElementById("roll-allotted-note");

    const escapeAttr = (value) => String(value ?? "")
      .replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/'/g, "&#39;")
      .replace(/</g, "&lt;").replace(/>/g, "&gt;");

    const fmtNum = (v) => (v === null || v === undefined || v === "" ? "—" : Number(v).toLocaleString("en-IN"));

    function checkedRollNos() {
      return Array.from(rollsContainer?.querySelectorAll("input[name='selectedRolls']:checked") || [])
        .map((el) => el.value);
    }

    function renderRollRows() {
      if (!rollsContainer) return;
      const previouslyChecked = new Set(checkedRollNos());
      // Seed the ticks from the order's existing allotment on the first render.
      INITIAL_ROLL_IDS.forEach((id) => previouslyChecked.add(String(id)));
      INITIAL_ROLL_IDS = [];

      // A roll ticked for another job that's already on a machine can't be
      // picked here, so it's left out of the list entirely -- only its count is
      // reported, in the header tag.
      const allottedCount = AVAILABLE_ROLLS.filter((r) => r.takenBy).length;
      const pickable = AVAILABLE_ROLLS.filter((r) => !r.takenBy);
      if (allottedNoteEl) {
        allottedNoteEl.hidden = allottedCount === 0;
        allottedNoteEl.textContent = allottedCount
          ? `${allottedCount} roll${allottedCount === 1 ? "" : "s"} allotted to other jobs`
          : "";
      }

      if (!pickable.length) {
        rollsContainer.innerHTML =
          `<div class="ap-notice"><i class="fa-solid fa-triangle-exclamation"></i> ` +
          (allottedCount
            ? `Every roll in stock for this paper and size is allotted to another job.`
            : `No rolls in stock for this paper and size.`) +
          `</div>`;
        syncRollSelection();
        return;
      }

      const rows = pickable.map((r) => {
        const id = escapeAttr(r.stockId);
        const no = escapeAttr(r.rollNo);
        const checked = previouslyChecked.has(String(r.stockId)) ? " checked" : "";
        // data-mtrs drives the Selected / Balance figures in the header without
        // needing to look the roll back up in AVAILABLE_ROLLS on every tick.
        return `<tr>` +
          `<td class="roll-check-cell"><input type="checkbox" name="selectedRolls" value="${id}" data-mtrs="${Number(r.paperMtrs) || 0}"${checked} /></td>` +
          `<td>${no}</td>` +
          `<td>${fmtNum(r.paperMtrs)}</td>` +
          `<td>${escapeAttr(r.location) || "—"}</td>` +
          `<td class="roll-fill"></td>` +
        `</tr>`;
      }).join("");

      rollsContainer.innerHTML =
        `<div class="ap-table-wrap"><table class="ap-table roll-table">` +
        `<thead><tr>` +
          `<th class="roll-check-cell"></th><th>Roll No</th><th>Running Mtrs</th><th>Location</th><th class="roll-fill"></th>` +
        `</tr></thead>` +
        `<tbody>${rows}</tbody></table></div>`;

      syncRollSelection();
    }

    // Running-metre budget for the run. Required is the figure the die/quantity
    // maths put in the Running Mtrs field above; Selected is the sum of the
    // ticked rolls; Balance is what's left over once the job has been run.
    // Once the ticks cover Required the remaining rolls are locked, so a run
    // can't quietly draw more paper than it needs -- unticking frees them again.
    function syncRollSelection() {
      if (!rollsContainer) return;
      const boxes = Array.from(rollsContainer.querySelectorAll("input[name='selectedRolls']"));
      const required = Number(runningMtrsInput?.value) || 0;
      const selected = boxes.reduce((sum, b) => (b.checked ? sum + (Number(b.dataset.mtrs) || 0) : sum), 0);
      const satisfied = required > 0 && selected >= required;

      boxes.forEach((box) => {
        box.disabled = satisfied && !box.checked;
        box.closest("tr")?.classList.toggle("roll-locked", box.disabled);
      });

      const requiredEl = document.getElementById("roll-mtr-required");
      const selectedEl = document.getElementById("roll-mtr-selected");
      const balanceEl = document.getElementById("roll-mtr-balance");
      if (requiredEl) requiredEl.textContent = required ? fmtNum(required) : "—";
      if (selectedEl) {
        selectedEl.textContent = fmtNum(selected);
        selectedEl.classList.toggle("is-met", satisfied);
      }
      if (balanceEl) {
        balanceEl.textContent = required ? fmtNum(selected - required) : "—";
        balanceEl.classList.toggle("is-negative", required > 0 && selected < required);
      }
    }

    // Clicking anywhere in a row toggles its tick. Clicks landing on the
    // checkbox itself are left alone -- the browser already toggles those, and
    // handling them here as well would undo it and leave the box unchanged.
    rollsContainer?.addEventListener("click", (e) => {
      if (e.target.closest("input[name='selectedRolls']")) return;
      const row = e.target.closest(".roll-table tbody tr");
      if (!row) return;
      const box = row.querySelector("input[name='selectedRolls']");
      if (box && !box.disabled) {
        box.checked = !box.checked;
        // Setting .checked in code fires no change event, so the totals below
        // have to be recomputed here; direct clicks are covered by the listener.
        syncRollSelection();
      }
    });

    rollsContainer?.addEventListener("change", (e) => {
      if (e.target.matches("input[name='selectedRolls']")) syncRollSelection();
    });

    renderRollRows();

    // What this order already had assigned, so re-opening it to edit shows the
    // previous machine/operator/helper/die instead of a blank form. Empty for an
    // order being assigned for the first time.
    const ASSIGNED = <%- safeJson({
      machineId: pendingProduction.assignedMachineId ? String(pendingProduction.assignedMachineId) : "",
      operatorId: pendingProduction.operatorId ? String(pendingProduction.operatorId) : "",
      helperId: pendingProduction.helperId ? String(pendingProduction.helperId) : "",
      bindingId: pendingProduction.productionBindingId ? String(pendingProduction.productionBindingId) : "",
    }) %>;

    // Restore the machine/operator/helper picked last time. Machine is set
    // first (its change handler auto-fills operator/helper by machine code), then
    // operator/helper are set explicitly so a stored pick that differs from the
    // code-based default still wins.
    function restoreAssignment() {
      if (ASSIGNED.machineId) machineChoices.setChoiceByValue(String(ASSIGNED.machineId));
      if (ASSIGNED.operatorId) operatorChoices.setChoiceByValue(String(ASSIGNED.operatorId));
      if (ASSIGNED.helperId) helperChoices.setChoiceByValue(String(ASSIGNED.helperId));
    }

    if (CANDIDATES.length > 0) {
      // Prefer the binding this order was actually assigned with, so its die and
      // paper come back pre-selected; fall back to the first candidate otherwise.
      const initialCandidateId =
        ASSIGNED.bindingId && CANDIDATES.some((c) => String(c._id) === String(ASSIGNED.bindingId))
          ? ASSIGNED.bindingId
          : CANDIDATES[0]._id;
      applyCandidate(initialCandidateId);
      restoreAssignment();
      if (candidateSelect) {
        // applyCandidate() rewrites the paper fields, so the stock figures have
        // to be re-queried for the newly applied spec. Not called on first load
        // -- the server already rendered the figures for that same candidate.
        candidateSelect.addEventListener("change", function () {
          applyCandidate(this.value);
          refreshPaperStock();
        });
      }
    } else {
      applyDie("");
      restoreAssignment();
    }
  });
</script>
