<% layout('/layout/boilerplate') -%>

<%
  const pp = pendingProduction;
  const item = pp.itemId || {};
  const owner = pp.userId || {};
  const isEmpty = (v) => v === undefined || v === null || (typeof v === "string" && v.trim() === "");
  const dash = (v) => (isEmpty(v) ? "—" : v);
  const fmtDate = (v) => {
    if (!v) return "—";
    const d = new Date(v);
    if (isNaN(d)) return "—";
    return String(d.getDate()).padStart(2, "0") + "/" + String(d.getMonth() + 1).padStart(2, "0") + "/" + d.getFullYear();
  };
  const balance = Math.max((Number(pp.quantity) || 0) - (Number(pp.dispatchedQuantity) || 0), 0);
  const fmtQty = (v) => (Number.isFinite(Number(v)) && v !== '' && v != null)
    ? Number(v).toLocaleString('en-IN')
    : (v || '—');
%>

<div class="contain" style="flex-direction: column; padding: 10px; gap: 14px;">
  <style>
    .ap-head h1 { font-size: 20px; color: #fff; margin: 0; }
    .ap-head .ap-sub { font-size: 13px; color: rgba(255, 255, 255, 0.85); margin-top: 2px; }

    .ap-card {
      width: 100%;
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      /* Not overflow:hidden -- the Die select's Choices.js dropdown lives
         inside this card and needs to overflow it (its own header's rounded
         top corners are handled directly on .ap-card-title below instead). */
      overflow: visible;
    }
    .ap-card-title {
      background: #044a78;
      color: #fff; font-size: 14px; font-weight: 600; letter-spacing: 0.2px;
      padding: 9px 16px; display: flex; align-items: center; justify-content: space-between; gap: 10px;
      border-radius: 9px 9px 0 0;
    }
    .ap-card-title select {
      font-size: 12.5px; padding: 5px 10px; border-radius: 6px; border: none; color: #044a78; font-weight: 600; cursor: pointer;
    }
    .ap-card .choices__list--dropdown {
      z-index: 60;
    }
    /* The Die select's Choices.js box was rendering shorter than the plain
       text inputs beside it (common.css zeroes out .choices__inner's
       min-height/padding for compactness elsewhere) -- match their height
       here specifically. */
    #die-field-wrap .choices__inner {
      min-height: 2.3rem;
      padding: 0.375rem 0.5rem;
      display: flex;
      align-items: center;
    }
    #die-field-wrap .choices__list--single {
      padding: 0;
    }
    /* The in-dropdown search box (.choices__input) was rendering with no
       padding -- force it explicitly since something in the cascade is
       stripping the default Choices.js 10px. */
    #die-field-wrap .choices__input {
      padding: 10px !important;
      box-sizing: border-box !important;
    }

    .ap-table-wrap { overflow-x: auto; border: 1px solid #e5e7eb; border-radius: 8px; }
    .ap-table { width: 100%; border-collapse: collapse; font-size: 13px; table-layout: fixed; }
    .ap-table th, .ap-table td { padding: 8px 14px; border-bottom: 1px solid #e5e7eb; border-right: 1px solid #e5e7eb; text-align: left; }
    .ap-table tr > *:last-child { border-right: none; }
    .ap-table th { background: #f8fafc; color: #044a78; font-weight: 700; white-space: nowrap; width: 10%; }
    .ap-table td { color: #1f2a44; font-weight: 600; word-break: break-word; }

    .ap-notice {
      background: #fff8e1; border: 1px solid #f0c36d; color: #7a5b00; border-radius: 8px;
      padding: 10px 14px; font-size: 13px; display: flex; align-items: center; gap: 8px;
    }

    .ap-form-card {
      width: 100%; background: #fff; border-radius: 10px;
      border: 1px solid #e2e8f0; padding: 16px 18px; display: flex; flex-direction: column; gap: 14px;
    }
    .ap-form-title { display: flex; align-items: center; gap: 8px; font-size: 15px; font-weight: 700; color: #044a78; }
    .ap-form-field { max-width: 460px; display: flex; flex-direction: column; gap: 6px; }
    .ap-form-field label { font-size: 13px; font-weight: 600; color: #374151; }
    .ap-submit-btn {
      align-self: flex-start; background: #044a78; color: #fff; border: none; border-radius: 8px;
      padding: 10px 22px; font-size: 14.5px; font-weight: 600; cursor: pointer; transition: opacity 0.2s;
    }
    .ap-submit-btn:hover { opacity: 0.88; }

    /* Auto-generated read-only field (e.g. Lot No) — matches jobCardForm style */
    .jc-readonly {
      background: #f0f7ff !important;
      color: #044a78 !important;
      font-weight: 700 !important;
      cursor: default !important;
    }

    /* Inputs & selects inside span-* boxes on this page need explicit padding
       because the global * { padding: 0 } reset in common.css strips Bootstrap's
       .form-control padding when the elements live outside a real <form> tag.
       Values match the label master form (common.css .form-control baseline). */
    .span-three input.form-control, .span-four input.form-control, .span-five input.form-control,
    .span-six input.form-control, .span-seven input.form-control, .span-eight input.form-control,
    .span-dual input.form-control,
    .span-three input.input-tag, .span-four input.input-tag, .span-five input.input-tag,
    .span-six input.input-tag, .span-seven input.input-tag, .span-eight input.input-tag,
    .span-dual input.input-tag {
      padding: 0.375rem 0.5rem !important;
      font-size: 1rem !important;
      height: auto !important;
      width: 100%;
    }
    .span-three select.form-control, .span-four select.form-control, .span-five select.form-control,
    .span-six select.form-control, .span-seven select.form-control, .span-eight select.form-control,
    .span-dual select.form-control,
    .span-three select.select-tag, .span-four select.select-tag, .span-five select.select-tag,
    .span-six select.select-tag, .span-seven select.select-tag, .span-eight select.select-tag,
    .span-dual select.select-tag {
      padding: 0.375rem 0.5rem !important;
      font-size: 1rem !important;
      height: auto !important;
      width: 100%;
    }
    /* Choices.js wrappers inside any span-* box */
    .span-three .choices__inner, .span-four .choices__inner, .span-five .choices__inner,
    .span-six .choices__inner, .span-seven .choices__inner, .span-eight .choices__inner,
    .span-dual .choices__inner {
      min-height: 2.3rem;
      padding: 0.375rem 0.5rem !important;
      display: flex;
      align-items: center;
    }
    .span-three .choices__list--single, .span-four .choices__list--single,
    .span-five .choices__list--single, .span-six .choices__list--single,
    .span-seven .choices__list--single, .span-eight .choices__list--single,
    .span-dual .choices__list--single {
      padding: 0;
    }
    /* Force the assign form to use the same 32-col grid so Machine / Operator /
       Helper render in a single row (ap-form-card sets flex which stacks them). */
    #assign-form {
      display: grid !important;
      grid-template-columns: repeat(32, 1fr);
      gap: 1rem;
    }
  </style>

  <div class="indi-head ap-head" style="display:flex; align-items:center; justify-content:space-between; gap:14px;">
    <div>
      <h1>Assign Production</h1>
      <div class="ap-sub">
        <%= dash(owner.clientName || item.clientName) %><% if (owner.userName || item.userName) { %> / <%= owner.userName || item.userName %><% } %>
      </div>
    </div>
    <div style="text-align:right; color:#fff; line-height:1.4;">
      <div style="font-size:17px; font-weight:600;">Date: <%= fmtDate(new Date()) %></div>
      <div style="font-size:22px; font-weight:700;">Lot No: <%= previewLotNo %></div>
    </div>
  </div>

  <div class="ap-card">
    <div class="ap-card-title"><span><i class="fa-solid fa-tag"></i> Order Details</span></div>
    <div class="ap-table-wrap">
      <table class="ap-table">
        <tbody>
          <tr>
            <th>PO Number</th><td><%= dash(pp.poNumber) %></td>
            <th>PO Date</th><td><%= fmtDate(poDate) %></td>
            <th>Est. Delivery</th><td><%= fmtDate(pp.estimatedDate) %></td>
          </tr>
          <tr>
            <th>Product ID</th><td><%= dash(item.productId) %></td>
            <th>Width</th><td><%= dash(item.labelWidth) %></td>
            <th>Height</th><td><%= dash(item.labelHeight) %></td>
          </tr>
          <tr>
            <th>Quantity</th><td><%= fmtQty(pp.quantity) %></td>
            <th>Dispatched</th><td><%= fmtQty(pp.dispatchedQuantity || 0) %></td>
            <th>Balance</th><td><%= fmtQty(balance) %></td>
          </tr>
          <tr>
            <th>Job Name</th><td><%= dash(item.jobName) %></td>
            <th>Family</th><td><%= dash(item.labelFamily) %></td>
            <th>Remarks</th><td><%= dash(pp.remarks) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <%
    const apPaperTypes = [...new Set((papers || []).map(p => p.family).filter(Boolean))];
    const apPaperCodes = [...new Set((papers || []).map(p => p.prodCode).filter(Boolean))];
    const apPrefillDieNo = (item && item.dieNo && item.dieNo !== '—') ? item.dieNo : '';
    // Compute bound dies from candidates (same logic as Production Reference card).
    // Only show dies actually linked to this order via a Production Binding;
    // fall back to the full master list only when no binding exists yet.
    const apBoundDies = [];
    const apSeenDieIds = new Set();
    candidates.forEach((c) => {
      if (!c.die) return;
      const sid = String(c.die._id);
      if (apSeenDieIds.has(sid)) return;
      apSeenDieIds.add(sid);
      apBoundDies.push(c.die);
    });
    const apDieOptions = apBoundDies;
  %>

  <div class="ap-card" style="overflow: visible;">
    <div class="ap-card-title">
      <span><i class="fa-solid fa-clipboard-list"></i> Job Card Details</span>
    </div>
    <div style="display: grid; grid-template-columns: repeat(32, 1fr); gap: 1rem; padding: 1rem; border: none; border-radius: 0; background: transparent;">

      <div class="span-three" style="display: none;">
        <label for="jcd-date">Date</label>
        <input type="date" id="jcd-date" name="date" form="assign-form" class="form-control input-tag"
               value="<%= new Date().toISOString().slice(0,10) %>" required />
      </div>

      <div class="span-three" style="display: none;">
        <label for="jcd-lot-no">Lot No</label>
        <input type="text" id="jcd-lot-no" name="lotNo" form="assign-form" class="form-control input-tag jc-readonly"
               value="<%= previewLotNo %>" readonly />
      </div>

      <div class="span-three" style="display: none;">
        <label for="jcd-quantity">Quantity</label>
        <input type="text" id="jcd-quantity" class="form-control input-tag"
               value="<%= pp.quantity ? fmtQty(pp.quantity) : '' %>" placeholder="Enter quantity"
               oninput="this.nextElementSibling.value=this.value.replace(/,/g,'')" />
        <input type="hidden" name="jcdQuantity" form="assign-form" value="<%= pp.quantity || '' %>" />
      </div>

      <div class="span-four" style="display: none;">
        <label for="jcd-product-id">Product ID</label>
        <input type="text" id="jcd-product-id" name="productId" form="assign-form" class="form-control input-tag"
               value="<%= dash(item.productId) !== '—' ? item.productId : '' %>" placeholder="Enter product ID" />
      </div>

      <div class="span-three" style="display: none;">
        <label for="jcd-width">Width</label>
        <input type="text" id="jcd-width" name="labelWidth" form="assign-form" class="form-control input-tag"
               value="<%= dash(item.labelWidth) !== '—' ? item.labelWidth : '' %>" placeholder="Width" />
      </div>

      <div class="span-three" style="display: none;">
        <label for="jcd-height">Height</label>
        <input type="text" id="jcd-height" name="labelHeight" form="assign-form" class="form-control input-tag"
               value="<%= dash(item.labelHeight) !== '—' ? item.labelHeight : '' %>" placeholder="Height" />
      </div>

      <div class="span-full form-subheading" style="grid-column: 1 / -1; margin: 0;">
        <h1>Paper Details</h1>
      </div>

      <div class="span-six">
        <label for="jcd-paper-type">Family</label>
        <input type="text" id="jcd-paper-type" name="jcdPaperType" form="assign-form" class="form-control input-tag"
               list="jcd-paper-type-options" placeholder="Family" autocomplete="off" value="<%= candidates[0]?.prodPaperFamily || candidates[0]?.prodPaperType || item.labelFamily || item.paperType || '' %>" />
        <datalist id="jcd-paper-type-options">
          <% apPaperTypes.forEach(t => { %><option value="<%= t %>"><% }); %>
        </datalist>
      </div>

      <div class="span-eight">
        <label for="jcd-vendor-name">Vendor Name</label>
        <input type="text" id="jcd-vendor-name" name="jcdVendorName" form="assign-form" class="form-control input-tag"
               value="<%= candidates[0]?.prodVendorName || '' %>" placeholder="Vendor name" autocomplete="off" />
      </div>

      <div class="span-six">
        <label for="jcd-paper-code">Paper Code</label>
        <input type="text" id="jcd-paper-code" name="jcdPaperCode" form="assign-form" class="form-control input-tag"
               list="jcd-paper-code-options" placeholder="Paper code" autocomplete="off" value="<%= candidates[0]?.prodPaperCode || '' %>" />
        <datalist id="jcd-paper-code-options">
          <% apPaperCodes.forEach(c => { %><option value="<%= c %>"><% }); %>
        </datalist>
      </div>

      <div class="span-six">
        <label for="jcd-paper-size">Paper Size</label>
        <input type="text" id="jcd-paper-size" name="jcdPaperSize" form="assign-form" class="form-control input-tag"
               placeholder="Paper size" value="<%= candidates[0]?.prodPaperSize || '' %>" />
      </div>

      <div class="span-six">
        <label for="jcd-rolls">No. of Rolls <span style="font-weight:400; font-size:11px; color:#9ca3af;">(for <%= fmtQty(balance) %> labels)</span></label>
        <input type="text" id="jcd-rolls" name="rolls" form="assign-form" class="form-control input-tag jc-readonly"
               placeholder="Select a die" readonly />
      </div>

    </div>
  </div>

  <div class="ap-card">
    <div class="ap-card-title">
      <span><i class="fa-solid fa-industry"></i> Die Details</span>
    </div>
    <div style="padding: 4px 0 0 0;">
      <% if (candidates.length === 0) { %>
      <div class="ap-notice" style="margin: 10px 16px 0;">
        <i class="fa-solid fa-circle-info"></i>
        No production binding found for this client/label — select a die and paper below to continue.
      </div>
      <% } %>
      <%
        const firstCandidate = candidates[0] || {};
        const boundDies = [];
        const seenDieIds = new Set();
        candidates.forEach((c) => {
          if (!c.die) return;
          const dieIdStr = String(c.die._id);
          if (seenDieIds.has(dieIdStr)) return;
          seenDieIds.add(dieIdStr);
          boundDies.push(c.die);
        });
        const dieOptions = boundDies.length ? boundDies : (dies || []);
        const dieLabel = (d) => [
          (d.dieWidth != null && d.dieHeight != null) ? `${d.dieWidth} x ${d.dieHeight}` : '',
          d.dieTotalUps != null ? `${d.dieTotalUps}ups` : '',
          d.dieType || '',
        ].filter(Boolean).join(' - ');
      %>
      <div style="display: grid; grid-template-columns: repeat(32, 1fr); gap: 1rem; padding: 1rem; border: none; border-radius: 0; background: transparent;">
        <div class="span-eight" id="die-field-wrap">
          <label for="manual-die-select">Die</label>
          <select id="manual-die-select" name="dieId" form="assign-form" class="form-control select-tag">
            <option value="" disabled hidden>Select die</option>
            <% dieOptions.forEach(d => { %>
              <option value="<%= d._id %>"
                      data-across="<%= d.dieFlatAcross || '' %>"
                      data-repgap="<%= d.dieFlatrepGap || '' %>"
                      data-dieno="<%= d.dieDieNo || '' %>"
                      data-width="<%= d.dieWidth || '' %>"
                      data-height="<%= d.dieHeight || '' %>"
                      data-acrossgap="<%= d.dieFlatAcrossGap || '' %>"
                      data-totalups="<%= d.dieTotalUps || '' %>"
                      <%= (dieOptions.length === 1 || (firstCandidate.die && String(firstCandidate.die._id) === String(d._id))) ? 'selected' : '' %>><%= dieLabel(d) %></option>
            <% }) %>
          </select>
        </div>
        <!-- Still submitted to the backend (ProductionBinding paper spec) but no
             longer shown in this card -- kept in sync with the visible "Paper
             Details" fields above (jcd-paper-code / jcd-paper-type / jcd-paper-size). -->
        <div style="display:none;">
          <input type="text" id="manual-paper-code" name="paperCode" form="assign-form" value="<%= firstCandidate.prodPaperCode || '' %>" />
          <datalist id="manual-paper-code-options">
            <% [...new Set((papers || []).map(p => p.prodCode).filter(Boolean))].forEach(pc => { %><option value="<%= pc %>"></option><% }) %>
          </datalist>
          <input type="text" id="manual-paper-type" name="paperFamily" form="assign-form" value="<%= firstCandidate.prodPaperFamily || firstCandidate.prodPaperType || item.labelFamily || item.paperType || '' %>" />
          <datalist id="manual-paper-type-options">
            <% [...new Set((papers || []).map(p => p.family).filter(Boolean))].forEach(pt => { %><option value="<%= pt %>"></option><% }) %>
          </datalist>
          <input type="text" id="manual-paper-gsm" name="paperGsm" form="assign-form" value="<%= firstCandidate.prodPaperGsm || '' %>" />
          <input type="text" id="manual-paper-size" name="paperSize" form="assign-form" value="<%= firstCandidate.prodPaperSize || '' %>" />
        </div>

        <div class="span-four">
          <label for="die-detail-no">Die No</label>
          <input type="text" id="die-detail-no" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
        <div class="span-four">
          <label for="die-detail-width">Width</label>
          <input type="text" id="die-detail-width" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
        <div class="span-four">
          <label for="die-detail-height">Height</label>
          <input type="text" id="die-detail-height" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
        <div class="span-four">
          <label for="die-detail-across-gap">Across Gap</label>
          <input type="text" id="die-detail-across-gap" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
        <div class="span-four">
          <label for="die-detail-repeat-gap">Repeat Gap</label>
          <input type="text" id="die-detail-repeat-gap" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
        <div class="span-four">
          <label for="die-detail-total-ups">Total Ups</label>
          <input type="text" id="die-detail-total-ups" class="form-control input-tag jc-readonly" placeholder="—" readonly />
        </div>
      </div>
      <div style="padding: 0 1rem 1rem;" id="reference-body-wrap">
        <div id="reference-body" class="ap-table-wrap"></div>
        <div id="no-die-notice" class="ap-notice" style="display: none;">
          <i class="fa-solid fa-triangle-exclamation"></i>
          Select a die to see which machines are eligible.
        </div>
        <div id="no-machine-notice" class="ap-notice" style="display: none;">
          <i class="fa-solid fa-triangle-exclamation"></i>
          No machines are bound to this die yet — add a Machine Binding first.
        </div>
      </div>
    </div>
  </div>

  <form id="assign-form" class="ap-form-card needs-validation" action="/fairtech/labels/production/assign/<%= pp._id %>" method="post" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <div class="span-dual" style="grid-column: span 11;">
      <label for="machine-select">Machine</label>
      <select id="machine-select" name="machineId" class="form-control select-tag" required>
        <option value="" disabled selected hidden>Select Machine</option>
      </select>
    </div>

    <div class="span-dual" style="grid-column: span 11;">
      <label for="operator-select">Operator</label>
      <select id="operator-select" name="operatorId" class="form-control select-tag">
        <option value="" selected>Select Operator</option>
        <% operatorEmployees.forEach((emp) => { %>
          <option value="<%= emp._id %>"><%= emp.empName %></option>
        <% }) %>
      </select>
    </div>

    <div class="span-dual" style="grid-column: span 10;">
      <label for="helper-select">Helper</label>
      <select id="helper-select" name="helperId" class="form-control select-tag">
        <option value="" selected>Select Helper</option>
        <% helperEmployees.forEach((emp) => { %>
          <option value="<%= emp._id %>"><%= emp.empName %></option>
        <% }) %>
      </select>
    </div>

    <div class="btn-grp span-full">
      <button type="submit">Assign &amp; Continue to Confirm</button>
    </div>
  </form>
</div>

<script id="candidates-data" type="application/json"><%- safeJson(candidates) %></script>
<script id="all-machines-data" type="application/json"><%- safeJson(allMachines) %></script>
<script id="die-machine-bindings-data" type="application/json"><%- safeJson(dieMachineBindings || []) %></script>
<script src="/js/choices.min.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const CANDIDATES = JSON.parse(document.getElementById("candidates-data").textContent);
    const ALL_MACHINES = JSON.parse(document.getElementById("all-machines-data").textContent);
    const DIE_MACHINE_BINDINGS = JSON.parse(document.getElementById("die-machine-bindings-data")?.textContent || "[]");
    const manualDieSelect = document.getElementById("manual-die-select");

    const machineSelectEl = document.getElementById("machine-select");
    const referenceBody = document.getElementById("reference-body");
    const candidateSelect = document.getElementById("candidate-select");
    const noMachineNotice = document.getElementById("no-machine-notice");
    const noDieNotice = document.getElementById("no-die-notice");
    const submitBtn = document.querySelector(".ap-submit-btn");

    // A die must be bound before a machine can be assigned — toggles the
    // machine select + submit button together so the form can't be forced.
    function setAssignable(allowed) {
      machineSelectEl.disabled = !allowed;
      if (submitBtn) {
        submitBtn.disabled = !allowed;
        submitBtn.style.opacity = allowed ? "1" : "0.5";
        submitBtn.style.cursor = allowed ? "pointer" : "not-allowed";
      }
    }

    const machineChoices = new Choices(machineSelectEl, { searchEnabled: true, shouldSort: false, itemSelectText: "" });
    new Choices(document.getElementById("operator-select"), { searchEnabled: true, shouldSort: false, itemSelectText: "" });
    new Choices(document.getElementById("helper-select"), { searchEnabled: true, shouldSort: false, itemSelectText: "" });

    const machineLabel = (m) => `${m.machineName} — ${m.location?.locationName || "?"} (${m.machineType})`;

    function setMachineOptions(machines) {
      const options = machines.map((m) => ({ value: m._id, label: machineLabel(m) }));
      machineChoices.clearStore();
      machineChoices.setChoices(
        [{ value: "", label: "Select Machine", disabled: true, selected: true }, ...options],
        "value", "label", true,
      );
    }

    function dash(v) {
      return v === undefined || v === null || v === "" ? "—" : v;
    }

    // Renders label/value pairs as a real table, 3 pairs (6 cells) per row —
    // matches the .pcd-table / .diff-table convention used elsewhere in the app.
    function kvTable(pairs) {
      const perRow = 3;
      let rows = "";
      for (let i = 0; i < pairs.length; i += perRow) {
        const chunk = pairs.slice(i, i + perRow);
        while (chunk.length < perRow) chunk.push(["", ""]);
        rows += "<tr>" + chunk.map(([k, v]) => (k === "" ? "<th></th><td></td>" : `<th>${k}</th><td>${dash(v)}</td>`)).join("") + "</tr>";
      }
      return `<table class="ap-table"><tbody>${rows}</tbody></table>`;
    }

    function renderReference(candidate) {
      if (!candidate) {
        referenceBody.innerHTML = "";
        return;
      }
      // Die/Paper themselves are shown as the editable fields above now --
      // this table is just supplementary context (block/vendor) for whichever
      // candidate is currently applied.
      const pairs = [];
      if (candidate.block) {
        const b = candidate.block;
        pairs.push(
          ["Block No", b.blockNo],
          ["Block Machine Type / No", `${dash(b.blockMachineType)} / ${dash(b.blockMachineNo)}`],
          ["Front / Back Color", `${dash(b.blockFrontColor)} / ${dash(b.blockBackColor)}`],
        );
      }
      referenceBody.innerHTML = pairs.length ? kvTable(pairs) : "";
    }

    // Prefer a matching candidate's richer machineIds (covers block-driven and
    // named-machine-fallback bindings, not just direct Machine Bindings) --
    // otherwise fall back to a plain die -> machine lookup for a manually
    // picked die that isn't part of any existing Production Binding.
    function computeEligibleMachines(dieId) {
      const matchingCandidate = CANDIDATES.find((c) => c.die && String(c.die._id) === String(dieId));
      if (matchingCandidate) {
        return ALL_MACHINES.filter((m) => matchingCandidate.machineIds.includes(String(m._id)));
      }
      const eligibleIds = DIE_MACHINE_BINDINGS
        .filter((b) => String(b.die) === String(dieId))
        .map((b) => String(b.machine));
      return ALL_MACHINES.filter((m) => eligibleIds.includes(String(m._id)));
    }

    // No. of Rolls: repeat length x = (Label Height + Label Gap, mm) / 1000
    // (metres per repeat down the web); a standard roll holds 1000m of
    // running length, so capacity-per-roll = (1000 / x) x Across Ups labels.
    // Rolls needed = remaining order balance / capacity-per-roll, rounded UP.
    const STANDARD_ROLL_METERS = 1000;
    const balanceQty = <%= balance %>;
    const labelHeightMm = <%= Number(item.labelHeight) || 0 %>;
    const labelGapMm = <%= Number(item.labelGap) || 0 %>;
    // Fallback family when a matching Production Binding exists but its own
    // paper-family fields were never filled in -- mirrors the server-rendered
    // initial value so applyCandidate() doesn't clobber it with a blank.
    const ITEM_LABEL_FAMILY = <%- JSON.stringify(item.labelFamily || item.paperType || "") %>;
    const rollsInput = document.getElementById("jcd-rolls");
    function updateRolls(dieId) {
      if (!rollsInput) return;
      const option = dieId ? manualDieSelect.querySelector(`option[value="${dieId}"]`) : null;
      const across = Number(option?.dataset.across);
      const repeatLengthM = (labelHeightMm + labelGapMm) / 1000;
      if (!option || !across || !balanceQty || !repeatLengthM) {
        rollsInput.value = "";
        return;
      }
      const capacityPerRoll = (STANDARD_ROLL_METERS / repeatLengthM) * across;
      rollsInput.value = String(Math.ceil(balanceQty / capacityPerRoll));
    }

    const dieDetailFields = {
      no: document.getElementById("die-detail-no"),
      width: document.getElementById("die-detail-width"),
      height: document.getElementById("die-detail-height"),
      acrossGap: document.getElementById("die-detail-across-gap"),
      repeatGap: document.getElementById("die-detail-repeat-gap"),
      totalUps: document.getElementById("die-detail-total-ups"),
    };
    function updateDieDetails(dieId) {
      const option = dieId ? manualDieSelect?.querySelector(`option[value="${dieId}"]`) : null;
      dieDetailFields.no.value = option?.dataset.dieno || "";
      dieDetailFields.width.value = option?.dataset.width || "";
      dieDetailFields.height.value = option?.dataset.height || "";
      dieDetailFields.acrossGap.value = option?.dataset.acrossgap || "";
      dieDetailFields.repeatGap.value = option?.dataset.repgap || "";
      dieDetailFields.totalUps.value = option?.dataset.totalups || "";
    }

    function applyDie(dieId) {
      updateRolls(dieId);
      updateDieDetails(dieId);

      if (!dieId) {
        setMachineOptions([]);
        if (noMachineNotice) noMachineNotice.style.display = "none";
        if (noDieNotice) noDieNotice.style.display = "flex";
        setAssignable(false);
        return;
      }
      if (noDieNotice) noDieNotice.style.display = "none";

      const eligible = computeEligibleMachines(dieId);
      setMachineOptions(eligible);
      if (noMachineNotice) noMachineNotice.style.display = eligible.length ? "none" : "flex";
      setAssignable(eligible.length > 0);
    }

    // Pre-fills the editable Die/Paper fields from a candidate for convenience
    // -- the operator can still change any of them before submitting.
    function applyCandidate(candidateId) {
      const candidate = CANDIDATES.find((c) => String(c._id) === String(candidateId)) || CANDIDATES[0];
      renderReference(candidate);

      const dieId = candidate?.die ? String(candidate.die._id) : "";
      if (manualDieChoices && dieId) {
        manualDieChoices.setChoiceByValue(dieId);
      } else if (manualDieSelect) {
        manualDieSelect.value = dieId;
      }
      const candidateFamily = candidate?.prodPaperFamily || candidate?.prodPaperType || ITEM_LABEL_FAMILY;
      document.getElementById("manual-paper-code").value = candidate?.prodPaperCode || "";
      document.getElementById("manual-paper-type").value = candidateFamily;
      document.getElementById("manual-paper-gsm").value = candidate?.prodPaperGsm || "";
      document.getElementById("manual-paper-size").value = candidate?.prodPaperSize || "";
      document.getElementById("jcd-vendor-name").value = candidate?.prodVendorName || "";
      document.getElementById("jcd-paper-type").value = candidateFamily;
      document.getElementById("jcd-paper-code").value = candidate?.prodPaperCode || "";
      document.getElementById("jcd-paper-size").value = candidate?.prodPaperSize || "";

      applyDie(dieId);
    }

    let manualDieChoices = null;
    if (manualDieSelect) {
      manualDieChoices = new Choices(manualDieSelect, { searchEnabled: true, shouldSort: false, itemSelectText: "" });
      manualDieSelect.addEventListener("change", function () { applyDie(this.value); });
    }

    if (CANDIDATES.length > 0) {
      applyCandidate(CANDIDATES[0]._id);
      if (candidateSelect) {
        candidateSelect.addEventListener("change", function () { applyCandidate(this.value); });
      }
    } else {
      applyDie("");
    }
  });
</script>
