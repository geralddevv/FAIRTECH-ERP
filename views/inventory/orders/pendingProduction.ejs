<% layout('/layout/boilerplate') %>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />

<style>
  @keyframes detailsPopIn {
    0% { transform: scale(0.96); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  @keyframes popIn {
    0% { transform: scale(0.9); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  .tape-details-card {
    position: relative;
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 18px 42px rgba(4, 74, 120, 0.14);
    border: none;
    overflow: hidden;
  }
  .details-scroll-area { max-height: calc(100vh - 48px); overflow-y: auto; padding-bottom: 20px; }
  .tape-details-header {
    display: flex; justify-content: space-between; gap: 16px; align-items: flex-start;
    padding: 26px 26px 24px;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.16), transparent 34%),
      linear-gradient(135deg, #044a78 0%, #03365a 100%);
    color: #fff;
  }
  .tape-details-header h1 { margin: 0; font-size: 27px; font-weight: 700; letter-spacing: 0.2px; line-height: 1.15; }
  .header-subtitle { margin-top: 10px; font-size: 14px; opacity: 0.92; line-height: 1.5; }
  .header-actions { display: inline-flex; align-items: center; gap: 10px; flex-wrap: wrap; justify-content: flex-end; }
  .header-action-link {
    display: inline-flex; align-items: center; gap: 8px; padding: 9px 14px; border-radius: 999px;
    background: rgba(255, 255, 255, 0.14); border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff; text-decoration: none; font-weight: 700; font-size: 13px; letter-spacing: 0.2px;
    backdrop-filter: blur(8px); transition: background 0.18s ease;
  }
  .tape-details-body { padding: 20px 26px; }
  .section-title { margin: 0 0 14px; color: #044a78; font-size: 17px; font-weight: 700; }
  .diff-table { width: 100%; border-collapse: collapse; border: 1px solid #e6eaf2; border-radius: 12px; overflow: hidden; }
  .diff-table th, .diff-table td { padding: 10px 12px; border-bottom: 1px solid #e6eaf2; text-align: left; font-size: 13px; vertical-align: top; }
  .diff-table .key-col { width: 32%; color: #5a6586; font-weight: 600; }
  .diff-table .resolved { font-weight: 700; color: #1f2a44; }

  .btn-action {
    height: 24px; padding: 2px 10px; color: white; border: none; border-radius: 4px; cursor: pointer;
    font-size: 11px; transition: opacity 0.2s; display: inline-flex; align-items: center; gap: 4px; font-weight: 600;
  }
  .btn-action:hover { opacity: 0.85; }
  #custom-dialog-no:hover { background: #f3f4f6; }
  #custom-dialog-yes:hover { opacity: 0.9; }
  #cancel-reason-input:focus { outline: none; border-color: #044a78; box-shadow: 0 0 0 2px rgba(26, 26, 46, 0.1); }
</style>

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <div class="indi-head">
    <h1>Pending Production</h1>
    <div class="download-btns" style="display: flex; gap: 10px; align-items: center">
      <a
        href="/fairtech/sales/order"
        style="padding: 6px 14px; background: #044a78; color: white; border-radius: 6px; text-decoration: none; font-size: 14px; font-weight: 500; display: inline-flex; align-items: center; gap: 6px;"
        onmouseover="this.style.opacity = '0.85'" onmouseout="this.style.opacity = '1'"
      >
        <i class="fa-solid fa-plus"></i><span>New Label Order</span>
      </a>
      <div class="download-selector" id="downloadSelector">
        <button class="download-selector__trigger">
          <span><i class="fa-solid fa-file-arrow-down"></i><span class="download-typo">Download</span></span>
          <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
        </button>
        <div class="download-selector__menu" id="downloads">
          <span class="download-selector__option" id="download-xlsx">
            <i class="fas fa-file-excel download-selector__option-icon"></i><span>Excel</span>
          </span>
        </div>
      </div>
    </div>
  </div>

  <div id="master-table" class="tabulator tabulator-modern"></div>
</div>

<!-- Cancel confirmation dialog -->
<div id="custom-confirm-dialog" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.5); z-index: 9999; justify-content: center; align-items: center;">
  <div style="background: white; border-radius: 8px; width: 440px; max-width: 90%; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2); overflow: hidden; animation: popIn 0.2s ease-out;">
    <div style="padding: 25px 20px; text-align: center">
      <p id="custom-dialog-message" style="margin: 0; color: #333; font-size: 16px; line-height: 1.5">Are you sure?</p>
      <div id="cancel-reason-wrap" style="display: none; margin-top: 15px; text-align: left">
        <label for="cancel-reason-input" style="font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 6px; display: block">Reason for Cancellation <span style="color: #ef4444">*</span></label>
        <textarea id="cancel-reason-input" rows="3" placeholder="Enter reason for cancellation..." style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; resize: none; font-family: inherit; box-sizing: border-box;"></textarea>
      </div>
    </div>
    <div style="padding: 15px 20px; background: #f9fafb; display: flex; justify-content: flex-end; gap: 10px; border-top: 1px solid #e5e7eb;">
      <button id="custom-dialog-no" onclick="closeCustomDialog()" style="padding: 8px 16px; border: 1px solid #d1d5db; background: white; color: #374151; border-radius: 6px; cursor: pointer; font-weight: 500;">Go Back</button>
      <button id="custom-dialog-yes" style="padding: 8px 16px; border: none; background: #ef4444; color: white; border-radius: 6px; cursor: pointer; font-weight: 500;">Yes, Cancel Order</button>
    </div>
  </div>
</div>

<!-- Details dialog -->
<div id="pending-order-details-dialog" style="display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.54); z-index: 10000; justify-content: center; align-items: center; padding: 24px; backdrop-filter: blur(6px);">
  <div id="pending-order-details-body" style="width: min(1180px, 100%); animation: detailsPopIn 0.2s ease-out"></div>
</div>

<!-- Tabulator JS -->
<script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script id="order-data" type="application/json">
  <%- safeJson(orders || []) %>
</script>

<script>
  const orderData = JSON.parse(document.getElementById("order-data").textContent);

  /* ----- Details dialog ----- */
  window.viewProduction = function (orderId) {
    const order = orderData.find((row) => String(row._id) === String(orderId));
    if (!order) return;

    const qty = Number(order.quantity) || 0;
    const produced = Number(order.dispatchedQuantity) || 0;
    const remaining = Math.max(qty - produced, 0);

    document.getElementById("pending-order-details-body").innerHTML = `
      <div class="tape-details-card">
        <div class="details-scroll-area">
          <div class="tape-details-header">
            <div class="header-copy">
              <h1>${order.productId || "Label"}</h1>
              <div class="header-subtitle">${order.clientName || "N/A"}${order.userName ? " | " + order.userName : ""}</div>
            </div>
            <div class="header-actions">
              <span class="header-action-link" style="pointer-events: none;"><i class="fa-solid fa-file-invoice"></i> PO: ${order.poNumber || "N/A"}</span>
              <button onclick="closeOrderDetailsDialog()" class="header-action-link" style="border: none; cursor: pointer;"><i class="fa-solid fa-xmark"></i></button>
            </div>
          </div>
          <div class="tape-details-body">
            <h3 class="section-title">Production Details</h3>
            <table class="diff-table">
              <tbody>
                <tr><td class="key-col">Client</td><td class="resolved">${order.clientName || "N/A"}</td></tr>
                <tr><td class="key-col">User</td><td class="resolved">${order.userName || "N/A"}</td></tr>
                <tr><td class="key-col">Label Product ID</td><td class="resolved">${order.productId || "N/A"}</td></tr>
                <tr><td class="key-col">Job Type</td><td class="resolved">${order.jobType || "N/A"}</td></tr>
                <tr><td class="key-col">Width</td><td class="resolved">${order.labelWidth || "N/A"}</td></tr>
                <tr><td class="key-col">Height</td><td class="resolved">${order.labelHeight || "N/A"}</td></tr>
                <tr><td class="key-col">Paper Type</td><td class="resolved">${order.paperType || "N/A"}</td></tr>
                <tr><td class="key-col">Per Roll Qty</td><td class="resolved">${order.perRollQty || "N/A"}</td></tr>
                <tr><td class="key-col">Order Quantity</td><td class="resolved">${qty}</td></tr>
                <tr><td class="key-col">Produced</td><td class="resolved">${produced}</td></tr>
                <tr><td class="key-col">Remaining</td><td class="resolved">${remaining}</td></tr>
                <tr><td class="key-col">PO Number</td><td class="resolved">${order.poNumber || "N/A"}</td></tr>
                <tr><td class="key-col">Estimated Delivery</td><td class="resolved">${order.estimatedDate ? new Date(order.estimatedDate).toLocaleDateString("en-IN") : "N/A"}</td></tr>
                <tr><td class="key-col">Remarks</td><td class="resolved">${order.remarks || "N/A"}</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    `;
    document.getElementById("pending-order-details-dialog").style.display = "flex";
  };
  window.closeOrderDetailsDialog = () => (document.getElementById("pending-order-details-dialog").style.display = "none");

  /* ----- Mark done -> reuse the sales order confirm / dispatch flow ----- */
  window.markProductionDone = function (orderId) {
    window.location.href = `/fairtech/sales/order/confirm?orderId=${orderId}`;
  };

  /* ----- Cancel ----- */
  window.requestCancel = function (orderId) {
    const dialog = document.getElementById("custom-confirm-dialog");
    const yesBtn = document.getElementById("custom-dialog-yes");
    const msg = document.getElementById("custom-dialog-message");
    document.getElementById("cancel-reason-wrap").style.display = "block";
    msg.textContent = "Are you sure you want to CANCEL this label order?";
    dialog.style.display = "flex";
    yesBtn.onclick = () => {
      const reason = document.getElementById("cancel-reason-input").value.trim();
      if (!reason) { alert("Please provide a reason for cancellation."); return; }
      submitStatusUpdate(orderId, "CANCELLED", reason);
    };
  };
  window.closeCustomDialog = () => (document.getElementById("custom-confirm-dialog").style.display = "none");

  function submitStatusUpdate(orderId, status, reason = "") {
    const form = document.createElement("form");
    form.method = "POST";
    form.action = "/fairtech/sales/order/status";
    const inputs = { orderId, status, cancelReason: reason, _csrf: "<%= csrfToken %>" };
    for (const [name, value] of Object.entries(inputs)) {
      const input = document.createElement("input");
      input.type = "hidden";
      input.name = name;
      input.value = value;
      form.appendChild(input);
    }
    document.body.appendChild(form);
    form.submit();
  }

  /* ----- Table ----- */
  const table = new Tabulator("#master-table", {
    data: orderData,
    placeholder: "No labels pending production",
    initialSort: [{ column: "createdAt", dir: "asc" }],
    columns: [
      {
        title: "Actions",
        hozAlign: "center",
        headerSort: false,
        formatter: (cell) => {
          const row = cell.getRow().getData();
          return `
            <div style="display:flex; gap:6px; justify-content:center; align-items:center;">
              <button onclick="viewProduction('${row._id}')" class="btn-action" style="background:#111827;" title="View Details"><i class="fa-solid fa-eye"></i></button>
              <button onclick="markProductionDone('${row._id}')" class="btn-action" style="background:#10b981;" title="Mark Production Done"><i class="fa-solid fa-check-double"></i></button>
              <button onclick="requestCancel('${row._id}')" class="btn-action" style="background:#ef4444;" title="Cancel Order"><i class="fa-solid fa-xmark"></i></button>
            </div>
          `;
        },
      },
      { title: "Date", field: "createdAt", headerFilter: "input", headerFilterPlaceholder: "Filter date...", formatter: (cell) => new Date(cell.getValue()).toLocaleDateString("en-IN") },
      { title: "Client", field: "clientName", headerFilter: "input", headerFilterPlaceholder: "Filter client...", formatter: (cell) => `<span style="font-weight:600; color:#044A78;">${cell.getValue() || "N/A"}</span>` },
      { title: "User", field: "userName", headerFilter: "input", headerFilterPlaceholder: "Filter user..." },
      { title: "Label ID", field: "productId", headerFilter: "input", headerFilterPlaceholder: "Filter label...", formatter: (cell) => `<span style="font-weight:600; color:#044A78;">${cell.getValue() || "N/A"}</span>` },
      { title: "Job Type", field: "jobType", hozAlign: "center", headerFilter: "input", headerFilterPlaceholder: "Filter..." },
      { title: "Width", field: "labelWidth", hozAlign: "center", headerFilter: "input", headerFilterPlaceholder: "Width" },
      { title: "Height", field: "labelHeight", hozAlign: "center", headerFilter: "input", headerFilterPlaceholder: "Height" },
      { title: "Qty", field: "quantity", hozAlign: "center", headerFilter: "input", headerFilterPlaceholder: "#" },
      {
        title: "Bal",
        hozAlign: "center",
        headerSort: false,
        formatter: (cell) => {
          const row = cell.getRow().getData();
          return `<span style="font-weight:700; color:#044A78;">${row.balance ?? row.quantity}</span>`;
        },
      },
      { title: "PO Number", field: "poNumber", headerFilter: "input", headerFilterPlaceholder: "Filter PO..." },
      { title: "Est. Delivery", field: "estimatedDate", headerFilter: "input", headerFilterPlaceholder: "Filter date...", formatter: (cell) => (cell.getValue() ? new Date(cell.getValue()).toLocaleDateString("en-IN") : "—") },
      { title: "Remarks", field: "remarks", headerFilter: "input", headerFilterPlaceholder: "Filter remarks..." },
    ],
  });

  document.getElementById("download-xlsx").addEventListener("click", () => {
    table.download("xlsx", "pending_production.xlsx", { sheetName: "PendingProduction" });
  });

  const selector = document.getElementById("downloadSelector");
  const trigger = selector.querySelector(".download-selector__trigger");
  trigger.addEventListener("click", (e) => { e.stopPropagation(); selector.classList.toggle("download-selector--active"); });
  document.addEventListener("click", () => selector.classList.remove("download-selector--active"));
</script>
