<% layout('/layout/boilerplate') %>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />

<style>
  .order-highlight {
    padding: 0.3rem 0.85rem;
    border-radius: 0.35rem;
    font-weight: 600;
    font-size: 1.15rem;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.5);
    background-color: rgba(255, 255, 255, 0.12);
    margin-left: 8px;
    display: inline-block;
  }
  .order-highlight.active {
    background-color: rgba(255, 255, 255, 0.18);
  }
  .order-highlight.filtered {
    background-color: rgba(16, 185, 129, 0.22);
    border-color: rgba(255, 255, 255, 0.65);
  }
</style>

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <div class="indi-head">
    <h1>
      Pending Orders
      <span id="table-total-display" class="order-highlight active">Pending Items: ₹0.00</span>
      <span id="filtered-value-display" class="order-highlight filtered" style="display: none">Filtered: ₹0.00</span>
    </h1>
    <div class="download-btns" style="display: flex; gap: 10px; align-items: center">
      <span id="color-label-value-display" class="order-highlight">Color Labels: ₹0.00</span>
      <span id="plain-label-value-display" class="order-highlight">Plain Label: ₹0.00</span>
      <span id="total-value-display" class="order-highlight active">Total: ₹0.00</span>
      <a
        href="/fairtech/sales/order/logs"
        style="
          padding: 6px 14px;
          background: #044a78;
          color: white;
          border-radius: 6px;
          text-decoration: none;
          font-size: 14px;
          font-weight: 500;
          display: inline-flex;
          align-items: center;
          gap: 6px;
          transition: opacity 0.2s;
        "
        onmouseover="this.style.opacity = '0.85'"
        onmouseout="this.style.opacity = '1'"
      >
        <i class="fa-solid fa-clock-rotate-left"></i>
        <span>View Logs</span>
      </a>
      <div class="download-selector" id="downloadSelector">
        <button class="download-selector__trigger">
          <span>
            <i class="fa-solid fa-file-arrow-down"></i>
            <span class="download-typo">Download</span>
          </span>
          <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
        </button>
        <div class="download-selector__menu" id="downloads">
          <span class="download-selector__option" id="download-pdf">
            <i class="fas fa-file-pdf download-selector__option-icon"></i>
            <span>PDF</span>
          </span>
          <span class="download-selector__option" id="download-xlsx">
            <i class="fas fa-file-excel download-selector__option-icon"></i>
            <span>Excel</span>
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="table-spinner"><div class="spinner-circle"></div></div>
  <div id="master-table" class="tabulator tabulator-modern"></div>
</div>

<!-- Tabulator JS -->
<script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script id="order-data" type="application/json">
  <%- safeJson(orders || []) %>
</script>
<script id="label-totals-data" type="application/json">
  <%- safeJson({ labelTotal: labelTotal || 0, colorLabelTotal: colorLabelTotal || 0 }) %>
</script>
<script>
  /* Safe JSON injection */
  const orderData = JSON.parse(document.getElementById("order-data").textContent);
  const labelTotals = JSON.parse(document.getElementById("label-totals-data").textContent);
  const enrichedOrderData = orderData.map((row) => {
    const rate = Number(row.orderRate) || 0;
    const balance = Math.max((Number(row.quantity) || 0) - (Number(row.dispatchedQuantity) || 0), 0);
    return {
      ...row,
      valueAmount: balance * rate,
    };
  });

  /* Dialog references */
  let customDialog, dialogMessage, dialogYes, dialogNo, cancelReasonWrap, cancelReasonInput;
  let detailsDialog, detailsBody, detailsCloseBtn;
  let currentConfirmCallback = null;

  document.addEventListener("DOMContentLoaded", () => {
    customDialog = document.getElementById("custom-confirm-dialog");
    dialogMessage = document.getElementById("custom-dialog-message");
    dialogYes = document.getElementById("custom-dialog-yes");
    dialogNo = document.getElementById("custom-dialog-no");
    cancelReasonWrap = document.getElementById("cancel-reason-wrap");
    cancelReasonInput = document.getElementById("cancel-reason-input");
    detailsDialog = document.getElementById("pending-order-details-dialog");
    detailsBody = document.getElementById("pending-order-details-body");
    detailsCloseBtn = document.getElementById("pending-order-details-close");
    dialogYes.addEventListener("click", () => {
      // Validate reason if cancelling
      if (cancelReasonWrap.style.display !== "none") {
        if (!cancelReasonInput.value.trim()) {
          cancelReasonInput.style.borderColor = "#ef4444";
          cancelReasonInput.placeholder = "Please provide a reason...";
          cancelReasonInput.focus();
          return;
        }
      }
      if (currentConfirmCallback) currentConfirmCallback();
      closeCustomDialog();
    });

    dialogNo.addEventListener("click", closeCustomDialog);
    if (detailsCloseBtn) {
      detailsCloseBtn.addEventListener("click", closeOrderDetailsDialog);
    }
    if (detailsDialog) {
      detailsDialog.addEventListener("click", (event) => {
        if (event.target === detailsDialog) {
          closeOrderDetailsDialog();
        }
      });
    }

    // Enter key support for confirmation
    document.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && customDialog.style.display === "flex") {
        // Prevent triggering if typing in the textarea
        if (e.target !== cancelReasonInput) {
          e.preventDefault();
          dialogYes.click();
        }
      }
    });
  });

  function showCustomConfirm(message, onConfirm, showReason = false) {
    dialogMessage.textContent = message;
    currentConfirmCallback = onConfirm;
    cancelReasonWrap.style.display = showReason ? "block" : "none";
    cancelReasonInput.value = "";
    cancelReasonInput.style.borderColor = "#d1d5db";
    customDialog.style.display = "flex";

    // Auto-focus appropriate element
    setTimeout(() => {
      if (showReason) {
        cancelReasonInput.focus();
      } else {
        dialogYes.focus();
      }
    }, 10);
  }

  function closeCustomDialog() {
    customDialog.style.display = "none";
    currentConfirmCallback = null;
    cancelReasonInput.value = "";
  }

  // Treats null/undefined/empty-string as "no data" -> "-", but preserves a
  // legitimate 0 (e.g. a real rate or quantity of zero isn't "missing").
  function orDash(value) {
    return (value === null || value === undefined || value === "") ? "-" : value;
  }

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function formatDate(value) {
    if (!value) return "-";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return "-";
    return date.toLocaleDateString("en-IN", { year: "numeric", month: "short", day: "2-digit" });
  }

  function getItemType(row) {
    let itemType = "TAPE";
    if (row.onModel === "PosRoll") itemType = "POS_ROLL";
    if (row.onModel === "Tafeta") itemType = "TAFETA";
    if (row.onModel === "Ttr") itemType = "TTR";
    if (row.onModel === "Label") itemType = "LABEL";
    return itemType;
  }

  function getItemName(row) {
    const tape = row.tapeId;
    if (!tape) return "-";
    if (row.onModel === "Tape") {
      if (tape.tapePaperCode) return tape.tapePaperCode;
      if (tape.tapeProductId) return String(tape.tapeProductId);
    }
    if (row.onModel === "PosRoll") {
      if (tape.posPaperCode) return `${tape.posPaperCode} ${tape.posGsm ?? ""}gsm`.trim();
      if (tape.posProductId) return String(tape.posProductId);
    }
    if (row.onModel === "Tafeta") {
      if (tape.tafetaMaterialCode) return `${tape.tafetaMaterialCode} ${tape.tafetaGsm ?? ""}gsm`.trim();
      if (tape.tafetaProductId) return String(tape.tafetaProductId);
    }
    if (row.onModel === "Ttr") {
      if (tape.ttrType) return tape.ttrType;
      if (tape.ttrProductId) return String(tape.ttrProductId);
    }
    if (row.onModel === "Label") {
      if (tape.labelWidth || tape.labelHeight) return `${tape.labelWidth || ""}x${tape.labelHeight || ""}`;
    }
    return "Unknown Item";
  }

  // GSM is only meaningful for Tape, POS Roll and Tafeta rows (TTR/Label have
  // no GSM field at all) — shown as its own column, "-" when not applicable.
  function getItemGsm(row) {
    const tape = row.tapeId;
    if (!tape) return "";
    if (row.onModel === "Tape") return tape.tapeGsm ?? "";
    if (row.onModel === "PosRoll") return tape.posGsm ?? "";
    if (row.onModel === "Tafeta") return tape.tafetaGsm ?? "";
    return "";
  }

  // Client GSM is the per-client-binding GSM (clientTapeGsm/clientPosGsm/
  // clientTafetaGsm on tapeBinding) — distinct from the item's own GSM above.
  // TTR/Label bindings have no client GSM field.
  function getClientGsm(row) {
    const binding = row.tapeBinding;
    if (!binding) return "";
    if (row.onModel === "Tape") return binding.clientTapeGsm ?? "";
    if (row.onModel === "PosRoll") return binding.clientPosGsm ?? "";
    if (row.onModel === "Tafeta") return binding.clientTafetaGsm ?? "";
    return "";
  }

  // Width/Mtrs are only meaningful for Tape and TTR rows — broken out of
  // getItemName() into their own table columns instead of a combined string.
  function getItemWidth(row) {
    const tape = row.tapeId;
    if (!tape) return "";
    if (row.onModel === "Tape") return tape.tapeWidth || "";
    if (row.onModel === "Ttr") return tape.ttrWidth || "";
    return "";
  }

  function getItemMtrs(row) {
    const tape = row.tapeId;
    if (!tape) return "";
    if (row.onModel === "Tape") return tape.tapeMtrs || "";
    if (row.onModel === "Ttr") return tape.ttrMtrs || "";
    return "";
  }

  // Per-field Fairtech vs Client comparison for the item bound to this order —
  // mirrors the item's own /tape|pos|tafeta|ttr/compare/:id page (itemCompare.ejs)
  // field-for-field, minus the Vendor column (this page never shows vendor data).
  // Fairtech values come from the item spec (row.tapeId); Client values come
  // from the client binding (row.tapeBinding) where one exists, otherwise they
  // fall back to the same item spec value (no separate client-negotiated spec).
  function getCompareRows(row) {
    const item = row.tapeId || {};
    const binding = row.tapeBinding || {};

    if (row.onModel === "Tape") {
      return [
        { field: "Paper Code", orgValue: orDash(item.tapePaperCode), clientValue: orDash(binding.tapeClientPaperCode) },
        { field: "GSM", orgValue: orDash(item.tapeGsm), clientValue: orDash(binding.clientTapeGsm) },
        { field: "Paper Type", orgValue: orDash(item.tapePaperType), clientValue: orDash(item.tapePaperType) },
        { field: "Width", orgValue: orDash(item.tapeWidth), clientValue: orDash(item.tapeWidth) },
        { field: "Meters", orgValue: orDash(item.tapeMtrs), clientValue: orDash(item.tapeMtrs) },
        { field: "Core ID", orgValue: orDash(item.tapeCoreId), clientValue: orDash(item.tapeCoreId) },
        { field: "Finish", orgValue: orDash(item.tapeFinish), clientValue: orDash(item.tapeFinish) },
        { field: "Adhesive GSM", orgValue: orDash(item.tapeAdhesiveGsm), clientValue: orDash(item.tapeAdhesiveGsm) },
        { field: "Minimum Qty", orgValue: "-", clientValue: orDash(binding.tapeMinQty) },
        { field: "Order Qty", orgValue: "-", clientValue: orDash(binding.tapeOdrQty) },
        { field: "Order Frequency", orgValue: "-", clientValue: orDash(binding.tapeOdrFreq) },
        { field: "Credit Term", orgValue: "-", clientValue: orDash(binding.tapeCreditTerm) },
        { field: "Rate Per Roll", orgValue: "-", clientValue: orDash(binding.tapeRatePerRoll) },
        { field: "Sale Cost", orgValue: "-", clientValue: orDash(binding.tapeSaleCost) },
        { field: "Meters Delivered", orgValue: "-", clientValue: orDash(binding.tapeMtrsDel) },
        { field: "Binding Status", orgValue: "-", clientValue: orDash(binding.status) },
      ];
    }
    if (row.onModel === "PosRoll") {
      return [
        { field: "Paper Code", orgValue: orDash(item.posPaperCode), clientValue: orDash(binding.posClientPaperCode) },
        { field: "Paper Type", orgValue: orDash(item.posPaperType), clientValue: orDash(item.posPaperType) },
        { field: "Color", orgValue: orDash(item.posColor), clientValue: orDash(item.posColor) },
        { field: "GSM", orgValue: orDash(item.posGsm), clientValue: orDash(binding.clientPosGsm) },
        { field: "Width", orgValue: orDash(item.posWidth), clientValue: orDash(item.posWidth) },
        { field: "Meters", orgValue: orDash(item.posMtrs), clientValue: orDash(item.posMtrs) },
        { field: "Core ID", orgValue: orDash(item.posCoreId), clientValue: orDash(item.posCoreId) },
        { field: "Minimum Qty", orgValue: "-", clientValue: orDash(binding.posMinQty) },
        { field: "Order Qty", orgValue: "-", clientValue: orDash(binding.posOdrQty) },
        { field: "Order Frequency", orgValue: "-", clientValue: orDash(binding.posOdrFreq) },
        { field: "Credit Term", orgValue: "-", clientValue: orDash(binding.posCreditTerm) },
        { field: "Rate Per Roll", orgValue: "-", clientValue: orDash(binding.posRatePerRoll) },
        { field: "Sale Cost", orgValue: "-", clientValue: orDash(binding.posSaleCost) },
        { field: "Meters Delivered", orgValue: "-", clientValue: orDash(binding.posMtrsDel) },
        { field: "Binding Status", orgValue: "-", clientValue: orDash(binding.status) },
      ];
    }
    if (row.onModel === "Tafeta") {
      return [
        { field: "Material Code", orgValue: orDash(item.tafetaMaterialCode), clientValue: orDash(binding.tafetaClientMaterialCode) },
        { field: "Material Type", orgValue: orDash(item.tafetaMaterialType), clientValue: orDash(binding.tafetaClientMaterialType) },
        { field: "Color", orgValue: orDash(item.tafetaColor), clientValue: orDash(item.tafetaColor) },
        { field: "GSM", orgValue: orDash(item.tafetaGsm), clientValue: orDash(binding.clientTafetaGsm) },
        { field: "Width", orgValue: orDash(item.tafetaWidth), clientValue: orDash(item.tafetaWidth) },
        { field: "Meters", orgValue: orDash(item.tafetaMtrs), clientValue: orDash(item.tafetaMtrs) },
        { field: "Core Length", orgValue: orDash(item.tafetaCoreLen), clientValue: orDash(item.tafetaCoreLen) },
        { field: "Notch", orgValue: orDash(item.tafetaNotch), clientValue: orDash(item.tafetaNotch) },
        { field: "Core ID", orgValue: orDash(item.tafetaCoreId), clientValue: orDash(item.tafetaCoreId) },
        { field: "Minimum Qty", orgValue: "-", clientValue: orDash(binding.tafetaMinQty) },
        { field: "Order Qty", orgValue: "-", clientValue: orDash(binding.tafetaOdrQty) },
        { field: "Order Frequency", orgValue: "-", clientValue: orDash(binding.tafetaOdrFreq) },
        { field: "Credit Term", orgValue: "-", clientValue: orDash(binding.tafetaCreditTerm) },
        { field: "Rate Per Roll", orgValue: "-", clientValue: orDash(binding.tafetaRatePerRoll) },
        { field: "Sale Cost", orgValue: "-", clientValue: orDash(binding.tafetaSaleCost) },
        { field: "Meters Delivered", orgValue: "-", clientValue: orDash(binding.tafetaMtrsDel) },
        { field: "Binding Status", orgValue: "-", clientValue: orDash(binding.status) },
      ];
    }
    if (row.onModel === "Ttr") {
      return [
        { field: "Material Code", orgValue: orDash(item.ttrMaterialCode), clientValue: orDash(binding.ttrClientMaterialCode) },
        { field: "Type", orgValue: orDash(item.ttrType), clientValue: orDash(binding.clientTtrType) },
        { field: "Color", orgValue: orDash(item.ttrColor), clientValue: orDash(item.ttrColor) },
        { field: "Ink Face", orgValue: orDash(item.ttrInkFace), clientValue: orDash(item.ttrInkFace) },
        { field: "Width", orgValue: orDash(item.ttrWidth), clientValue: orDash(item.ttrWidth) },
        { field: "Meters", orgValue: orDash(item.ttrMtrs), clientValue: orDash(item.ttrMtrs) },
        { field: "Core ID", orgValue: orDash(item.ttrCoreId), clientValue: orDash(item.ttrCoreId) },
        { field: "Core Length", orgValue: orDash(item.ttrCoreLength), clientValue: orDash(item.ttrCoreLength) },
        { field: "Notch", orgValue: orDash(item.ttrNotch), clientValue: orDash(item.ttrNotch) },
        { field: "Winding", orgValue: orDash(item.ttrWinding), clientValue: orDash(item.ttrWinding) },
        { field: "Minimum Qty", orgValue: "-", clientValue: orDash(binding.ttrMinQty) },
        { field: "Minimum Order Qty", orgValue: "-", clientValue: orDash(binding.ttrOdrQty) },
        { field: "Order Frequency", orgValue: "-", clientValue: orDash(binding.ttrOdrFreq) },
        { field: "Credit Term", orgValue: "-", clientValue: orDash(binding.ttrCreditTerm) },
        { field: "Rate Per Roll", orgValue: "-", clientValue: orDash(binding.ttrRatePerRoll) },
        { field: "Sale Cost", orgValue: "-", clientValue: orDash(binding.ttrSaleCost) },
        { field: "Meters Delivered", orgValue: "-", clientValue: orDash(binding.ttrMtrsDel) },
        { field: "Binding Status", orgValue: "-", clientValue: orDash(binding.status) },
      ];
    }
    return [];
  }

  function closeOrderDetailsDialog() {
    if (detailsDialog) detailsDialog.style.display = "none";
  }

  window.viewPendingOrder = function (orderId) {
    const order = orderData.find((row) => String(row._id) === String(orderId));
    if (!order || !detailsDialog || !detailsBody) return;

    const itemType = getItemType(order);
    const itemName = getItemName(order);
    const client = order.userId?.clientName || "-";
    const user = order.userId?.userName || "-";
    const sourceLocation = order.sourceLocation || "-";
    const poNumber = order.poNumber || "-";
    const remarks = order.remarks || "-";
    const orderRate = orDash(order.orderRate);
    const quantity = Number(order.quantity) || 0;
    const dispatched = Number(order.dispatchedQuantity) || 0;
    const remaining = Math.max(quantity - dispatched, 0);

    detailsBody.innerHTML = `
      <div class="tape-details-card">
        <div class="details-scroll-area">
          <div class="tape-details-header">
            <div class="header-copy">
              <h1>${escapeHtml(itemName)}</h1>
              <div class="header-subtitle">${escapeHtml(client)} | ${escapeHtml(user)}</div>
            </div>
            <div class="header-actions">
              <span class="header-action-link" style="pointer-events: none;">
                <i class="fa-solid fa-box"></i>
                ${escapeHtml(itemType)}
              </span>
              <button
                id="pending-order-details-close"
                type="button"
                class="header-action-link"
                onclick="closeOrderDetailsDialog()"
                style="border: none; cursor: pointer; font-weight: 700;"
                aria-label="Close dialog"
                title="Close dialog"
              >
                <i class="fa-solid fa-xmark"></i>
              </button>
            </div>
          </div>

          <div class="tape-details-body">
            <div class="details-list-scroll">
              <h3 class="section-title">Order Details</h3>
              <table class="kv-table">
                <tbody>
                  <tr><td class="kv-label">Item Type</td><td class="kv-value">${escapeHtml(itemType)}</td></tr>
                  <tr><td class="kv-label">Client</td><td class="kv-value">${escapeHtml(client)}</td></tr>
                  <tr><td class="kv-label">User</td><td class="kv-value">${escapeHtml(user)}</td></tr>
                  <tr><td class="kv-label">Source Location</td><td class="kv-value">${escapeHtml(sourceLocation)}</td></tr>
                  <tr><td class="kv-label">PO Number</td><td class="kv-value">${escapeHtml(poNumber)}</td></tr>
                  <tr><td class="kv-label">Quantity</td><td class="kv-value">${escapeHtml(quantity)}</td></tr>
                  <tr><td class="kv-label">Dispatched</td><td class="kv-value">${escapeHtml(dispatched)}</td></tr>
                  <tr><td class="kv-label">Remaining</td><td class="kv-value">${escapeHtml(remaining)}</td></tr>
                  <tr><td class="kv-label">Order Rate</td><td class="kv-value">${escapeHtml(orderRate)}</td></tr>
                  <tr><td class="kv-label">Estimated Date</td><td class="kv-value">${escapeHtml(formatDate(order.estimatedDate))}</td></tr>
                  <tr>
                    <td class="kv-label">Remarks</td>
                    <td class="kv-value ${remarks === "-" ? "muted" : ""}" style="white-space: pre-wrap; line-height: 1.6;">${escapeHtml(remarks)}</td>
                  </tr>
                </tbody>
              </table>

              ${getCompareRows(order).length ? `
              <h3 class="section-title" style="margin-top: 20px;">Fairtech vs Client Comparison</h3>
              <table class="diff-table">
                <thead>
                  <tr>
                    <th class="key-col">Field</th>
                    <th>Fairtech</th>
                    <th>Client</th>
                  </tr>
                </thead>
                <tbody>
                  ${getCompareRows(order).map((r) => `
                  <tr>
                    <td class="key-col">${escapeHtml(r.field)}</td>
                    <td class="resolved">${escapeHtml(r.orgValue)}</td>
                    <td class="resolved">${escapeHtml(r.clientValue)}</td>
                  </tr>`).join("")}
                </tbody>
              </table>` : ""}
            </div>
          </div>
        </div>
        </div>
    `;

    detailsDialog.style.display = "flex";
  };

  // Handler for cancel request
  window.requestCancel = function (orderId) {
    dialogYes.style.background = "#ef4444";
    dialogYes.textContent = "Yes, Cancel Order";

    showCustomConfirm(
      "Are you sure you want to CANCEL this order? This cannot be undone.",
      () => {
        const form = document.createElement("form");
        form.method = "POST";
        form.action = "/fairtech/sales/order/status";

        const idInput = document.createElement("input");
        idInput.type = "hidden";
        idInput.name = "orderId";
        idInput.value = orderId;
        form.appendChild(idInput);

        const statusInput = document.createElement("input");
        statusInput.type = "hidden";
        statusInput.name = "status";
        statusInput.value = "CANCELLED";
        form.appendChild(statusInput);

        const reasonInput = document.createElement("input");
        reasonInput.type = "hidden";
        reasonInput.name = "cancelReason";
        reasonInput.value = cancelReasonInput.value.trim();
        form.appendChild(reasonInput);

        const csrfInput = document.createElement("input");
        csrfInput.type = "hidden";
        csrfInput.name = "_csrf";
        csrfInput.value = document.querySelector('meta[name="csrf-token"]')?.content;
        form.appendChild(csrfInput);

        document.body.appendChild(form);
        form.submit();
      },
      true,
    );
  };
  // Handler for create order request
  window.checkCreateOrder = function (url) {
    dialogYes.style.background = "#10b981"; // Green for create
    dialogYes.textContent = "Yes, Proceed Order";

    showCustomConfirm(
      "Are you sure you want to proceed with this order?",
      () => {
        window.location.href = url;
      },
      false, // No reason needed
    );
  };

  const table = new Tabulator("#master-table", {
    data: enrichedOrderData,
    // layout: "fitColumns",
    responsiveLayout: false,
    movableColumns: true,
    placeholder: "No pending orders found",
    initialSort: [{ column: "poDate", dir: "asc" }],
    columns: [
      {
        title: "Actions",
        hozAlign: "center",
        headerSort: false,
        width: 180,
        formatter: (cell) => {
          const row = cell.getRow().getData();
          const client = row.userId ? row.userId.clientName : "";
          const user = row.userId ? row.userId._id : "";
          const item = row.tapeBinding ? row.tapeBinding._id : "";
          let itemType = "TAPE";
          if (row.onModel === "PosRoll") itemType = "POS_ROLL";
          if (row.onModel === "Tafeta") itemType = "TAFETA";
          if (row.onModel === "Ttr") itemType = "TTR";
          if (row.onModel === "Label") itemType = "LABEL";

          const confirmUrl = `/fairtech/sales/order/confirm?orderId=${row._id}&type=${itemType}&client=${encodeURIComponent(client)}&user=${user}&item=${item}`;
          const editUrl = `/fairtech/sales/order?orderId=${row._id}&type=${itemType}&client=${encodeURIComponent(client)}&user=${user}&item=${item}`;
          return `
                <div style="display:flex; gap:6px; justify-content:center; flex-wrap:nowrap; align-items:center; white-space:nowrap;">
                    <button
                        onclick="viewPendingOrder('${row._id}')"
                        style="height:24px; padding:2px 10px; background:#111827; color:white; border:none; border-radius:4px; cursor:pointer; font-size:11px; transition: background 0.2s; display:inline-flex; align-items:center; gap:4px; font-weight:600;"
                        onmouseover="this.style.background='#374151'"
                        onmouseout="this.style.background='#111827'"
                        title="View Details">
                        <i class="fa-solid fa-eye"></i>
                    </button>
                    <a href="javascript:void(0)"
                        onclick="checkCreateOrder('${confirmUrl}')"
                        style="height:24px; padding:2px 10px; background:#10b981; color:white; border:none; border-radius:4px; cursor:pointer; font-size:11px; transition: background 0.2s; text-decoration:none; display:inline-flex; align-items:center; gap:4px; font-weight:600;"
                        onmouseover="this.style.background='#059669'"
                        onmouseout="this.style.background='#10b981'"
                        title="Create Order">
                        <i class="fa-solid fa-truck-moving"></i>
                    </a>
                    <button onclick="requestCancel('${row._id}')"
                        style="height:24px; padding:2px 10px; background:#ef4444; color:white; border:none; border-radius:4px; cursor:pointer; font-size:12px; transition: background 0.2s; font-weight:600;"
                        onmouseover="this.style.background='#dc2626'"
                        onmouseout="this.style.background='#ef4444'"
                        title="Cancel Order">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                    <a href="${editUrl}"
                        style="height:24px; padding:2px 10px; background:#3b82f6; color:white; border:none; border-radius:4px; cursor:pointer; font-size:11px; transition: background 0.2s; text-decoration:none; display:inline-flex; align-items:center; gap:4px; font-weight:600;"
                        onmouseover="this.style.background='#2563eb'"
                        onmouseout="this.style.background='#3b82f6'"
                        title="Edit Order">
                        <i class="fa-solid fa-pencil"></i>
                    </a>
                </div>
            `;
        },
      },
      {
        title: "Date",
        field: "poDate",
        width: 105,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        sorter: (a, b, aRow, bRow) => {
          const aDate = new Date(a || aRow.getData().createdAt).getTime() || 0;
          const bDate = new Date(b || bRow.getData().createdAt).getTime() || 0;
          return aDate - bDate;
        },
        formatter: (cell) => {
          const raw = cell.getValue() || cell.getRow().getData().createdAt;
          if (!raw) return "-";
          const d = new Date(raw);
          if (isNaN(d.getTime())) return "-";
          return `${String(d.getDate()).padStart(2, "0")}/${String(d.getMonth() + 1).padStart(2, "0")}/${d.getFullYear()}`;
        },
      },
      {
        title: "PO No",
        field: "poNumber",
        width: 120,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        formatter: (cell) => {
          const val = cell.getValue();
          return val == null || val === "" ? `<span style="color:#9ca3af;">—</span>` : escapeHtml(val);
        },
      },
      {
        title: "Client",
        field: "userId.clientName",
        width: 200,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
      },
      {
        title: "Client Type",
        field: "userId.clientType",
        width: 110,
        hozAlign: "center",
        headerFilter: "list",
        headerFilterParams: { values: { "": "All", DEALER: "Dealer", CLIENT: "Client" } },
        headerFilterPlaceholder: "All",
        formatter: (cell) => {
          const val = String(cell.getValue() || "").toUpperCase();
          if (!val) return "";
          const isDealer = val === "DEALER";
          const color = isDealer ? "#dc2626" : "#059669";
          return `<span style="color:${color}; font-weight:700;">${val}</span>`;
        },
      },
      { title: "User", field: "userId.userName", width: 150, headerFilter: "input", headerFilterPlaceholder: "Search" },
      {
        title: "Item Type",
        field: "onModel",
        width: 100,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        formatter: (cell) => {
          const val = cell.getValue();
          if (val === "PosRoll") return "POS Roll";
          if (val === "Tafeta") return "Tafeta";
          if (val === "Ttr") return "TTR";
          if (val === "Label") return "Label";
          return "Tape";
        },
      },
      {
        title: "Item Details",
        field: "tapeId",
        width: 200,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        headerFilterFunc: (headerValue, rowValue, rowData, filterParams) => {
          const name = getItemName(rowData);
          return String(name).toLowerCase().includes(String(headerValue).toLowerCase());
        },
        formatter: (cell) => {
          const row = cell.getRow().getData();
          const name = getItemName(row);

          return `<span style="color:#044A78; font-weight:600; display:block;">
                    ${name}
                  </span>`;
        },
      },
      {
        title: "GSM/Micron",
        field: "tapeId",
        hozAlign: "center",
        width: 100,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        headerFilterFunc: (headerValue, rowValue, rowData, filterParams) => {
          const gsm = getItemGsm(rowData);
          return String(gsm).toLowerCase().includes(String(headerValue).toLowerCase());
        },
        // Column shares its `field` with "Item Details"/"Width" (all read tapeId).
        sorter: (a, b, aRow, bRow) => (Number(getItemGsm(aRow.getData())) || 0) - (Number(getItemGsm(bRow.getData())) || 0),
        formatter: (cell) => {
          const gsm = getItemGsm(cell.getRow().getData());
          return gsm !== "" && gsm != null ? String(gsm) : "-";
        },
      },
      {
        title: "Client GSM",
        field: "tapeBinding",
        hozAlign: "center",
        width: 110,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        headerFilterFunc: (headerValue, rowValue, rowData, filterParams) => {
          const gsm = getClientGsm(rowData);
          return String(gsm).toLowerCase().includes(String(headerValue).toLowerCase());
        },
        sorter: (a, b, aRow, bRow) => (Number(getClientGsm(aRow.getData())) || 0) - (Number(getClientGsm(bRow.getData())) || 0),
        formatter: (cell) => {
          const gsm = getClientGsm(cell.getRow().getData());
          return gsm !== "" && gsm != null ? String(gsm) : "-";
        },
      },
      {
        title: "Width",
        field: "tapeId",
        hozAlign: "center",
        width: 90,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        headerFilterFunc: (headerValue, rowValue, rowData, filterParams) => {
          const width = getItemWidth(rowData);
          return String(width).toLowerCase().includes(String(headerValue).toLowerCase());
        },
        // Column shares its `field` with "Item Details" (both read tapeId) —
        // the default sorter would sort by the raw tapeId reference, not the
        // displayed width, so sort by the same derived value shown in the cell.
        sorter: (a, b, aRow, bRow) => (Number(getItemWidth(aRow.getData())) || 0) - (Number(getItemWidth(bRow.getData())) || 0),
        formatter: (cell) => {
          const width = getItemWidth(cell.getRow().getData());
          return width ? `${width}` : "";
        },
      },
      {
        title: "Mtrs",
        field: "tapeId",
        hozAlign: "center",
        width: 90,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        headerFilterFunc: (headerValue, rowValue, rowData, filterParams) => {
          const mtrs = getItemMtrs(rowData);
          return String(mtrs).toLowerCase().includes(String(headerValue).toLowerCase());
        },
        // Same tapeId field-sharing issue as Width above — sort by the derived value.
        sorter: (a, b, aRow, bRow) => (Number(getItemMtrs(aRow.getData())) || 0) - (Number(getItemMtrs(bRow.getData())) || 0),
        formatter: (cell) => {
          const mtrs = getItemMtrs(cell.getRow().getData());
          return mtrs ? `${mtrs}` : "";
        },
      },
      {
        title: "Qty",
        field: "quantity",
        hozAlign: "center",
        width: 70,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        formatter: (cell) => {
          const val = cell.getValue();
          return val === 0 ? "" : val;
        },
      },
      {
        title: "Sent",
        field: "dispatchedQuantity",
        hozAlign: "center",
        width: 65,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        formatter: (cell) => {
          const val = cell.getValue();
          return val === 0 ? "" : val;
        },
      },
      {
        title: "Bal",
        field: "balance", // Field name for filter identification
        hozAlign: "center",
        width: 65,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        headerFilterFunc: (headerValue, rowValue, rowData, filterParams) => {
          const bal = (rowData.quantity || 0) - (rowData.dispatchedQuantity || 0);
          return String(bal).includes(String(headerValue));
        },
        formatter: (cell) => {
          const row = cell.getRow().getData();
          const quantity = row.quantity || 0;
          const dispatched = row.dispatchedQuantity || 0;
          const remaining = quantity - dispatched;
          return `<span style="font-weight:700; color:#044A78;">${remaining}</span>`;
        },
      },
      {
        title: "Stock",
        field: "totalStock",
        hozAlign: "center",
        width: 80,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        formatter: (cell) => {
          const row = cell.getRow().getData();
          const val = cell.getValue() || 0;
          const quantity = Number(row.quantity) || 0;
          const dispatched = Number(row.dispatchedQuantity) || 0;
          const balance = Math.max(quantity - dispatched, 0);
          const itemId = row.tapeId?._id || row.tapeId;
          const model = row.onModel;

          if (!itemId || !model) return val;

          let typeSlug = "tape";
          if (model === "PosRoll") typeSlug = "pos-roll";
          else if (model === "Tafeta") typeSlug = "tafeta";
          else if (model === "Ttr") typeSlug = "ttr";
          else if (model === "Label") typeSlug = "label";

          const url = `/fairtech/${typeSlug}/profile/${itemId}`;
          
          let color = Number(val) < balance ? "#dc2626" : "#059669";
          if (row.hasPendingPo) color = "#d97706"; // Yellowish orange for pending PO

          return `<a href="${url}" style="text-decoration:underline; font-weight:700; color:${color}">${val}</a>`;
        },
      },
      {
        title: "Rate (₹)",
        field: "orderRate",
        hozAlign: "right",
        width: 90,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        formatter: (cell) => {
          const val = cell.getValue();
          if (val == null || val === "") return `<span style="color:#9ca3af;">—</span>`;
          return `<span style="font-weight:600; color:#0f766e;">₹${Number(val).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 3 })}</span>`;
        },
      },
      {
        title: "Value (₹)",
        field: "valueAmount",
        hozAlign: "right",
        width: 110,
        sorter: (a, b) => Number(a || 0) - Number(b || 0),
        headerSort: true,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        headerFilterFunc: (headerValue, rowValue) => {
          const filterText = String(headerValue ?? "").trim();
          if (!filterText) return true;

          const normalized = filterText.replace(/[^0-9.-]/g, "");
          if (!normalized) return true;

          return String(Number(rowValue) || 0).includes(normalized);
        },
        formatter: (cell) => {
          const value = Number(cell.getValue()) || 0;
          if (value === 0) return `<span style="color:#9ca3af;">—</span>`;
          return `<span style="font-weight:700; color:#044A78;">₹${value.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</span>`;
        },
      },
      {
        title: "Source",
        field: "sourceLocation",
        hozAlign: "center",
        width: 80,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
      },
      {
        title: "Est. Delivery",
        field: "estimatedDate",
        width: 120,
        headerFilter: "input",
        headerFilterPlaceholder: "Search",
        formatter: (cell) => new Date(cell.getValue()).toLocaleDateString("en-IN"),
      },
      { title: "Remarks", field: "remarks", headerFilter: "input", headerFilterPlaceholder: "Search" },
    ],
  });

  // Pre-compute grand total from all rows (never changes)
  const tableTotal = enrichedOrderData.reduce((sum, row) => sum + (Number(row.valueAmount) || 0), 0);
  const labelTotal = Number(labelTotals.labelTotal) || 0;
  const colorLabelTotal = Number(labelTotals.colorLabelTotal) || 0;
  // Grand total = this table's pending value (Tape/POS/Tafeta/TTR) + Plain
  // Labels + Color Labels (those live on their own pending pages, so they're
  // never part of the table rows above).
  const grandTotal = tableTotal + labelTotal + colorLabelTotal;

  function formatINR(value) {
    return "₹" + value.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  // Set the static totals on load
  const tableTotalDisplay = document.getElementById("table-total-display");
  if (tableTotalDisplay) tableTotalDisplay.textContent = "Pending Items: " + formatINR(tableTotal);
  const colorLabelDisplay = document.getElementById("color-label-value-display");
  if (colorLabelDisplay) colorLabelDisplay.textContent = "Color Labels: " + formatINR(colorLabelTotal);
  const plainLabelDisplay = document.getElementById("plain-label-value-display");
  if (plainLabelDisplay) plainLabelDisplay.textContent = "Plain Label: " + formatINR(labelTotal);
  const totalDisplay = document.getElementById("total-value-display");
  if (totalDisplay) totalDisplay.textContent = "Total: " + formatINR(grandTotal);

  // Update filtered value whenever filters change
  // dataFiltered passes (filters, rows) where rows = currently visible row components
  table.on("dataFiltered", function (filters, rows) {
    const filteredEl = document.getElementById("filtered-value-display");
    if (!filteredEl) return;

    // Show filtered badge if any filters are active
    const isFiltered = filters && filters.length > 0;

    if (!isFiltered) {
      filteredEl.style.display = "none";
      return;
    }

    let filteredTotal = 0;
    rows.forEach((row) => {
      const data = row.getData();
      filteredTotal += Number(data.valueAmount) || 0;
    });

    filteredEl.textContent = "Filtered: " + formatINR(filteredTotal);
    filteredEl.style.display = "inline-block";
  });

  // Dropdown toggle
  const selector = document.getElementById("downloadSelector");
  const trigger = selector.querySelector(".download-selector__trigger");
  trigger.addEventListener("click", (e) => {
    e.stopPropagation();
    selector.classList.toggle("download-selector--active");
  });
  document.addEventListener("click", () => selector.classList.remove("download-selector--active"));

  // Downloads
  document.getElementById("download-pdf").addEventListener("click", () => {
    table.download("pdf", "pending_orders.pdf", { orientation: "landscape", title: "Pending Orders" });
    selector.classList.remove("download-selector--active");
  });
  document.getElementById("download-xlsx").addEventListener("click", () => {
    table.download("xlsx", "pending_orders.xlsx", { sheetName: "PendingOrders" });
    selector.classList.remove("download-selector--active");
  });
</script>

