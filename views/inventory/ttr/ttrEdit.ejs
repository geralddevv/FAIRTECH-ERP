<% layout('/layout/boilerplate') %>
<style>
  input[readonly], select[disabled] { background: #f1f5f9; cursor: not-allowed; }
</style>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <form action="/fairtech/ttr/edit/<%= ttr._id %>" method="post" class="needs-validation" autocomplete="off" novalidate>
    <div class="span-full form-heading">
      <h1>TTR Master</h1>
    </div>

    <div class="span-six">
      <label>Product ID</label>
      <input type="text" class="form-control input-tag" value="<%= ttr.ttrProductId %>" readonly />
    </div>
    <div class="span-five">
      <label>Type</label>
      <input type="text" class="form-control" value="<%= ttr.ttrType %>" readonly />
    </div>
    <div class="span-five">
      <label>Color</label>
      <input type="text" class="form-control" value="<%= ttr.ttrColor %>" readonly />
    </div>
    <div class="span-six">
      <label>Material Code</label>
      <input type="text" class="form-control" value="<%= ttr.ttrMaterialCode %>" readonly />
    </div>
    <div class="span-five">
      <label>Width</label>
      <input type="text" class="form-control" value="<%= ttr.ttrWidth %>" readonly />
    </div>
    <div class="span-five">
      <label>MTRS</label>
      <input type="text" class="form-control" value="<%= ttr.ttrMtrs %>" readonly />
    </div>
    <div class="span-six">
      <label>Ink Face</label>
      <input type="text" class="form-control" value="<%= ttr.ttrInkFace || 'OUT' %>" readonly />
    </div>
    <div class="span-six">
      <label>Core ID</label>
      <input type="text" class="form-control" value="<%= ttr.ttrCoreId %>" readonly />
    </div>
    <div class="span-seven">
      <label>Core Length</label>
      <input type="text" class="form-control" value="<%= ttr.ttrCoreLength %>" readonly />
    </div>
    <div class="span-six">
      <label>Notch</label>
      <input type="text" class="form-control" value="<%= ttr.ttrNotch %>" readonly />
    </div>
    <div class="span-seven">
      <label>Winding</label>
      <input type="text" class="form-control" value="<%= ttr.ttrWinding %>" readonly />
    </div>

    <div class="span-five">
      <label>Status</label>
      <select name="status" class="form-control select-tag" required>
        <option value="ACTIVE" <%= (ttr.status || "ACTIVE") === "ACTIVE" ? "selected" : "" %>>ACTIVE</option>
        <option value="INACTIVE" <%= ttr.status === "INACTIVE" ? "selected" : "" %>>INACTIVE</option>
      </select>
    </div>

    <div class="span-full btn-grp" style="flex-direction: row-reverse;">
      <button class="submit-btn" type="submit">Update Status</button>
      <button type="button" id="cancelBtn">Cancel</button>
    </div>
  </form>
</div>

<script>
  document.getElementById("cancelBtn").addEventListener("click", () => {
    window.history.back();
  });
</script>
