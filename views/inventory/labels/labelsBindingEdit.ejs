<% layout('/layout/boilerplate') -%>
<style>
  .label-id-success {
    border: 2px solid #28a745 !important;
    background-color: #f3fff6;
    color: #155724;
    font-weight: 600;
  }
  .label-id-error {
    border: 2px solid #dc3545 !important;
    background-color: #fff5f5;
    color: #721c24;
    font-weight: 600;
  }
</style>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <form
    class="needs-validation"
    action="/fairtech/labels-binding/edit/<%= binding._id %>"
    method="post"
    autocomplete="off"
    novalidate
  >
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="hidden" name="returnTo" value="<%= returnTo || '' %>" />
    <input type="hidden" name="labelMasterId" id="label-master-id" value="<%= binding.labelMasterId ? binding.labelMasterId.toString() : '' %>" />

    <div class="span-full form-heading">
      <h1>Edit Label Binding</h1>
    </div>

    <!-- ================= USER INFO (READ-ONLY) ================= -->
    <div class="span-full form-subheading">
      <h1>User Information</h1>
    </div>
    <div class="span-seven">
      <label>Product ID</label>
      <input type="text" id="product-id" class="form-control input-tag label-id-success" value="<%= binding.productId || '' %>" readonly />
    </div>
    <div class="span-six">
      <label>Client Name</label>
      <input type="text" class="form-control input-tag" value="<%= binding.clientName || '' %>" readonly />
    </div>
    <div class="span-six">
      <label>User Name</label>
      <input type="text" class="form-control input-tag" value="<%= binding.userName || '' %>" readonly />
    </div>
    <div class="span-six">
      <label>User Contact</label>
      <input type="text" class="form-control input-tag" value="<%= binding.userContact || '' %>" readonly />
    </div>
    <div class="span-seven">
      <label for="binding-location">Location</label>
      <select name="location" id="binding-location" class="form-control select-tag" required>
        <% (userLocations || []).forEach(loc => { %>
          <option value="<%= loc %>" <%= (binding.location || '') === loc ? 'selected' : '' %>><%= loc %></option>
        <% }) %>
      </select>
    </div>

    <!-- ================= LABEL SPECIFICATIONS ================= -->
    <div class="span-full form-subheading" style="display: flex; justify-content: space-between; align-items: center;">
      <h1>Label Specifications</h1>
      <button type="button" id="reset-specs-btn" style="padding: 4px 12px; border-radius: 4px; background-color: #dc3545; color: white; border: none; cursor: pointer; font-size: 14px;">
        Reset
      </button>
    </div>

    <div id="spec-row-1" style="grid-column: span 32; display: flex; gap: 1rem;">
      <div class="span-four" style="flex: 4; min-width: 0;">
        <label for="job-type">Job Type</label>
        <select id="job-type" class="form-control select-tag">
          <option value="" disabled selected hidden>Search</option>
        </select>
      </div>
      <div class="color-field span-five" style="flex: 5; min-width: 0;">
        <label for="job-name">Job Name</label>
        <select id="job-name" class="form-control select-tag">
          <option value="" disabled selected hidden>Search</option>
        </select>
      </div>
      <div class="plain-field span-six" style="flex: 6; min-width: 0;">
        <label for="instructions">Instructions</label>
        <select id="instructions" class="form-control select-tag">
          <option value="" disabled selected hidden>Search</option>
        </select>
      </div>
      <div id="width-div" class="dim-field span-three" style="flex: 3; min-width: 0;">
        <label for="width">Width</label>
        <select id="width" class="form-control select-tag">
          <option value="" disabled selected hidden>Search</option>
        </select>
      </div>
      <div id="height-div" class="dim-field span-three" style="flex: 3; min-width: 0;">
        <label for="height">Height</label>
        <select id="height" class="form-control select-tag">
          <option value="" disabled selected hidden>Search</option>
        </select>
      </div>
      <div id="gap-div" class="dim-field span-three" style="flex: 3; min-width: 0;">
        <label for="gap">Gap</label>
        <select id="gap" class="form-control select-tag">
          <option value="" disabled selected hidden>Search</option>
        </select>
      </div>
    </div>

    <!-- ================= CLIENT SPECIFICATIONS ================= -->
    <div style="grid-column: span 32; display: flex; flex-direction: column; gap: 1rem;">
      <div class="span-full form-subheading">
        <h1>Client Specifications</h1>
      </div>
      <div style="display: flex; gap: 1rem;">
        <div class="span-three" style="flex: 0.8; min-width: 0;">
          <label for="ups-input">Up's</label>
          <input type="text" id="ups-input" class="form-control" name="labelUps" value="<%= binding.labelUps || '' %>" placeholder="Enter Up's" required />
        </div>
        <div class="span-three" style="flex: 0.8; min-width: 0;">
          <label for="core-input">Core</label>
          <select id="core-input" class="form-control" name="labelCore" style="border: 1px solid var(--primary-color); border-radius: 0.5rem;" required>
            <option value="" disabled hidden>Select</option>
            <option value="0.5" <%= binding.labelCore === "0.5" ? "selected" : "" %>>0.5</option>
            <option value="1" <%= binding.labelCore === "1" ? "selected" : "" %>>1</option>
            <option value="1.5" <%= binding.labelCore === "1.5" ? "selected" : "" %>>1.5</option>
            <option value="2" <%= binding.labelCore === "2" ? "selected" : "" %>>2</option>
            <option value="3" <%= binding.labelCore === "3" ? "selected" : "" %>>3</option>
          </select>
        </div>
        <div class="span-three" style="flex: 0.8; min-width: 0;">
          <label for="family-input">Family</label>
          <select id="family-input" class="form-control" name="labelFamily" style="border: 1px solid var(--primary-color); border-radius: 0.5rem;" required>
            <option value="" disabled hidden>Select</option>
            <option value="CHROMO" <%= binding.labelFamily === "CHROMO" ? "selected" : "" %>>CHROMO</option>
            <option value="DT" <%= binding.labelFamily === "DT" ? "selected" : "" %>>DT</option>
            <option value="MAPLTIO" <%= binding.labelFamily === "MAPLTIO" ? "selected" : "" %>>MAPLTIO</option>
            <option value="PP" <%= binding.labelFamily === "PP" ? "selected" : "" %>>PP</option>
          </select>
        </div>
        <div class="span-three" style="flex: 0.8; min-width: 0;">
          <label for="cli-sku-code-input">SKU Code</label>
          <input type="text" id="cli-sku-code-input" class="form-control" name="clientSkuCode" value="<%= binding.clientSkuCode || '' %>" placeholder="Enter SKU Code" />
        </div>
        <div class="span-three" style="flex: 0.8; min-width: 0;">
          <label for="cli-instructions-input">Instructions</label>
          <input type="text" id="cli-instructions-input" class="form-control" name="clientInstructions" value="<%= binding.clientInstructions || '' %>" placeholder="Enter Instructions" />
        </div>
      </div>
    </div>

    <!-- ================= COST & PRICING ================= -->
    <div style="grid-column: span 32; display: flex; flex-direction: column; gap: 1rem;">
      <div class="span-full form-subheading">
        <h1>Cost & Pricing</h1>
      </div>
      <div style="display: flex; gap: 1rem;">
        <div class="span-four" style="flex: 1; min-width: 0;">
          <label for="rate-per-k">Rate Per 1000</label>
          <input type="text" id="rate-per-k" class="form-control" name="ratePerK" value="<%= binding.ratePerK || '' %>" placeholder="Enter Rate Per 1000" required />
        </div>
        <div class="span-four" style="flex: 1; min-width: 0;">
          <label for="rate-per-label">Rate Per Label</label>
          <input type="text" id="rate-per-label" class="form-control" name="ratePerLabel" value="<%= binding.ratePerLabel || '' %>" placeholder="Auto-calculated" tabindex="-1" readonly required />
        </div>
        <div class="span-four" style="flex: 1; min-width: 0;">
          <label for="per-roll-qty">Per Roll QTY</label>
          <input type="text" id="per-roll-qty" class="form-control" name="perRollQty" value="<%= binding.perRollQty || '' %>" placeholder="Enter Per Roll QTY" required />
        </div>
        <div class="span-four" style="flex: 1; min-width: 0;">
          <label for="labels-del">Labels Delivered</label>
          <input type="text" id="labels-del" class="form-control" name="labelsDel" value="<%= binding.labelsDel || '' %>" placeholder="Enter Labels Delivered" />
        </div>
        <div class="span-four" style="flex: 1; min-width: 0;">
          <label for="per-roll">Rate Per Roll</label>
          <input type="text" id="per-roll" class="form-control" name="perRoll" value="<%= binding.perRoll || '' %>" placeholder="Auto-calculated" tabindex="-1" readonly required />
        </div>
        <div class="span-three" style="flex: 0.8; min-width: 0;">
          <label for="sale-cost">Sale Cost</label>
          <input type="text" id="sale-cost" class="form-control" name="saleCost" value="<%= binding.saleCost || '' %>" placeholder="Auto-calculated" tabindex="-1" readonly required />
        </div>
      </div>
    </div>

    <!-- ================= ORDER INFORMATION ================= -->
    <div class="span-full form-subheading">
      <h1>Order Information</h1>
    </div>
    <%
      // This binding may predate the Rolls option's removal -- MOQ is always
      // in labels now, so convert an existing roll-based MOQ to its label
      // equivalent instead of silently reinterpreting the same number.
      const displayMoq = binding.moqUnit === "ROLLS"
        ? (Number(binding.minOrderQty) || 0) * (Number(binding.perRollQty) || 0) || binding.minOrderQty
        : binding.minOrderQty;
    %>
    <div class="span-seven">
      <div style="display: flex; justify-content: space-between; align-items: center; gap: 24px; margin-bottom: 4px;">
        <label for="order-qty" style="margin: 0;">MOQ</label>
        <span style="font-size: 13px; font-weight: 600; color: #6b7280; margin-left: auto;">Enter value in labels</span>
      </div>
      <input type="hidden" name="moqUnit" value="LABELS" />
      <input type="text" id="order-qty" class="form-control" name="minOrderQty" value="<%= displayMoq || '' %>" placeholder="Enter MOQ" required />
    </div>
    <div class="span-six">
      <label for="total-order-qty">Order QTY</label>
      <input type="text" id="total-order-qty" class="form-control" name="orderQty" value="<%= binding.OrderQty || '' %>" placeholder="Enter Order QTY" required />
    </div>
    <div class="span-seven">
      <label for="rep-order-fq">Repeat Order Frequency</label>
      <input type="text" id="rep-order-fq" class="form-control" name="repOrderFq" value="<%= binding.repOrderFq || '' %>" placeholder="Enter Repeat Order Frequency" required />
    </div>
    <div class="span-six">
      <label for="credit-term">CR</label>
      <input type="text" id="credit-term" class="form-control" name="creditTerm" value="<%= binding.creditTerm || '' %>" placeholder="Enter Credit Term" required />
    </div>
    <div class="span-six">
      <label for="status">Status</label>
      <select id="status" name="status" class="form-control select-tag" required>
        <option value="ACTIVE" <%= binding.status === "ACTIVE" ? "selected" : "" %>>ACTIVE</option>
        <option value="INACTIVE" <%= binding.status === "INACTIVE" ? "selected" : "" %>>INACTIVE</option>
      </select>
    </div>

    <!-- ================= BUTTONS ================= -->
    <div class="span-full btn-grp" style="flex-direction: row-reverse;">
      <button class="submit-btn" type="submit">Update Label Binding</button>
      <button type="button" id="cancelBtn">Cancel</button>
    </div>
  </form>
</div>

<script id="masters-data" type="application/json">
  <%- safeJson(masters) %>
</script>
<script id="binding-data" type="application/json">
  <%- safeJson(binding) %>
</script>
<script src="/js/choices.min.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const MASTERS = JSON.parse(document.getElementById("masters-data").textContent);
    const BINDING = JSON.parse(document.getElementById("binding-data").textContent);

    const SPEC = [
      ["job-type",     "jobType"],
      ["job-name",     "jobName"],
      ["instructions", "instructions"],
      ["width",        "labelWidth"],
      ["height",       "labelHeight"],
      ["gap",          "labelGap"],
    ];

    const COLOR_FIELDS = new Set(["jobName"]);
    function isFieldActive(key) {
      const jt = String(getVal("#job-type")).toUpperCase();
      if (COLOR_FIELDS.has(key)) return jt === "COLOR";
      if (key === "instructions") return jt === "PLAIN";
      return true;
    }

    const masterIdEl  = document.getElementById("label-master-id");
    const productIdEl = document.getElementById("product-id");

    const $ = (sel) => document.querySelector(sel);
    const getVal = (sel) => { const el = $(sel); return el ? String(el.value || "").trim() : ""; };
    const setVal = (sel, val) => { const el = $(sel); if (el) el.value = val ?? ""; };
    const toggle = (sel, show) => { const el = $(sel); if (el) el.style.display = show ? "" : "none"; };

    let smartFilterBusy = false;
    let initMode = false;

    /* ── Choices init ── */
    const specChoices = {};
    SPEC.forEach(([id]) => {
      const el = document.getElementById(id);
      if (el) specChoices[id] = new Choices(el, { searchEnabled: true, shouldSort: false, itemSelectText: "" });
    });

    const locationEl = document.getElementById("binding-location");
    if (locationEl) new Choices(locationEl, { searchEnabled: true, shouldSort: false, itemSelectText: "" });

    /* ── Smart filter helpers ── */
    const distinct = (list, key) =>
      [...new Set(list.map((m) => String(m[key] ?? "")).filter((v) => v !== ""))];

    function selections() {
      const sel = {};
      SPEC.forEach(([id, key]) => {
        if (!isFieldActive(key)) return;
        const el = document.getElementById(id);
        if (el && el.value) sel[key] = el.value;
      });
      return sel;
    }

    function mastersMatching(sel, excludeKey) {
      return MASTERS.filter((m) =>
        Object.entries(sel).every(([k, v]) => k === excludeKey || String(m[k] ?? "") === String(v))
      );
    }

    function repopulate() {
      const sel = selections();
      SPEC.forEach(([id, key]) => {
        const inst = specChoices[id];
        const el   = document.getElementById(id);
        if (!inst || !el) return;

        if (!isFieldActive(key)) {
          if (el.value) el.value = "";
          inst.clearStore();
          inst.setChoices([{ value: "", label: "Search", disabled: true, selected: true }], "value", "label", true);
          return;
        }

        const current = el.value;
        const options  = distinct(mastersMatching(sel, key), key);
        const optionSet = new Set(options.map(String));

        const newChoices = options.map((v) => ({
          value: String(v), label: String(v), selected: String(v) === current,
        }));

        let autoVal = null;
        if (options.length === 1 && !current && !initMode) {
          newChoices[0].selected = true;
          autoVal = options[0];
        }

        inst.clearStore();
        inst.setChoices(
          [{ value: "", label: "Search", disabled: true, selected: !newChoices.some((c) => c.selected) }, ...newChoices],
          "value", "label", true,
        );

        if (current && optionSet.has(String(current))) {
          inst.setChoiceByValue(String(current));
        } else if (autoVal) {
          inst.setChoiceByValue(String(autoVal));
        } else if (!options.length) {
          el.value = "";
        }
      });
    }

    function repopulateUntilStable() {
      for (let i = 0; i < SPEC.length + 1; i++) {
        const before = SPEC.map(([id]) => document.getElementById(id).value).join("|");
        repopulate();
        const after = SPEC.map(([id]) => document.getElementById(id).value).join("|");
        if (before === after) break;
      }
    }

    /* ── Visibility ── */
    function refreshJobVisibility() {
      const type    = String(getVal("#job-type")).toUpperCase();
      const isColor = type === "COLOR";
      const isPlain = type === "PLAIN";
      document.querySelectorAll(".color-field").forEach(el => { el.style.display = isColor ? "" : "none"; });
      document.querySelectorAll(".plain-field").forEach(el => { el.style.display = isPlain ? "" : "none"; });
      document.querySelectorAll(".dim-field").forEach(el => { el.style.display = (isPlain || isColor) ? "" : "none"; });
    }

    /* ── Resolve master ── */
    function resolveMaster() {
      const sel = selections();
      if (Object.keys(sel).length === 0) return;

      const matches = mastersMatching(sel);
      productIdEl.classList.remove("label-id-success", "label-id-error");
      if (matches.length === 1) {
        masterIdEl.value = matches[0]._id;
        productIdEl.value = matches[0].labelProductId;
        productIdEl.classList.add("label-id-success");
        updateRates();
      } else if (matches.length === 0) {
        masterIdEl.value = "";
        productIdEl.classList.add("label-id-error");
      } else {
        productIdEl.value = `${matches.length} matches — refine specs`;
      }
    }

    function handleSpecChange() {
      if (smartFilterBusy) return;
      smartFilterBusy = true;
      try {
        repopulateUntilStable();
        resolveMaster();
        refreshJobVisibility();
      } finally {
        smartFilterBusy = false;
      }
    }

    SPEC.forEach(([id]) => {
      const el = document.getElementById(id);
      if (el) el.addEventListener("change", handleSpecChange);
    });

    /* ── Reset ── */
    document.getElementById("reset-specs-btn").addEventListener("click", () => {
      smartFilterBusy = true;
      SPEC.forEach(([id]) => {
        const el = document.getElementById(id);
        if (el) el.value = "";
        if (specChoices[id]) specChoices[id].setChoiceByValue("");
      });
      repopulate();
      smartFilterBusy = false;
      resolveMaster();
      refreshJobVisibility();
    });

    /* ── Rate / sale cost ── */
    function updateRates() {
      const ratePerK   = Number(getVal("#rate-per-k")) || 0;
      const perRollQty = Number(getVal("#per-roll-qty")) || 0;
      const ratePerLabel = ratePerK / 1000;
      setVal("#rate-per-label", ratePerLabel || "");
      setVal("#per-roll", ratePerLabel && perRollQty ? (ratePerLabel * perRollQty).toFixed(2) : "");
      const w = Number(getVal("#width")) || 0;
      const h = Number(getVal("#height")) || 0;
      if (!w || !h || !ratePerLabel) { setVal("#sale-cost", "0.00"); return; }
      const area = (w * h) / 625;
      setVal("#sale-cost", area ? (ratePerLabel / area).toFixed(4) : "0.00");
    }

    document.getElementById("rate-per-k").addEventListener("input", updateRates);
    document.getElementById("per-roll-qty").addEventListener("input", updateRates);

    /* ── Init: prefill spec dropdowns from binding ── */
    smartFilterBusy = true;
    initMode = true;

    // Step 1: populate all options with no filter so Choices has options to select from.
    repopulate();

    // Step 2: set job-type first — visibility of instructions/color fields depends on it.
    if (BINDING.jobType && specChoices["job-type"]) {
      specChoices["job-type"].setChoiceByValue(String(BINDING.jobType));
    }

    // Step 3: re-populate with job-type known so conditional fields (instructions, color
    // fields) are now active and get their option lists built.
    repopulate();

    // Step 4: set all remaining spec values now that every dropdown has its options.
    const specPrefill = [
      ["job-name",     BINDING.jobName],
      ["instructions", BINDING.instructions],
      ["width",        BINDING.labelWidth],
      ["height",       BINDING.labelHeight],
      ["gap",          BINDING.labelGap],
    ];
    specPrefill.forEach(([id, val]) => {
      if (val && specChoices[id]) specChoices[id].setChoiceByValue(String(val));
    });

    // Step 5: cascade-filter and stabilize.
    repopulateUntilStable();
    initMode = false;
    smartFilterBusy = false;
    refreshJobVisibility();
    resolveMaster();

    /* ── Cancel ── */
    document.getElementById("cancelBtn").addEventListener("click", () => window.history.back());

    /* ── Order QTY comma formatting ── */
    function formatQtyWithCommas(raw) {
      const digits = String(raw ?? "").replace(/[^\d]/g, "");
      return digits ? Number(digits).toLocaleString("en-US") : "";
    }
    const totalOrderQtyInput = document.getElementById("total-order-qty");
    if (totalOrderQtyInput) {
      totalOrderQtyInput.value = formatQtyWithCommas(totalOrderQtyInput.value);
      totalOrderQtyInput.addEventListener("input", function () {
        const prev = this.value;
        const formatted = formatQtyWithCommas(prev);
        if (formatted === prev) return;
        const caret = this.selectionStart ?? prev.length;
        const digitsBeforeCaret = prev.slice(0, caret).replace(/[^\d]/g, "").length;
        this.value = formatted;
        let pos = 0, seen = 0;
        while (pos < formatted.length && seen < digitsBeforeCaret) {
          if (/\d/.test(formatted[pos])) seen++;
          pos++;
        }
        this.setSelectionRange(pos, pos);
      });
      const bindingForm = totalOrderQtyInput.closest("form");
      if (bindingForm) {
        bindingForm.addEventListener("submit", () => {
          totalOrderQtyInput.value = totalOrderQtyInput.value.replace(/,/g, "");
        });
      }
    }
  });
</script>
