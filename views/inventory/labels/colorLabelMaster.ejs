<% layout('/layout/boilerplate') %>
<%
  const m = (typeof master !== 'undefined' && master) ? master : null;
  const isEdit = !!m;
  const formAction = isEdit ? `/fairtech/labels/edit/${m._id}` : '/fairtech/form/color-label-master';
  const labelIdValue = isEdit
    ? m.labelProductId
    : (typeof previewLabelProductId !== 'undefined' ? previewLabelProductId : '');
  const sel = (current, option) => String(current) === String(option) ? 'selected' : '';
  const val = (key, d = '') => (m && m[key] != null && m[key] !== '') ? m[key] : d;
%>
<!-- The main content -->
<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <form id="label-master-form" action="<%= formAction %>" method="post" enctype="multipart/form-data" class="needs-validation" autocomplete="off" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="hidden" name="jobType" value="COLOR" />

    <div class="span-full form-heading">
      <h1><%= isEdit ? 'Edit Color Label' : 'Color Label' %></h1>
    </div>

    <div class="span-full form-subheading">
      <h1>Job Details</h1>
    </div>

    <div style="grid-column: span 32; display: flex; flex-direction: row; align-items: flex-start; gap: 1rem;">
      <div class="span-four" style="flex: 1; min-width: 0;">
        <label for="label-product-id">Label ID</label>
        <input
          type="text"
          value="<%= labelIdValue %>"
          id="label-product-id"
          class="form-control"
          name="labelProductId"
          readonly
          required
        />
      </div>

      <input type="hidden" name="jobName" value="COLOR" />

      <div class="span-seven" style="flex: 2; min-width: 0;">
        <label>No of Color</label>
        <div style="width: 100%; display: flex; justify-content: space-between; gap: 10px;">
          <input type="number" id="front-color" class="form-control" name="frontColor" value="<%= val('frontColor') %>" placeholder="Enter Front" />
          <input type="number" id="back-color" class="form-control" name="backColor" value="<%= val('backColor') %>" placeholder="Enter Back" />
        </div>
      </div>

      <div class="span-four" style="flex: 1; min-width: 0;">
        <label for="varnish">Varnish</label>
        <select name="varnish" id="varnish" class="form-control select-tag">
          <option value="NO" <%= sel(val('varnish', 'NO'), 'NO') %>>NO</option>
          <option value="FULL" <%= sel(val('varnish'), 'FULL') %>>FULL</option>
          <option value="WINDOW" <%= sel(val('varnish'), 'WINDOW') %>>WINDOW</option>
          <option value="SPOT" <%= sel(val('varnish'), 'SPOT') %>>SPOT</option>
        </select>
      </div>

      <div class="span-four" style="flex: 1; min-width: 0;">
        <label for="foil-no">No of Foil</label>
        <input type="number" id="foil-no" class="form-control" name="foilNo" value="<%= val('foilNo', '0') %>" placeholder="Enter No of Foil" />
      </div>
    </div>

    <div id="specs-wrapper" style="grid-column: span 20; display: flex; flex-direction: column; gap: 1rem;">
      <div class="span-full form-subheading">
        <h1>Product Specifications</h1>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr 0.8fr 1fr; gap: 1rem;">
        <div class="span-three" style="grid-column: auto;">
          <label for="width">Width</label>
          <input type="text" id="width" class="form-control" name="labelWidth" value="<%= val('labelWidth') %>" placeholder="Enter Width" required />
        </div>
        <div class="span-three" style="grid-column: auto;">
          <label for="height">Height</label>
          <input type="text" id="height" class="form-control" name="labelHeight" value="<%= val('labelHeight') %>" placeholder="Enter Height" required />
        </div>
        <div class="span-three" style="grid-column: auto;">
          <label for="gap">Gap</label>
          <input type="text" id="gap" class="form-control" name="labelGap" value="<%= val('labelGap', '3') %>" placeholder="Enter Gap" required />
        </div>
        <div class="span-three" style="grid-column: auto;">
          <label for="first-out">First Out</label>
          <input type="text" id="first-out" class="form-control" name="firstOut" value="<%= val('firstOut') %>" placeholder="Enter First Out" required />
        </div>
      </div>
    </div>

    <div id="attachments-div" style="grid-column: span 12; display: flex; flex-direction: column; gap: 1rem;">
      <div class="span-full form-subheading">
        <h1>Attachments</h1>
      </div>
      <% if (isEdit) { %>
        <p style="margin:0;color:#6b7280;font-size:12px;">Leave a file empty to keep the current attachment; choose a file to replace it.</p>
      <% } %>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
        <div class="span-four" style="grid-column: auto;">
          <label for="pdf-file">PDF File</label>
          <input type="file" id="pdf-file" class="form-control" name="pdfFile" accept=".pdf,application/pdf" />
          <% if (isEdit && m.pdfFile) { %><small><a href="/fairtech/labels/file/<%= m._id %>/pdf" target="_blank" rel="noopener">Current PDF</a></small><% } %>
        </div>
        <div class="span-four" style="grid-column: auto;">
          <label for="cdr-file">CDR File</label>
          <input type="file" id="cdr-file" class="form-control" name="cdrFile" accept=".cdr,application/x-coreldraw,application/cdr,application/octet-stream" />
          <% if (isEdit && m.cdrFile) { %><small><a href="/fairtech/labels/file/<%= m._id %>/cdr">Current CDR</a></small><% } %>
        </div>
        <div class="span-four" style="grid-column: auto;">
          <label for="jpg-file">JPG File</label>
          <input type="file" id="jpg-file" class="form-control" name="jpgFile" accept=".jpg,.jpeg,image/jpeg" />
          <% if (isEdit && m.jpgFile) { %><small><a href="/fairtech/labels/file/<%= m._id %>/jpg" target="_blank" rel="noopener">Current JPG</a></small><% } %>
        </div>
      </div>
    </div>

    <div class="btn-grp span-full">
      <button id="label-master-submit-btn" type="submit"><%= isEdit ? 'Update Color Label' : 'Save Color Label' %></button>
    </div>
  </form>
</div>
