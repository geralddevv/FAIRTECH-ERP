<% layout('/layout/boilerplate') -%>

<style>
  .tape-details-shell {
    padding: 18px;
    background: linear-gradient(180deg, #eef5fb 0%, #f7f9fc 100%);
  }

  .tape-details-card {
    position: relative;
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 18px 42px rgba(4, 74, 120, 0.12);
    border: 1px solid rgba(4, 74, 120, 0.12);
    overflow: hidden;
  }

  .tape-details-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-end;
    padding: 24px 24px 22px;
    background:
      radial-gradient(circle at top right, rgba(255,255,255,0.16), transparent 34%),
      linear-gradient(135deg, #044a78 0%, #03365a 100%);
    color: #fff;
  }

  .header-copy {
    max-width: 100%;
  }

  .tape-details-header h1 {
    margin: 0;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: 0.2px;
  }

  .status-pill {
    display: inline-block;
    margin-top: 6px;
    padding: 3px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .pill-active {
    background: rgba(34, 197, 94, 0.18);
    color: #16a34a;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .pill-inactive {
    background: rgba(156, 163, 175, 0.18);
    color: #6b7280;
    border: 1px solid rgba(156, 163, 175, 0.5);
  }

  .status-dialog-body {
    padding: 20px 24px 8px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .status-radio-group {
    display: flex;
    gap: 12px;
  }

  .status-radio-label {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-radius: 10px;
    border: 2px solid #e5e7eb;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    color: #374151;
    transition: border-color 0.15s, background 0.15s;
  }

  .status-radio-label:has(input:checked) {
    border-color: #044a78;
    background: #eef5fb;
    color: #044a78;
  }

  .header-actions {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .header-action-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.2px;
    backdrop-filter: blur(8px);
    transition: background 0.18s ease;
  }

  .header-action-link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.2);
  }

  .section-title {
    margin: 0 0 14px;
    color: #044a78;
    font-size: 17px;
    font-weight: 700;
  }

  .item-details-box {
    border: 1px solid #e6eaf2;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
  }

  .item-details-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
  }

  .item-detail {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 8px;
    padding: 4px 6px;
    border-bottom: 1px solid #eef2f7;
    border-right: 1px solid #e5e7eb;
    line-height: 1.2;
  }

  .item-detail-label {
    font-size: 12px;
    color: #6b7280;
  }

  .item-detail-value {
    font-size: 12px;
    color: #111827;
    font-weight: 600;
  }

  .item-detail:nth-child(4n) {
    border-right: none;
  }

  .item-detail:last-child {
    border-bottom: none;
  }

  .item-detail:nth-last-child(-n + 4) {
    border-bottom: none;
  }

  .tape-details-body {
    padding: 22px 24px 24px;
  }

  .details-section {
    margin-top: 20px;
  }

  .details-section:first-of-type {
    margin-top: 0;
  }

  .bindings-table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid #e6eaf2;
    border-radius: 12px;
    overflow: hidden;
    font-size: 13px;
  }

  .bindings-table th,
  .bindings-table td {
    padding: 9px 12px;
    border-bottom: 1px solid #e6eaf2;
    text-align: left;
    white-space: nowrap;
  }

  .bindings-table th {
    background: #f4f7ff;
    color: #044a78;
    font-weight: 700;
  }

  .bindings-table tbody tr:hover {
    background: #fbfdff;
  }

  .bindings-table tr:last-child td {
    border-bottom: none;
  }

  .empty-state {
    padding: 28px 18px;
    text-align: center;
    color: #6b6f8c;
    border: 1px solid #e6eaf2;
    border-radius: 12px;
  }

  .empty-state h3 {
    margin: 0 0 6px;
    color: #044a78;
  }

  @media (max-width: 1100px) {
    .item-details-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 768px) {
    .tape-details-header { flex-direction: column; align-items: flex-start; padding-top: 24px; }
    .item-details-grid { grid-template-columns: 1fr; }
    .item-detail { grid-template-columns: 1fr; gap: 4px; border-right: none; }
    .bindings-table { display: block; overflow-x: auto; }
  }
</style>

<div class="main-content tape-details-shell">
  <div class="tape-details-card">

    <div class="tape-details-header">
      <div class="header-copy">
        <h1><%= master.labelProductId %></h1>
        <span class="status-pill <%= (master.status || 'ACTIVE') === 'ACTIVE' ? 'pill-active' : 'pill-inactive' %>">
          <%= master.status || 'ACTIVE' %>
        </span>
      </div>
      <div class="header-actions">
        <a class="header-action-link" href="/fairtech/labels/edit/<%= master._id %>">
          <i class="fa-solid fa-pen-to-square"></i> Edit Label
        </a>
        <button class="header-action-link" type="button" onclick="openStatusDialog()">
          <i class="fa-solid fa-toggle-on"></i> Change Status
        </button>
        <% if (master.pdfFile) { %>
          <a class="header-action-link" href="/fairtech/labels/file/<%= master._id %>/pdf" target="_blank" rel="noopener">
            <i class="fa-solid fa-file-pdf"></i> PDF
          </a>
        <% } %>
        <% if (master.cdrFile) { %>
          <a class="header-action-link" href="/fairtech/labels/file/<%= master._id %>/cdr" target="_blank" rel="noopener">
            <i class="fa-solid fa-file-arrow-down"></i> CDR
          </a>
        <% } %>
        <% if (master.jpgFile) { %>
          <a class="header-action-link" href="/fairtech/labels/file/<%= master._id %>/jpg" target="_blank" rel="noopener">
            <i class="fa-solid fa-file-image"></i> JPG
          </a>
        <% } %>
      </div>
    </div>

    <div class="tape-details-body">

      <div class="details-section">
        <h3 class="section-title">Label Details</h3>
        <div class="item-details-box">
          <div class="item-details-grid">
            <% (rows || []).forEach((row) => { %>
              <div class="item-detail">
                <div class="item-detail-label"><%= row.label %></div>
                <div class="item-detail-value"><%= row.value %></div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<form id="statusForm" method="POST" action="/fairtech/labels/edit/<%= master._id %>" style="display:none;">
  <input type="hidden" name="status" id="statusInput">
</form>

<div class="logout-modal" id="statusModal" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" style="width: min(400px, 95vw); padding: 0; border-radius: 14px; border: none;">
    <div class="dialog-header" style="padding: 18px 22px 14px; border-radius: 14px 14px 0 0; background: #044a78; color: #fff;">
      <h2 style="margin: 0; font-size: 17px; font-weight: 700;">Change Status</h2>
      <p style="margin: 4px 0 0; font-size: 13px; opacity: 0.8;"><%= master.labelProductId %></p>
    </div>
    <div class="dialog-body" style="padding: 20px 22px 22px; border-radius: 0 0 14px 14px; background: #fff;">
      <div class="status-radio-group">
        <label class="status-radio-label">
          <input type="radio" name="statusChoice" value="ACTIVE" <%= (master.status || 'ACTIVE') === 'ACTIVE' ? 'checked' : '' %>>
          <i class="fa-solid fa-circle-check" style="color: #16a34a;"></i> ACTIVE
        </label>
        <label class="status-radio-label">
          <input type="radio" name="statusChoice" value="INACTIVE" <%= master.status === 'INACTIVE' ? 'checked' : '' %>>
          <i class="fa-solid fa-circle-xmark" style="color: #9ca3af;"></i> INACTIVE
        </label>
      </div>
      <div class="logout-actions" style="margin-top: 18px;">
        <button class="logout-btn" type="button" onclick="closeStatusModal()">Cancel</button>
        <button class="logout-btn primary" type="button" onclick="submitStatus()">Update</button>
      </div>
    </div>
  </div>
</div>

<form id="deleteForm" method="POST" style="display:none;"></form>
<div class="logout-modal" id="deleteModal" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true">
    <h2 class="logout-title">Remove binding?</h2>
    <p class="logout-text">This will permanently remove this client label binding.</p>
    <div class="logout-actions">
      <button class="logout-btn" type="button" id="deleteCancelBtn">Cancel</button>
      <button class="logout-btn primary" type="button" id="deleteConfirmBtn">Remove</button>
    </div>
  </div>
</div>

<script>
  const statusModal = document.getElementById("statusModal");

  function openStatusDialog() {
    statusModal.classList.add("show");
    statusModal.setAttribute("aria-hidden", "false");
  }

  function closeStatusModal() {
    statusModal.classList.remove("show");
    statusModal.setAttribute("aria-hidden", "true");
  }

  function submitStatus() {
    const chosen = statusModal.querySelector('input[name="statusChoice"]:checked');
    if (!chosen) return;
    const csrf = document.querySelector('meta[name="csrf-token"]')?.getAttribute("content") || "";
    const form = document.getElementById("statusForm");
    let csrfInput = form.querySelector('input[name="_csrf"]');
    if (!csrfInput) {
      csrfInput = Object.assign(document.createElement("input"), { type: "hidden", name: "_csrf" });
      form.appendChild(csrfInput);
    }
    csrfInput.value = csrf;
    document.getElementById("statusInput").value = chosen.value;
    form.submit();
  }

  statusModal.addEventListener("click", (e) => { if (e.target === statusModal) closeStatusModal(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeStatusModal(); });

  let bindingToDelete = "";
  const deleteModal = document.getElementById("deleteModal");
  const deleteForm  = document.getElementById("deleteForm");

  window.promptDelete = function (id) {
    bindingToDelete = String(id || "");
    deleteModal.classList.add("show");
    deleteModal.setAttribute("aria-hidden", "false");
  };

  function closeModal() {
    deleteModal.classList.remove("show");
    deleteModal.setAttribute("aria-hidden", "true");
    bindingToDelete = "";
  }

  document.getElementById("deleteCancelBtn").addEventListener("click", closeModal);
  deleteModal.addEventListener("click", (e) => { if (e.target === deleteModal) closeModal(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });

  document.getElementById("deleteConfirmBtn").addEventListener("click", () => {
    if (!bindingToDelete) return closeModal();
    const csrf = document.querySelector('meta[name="csrf-token"]')?.getAttribute("content") || "";
    let inp = deleteForm.querySelector('input[name="_csrf"]');
    if (!inp) {
      inp = Object.assign(document.createElement("input"), { type: "hidden", name: "_csrf" });
      deleteForm.appendChild(inp);
    }
    inp.value = csrf;
    deleteForm.action = `/fairtech/labels-binding/delete/${bindingToDelete}`;
    deleteForm.submit();
  });
</script>
