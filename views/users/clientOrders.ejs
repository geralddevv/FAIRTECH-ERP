<% layout('/layout/boilerplate') -%>

<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />
<link href="https://unpkg.com/tabulator-tables@5.6.2/dist/css/tabulator_modern.min.css" rel="stylesheet" />

<div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
  <div class="indi-head">
    <h1>Purchase History — <%= clientName %></h1>
    <div style="display: flex; gap: 10px; align-items: center">
      <a
        href="/fairtech/client/view"
        style="
          padding: 6px 14px;
          background: #044a78;
          color: white;
          border-radius: 6px;
          text-decoration: none;
          font-size: 14px;
          font-weight: 500;
          display: inline-flex;
          align-items: center;
          gap: 6px;
          transition: opacity 0.2s;
        "
        onmouseover="this.style.opacity = '0.85'"
        onmouseout="this.style.opacity = '1'"
      >
        <i class="fa-solid fa-arrow-left"></i>
        <span>Back to Clients</span>
      </a>
    </div>
  </div>

  <div class="table-spinner"><div class="spinner-circle"></div></div>
  <div id="master-table" class="tabulator tabulator-modern"></div>
</div>

<script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
<script id="orders-data" type="application/json"><%- safeJson(orders) %></script>
<script>
  const rawOrders = JSON.parse(document.getElementById("orders-data").textContent);

  const ITEM_TYPE_LABELS = {
    Tape: "TAPE",
    PosRoll: "POS ROLL",
    Tafeta: "TAFETA",
    Ttr: "TTR",
    Label: "PLAIN LABEL",
    ColorLabel: "COLOR LABEL",
  };

  function getItemName(row) {
    const item = row.item;
    if (!item) return "N/A";
    switch (row.onModel) {
      case "Tape":
        return item.tapePaperCode || item.tapeProductId || "N/A";
      case "PosRoll":
        return item.posPaperCode ? `${item.posPaperCode} ${item.posGsm ?? ""}gsm`.trim() : (item.posProductId || "N/A");
      case "Tafeta":
        return item.tafetaMaterialCode ? `${item.tafetaMaterialCode} ${item.tafetaGsm ?? ""}gsm`.trim() : (item.tafetaProductId || "N/A");
      case "Ttr":
        return item.ttrType || item.ttrProductId || "N/A";
      case "Label":
      case "ColorLabel":
        return item.productId || `${item.labelWidth || ""}x${item.labelHeight || ""}`.trim() || "N/A";
      default:
        return "N/A";
    }
  }

  function formatDate(v) {
    if (!v) return "-";
    const d = new Date(v);
    if (isNaN(d)) return "-";
    return d.toLocaleDateString("en-IN", { year: "numeric", month: "short", day: "2-digit" });
  }

  const tableData = rawOrders.map((o) => {
    const qty = Number(o.quantity) || 0;
    const dispatched = Number(o.dispatchedQuantity) || 0;
    return {
      ...o,
      userName: o.userId?.userName || "",
      itemTypeLabel: ITEM_TYPE_LABELS[o.onModel] || o.onModel || "N/A",
      itemName: getItemName(o),
      dateText: formatDate(o.createdAt),
      estimatedDateText: formatDate(o.estimatedDate),
      balance: Math.max(qty - dispatched, 0),
      valueAmount: qty * (Number(o.orderRate) || 0),
    };
  });

  const withTextFilter = (column, placeholder = "Search") => ({
    headerFilter: "input",
    headerFilterPlaceholder: placeholder,
    minWidth: 100,
    ...column,
  });

  new Tabulator("#master-table", {
    data: tableData,
    height: "100%",
    responsiveLayout: false,
    movableColumns: true,
    initialSort: [{ column: "dateText", dir: "desc" }],
    placeholder: "No purchases found for this client.",
    columns: [
      withTextFilter({ title: "Date", field: "dateText", width: 130 }),
      withTextFilter({ title: "User", field: "userName", widthGrow: 1 }),
      withTextFilter({ title: "Item Type", field: "itemTypeLabel", width: 130 }),
      withTextFilter({
        title: "Item",
        field: "itemName",
        widthGrow: 2,
        formatter: (cell) => `<span style="color:#044A78;font-weight:600;">${cell.getValue()}</span>`,
      }),
      withTextFilter({ title: "Qty", field: "quantity", hozAlign: "center", width: 80 }),
      withTextFilter({ title: "Sent", field: "dispatchedQuantity", hozAlign: "center", width: 80 }),
      withTextFilter({
        title: "Bal",
        field: "balance",
        hozAlign: "center",
        width: 80,
        formatter: (cell) => `<span style="font-weight:700;color:#044A78;">${cell.getValue()}</span>`,
      }),
      withTextFilter({
        title: "Rate (₹)",
        field: "orderRate",
        hozAlign: "right",
        width: 100,
        formatter: (cell) => {
          const val = cell.getValue();
          if (val == null) return "-";
          return `₹${Number(val).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 3 })}`;
        },
      }),
      withTextFilter({
        title: "Value (₹)",
        field: "valueAmount",
        hozAlign: "right",
        width: 120,
        sorter: "number",
        formatter: (cell) => `₹${Number(cell.getValue() || 0).toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`,
      }),
      {
        title: "Status",
        field: "status",
        width: 120,
        hozAlign: "center",
        headerFilter: "select",
        headerFilterParams: {
          values: { "": "All", PENDING: "Pending", CONFIRMED: "Confirmed", DISPATCHED: "Dispatched", DELIVERED: "Delivered", CANCELLED: "Cancelled" },
          clearable: true,
        },
        formatter: (cell) => {
          const status = cell.getValue() || "";
          const colors = {
            PENDING: "#f59e0b",
            CONFIRMED: "#3b82f6",
            DISPATCHED: "#8b5cf6",
            DELIVERED: "#10b981",
            CANCELLED: "#ef4444",
          };
          const bg = colors[status] || "#6b7280";
          return `<span style="display:inline-block;padding:2px 10px;background:${bg};color:white;border-radius:12px;font-size:11px;font-weight:600;">${status}</span>`;
        },
      },
      withTextFilter({ title: "PO No", field: "poNumber" }),
      withTextFilter({ title: "Est. Delivery", field: "estimatedDateText" }),
      withTextFilter({ title: "Remarks", field: "remarks" }),
    ],
  });
</script>
