<% layout('/layout/boilerplate') -%>

<div class="main-content" style="padding: 10px; display: flex; flex-direction: column; gap: 10px;">
  <div>
    <style>
      #coordinator-vendor-status:disabled {
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        background-image: none !important;
        padding-right: 14px;
      }

      .locations-headings {
        margin-bottom: 0;
        grid-column: span 32;
        background-color: #044A78;
        color: white;
        padding: 10px;
        border-radius: 5px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
      }

      .locations-headings span {
        flex: 1;
        font-size: 16px;
        font-weight: 600;
        padding-left: 15px;
      }

      .locations-details {
        grid-column: span 32;
      }

      .location-row {
        margin-bottom: 10px;
        padding: 10px;
        border-radius: 5px;
        border: 2px solid #044A78;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .location-row .loc-line {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 8px;
        align-items: center;
      }

      .location-row .loc-title {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #044A78;
        margin-bottom: 6px;
      }

      /* All pick up fields (type selector first) on a single wrapping row. */
      .location-row .loc-fields {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }

      .location-row .loc-dispatch-mode {
        flex: 0 0 150px;
      }

      /* Transparent wrapper so the transport fields share the .loc-fields row. */
      .location-row .loc-transport {
        display: contents;
      }

      .location-row .loc-fields > input,
      .location-row .loc-transport > input,
      .location-row .loc-transport > select {
        flex: 1 1 130px;
        min-width: 110px;
      }

      .location-row .loc-self .loc-self-badge {
        display: inline-block;
        background: #eef5fb;
        color: #044A78;
        border: 1px dashed #044A78;
        border-radius: 4px;
        padding: 6px 12px;
        font-size: 13px;
        font-weight: 600;
      }

      .location-row input,
      .location-row select,
      .location-row textarea {
        width: 100%;
        border: 1px solid #044A78;
        height: 38px;
      }

      .location-row textarea {
        resize: none;
      }
    </style>
    <% const vendorSource = typeof vendor !== "undefined" && vendor ? vendor : user; %>
    <%
      const initialLocationDetails = typeof locals.initialLocationDetails !== "undefined" && Array.isArray(locals.initialLocationDetails) && locals.initialLocationDetails.length
        ? locals.initialLocationDetails
        : (Array.isArray(user.locationDetails) && user.locationDetails.length
          ? user.locationDetails
          : [{ userLocation: user.userLocation || "", dispatchAddress: user.dispatchAddress || "" }]);
    %>
    <form
      id="vendor-user-edit-form"
      action="/fairtech/form/edit/vendor-user/<%= user._id %>"
      method="post"
      class="user-content span-full needs-validation"
      style="display:grid;grid-template-columns:repeat(32,1fr);gap:10px;"
      autocomplete="off"
      novalidate
    >
      <div class="span-full form-heading">
        <h1>Edit Vendor Coordinator</h1>
      </div>
          
      <div class="span-full form-subheading">
        <h1>Vendor Information</h1>
      </div>

      <div class="span-dual">
        <label for="userform-vendor-name">Vendor Name</label>
        <input
          type="text"
          id="userform-vendor-name"
          class="form-control input-tag"
          name="vendorName"
          value="<%= vendorSource.vendorName %>"
          disabled
          required
        />
      </div>

      <div class="span-five">
        <label for="user-vendor-id">Vendor Id</label>
        <input
          id="user-vendor-id"
          class="form-control input-tag"
          name="vendorId"
          value="<%= vendorSource.vendorId %>"
          disabled
          required
        />
      </div>

      <div class="span-five">
        <label for="coordinator-vendor-status">Vendor Status</label>
        <select name="vendorStatus" id="coordinator-vendor-status" class="form-control select-tag" disabled required>
          <option value="" disabled hidden>Select</option>
          <option value="ACTIVE" <%= vendorSource.vendorStatus === "ACTIVE" ? "selected" : "" %>>ACTIVE</option>
          <option value="INACTIVE" <%= vendorSource.vendorStatus === "INACTIVE" ? "selected" : "" %>>INACTIVE</option>
          <option value="BLACKLISTED" <%= vendorSource.vendorStatus === "BLACKLISTED" ? "selected" : "" %>>BLACKLISTED</option>
          <option value="OTHERS" <%= vendorSource.vendorStatus === "OTHERS" ? "selected" : "" %>>OTHERS</option>
        </select>
      </div>

      <div class="span-seven">
        <label for="coordinator-ho-location">H/O Location</label>
        <input
          type="text"
          id="coordinator-ho-location"
          class="form-control input-tag"
          name="hoLocation"
          value="<%= vendorSource.hoLocation %>"
          disabled
          required
        />
      </div>

      <div class="span-seven">
        <label for="coordinator-warehouse-location">Warehouse Location</label>
        <input
          type="text"
          id="coordinator-warehouse-location"
          class="form-control input-tag"
          name="warehouseLocation"
          value="<%= vendorSource.warehouseLocation %>"
          disabled
          required
        />
      </div>

      <div class="span-full form-subheading">
        <h1>Coordinator Information</h1>
      </div>

      <div class="span-seven">
        <label for="user-name">Coordinator Name</label>
        <input type="text" id="user-name" class="form-control input-tag" name="userName" value="<%= user.userName %>" required />
      </div>

      <div class="span-six">
        <label for="user-location">Location</label>
        <input type="text" id="user-location" class="form-control input-tag" name="userLocation" value="<%= user.userLocation %>" required />
      </div>

      <div class="span-six">
        <label for="user-department">Department</label>
        <input
          type="text"
          id="user-department"
          class="form-control input-tag"
          name="userDepartment"
          value="<%= user.userDepartment %>"
          required
        />
      </div>

      <div class="span-six">
        <label for="user-contact-no">Contact No</label>
        <input type="text" id="user-contact-no" class="form-control input-tag" name="userContact" value="<%= user.userContact %>" required />
      </div>

      <div class="span-seven">
        <label for="user-email">Email</label>
        <input type="email" id="user-email" class="form-control" name="userEmail" value="<%= user.userEmail %>" required />
      </div>

      <div class="span-full form-subheading" style="display: flex; align-items: center; gap: 12px;">
        <h1>Location Details</h1>
        <div style="display: inline-flex; align-items: center; gap: 6px; margin-left: 10px;">
          <button type="button" id="locations-minus" style="width: 30px; height: 30px; border: 1px solid #044A78; background: white; color: #044A78; border-radius: 4px; font-size: 18px; line-height: 1; cursor: pointer;">-</button>
          <input
            type="text"
            id="locations-count"
            style="width: 56px; height: 30px; text-align: center; border: 1px solid #044A78; border-radius: 4px;"
            class="form-control"
            name="locationsCount"
            value="<%= initialLocationDetails.length %>"
            readonly
          />
          <button type="button" id="locations-plus" style="width: 30px; height: 30px; border: 1px solid #044A78; background: white; color: #044A78; border-radius: 4px; font-size: 18px; line-height: 1; cursor: pointer;">+</button>
        </div>
      </div>

      <div class="span-full" style="font-size: 12px; color: #64748b; padding: 10px 14px;">
        Each location has its own pick up details. Choose Transport or Self Pick Up per location.
      </div>

      <div id="locations-details" class="locations-details">
        <% initialLocationDetails.forEach((loc, index) => { %>
          <% const isSelf = String(loc.selfDispatch || "") === "Self Dispatch"; %>
          <div class="location-row">
            <div class="loc-line">
              <input
                type="text"
                class="form-control input-tag"
                name="locationDetails[<%= index %>][userLocation]"
                placeholder="Enter Location"
                aria-label="Location <%= index + 1 %>"
                value="<%= String(loc.userLocation || loc.location || '').toUpperCase() %>"
                oninput="this.value = this.value.toUpperCase()"
                required
              />
              <input
                type="text"
                class="form-control input-tag"
                name="locationDetails[<%= index %>][dispatchAddress]"
                placeholder="Enter Address"
                aria-label="Address <%= index + 1 %>"
                value="<%= String(loc.dispatchAddress || loc.address || '').toUpperCase() %>"
                oninput="this.value = this.value.toUpperCase()"
                required
              />
            </div>
            <div class="loc-dispatch">
              <span class="loc-title">Pick Up Details — Location <%= index + 1 %></span>
              <div class="loc-fields">
                <select class="loc-dispatch-mode form-control select-tag" aria-label="Pick Up Type for location <%= index + 1 %>">
                  <option value="TRANSPORT" <%= isSelf ? '' : 'selected' %>>Transport</option>
                  <option value="SELF" <%= isSelf ? 'selected' : '' %>>Self Pick Up</option>
                </select>
                <input type="hidden" class="loc-self-dispatch" name="locationDetails[<%= index %>][selfDispatch]" value="<%= isSelf ? 'Self Dispatch' : '' %>" />
                <div class="loc-transport" style="<%= isSelf ? 'display:none;' : '' %>">
                  <input type="text" class="form-control input-tag" name="locationDetails[<%= index %>][transportName]" placeholder="Transport Name" value="<%= String(loc.transportName || '').toUpperCase() %>" oninput="this.value = this.value.toUpperCase()" />
                  <input type="text" class="form-control input-tag loc-transport-contact" name="locationDetails[<%= index %>][transportContact]" placeholder="Transport Contact" value="<%= loc.transportContact || '' %>" />
                  <input type="text" class="form-control input-tag" name="locationDetails[<%= index %>][dropLocation]" placeholder="Drop Location 1" value="<%= String(loc.dropLocation || '').toUpperCase() %>" oninput="this.value = this.value.toUpperCase()" />
                  <input type="text" class="form-control input-tag" name="locationDetails[<%= index %>][dropLocation1]" placeholder="Drop Location 2" value="<%= String(loc.dropLocation1 || '').toUpperCase() %>" oninput="this.value = this.value.toUpperCase()" />
                  <select class="form-control select-tag" name="locationDetails[<%= index %>][deliveryMode]">
                    <option value="">Pick Up Mode</option>
                    <option value="DOOR" <%= loc.deliveryMode === 'DOOR' ? 'selected' : '' %>>DOOR</option>
                    <option value="GODOWN" <%= loc.deliveryMode === 'GODOWN' ? 'selected' : '' %>>GODOWN</option>
                  </select>
                  <input type="text" class="form-control input-tag" name="locationDetails[<%= index %>][deliveryLocation]" placeholder="Pick Up Loc" value="<%= String(loc.deliveryLocation || '').toUpperCase() %>" oninput="this.value = this.value.toUpperCase()" />
                  <input type="text" class="form-control input-tag" name="locationDetails[<%= index %>][deliveryLocation1]" placeholder="Pick Up Loc 1" value="<%= String(loc.deliveryLocation1 || '').toUpperCase() %>" oninput="this.value = this.value.toUpperCase()" />
                  <select class="form-control select-tag" name="locationDetails[<%= index %>][vendorPayment]">
                    <option value="">Payment</option>
                    <option value="PAY" <%= loc.vendorPayment === 'PAY' ? 'selected' : '' %>>PAY</option>
                    <option value="TO PAY" <%= loc.vendorPayment === 'TO PAY' ? 'selected' : '' %>>TO PAY</option>
                    <option value="NA" <%= loc.vendorPayment === 'NA' ? 'selected' : '' %>>NA</option>
                  </select>
                </div>
                <div class="loc-self" style="<%= isSelf ? '' : 'display:none;' %>">
                  <span class="loc-self-badge">Self Pick Up</span>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <div class="span-full btn-grp" style="flex-direction: row;">
        <button type="button" id="cancelBtn">Cancel</button>
        <button id="vendor-user-edit-submit" class="submit-btn" type="submit">Update Coordinator Details</button>
      </div>
    </form>
  </div>
</div>

<script>
  const form = document.getElementById("vendor-user-edit-form");
  const submitBtn = document.getElementById("vendor-user-edit-submit");
  const cancelBtn = document.getElementById("cancelBtn");

  const locationCountInput = document.getElementById("locations-count");
  const locationContainer = document.getElementById("locations-details");
  const locationMinusBtn = document.getElementById("locations-minus");
  const locationPlusBtn = document.getElementById("locations-plus");

  function normalizeLocationCount(value) {
    const parsed = Number.parseInt(value, 10);
    if (!Number.isFinite(parsed) || parsed < 1) return 1;
    return Math.min(parsed, 20);
  }

  function escapeAttr(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;");
  }

  function formatMobileValue(value) {
    const digits = String(value ?? "").replace(/\D/g, "").slice(0, 10);
    return digits.length > 5 ? `${digits.slice(0, 5)} ${digits.slice(5)}` : digits;
  }

  const EMPTY_ROW = {
    userLocation: "",
    dispatchAddress: "",
    selfDispatch: "",
    transportName: "",
    transportContact: "",
    dropLocation: "",
    dropLocation1: "",
    deliveryMode: "",
    deliveryLocation: "",
    deliveryLocation1: "",
    vendorPayment: "",
  };

  function readRowValues(row) {
    const get = (suffix) => row.querySelector(`[name$="[${suffix}]"]`)?.value || "";
    return {
      userLocation: get("userLocation"),
      dispatchAddress: get("dispatchAddress"),
      selfDispatch: get("selfDispatch"),
      transportName: get("transportName"),
      transportContact: get("transportContact"),
      dropLocation: get("dropLocation"),
      dropLocation1: get("dropLocation1"),
      deliveryMode: get("deliveryMode"),
      deliveryLocation: get("deliveryLocation"),
      deliveryLocation1: get("deliveryLocation1"),
      vendorPayment: get("vendorPayment"),
    };
  }

  function buildRowHtml(i, v) {
    const isSelf = v.selfDispatch === "Self Dispatch";
    const sel = (val, opt) => (val === opt ? "selected" : "");
    return `
      <div class="location-row">
        <div class="loc-line">
          <input type="text" class="form-control input-tag" name="locationDetails[${i}][userLocation]"
            placeholder="Enter Location" aria-label="Location ${i + 1}"
            value="${escapeAttr(v.userLocation.toUpperCase())}" oninput="this.value = this.value.toUpperCase()" required />
          <input type="text" class="form-control input-tag" name="locationDetails[${i}][dispatchAddress]"
            placeholder="Enter Address" aria-label="Address ${i + 1}"
            value="${escapeAttr(v.dispatchAddress.toUpperCase())}" oninput="this.value = this.value.toUpperCase()" required />
        </div>
        <div class="loc-dispatch">
          <span class="loc-title">Pick Up Details — Location ${i + 1}</span>
          <div class="loc-fields">
            <select class="loc-dispatch-mode form-control select-tag" aria-label="Pick Up Type for location ${i + 1}">
              <option value="TRANSPORT" ${isSelf ? "" : "selected"}>Transport</option>
              <option value="SELF" ${isSelf ? "selected" : ""}>Self Pick Up</option>
            </select>
            <input type="hidden" class="loc-self-dispatch" name="locationDetails[${i}][selfDispatch]" value="${isSelf ? "Self Dispatch" : ""}" />
            <div class="loc-transport" style="${isSelf ? "display:none;" : ""}">
              <input type="text" class="form-control input-tag" name="locationDetails[${i}][transportName]"
                placeholder="Transport Name" value="${escapeAttr(v.transportName.toUpperCase())}" oninput="this.value = this.value.toUpperCase()" />
              <input type="text" class="form-control input-tag loc-transport-contact" name="locationDetails[${i}][transportContact]"
                placeholder="Transport Contact" value="${escapeAttr(v.transportContact)}" />
              <input type="text" class="form-control input-tag" name="locationDetails[${i}][dropLocation]"
                placeholder="Drop Location 1" value="${escapeAttr(v.dropLocation.toUpperCase())}" oninput="this.value = this.value.toUpperCase()" />
              <input type="text" class="form-control input-tag" name="locationDetails[${i}][dropLocation1]"
                placeholder="Drop Location 2" value="${escapeAttr(v.dropLocation1.toUpperCase())}" oninput="this.value = this.value.toUpperCase()" />
              <select class="form-control select-tag" name="locationDetails[${i}][deliveryMode]">
                <option value="">Pick Up Mode</option>
                <option value="DOOR" ${sel(v.deliveryMode, "DOOR")}>DOOR</option>
                <option value="GODOWN" ${sel(v.deliveryMode, "GODOWN")}>GODOWN</option>
              </select>
              <input type="text" class="form-control input-tag" name="locationDetails[${i}][deliveryLocation]"
                placeholder="Pick Up Loc" value="${escapeAttr(v.deliveryLocation.toUpperCase())}" oninput="this.value = this.value.toUpperCase()" />
              <input type="text" class="form-control input-tag" name="locationDetails[${i}][deliveryLocation1]"
                placeholder="Pick Up Loc 1" value="${escapeAttr(v.deliveryLocation1.toUpperCase())}" oninput="this.value = this.value.toUpperCase()" />
              <select class="form-control select-tag" name="locationDetails[${i}][vendorPayment]">
                <option value="">Payment</option>
                <option value="PAY" ${sel(v.vendorPayment, "PAY")}>PAY</option>
                <option value="TO PAY" ${sel(v.vendorPayment, "TO PAY")}>TO PAY</option>
                <option value="NA" ${sel(v.vendorPayment, "NA")}>NA</option>
              </select>
            </div>
            <div class="loc-self" style="${isSelf ? "" : "display:none;"}">
              <span class="loc-self-badge">Self Pick Up</span>
            </div>
          </div>
        </div>
      </div>
    `;
  }

  function renderLocationRows(count) {
    if (!locationContainer) return;

    const safeCount = normalizeLocationCount(count);
    const existingRows = Array.from(locationContainer.querySelectorAll(".location-row"));
    const currentValues = existingRows.map(readRowValues);

    let html = "";
    for (let i = 0; i < safeCount; i += 1) {
      html += buildRowHtml(i, currentValues[i] || { ...EMPTY_ROW });
    }
    locationContainer.innerHTML = html;
  }

  function setLocationCount(value) {
    if (!locationCountInput || !locationContainer) return;
    const safeCount = normalizeLocationCount(value);
    locationCountInput.value = String(safeCount);
    renderLocationRows(safeCount);
  }

  function applyDispatchMode(row, mode) {
    if (!row) return;
    const transport = row.querySelector(".loc-transport");
    const self = row.querySelector(".loc-self");
    const hidden = row.querySelector(".loc-self-dispatch");
    const isSelf = mode === "SELF";
    if (transport) transport.style.display = isSelf ? "none" : "";
    if (self) self.style.display = isSelf ? "" : "none";
    if (hidden) hidden.value = isSelf ? "Self Dispatch" : "";
  }

  function initLocationRepeater() {
    if (!locationCountInput || !locationContainer) return;

    // Re-render so the count input and rows stay in sync (values preserved).
    setLocationCount(locationCountInput.value || 1);

    locationMinusBtn?.addEventListener("click", () => {
      const current = normalizeLocationCount(locationCountInput.value || 1);
      setLocationCount(Math.max(1, current - 1));
    });

    locationPlusBtn?.addEventListener("click", () => {
      const current = normalizeLocationCount(locationCountInput.value || 1);
      setLocationCount(Math.min(20, current + 1));
    });

    // Per-row pick up type toggle (delegated, survives re-renders).
    locationContainer.addEventListener("change", (e) => {
      const modeSel = e.target.closest(".loc-dispatch-mode");
      if (!modeSel) return;
      applyDispatchMode(modeSel.closest(".location-row"), modeSel.value);
    });

    // Mobile formatting for each row's transport contact.
    locationContainer.addEventListener("input", (e) => {
      const el = e.target.closest(".loc-transport-contact");
      if (!el) return;
      el.value = formatMobileValue(el.value);
    });
  }

  if (cancelBtn) {
    cancelBtn.addEventListener("click", () => {
      window.location.href = "/fairtech/vendor/coordinator/details/<%= user._id %>";
    });
  }

  initLocationRepeater();

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    submitBtn.disabled = true;
    try {
      const res = await fetch(form.action, { method: "POST", body: new FormData(form) });
      const data = await res.json();
      if (!res.ok || !data?.success) {
        submitBtn.disabled = false;
        if (window.showToast) window.showToast(data?.message || "Failed to update coordinator", true);
        return;
      }
      window.location.href = data.redirect || "/fairtech/vendor/coordinator/view";
    } catch (err) {
      submitBtn.disabled = false;
      if (window.showToast) window.showToast("Failed to update coordinator", true);
    }
  });
</script>
