<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />

<body>
  <div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
    <style>
      .header-action-btn {
        background-color: #f0f0f0;
        color: #044a78;
        padding: 2px 14px;
        font-size: 14px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        border-radius: 0.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: all 0.2s ease-in-out;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .header-action-btn:hover {
        background-color: #e4e4e4;
      }
      #prodcalc-table {
        width: 100%;
        flex: 1 1 auto;
        min-height: 0;
      }
      .row-margin-profit {
        background-color: #d7f5dc !important;
      }
      .row-margin-edge {
        background-color: #fdf3c7 !important;
      }
      .row-margin-loss {
        background-color: #fadbd8 !important;
      }
    </style>

    <div class="indi-head">
      <h1>Production Binding</h1>

      <div style="display: flex; gap: 10px; align-items: center">
        <button class="header-action-btn" onclick="window.location.href = '/fairtech/form/prodcalc'">
          <i class="fa-solid fa-plus" style="margin-right: 4px"></i> New Binding
        </button>

        <div class="download-selector" id="downloadSelector">
          <button class="download-selector__trigger">
            <span>
              <i class="fa-solid fa-file-arrow-down"></i>
              <span class="download-typo">Download</span>
            </span>
            <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
          </button>
          <div class="download-selector__menu" id="downloads">
            <span class="download-selector__option" id="download-pdf">
              <i class="fas fa-file-pdf download-selector__option-icon"></i>
              <span>PDF</span>
            </span>
            <span class="download-selector__option" id="download-xlsx">
              <i class="fas fa-file-excel download-selector__option-icon"></i>
              <span>Excel</span>
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="table-spinner"><div class="spinner-circle"></div></div>
    <div id="prodcalc-table" class="tabulator tabulator-modern"></div>
  </div>

  <!-- Tabulator JS -->
  <script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.4.0/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.20/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>

  <script>
    // ================= DOWNLOAD DROPDOWN UI =================

    const downloadSelector = document.getElementById("downloadSelector");
    const triggerBtn = downloadSelector.querySelector(".download-selector__trigger");

    triggerBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      downloadSelector.classList.toggle("download-selector--active");
      const icon = triggerBtn.querySelector(".download-selector__trigger-icon");
      icon.style.transform = downloadSelector.classList.contains("download-selector--active")
        ? "rotate(180deg)"
        : "rotate(0deg)";
    });

    document.addEventListener("click", () => {
      downloadSelector.classList.remove("download-selector--active");
      const icon = triggerBtn.querySelector(".download-selector__trigger-icon");
      icon.style.transform = "rotate(0deg)";
    });

    downloadSelector.querySelector(".download-selector__menu").addEventListener("click", (e) => {
      e.stopPropagation();
    });

    // ================= TABULATOR DATA =================

    let tableData = [];
    try {
      tableData = <%- safeJson(jsonData || []) %>;
    } catch (err) {
      console.error("Prod Calc View JSON error", err);
    }

    const fmtDate = (v) => {
      if (!v) return "";
      const d = new Date(v);
      if (isNaN(d)) return "";
      const dd = String(d.getDate()).padStart(2, "0");
      const mm = String(d.getMonth() + 1).padStart(2, "0");
      const yyyy = d.getFullYear();
      return `${dd}/${mm}/${yyyy}`;
    };

    // Add Indian-style thousands separators while preserving the value's own
    // sign and decimal places, so large amounts are easy to read.
    const fmtNum = (v) => {
      if (v === undefined || v === null || v === "") return "";
      const n = Number(v);
      if (!Number.isFinite(n)) return String(v);
      const str = String(v);
      const dot = str.indexOf(".");
      const decimals = dot === -1 ? 0 : str.length - dot - 1;
      return n.toLocaleString("en-IN", { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
    };

    // ================= TABULATOR INIT =================

    let table; // MUST be global for download to work

    const withTextFilter = (column, placeholder = "Search") => ({
      headerFilter: "input",
      headerFilterPlaceholder: placeholder,
      minWidth: 100,
      ...column,
    });

    // Margin band: prodActual (the Actual % field, e.g. "12.34") negative
    // means a loss, 0-10% is a thin/breakeven "edge" margin, above that is a
    // healthy profit.
    const EDGE_MARGIN_PERCENT = 10;

    function marginRowClass(row) {
      const pct = parseFloat(row.prodActual);
      if (isNaN(pct)) return "";
      if (pct < 0) return "row-margin-loss";
      if (pct < EDGE_MARGIN_PERCENT) return "row-margin-edge";
      return "row-margin-profit";
    }

    function initTable() {
      table = new Tabulator("#prodcalc-table", {
        data: tableData,
        height: "100%",
        virtualDom: true,
        responsiveLayout: false,
        initialSort: [{ column: "createdAt", dir: "desc" }],
        movableColumns: true,
        placeholder: "No production bindings saved yet",
        rowFormatter: (row) => {
          const rowEl = row.getElement();
          rowEl.classList.remove("row-margin-profit", "row-margin-edge", "row-margin-loss");
          const cls = marginRowClass(row.getData());
          if (cls) rowEl.classList.add(cls);
        },
        columns: [
          {
            title: "Actions",
            hozAlign: "center",
            headerSort: false,
            width: 130,
            formatter: (cell) => {
              const id = cell.getRow().getData()._id;
              return `
                <div style="display:flex; gap:6px; justify-content:center; align-items:center; white-space:nowrap;">
                  <button onclick="viewProdBinding('${id}')" title="View Details"
                    style="height:24px; padding:2px 9px; background:#111827; color:#fff; border:none; border-radius:4px; cursor:pointer; font-size:11px;"
                    onmouseover="this.style.background='#374151'" onmouseout="this.style.background='#111827'"><i class="fa-solid fa-eye"></i></button>
                  <button onclick="editProdBinding('${id}')" title="Edit"
                    style="height:24px; padding:2px 9px; background:#3b82f6; color:#fff; border:none; border-radius:4px; cursor:pointer; font-size:11px;"
                    onmouseover="this.style.background='#2563eb'" onmouseout="this.style.background='#3b82f6'"><i class="fa-solid fa-pencil"></i></button>
                  <button onclick="deleteProdBinding('${id}')" title="Delete"
                    style="height:24px; padding:2px 9px; background:#ef4444; color:#fff; border:none; border-radius:4px; cursor:pointer; font-size:12px;"
                    onmouseover="this.style.background='#dc2626'" onmouseout="this.style.background='#ef4444'"><i class="fa-solid fa-trash"></i></button>
                </div>`;
            },
          },
          withTextFilter({
            title: "Date",
            field: "createdAt",
            formatter: (cell) => fmtDate(cell.getValue()),
            width: 110,
            headerSort: true,
          }),
          withTextFilter({ title: "Client", field: "companyName", widthGrow: 2 }),
          withTextFilter({ title: "User", field: "userName", widthGrow: 2 }),
          withTextFilter({ title: "Location", field: "userLocation", widthGrow: 1 }),
          withTextFilter({ title: "Job Name", field: "jobName", widthGrow: 2 }),
          withTextFilter({ title: "Width", field: "labelWidth", width: 100, hozAlign: "right" }),
          withTextFilter({ title: "Height", field: "labelHeight", width: 100, hozAlign: "right" }),
          withTextFilter({ title: "Order Qty", field: "orderQuantity", width: 110, hozAlign: "right", formatter: (cell) => fmtNum(cell.getValue()) }),
          withTextFilter({ title: "Die No", field: "prodDieno", width: 100 }),
          withTextFilter({ title: "Machine No", field: "dieMachineNo", widthGrow: 1 }),
          withTextFilter({ title: "Vendor", field: "prodVendorName", widthGrow: 1 }),
          withTextFilter({ title: "Prod Rate", field: "productionRate", width: 100, hozAlign: "right", formatter: (cell) => fmtNum(cell.getValue()) }),
          withTextFilter({ title: "Sales Rate", field: "prodSalesRate", width: 100, hozAlign: "right", formatter: (cell) => fmtNum(cell.getValue()) }),
          withTextFilter({ title: "Order Value", field: "prodOrderValue", width: 110, hozAlign: "right", formatter: (cell) => fmtNum(cell.getValue()) }),
          withTextFilter({ title: "Margin", field: "prodMargin", width: 100, hozAlign: "right", formatter: (cell) => fmtNum(cell.getValue()) }),
          withTextFilter({
            title: "Margin %",
            field: "prodActual",
            width: 100,
            hozAlign: "right",
            formatter: (cell) => {
              const v = cell.getValue();
              return v !== undefined && v !== "" ? `${v}%` : "";
            },
          }),
        ],
      });
    }

    window.addEventListener("load", initTable);

    // ================= ACTIONS: VIEW / EDIT / DELETE =================

    const escHtml = (v) => String(v ?? "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
    const findRow = (id) => tableData.find((r) => String(r._id) === String(id));
    const dash = (v) => { const s = fmtNum(v); return escHtml(s === "" ? "—" : s); };

    window.editProdBinding = function (id) {
      window.location.href = `/fairtech/form/prodcalc?editId=${encodeURIComponent(id)}`;
    };

    window.viewProdBinding = function (id) {
      const d = findRow(id);
      const dialog = document.getElementById("prodcalc-details-dialog");
      const body = document.getElementById("prodcalc-details-body");
      if (!d || !dialog || !body) return;

      const row = (label, val) => `<tr><td class="pk">${label}</td><td class="pv">${escHtml(val ?? "") || "—"}</td></tr>`;
      const size = (d.labelWidth || d.labelHeight) ? `${d.labelWidth || ""} × ${d.labelHeight || ""}` : "—";
      const calcRow = (name, base, alt) => `<tr><td class="pk">${name}</td><td class="pv">${dash(base)}</td><td class="pv">${dash(alt)}</td></tr>`;
      const pct = (v) => (v !== undefined && v !== null && v !== "") ? `${escHtml(v)}%` : "—";

      body.innerHTML = `
        <div class="pc-card">
          <div class="pc-head">
            <div><h1>${escHtml(d.companyName || "—")}</h1><div class="pc-sub">${escHtml(d.userName || "")}${d.userLocation ? " · " + escHtml(d.userLocation) : ""}</div></div>
            <button type="button" onclick="closeProdDetails()" class="pc-x" title="Close"><i class="fa-solid fa-xmark"></i></button>
          </div>
          <div class="pc-body">
            <table class="pc-table">
              ${row("Job Name", d.jobName)}
              ${row("Family", d.labelFamily)}
              ${row("Label Size", size)}
              ${row("Paper Type", d.paperType)}
              ${row("Paper Code", d.prodPaperCode)}
              ${row("Paper Size", d.prodPaperSize)}
              ${row("Vendor", d.prodVendorName)}
              ${row("M Rate", d.prodMRate)}
              <tr><td class="pk">Order Qty</td><td class="pv">${dash(d.orderQuantity)}</td></tr>
              ${row("Die No", d.prodDieno)}
              ${row("Machine No", d.dieMachineNo)}
            </table>
            <h3 class="pc-h3">Calculated Values</h3>
            <table class="pc-table">
              <thead><tr><th>Metric</th><th>645</th><th>625</th></tr></thead>
              ${calcRow("Production Area", d.prodArea, d.prodArea625)}
              ${calcRow("Production Rate", d.productionRate, d.productionRate625)}
              ${calcRow("Sq Mtrs Rate", d.prodSqMeter, d.prodSqMeter625)}
              ${calcRow("M Cost", d.prodMCost, d.prodMCost625)}
              ${calcRow("Margin", d.prodMargin, d.prodMargin625)}
              <tr><td class="pk">Actual %</td><td class="pv">${pct(d.prodActual)}</td><td class="pv">${pct(d.prodActual625)}</td></tr>
            </table>
          </div>
        </div>`;
      dialog.style.display = "flex";
    };

    window.closeProdDetails = function () {
      const dialog = document.getElementById("prodcalc-details-dialog");
      if (dialog) dialog.style.display = "none";
    };

    let pendingDeleteId = null;
    window.deleteProdBinding = function (id) {
      pendingDeleteId = id;
      const d = findRow(id);
      const msg = document.getElementById("pc-confirm-msg");
      if (msg) msg.textContent = `Delete the production binding for "${d?.companyName || "this client"}"? This cannot be undone.`;
      document.getElementById("pc-confirm-dialog").style.display = "flex";
    };

    function closeProdConfirm() {
      pendingDeleteId = null;
      document.getElementById("pc-confirm-dialog").style.display = "none";
    }

    async function confirmDeleteYes() {
      if (!pendingDeleteId) return;
      const id = pendingDeleteId;
      const btn = document.getElementById("pc-confirm-yes");
      btn.disabled = true;
      try {
        const res = await fetch(`/fairtech/prodcalc/${encodeURIComponent(id)}`, { method: "DELETE" });
        const out = await res.json().catch(() => ({}));
        if (res.ok && out.success) {
          window.location.reload();
        } else {
          alert(out.message || "Failed to delete production binding.");
          btn.disabled = false;
        }
      } catch (err) {
        alert("Failed to delete production binding.");
        btn.disabled = false;
      }
    }

    window.addEventListener("load", () => {
      document.getElementById("pc-confirm-no").addEventListener("click", closeProdConfirm);
      document.getElementById("pc-confirm-yes").addEventListener("click", confirmDeleteYes);
      ["prodcalc-details-dialog", "pc-confirm-dialog"].forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.addEventListener("click", (e) => { if (e.target === el) el.style.display = "none"; });
      });
    });

    // ================= DOWNLOAD ACTIONS =================

    document.getElementById("download-pdf").addEventListener("click", () => {
      if (!table) return;
      table.download("pdf", "production-bindings.pdf", {
        orientation: "landscape",
        title: "Production Bindings",
      });
      downloadSelector.classList.remove("download-selector--active");
    });

    document.getElementById("download-xlsx").addEventListener("click", () => {
      if (!table) return;
      table.download("xlsx", "production-bindings.xlsx", {
        sheetName: "Production Bindings",
      });
      downloadSelector.classList.remove("download-selector--active");
    });
  </script>

  <!-- Production Binding details dialog -->
  <div id="prodcalc-details-dialog" class="pc-overlay">
    <div id="prodcalc-details-body" class="pc-dialog"></div>
  </div>

  <!-- Delete confirmation dialog -->
  <div id="pc-confirm-dialog" class="pc-overlay">
    <div class="pc-confirm">
      <p id="pc-confirm-msg">Delete this production binding? This cannot be undone.</p>
      <div class="pc-confirm-actions">
        <button id="pc-confirm-no" class="pc-btn-secondary" type="button">Cancel</button>
        <button id="pc-confirm-yes" class="pc-btn-danger" type="button">Delete</button>
      </div>
    </div>
  </div>

  <style>
    .pc-overlay { display:none; position:fixed; inset:0; background:rgba(15,23,42,0.5); z-index:10000; justify-content:center; align-items:center; padding:24px; }
    .pc-dialog { width:min(640px,100%); }
    .pc-card { background:#fff; border-radius:14px; overflow:hidden; box-shadow:0 18px 42px rgba(4,74,120,0.18); max-height:calc(100vh - 48px); display:flex; flex-direction:column; }
    .pc-head { display:flex; justify-content:space-between; align-items:flex-start; gap:16px; padding:20px 24px; background:linear-gradient(135deg,#044a78,#03365a); color:#fff; }
    .pc-head h1 { margin:0; font-size:20px; font-weight:700; }
    .pc-sub { margin-top:4px; font-size:13px; opacity:0.85; }
    .pc-x { background:rgba(255,255,255,0.15); border:none; color:#fff; width:32px; height:32px; border-radius:8px; cursor:pointer; font-size:14px; }
    .pc-body { padding:18px 24px 22px; overflow-y:auto; }
    .pc-h3 { margin:18px 0 8px; color:#044a78; font-size:14px; font-weight:700; }
    .pc-table { width:100%; border-collapse:collapse; font-size:13px; border:1px solid #e5e7eb; border-radius:8px; overflow:hidden; }
    .pc-table th { background:#f4f7ff; color:#044a78; text-align:right; padding:8px 12px; font-weight:700; }
    .pc-table th:first-child { text-align:left; }
    .pc-table td { padding:7px 12px; border-top:1px solid #eef1f6; }
    .pc-table .pk { color:#5a6586; font-weight:600; width:38%; }
    .pc-table .pv { color:#1f2a44; font-weight:700; text-align:right; }
    .pc-table .pk + .pv { text-align:left; }
    .pc-confirm { background:#fff; border-radius:12px; width:min(420px,100%); padding:22px; box-shadow:0 18px 42px rgba(0,0,0,0.2); }
    .pc-confirm p { margin:0 0 18px; color:#333; font-size:15px; line-height:1.5; }
    .pc-confirm-actions { display:flex; justify-content:flex-end; gap:10px; }
    .pc-btn-secondary { padding:8px 16px; border:1px solid #d1d5db; background:#fff; color:#374151; border-radius:6px; cursor:pointer; font-weight:500; }
    .pc-btn-danger { padding:8px 16px; border:none; background:#ef4444; color:#fff; border-radius:6px; cursor:pointer; font-weight:600; }
    .pc-btn-danger:disabled { opacity:0.6; cursor:default; }
  </style>
</body>
