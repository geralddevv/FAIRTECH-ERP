<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<!-- Tabulator CSS -->
<link href="https://unpkg.com/tabulator-tables@5.5.2/dist/css/tabulator.min.css" rel="stylesheet" />
<link href="https://unpkg.com/tabulator-tables@5.6.2/dist/css/tabulator_modern.min.css" rel="stylesheet" />

<body>
  <div class="contain" style="flex-direction: column; padding: 10px; gap: 10px">
    <style>
      .header-action-btn {
        background-color: #f0f0f0;
        color: #044a78;
        padding: 2px 14px;
        font-size: 14px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        border-radius: 0.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: all 0.2s ease-in-out;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .header-action-btn:hover {
        background-color: #e4e4e4;
      }
      #master-table {
        width: 100%;
        flex: 1 1 auto;
        min-height: 0;
      }
    </style>

    <div class="indi-head">
      <h1>Die Master</h1>
      <div style="display: flex; gap: 10px; align-items: center">
        <button class="header-action-btn" onclick="window.location.href = '/fairtech/form/die'">
          <i class="fa-solid fa-plus" style="margin-right: 4px"></i> Die
        </button>
        <div class="download-selector" id="downloadSelector">
          <button class="download-selector__trigger">
            <span>
              <i class="fa-solid fa-file-arrow-down"></i>
              <span class="download-typo">Download</span>
            </span>
            <i class="fas fa-chevron-down download-selector__trigger-icon"></i>
          </button>
          <div class="download-selector__menu" id="downloads">
            <span class="download-selector__option" id="download-pdf">
              <i class="fas fa-file-pdf download-selector__option-icon"></i>
              <span>PDF</span>
            </span>
            <span class="download-selector__option" id="download-xlsx">
              <i class="fas fa-file-excel download-selector__option-icon"></i>
              <span>Excel</span>
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="table-spinner"><div class="spinner-circle"></div></div>
    <div id="master-table" class="tabulator tabulator-modern"></div>
  </div>

  <!-- Tabulator JS -->
  <script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

  <script id="table-data" type="application/json"><%- safeJson(jsonData) %></script>
  <script>
    const tableData = JSON.parse(document.getElementById("table-data").textContent).map(row => ({
      ...row,
      _family: Array.isArray(row.dieFamily) ? row.dieFamily.join(", ") : (row.dieFamily || ""),
      _machineNo: Array.isArray(row.dieMachineNo) ? row.dieMachineNo.join(", ") : (row.dieMachineNo || ""),
      _size: row.dieWidth && row.dieHeight ? `${row.dieWidth} × ${row.dieHeight}` : "",
    }));

    const withTextFilter = (column) => ({
      headerFilter: "input",
      headerFilterPlaceholder: "Search",
      minWidth: 100,
      ...column,
    });

    const table = new Tabulator("#master-table", {
      data: tableData,
      height: "100%",
      responsiveLayout: false,
      movableColumns: true,
      placeholder: "No data to display",
      columns: [
        {
          title: "",
          width: 50,
          hozAlign: "center",
          headerSort: false,
          formatter: function (cell) {
            const row = cell.getRow().getData();
            if (!row._id) return "";
            return `
              <button
                onclick="window.location.href='/fairtech/die/profile/${row._id}'"
                style="padding:2px 10px;background:#044A78;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px;">
                <i class="fa-solid fa-eye"></i>
              </button>
            `;
          },
        },
        withTextFilter({ title: "Die No", field: "dieDieNo", minWidth: 150 }),
        {
          title: "Status",
          field: "blockStatus",
          hozAlign: "center",
          headerFilter: "input",
          headerFilterPlaceholder: "Search",
          width: 100,
          formatter: function (cell) {
            const val = cell.getValue() || "";
            const isActive = val === "ACTIVE";
            const bg = isActive ? "#28a745" : "#dc3545";
            return `<span style="background:${bg};color:#fff;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;">${val}</span>`;
          },
        },
        withTextFilter({ title: "Family", field: "_family" }),
        withTextFilter({ title: "Die Type", field: "dieType" }),
        withTextFilter({ title: "Machine No", field: "_machineNo" }),
        withTextFilter({ title: "Size (W × H)", field: "_size" }),
        withTextFilter({ title: "Total Ups", field: "dieTotalUps" }),
        withTextFilter({ title: "Across Gap", field: "dieFlatAcrossGap" }),
        withTextFilter({ title: "Repeat Gap", field: "dieFlatrepGap" }),
        withTextFilter({ title: "Across Ups", field: "dieFlatAcross" }),
        withTextFilter({ title: "Down Ups", field: "dieFlatDown" }),
        withTextFilter({ title: "Paper Type", field: "diePapType" }),
        withTextFilter({ title: "Die Make", field: "dieMake" }),
        withTextFilter({ title: "Blade Type", field: "dieBladType" }),
        withTextFilter({ title: "Owned By", field: "dieOwnedBy" }),
        withTextFilter({ title: "Client Name", field: "dieClientName" }),
        withTextFilter({ title: "Remark", field: "dieFlatRemark" }),
      ],
    });

    // Dropdown toggle
    const selector = document.getElementById("downloadSelector");
    const trigger = selector.querySelector(".download-selector__trigger");

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      selector.classList.toggle("download-selector--active");
    });

    document.addEventListener("click", () => {
      selector.classList.remove("download-selector--active");
    });

    document.getElementById("download-pdf").addEventListener("click", () => {
      table.download("pdf", "die-master.pdf", {
        orientation: "landscape",
        title: "Die Master Data",
      });
      selector.classList.remove("download-selector--active");
    });

    document.getElementById("download-xlsx").addEventListener("click", () => {
      table.download("xlsx", "die-master.xlsx", {
        sheetName: "Die Master",
      });
      selector.classList.remove("download-selector--active");
    });
  </script>
</body>
