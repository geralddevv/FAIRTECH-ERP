      /* ══════════════════════════════════════
         SMART FILTER FACTORY (die + block)
      ══════════════════════════════════════ */
      function createSmartFilter(data, spec, onResolve) {
        const choicesMap = {};
        let _suppress = false;
        spec.forEach(([id]) => {
          const el = document.getElementById(id);
          if (!el) return;
          if (el.multiple) {
            choicesMap[id] = new Choices(el, {
              removeItemButton: true,
              searchEnabled: true,
              shouldSort: true,
              itemSelectText: "",
              placeholderValue: "Select machine(s)",
            });
          } else {
            choicesMap[id] = new Choices(el, { searchEnabled: true, shouldSort: true, itemSelectText: "" });
          }
        });

        const distinct = (list, key) =>
          [...new Set(list.map(m => String(m[key] ?? "")).filter(v => v !== ""))];

        function selections() {
          const sel = {};
          spec.forEach(([id, key]) => {
            const el = document.getElementById(id);
            if (!el) return;
            if (el.multiple) {
              const vals = Array.from(el.selectedOptions).map(o => o.value).filter(v => v);
              if (vals.length) sel[key] = vals;
            } else {
              if (el.value) sel[key] = el.value;
            }
          });
          return sel;
        }

        function dataMatching(sel, excludeKey) {
          return data.filter(m => Object.entries(sel).every(([k, v]) => {
            if (k === excludeKey) return true;
            if (Array.isArray(v)) return v.includes(String(m[k] ?? ""));
            return String(m[k] ?? "") === String(v);
          }));
        }

        function getStateKey() {
          return spec.map(([id]) => {
            const el = document.getElementById(id);
            if (!el) return "";
            if (el.multiple) return Array.from(el.selectedOptions).map(o => o.value).sort().join(",");
            return el.value;
          }).join("|");
        }

        function repopulate() {
          const sel = selections();
          spec.forEach(([id, key]) => {
            const inst = choicesMap[id];
            const el   = document.getElementById(id);
            if (!inst || !el) return;
            if (el.multiple) return; // machine no always shows all options

            const current = el.value;
            const options = distinct(dataMatching(sel, key), key);
            const newChoices = options.map(v => ({ value: String(v), label: String(v), selected: String(v) === current }));

            let autoVal = null;
            if (options.length === 1 && !current) { newChoices[0].selected = true; autoVal = options[0]; }

            inst.clearStore();
            inst.setChoices(
              [{ value: "", label: "Search", disabled: true, selected: !newChoices.some(c => c.selected) }, ...newChoices],
              "value", "label", true
            );

            if (current && new Set(options.map(String)).has(String(current))) inst.setChoiceByValue(String(current));
            else if (autoVal) inst.setChoiceByValue(String(autoVal));
            else if (!options.length) el.value = "";
          });
        }

        function repopulateUntilStable() {
          for (let i = 0; i < spec.length + 1; i++) {
            const before = getStateKey();
            repopulate();
            const after = getStateKey();
            if (before === after) break;
          }
        }

        function resolve() {
          const matches = dataMatching(selections());
          onResolve(matches.length === 1 ? matches[0] : null, matches.length);
        }

        spec.forEach(([id]) => {
          const el = document.getElementById(id);
          if (el) el.addEventListener("change", () => { if (_suppress) return; repopulateUntilStable(); resolve(); });
        });

        // Populate options on load without auto-selecting or resolving
        spec.forEach(([id, key]) => {
          const inst = choicesMap[id];
          const el = document.getElementById(id);
          if (!inst) return;
          const options = distinct(data, key);
          inst.clearStore();
          if (el && el.multiple) {
            inst.setChoices(options.map(v => ({ value: String(v), label: String(v) })), "value", "label", true);
          } else {
            inst.setChoices(
              [{ value: "", label: "Search", disabled: true, selected: true },
               ...options.map(v => ({ value: String(v), label: String(v) }))],
              "value", "label", true
            );
          }
        });

        return {
          setField(id, value) {
            const el = document.getElementById(id);
            const inst = choicesMap[id];
            if (!el || !inst) return;
            _suppress = true;
            if (el.multiple) {
              inst.removeActiveItems();
              if (value) inst.setChoiceByValue(String(value));
            } else {
              if (value) inst.setChoiceByValue(String(value));
            }
            _suppress = false;
          },
          reset() {
            _suppress = true;
            spec.forEach(([id]) => {
              const el = document.getElementById(id); const inst = choicesMap[id];
              if (el && el.multiple) {
                if (inst) inst.removeActiveItems();
              } else {
                if (el) el.value = "";
                if (inst) { inst.clearStore(); inst.setChoices([{ value: "", label: "Search", disabled: true, selected: true }], "value", "label", true); }
              }
            });
            _suppress = false;
            onResolve(null, 0);
            repopulateUntilStable();
          },
          applyAndFilter(fieldsMap) {
            _suppress = true;
            // Reset all fields to full option set first
            spec.forEach(([id, key]) => {
              const el = document.getElementById(id);
              const inst = choicesMap[id];
              if (!el || !inst) return;
              if (el.multiple) {
                inst.removeActiveItems();
              } else {
                const options = distinct(data, key);
                inst.clearStore();
                inst.setChoices(
                  [{ value: "", label: "Search", disabled: true, selected: true },
                   ...options.map(v => ({ value: String(v), label: String(v) }))],
                  "value", "label", true
                );
              }
            });
            // Apply the specified pre-filter values
            Object.entries(fieldsMap).forEach(([id, value]) => {
              const el = document.getElementById(id);
              const inst = choicesMap[id];
              if (!el || !inst || value === undefined || value === null || value === "") return;
              inst.setChoiceByValue(String(value));
            });
            _suppress = false;
            repopulateUntilStable();
            resolve();
          }
        };
      }

      /* ── Die ── */
      const DIES        = JSON.parse(document.getElementById("dies-data").textContent);
      const dieIdHidden = document.getElementById("die-id-hidden");
      const dieSelectEl = document.getElementById("die-select");
      const dieSpecsCard = document.getElementById("die-specs-card");

      const dieChoices = new Choices(dieSelectEl, { searchEnabled: true, shouldSort: false, itemSelectText: "" });

      const dieMachineInput  = document.getElementById("die-machine-no");
      const dieMachineSelect = document.getElementById("die-machine-no-select");
      let dieMachineChoices  = null;

      function dieMachineShowInput() {
        if (dieMachineChoices) { dieMachineChoices.destroy(); dieMachineChoices = null; }
        dieMachineSelect.innerHTML = "";
        dieMachineInput.style.display = "block";
        dieMachineSelect.style.display = "none";
      }

      function dieMachineShowSelect(machineNames, selectedNames) {
        if (dieMachineChoices) { dieMachineChoices.destroy(); dieMachineChoices = null; }
        dieMachineSelect.innerHTML = "";
        const selected = new Set((selectedNames || machineNames).map(String));
        machineNames.forEach(name => {
          const opt = document.createElement("option");
          opt.value = name;
          opt.textContent = name;
          // Choices.js reads the "selected" HTML attribute (not the live .selected
          // property) when scanning options at construction time — setting only
          // the property leaves it thinking nothing is selected and renders no chips.
          if (selected.has(String(name))) opt.setAttribute("selected", "selected");
          dieMachineSelect.appendChild(opt);
        });
        dieMachineChoices = new Choices(dieMachineSelect, {
          removeItemButton: true,
          searchEnabled: true,
          shouldSort: false,
          itemSelectText: "",
          placeholderValue: "Select Machine(s)",
          placeholder: true,
        });
        dieMachineInput.style.display = "none";
        dieMachineSelect.style.display = "block";
      }

      let filteredDies = [];

      function loadDieOptions(width, height) {
        filteredDies = DIES.filter(d =>
          String(d.dieWidth) === String(width) && String(d.dieHeight) === String(height)
        );
        dieChoices.clearStore();
        if (filteredDies.length) {
          const onlyMatch = filteredDies.length === 1;
          dieChoices.setChoices(
            [{ value: "", label: "Search", disabled: true, selected: !onlyMatch },
             ...filteredDies.map(d => ({
               value: String(d._id),
               label: `${d.dieWidth} x ${d.dieHeight} - ${d.dieTotalUps}ups - ${d.dieType}`,
               selected: onlyMatch,
             }))],
            "value", "label", true
          );
          // Only one die fits this label's size — select it instead of making
          // the operator pick from a list of one.
          if (onlyMatch) { applyDieSelection(filteredDies[0]); return; }
        } else {
          dieChoices.setChoices(
            [{ value: "", label: "No dies found for this size", disabled: true, selected: true }],
            "value", "label", true
          );
        }
        dieSpecsCard.style.display = "none";
        clearDieSpecs();
        dieIdHidden.value = "";
        dieMachineShowInput();
        const dieAcrossEl = document.getElementById("prod-die-across");
        const dieNoEl     = document.getElementById("prod-die-no");
        if (dieAcrossEl) dieAcrossEl.value = "";
        if (dieNoEl)     dieNoEl.value     = "";
        recalcProduction();
      }

      function resetDieSelect() {
        filteredDies = [];
        dieChoices.clearStore();
        dieChoices.setChoices(
          [{ value: "", label: "Select a label first", disabled: true, selected: true }],
          "value", "label", true
        );
        dieSpecsCard.style.display = "none";
        clearDieSpecs();
        dieIdHidden.value = "";
        dieMachineShowInput();
        const dieAcrossEl = document.getElementById("prod-die-across");
        const dieNoEl     = document.getElementById("prod-die-no");
        if (dieAcrossEl) dieAcrossEl.value = "";
        if (dieNoEl)     dieNoEl.value     = "";
        recalcProduction();
      }

      // Applies a resolved die's specs/hidden fields + machine multi-select.
      // `selectedMachineNames`, when given, pre-checks only that subset of the
      // die's machine list instead of defaulting to "all selected" — used by
      // the edit-mode prefill to restore the machines actually saved on the binding.
      function applyDieSelection(die, selectedMachineNames) {
        if (!die) {
          dieSpecsCard.style.display = "none";
          clearDieSpecs();
          dieIdHidden.value = "";
          dieMachineShowInput();
          const dieAcrossReset = document.getElementById("prod-die-across");
          const dieNoReset     = document.getElementById("prod-die-no");
          if (dieAcrossReset) dieAcrossReset.value = "";
          if (dieNoReset)     dieNoReset.value     = "";
          recalcProduction();
          return;
        }
        populateDieSpecs(die);
        dieIdHidden.value = String(die._id);
        dieSpecsCard.style.display = "block";
        const dieAcrossEl = document.getElementById("prod-die-across");
        const dieNoEl     = document.getElementById("prod-die-no");
        if (dieAcrossEl) dieAcrossEl.value = die.dieFlatAcross || "";
        if (dieNoEl)     dieNoEl.value     = die.dieDieNo      || "";

        // Populate machine multi-select with machines bound to this die
        const machines = Array.isArray(die.dieMachineNo)
          ? die.dieMachineNo
          : (die.dieMachineNo ? [die.dieMachineNo] : []);
        if (machines.length) {
          dieMachineShowSelect(machines, selectedMachineNames);
        } else {
          dieMachineShowInput();
        }
        recalcProduction();
      }

      dieSelectEl.addEventListener("change", function () {
        // Choices.js can fire "change" on its own during setChoiceByValue()
        // (edit-mode prefill) — mute it the same way client/user/label selects
        // are muted, so the explicit applyDieSelection(die, selectedMachineNames)
        // call in prefillFromEdit is the only thing that ever sets the machine
        // multi-select, instead of racing it and resetting to "all selected".
        if (prefilling) return;
        if (this.value && this.value === dieIdHidden.value) return;
        const die = filteredDies.find(d => String(d._id) === this.value);
        applyDieSelection(die);
      });

      document.getElementById("die-reset-btn").addEventListener("click", resetDieSelect);

      function populateDieSpecs(d) {
        const dt = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val || "—"; };
        dt("ds-die-no", d.dieDieNo);
        dt("ds-die-type", d.dieType);
        dt("ds-die-make", d.dieMake);
        dt("ds-blad-type", d.dieBladType);
        dt("ds-machine-no", Array.isArray(d.dieMachineNo) ? d.dieMachineNo.join(", ") : (d.dieMachineNo || ""));
        dt("ds-family", Array.isArray(d.dieFamily)    ? d.dieFamily.join(", ")    : (d.dieFamily    || ""));
        dt("ds-teeth", d.dieTeeth);
        dt("ds-width", d.dieWidth);
        dt("ds-height", d.dieHeight);
        dt("ds-across-gap", d.dieFlatAcrossGap);
        dt("ds-rep-gap", d.dieFlatrepGap);
        dt("ds-flat-across", d.dieFlatAcross);
        dt("ds-flat-down", d.dieFlatDown);
        dt("ds-total-ups", d.dieTotalUps);
        dt("ds-pap-type", d.diePapType);
        dt("ds-status", d.dieStatus);
        dt("ds-owned-by", d.dieOwnedBy);
        dt("ds-client-name", d.dieClientName);
        dt("ds-remark", d.dieFlatRemark);
      }

      function clearDieSpecs() {
        ["ds-die-make","ds-blad-type","ds-teeth","ds-width","ds-height","ds-across-gap",
         "ds-rep-gap","ds-flat-across","ds-flat-down","ds-total-ups","ds-pap-type",
         "ds-status","ds-owned-by","ds-remark"
        ].forEach(id => { const el = document.getElementById(id); if (el) el.textContent = "—"; });
      }

      /* ── Block ── */
      const BLOCKS = JSON.parse(document.getElementById("blocks-data").textContent);
      const blockDisplayEl = document.getElementById("block-no-display");
      const blockIdHidden = document.getElementById("block-id-hidden");

      const blockFilter = createSmartFilter(BLOCKS, [
        ["block-machine-no", "blockMachineNo"],
        ["block-machine-type", "blockMachineType"],
        ["block-artwork-no", "blockArtworkNo"],
        ["block-width", "blockWidth"],
        ["block-height", "blockHeight"],
      ], (match, count) => {
        blockIdHidden.value = "";
        blockDisplayEl.classList.remove("resolved-success", "resolved-error");
        if (match) { blockDisplayEl.value = match.blockNo; blockIdHidden.value = match._id; blockDisplayEl.classList.add("resolved-success"); }
        else if (count === 0) { blockDisplayEl.value = "No match"; blockDisplayEl.classList.add("resolved-error"); }
        else { blockDisplayEl.value = count > 1 ? `${count} matches — refine` : ""; }
      });
      document.getElementById("block-reset-btn").addEventListener("click", () => blockFilter.reset());

      /* AUTO-CALCULATE (runs as the relevant inputs change) */
      function recalcProduction() {
        // Tolerant numeric read: strips stray characters (e.g. an inch mark in
        // a label height like `6"`, spaces, thousands commas) so a value like
        // `6"` parses as 6 instead of NaN — NaN would silently fail the ready
        // gate below and blank the whole calc.
        const g = id => {
          const n = parseFloat(String(document.getElementById(id)?.value ?? "").replace(/[^0-9.\-]/g, ""));
          return Number.isFinite(n) ? n : 0;
        };
        // Same tolerant read for the die-specs cells, which are rendered as text
        // (textContent) rather than form inputs.
        const gTxt = id => {
          const n = parseFloat(String(document.getElementById(id)?.textContent ?? "").replace(/[^0-9.\-]/g, ""));
          return Number.isFinite(n) ? n : 0;
        };

        const paperSizeVal = g("prod-paper-size");
        const dieAcrossVal = g("prod-die-across");
        const labelHeightVal = g("label-height");
        const ratePerLabelVal = g("rate-per-label");
        // Repeat gap from the selected die (down/repeat direction) — added to the
        // label height instead of the old hardcoded 3 mm.
        const repeatGapVal = gTxt("ds-rep-gap");

        const setText = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
        const setVal  = (id, val) => { const el = document.getElementById(id); if (el) el.value = val; };

        // Reset both rows and the persisted values — used until every input is ready.
        function clearCalc() {
          ["c645", "c625"].forEach((p) =>
            ["area", "rate", "sqm", "margin", "margin1k", "actual"].forEach((k) => setText(`${p}-${k}`, "—")));
          ["", "-625"].forEach((suffix) =>
            ["prod-area", "prod-rate", "prod-tot-sqr-m", "prod-margin", "prod-margin1k", "prod-actual-percentage"]
              .forEach((f) => setVal(`${f}${suffix}`, "")));
        }

        // Auto-calculate only once every field the formulas depend on has a value.
        const ready = paperSizeVal && dieAcrossVal && labelHeightVal && ratePerLabelVal;
        if (!ready) { clearCalc(); return; }

        // Everything below is computed once per area divisor (645 and 625).
        function computeForDivisor(divisor) {
          const productionVal = ((paperSizeVal / dieAcrossVal) * (labelHeightVal + repeatGapVal)) / divisor;
          // Production rate = ratePerLabel / production area.
          const productionRateVal = ratePerLabelVal / productionVal;
          // Sq metre rate = production rate * 1550.
          const sqMtrsRateVal = productionRateVal * 1550;
          // Margin = ratePerLabel - (production rate * production area).
          const marginVal = ratePerLabelVal - (productionRateVal * productionVal);
          // Per-1000 margin = margin * 1000.
          const marginPer1kVal = marginVal * 1000;
          // Actual % is the margin as a percentage of the per-label rate.
          const marginPercentageVal = (marginVal / ratePerLabelVal) * 100;
          return { productionVal, productionRateVal, sqMtrsRateVal, marginVal, marginPer1kVal, marginPercentageVal };
        }

        const r645 = computeForDivisor(645);
        const r625 = computeForDivisor(625);

        // Grouped display value (Indian commas), or "—" when not computable.
        const grp = (num, dec) =>
          Number.isFinite(num) ? Number(num).toLocaleString("en-IN", { minimumFractionDigits: dec, maximumFractionDigits: dec }) : "—";
        // Raw persisted value (no grouping), or "" when not computable.
        const raw = (num, dec) => (Number.isFinite(num) ? num.toFixed(dec) : "");

        function fillRow(prefix, r) {
          setText(`${prefix}-area`, grp(r.productionVal, 5));
          setText(`${prefix}-rate`, grp(r.productionRateVal, 5));
          setText(`${prefix}-sqm`, grp(r.sqMtrsRateVal, 5));
          setText(`${prefix}-margin`, grp(r.marginVal, 5));
          setText(`${prefix}-margin1k`, grp(r.marginPer1kVal, 5));
          setText(`${prefix}-actual`, Number.isFinite(r.marginPercentageVal) ? `${grp(r.marginPercentageVal, 5)}%` : "—");
        }

        fillRow("c645", r645);
        fillRow("c625", r625);

        function persist(suffix, r) {
          setVal(`prod-area${suffix}`, raw(r.productionVal, 5));
          setVal(`prod-rate${suffix}`, raw(r.productionRateVal, 5));
          setVal(`prod-tot-sqr-m${suffix}`, raw(r.sqMtrsRateVal, 5));
          setVal(`prod-margin${suffix}`, raw(r.marginVal, 5));
          setVal(`prod-margin1k${suffix}`, raw(r.marginPer1kVal, 5));
          setVal(`prod-actual-percentage${suffix}`, raw(r.marginPercentageVal, 5));
        }

        persist("", r645);        // existing field names carry the 645 basis
        persist("-625", r625);    // 625 basis stored alongside
      }

      // Auto-calculate as the user types the material inputs (paper size).
      ["prod-paper-size"].forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.addEventListener("input", recalcProduction);
      });

      /* EDIT MODE — prefill the whole form from an existing binding */
      const EDIT_BINDING = (() => {
        try { return JSON.parse(document.getElementById("edit-binding-data").textContent); }
        catch { return null; }
      })();

      async function prefillFromEdit(d) {
        if (!d) return;
        prefilling = true;   // mute the auto-cascade + keep the stored sales values
        try {
          // 1) Client → fetch its users + labels.
          if (d.companyName) {
            clientChoices.setChoiceByValue(d.companyName);
            await loadClientData(d.companyName);
          }
          // 2) User.
          if (d.userId) {
            userChoices.setChoiceByValue(String(d.userId));
            fillUserDetails(String(d.userId));
          }
          // 3) Location (override any single-location auto-select).
          if (d.userLocation) locationChoices.setChoiceByValue(d.userLocation);
          renderLabelChoices();
          // 4) Label → specs card + form fields + die options.
          if (d.labelProductId) {
            const lid = String(d.labelProductId);
            labelChoices.setChoiceByValue(lid);
            const b = clientLabels.find((x) => String(x._id) === lid);
            if (b) {
              populateSpecsCard(b);
              applyBindingToForm(b);   // getValues muted; loads die options
              specsCard.style.display = "block";
            }
          }
          // 5) Die → sets die across / no + machines.
          if (d.dieId) {
            dieChoices.setChoiceByValue(String(d.dieId));
            const die = filteredDies.find(x => String(x._id) === String(d.dieId));
            const selectedMachineNames = Array.isArray(d.dieMachineNo)
              ? d.dieMachineNo
              : (d.dieMachineNo ? [d.dieMachineNo] : null);
            applyDieSelection(die, selectedMachineNames);
          }
          // 6) Block → resolve via the smart filter using the block's own values.
          if (d.blockId) {
            const blk = BLOCKS.find((x) => String(x._id) === String(d.blockId));
            if (blk) {
              blockFilter.applyAndFilter({
                "block-machine-no": blk.blockMachineNo,
                "block-machine-type": blk.blockMachineType,
                "block-artwork-no": blk.blockArtworkNo,
                "block-width": blk.blockWidth,
                "block-height": blk.blockHeight,
              });
            }
          }
          // 7) Vendor + stored production/pricing values (authoritative on edit).
          if (d.prodVendorName) vendorChoices.setChoiceByValue(d.prodVendorName);
          // Paper Code/Family are Choices.js selects -- setChoiceByValue,
          // not raw .value=, so the visible widget actually updates.
          if (d.prodPaperCode) paperCodeChoices.setChoiceByValue(d.prodPaperCode);
          if (d.prodPaperFamily) paperFamilyChoices.setChoiceByValue(d.prodPaperFamily);
          const setIf = (id, val) => {
            const el = document.getElementById(id);
            if (el && val != null && val !== "") el.value = val;
          };
          setIf("prod-paper-size", d.prodPaperSize);
          setIf("prod-paper-rate", d.prodPaperRate);
          // Stored rate is authoritative on edit -- don't let a resolve
          // triggered by the vendor/paper-code prefill above overwrite it.
          if (d.prodPaperRate != null && d.prodPaperRate !== "") prodPaperRateInput.dataset.userEdited = "true";
          setIf("rate-per-1k", d.perOneK);
          setIf("rate-per-label", d.ratePerLabel);
          setIf("order-quantity", d.orderQuantity);
          setIf("prod-cost-percentage", d.cost);
          setIf("job-ups", d.jobUps);
          setIf("job-name", d.jobName);
          setIf("paper-type", d.paperType);
          setIf("label-family", d.labelFamily);
          setIf("printed", d.printed);
          setIf("prod-die-across", d.prodDieAcross);
          setIf("prod-die-no", d.prodDieno);
        } catch (err) {
          console.error("Edit prefill error:", err);
        } finally {
          prefilling = false;
        }
        recalcProduction();
      }

      // "Bind" from a Pending Production row — same prefill routine as edit
      // mode, but no editId hidden field was rendered so submitting creates
      // a brand-new binding instead of updating one.
      const PREFILL_BINDING = (() => {
        try { return JSON.parse(document.getElementById("prefill-binding-data").textContent); }
        catch { return null; }
      })();

      // safeJson() serializes a missing value as "{}" (not "null"), so both
      // blobs above are always truthy objects even when empty -- checking a
      // field that's only ever present on a real binding avoids treating an
      // empty "{}" as one.
      if (EDIT_BINDING && EDIT_BINDING._id) prefillFromEdit(EDIT_BINDING);
      else if (PREFILL_BINDING && PREFILL_BINDING.labelProductId) prefillFromEdit(PREFILL_BINDING);

    });
  </script>

  <script id="machines-data" type="application/json"><%- safeJson(machines) %></script>
  <script id="dies-data" type="application/json"><%- safeJson(dies) %></script>
  <script id="blocks-data" type="application/json"><%- safeJson(blocks) %></script>
  <script id="edit-binding-data" type="application/json"><%- safeJson((typeof editBinding !== "undefined" && editBinding) || null) %></script>
  <script id="prefill-binding-data" type="application/json"><%- safeJson((typeof prefillBinding !== "undefined" && prefillBinding) || null) %></script>
