  <script>
    document.addEventListener("DOMContentLoaded", () => {

      /* ══════════════════════════════════════
         CLIENT → USER → CONTACT → LOCATION
      ══════════════════════════════════════ */
      const clientSelect   = document.getElementById("company-name");
      const userSelect     = document.getElementById("user-name");
      const contactInput   = document.getElementById("user-contact");
      const locationSelect = document.getElementById("user-location");
      const asterisk       = document.querySelector(".asterisk");
      const labelSelect    = document.getElementById("label-select");
      const specsCard      = document.getElementById("specs-card");

      const clientChoices   = new Choices(clientSelect,   { searchEnabled: true, shouldSort: false, itemSelectText: "" });
      const userChoices     = new Choices(userSelect,     { searchEnabled: true, shouldSort: false, itemSelectText: "" });
      const locationChoices = new Choices(locationSelect, { searchEnabled: true, shouldSort: false, itemSelectText: "" });
      const labelChoices    = new Choices(labelSelect,    { searchEnabled: true, shouldSort: false, itemSelectText: "" });
      const vendorChoices   = new Choices(document.getElementById("prod-vendor-name"), { searchEnabled: true, shouldSort: false, itemSelectText: "" });

      let fetchedClientData = null;
      let clientLabels = [];

      clientSelect.addEventListener("change", async function () {
        /* reset downstream */
        userChoices.removeActiveItems();    userChoices.clearStore();
        locationChoices.removeActiveItems(); locationChoices.clearStore();
        labelChoices.removeActiveItems();   labelChoices.clearStore();
        contactInput.value = "";
        specsCard.style.display = "none";
        clearSpecsCard();
        clearFormFields();
        fetchedClientData = null;
        clientLabels = [];

        const name = this.value;
        if (!name) return;

        try {
          /* user data */
          const uRes = await fetch(`/fairtech/form/labels/${encodeURIComponent(name)}`);
          if (!uRes.ok) throw new Error("user fetch failed");
          fetchedClientData = await uRes.json();

          if (asterisk) {
            asterisk.textContent = `(${fetchedClientData.clientType})`;
            asterisk.style.color = fetchedClientData.clientType === "DEALER" ? "red" : "green";
          }

          const usernames = [...new Set((fetchedClientData.users || []).map(u => u.userName))];
          userChoices.setChoices(usernames.map(n => ({ value: n, label: n })), "value", "label", true);
          if (usernames.length === 1) { userChoices.setChoiceByValue(usernames[0]); fillUserDetails(usernames[0]); }

          /* label bindings */
          const lRes = await fetch(`/fairtech/form/prodcalc/client-labels/${encodeURIComponent(name)}`);
          if (!lRes.ok) throw new Error("label fetch failed");
          clientLabels = await lRes.json();

          if (clientLabels.length) {
            labelChoices.setChoices(
              clientLabels.map(b => ({
                value: b._id,
                label: `${b.labelWidth} x ${b.labelHeight} - ${b.labelFamily || b.paperType || "—"} - ${b.jobType}`,
              })),
              "value", "label", true
            );
          } else {
            labelChoices.setChoices([{ value: "", label: "No labels found for this client", disabled: true }], "value", "label", true);
          }
        } catch (err) {
          console.error("Client fetch error:", err);
        }
      });

      userSelect.addEventListener("change", function () { fillUserDetails(this.value); });

      function fillUserDetails(selectedName) {
        locationChoices.removeActiveItems();
        locationChoices.clearStore();
        contactInput.value = "";
        if (!selectedName || !fetchedClientData) return;

        const matched = (fetchedClientData.users || []).filter(u => u.userName === selectedName);
        if (!matched.length) return;

        contactInput.value = matched[0].userContact || "";

        const seen = new Set();
        const locs = [];
        for (const u of matched) {
          const p = (u.userLocation || "").trim();
          if (p && !seen.has(p)) { seen.add(p); locs.push(p); }
          for (const ld of (u.locationDetails || [])) {
            const l = (ld.userLocation || "").trim();
            if (l && !seen.has(l)) { seen.add(l); locs.push(l); }
          }
        }
        locationChoices.setChoices(locs.map(l => ({ value: l, label: l })), "value", "label", true);
        if (locs.length === 1) locationChoices.setChoiceByValue(locs[0]);
      }

      /* ══════════════════════════════════════
         LABEL SELECTION → SPECS CARD + FORM
      ══════════════════════════════════════ */
      labelSelect.addEventListener("change", function () {
        const binding = clientLabels.find(b => String(b._id) === this.value);
        if (!binding) { specsCard.style.display = "none"; clearSpecsCard(); clearFormFields(); return; }
        populateSpecsCard(binding);
        applyBindingToForm(binding);
        specsCard.style.display = "block";
      });

      function txt(id, val) {
        const el = document.getElementById(id);
        if (el) el.textContent = val || "—";
      }

      function show(id, visible) {
        const el = document.getElementById(id);
        if (el) el.style.display = visible ? "" : "none";
      }

      function populateSpecsCard(b) {
        const isColor = b.jobType === "COLOR";
        const isPlain = b.jobType === "PLAIN";

        txt("d-job-type",    b.jobType);
        txt("d-job-name",    b.jobName);
        txt("d-front-color", b.frontColor);
        txt("d-back-color",  b.backColor);
        txt("d-instructions",b.instructions);
        txt("d-varnish",     b.varnish);
        txt("d-foil-no",     b.foilNo);
        txt("d-paper-type",  b.paperType);
        txt("d-width",       b.labelWidth);
        txt("d-height",      b.labelHeight);
        txt("d-gap",         b.labelGap);
        txt("d-ups",         b.labelUps);
        txt("d-core",        b.labelCore);
        txt("d-per-roll-qty",b.perRollQty);
        txt("d-first-out",   b.firstOut);
        txt("d-rate-per-k",  b.ratePerK);
        txt("d-rate-per-label", b.ratePerLabel);
        txt("d-per-roll",    b.perRoll);

        show("d-job-name-wrap",    isColor);
        show("d-front-color-wrap", isColor);
        show("d-back-color-wrap",  isColor);
        show("d-instructions-wrap",isPlain);
        show("d-first-out-wrap",   !isPlain);
      }

      function applyBindingToForm(b) {
        document.getElementById("label-width").value  = b.labelWidth  || "";
        document.getElementById("label-height").value = b.labelHeight || "";
        document.getElementById("paper-type").value   = b.paperType   || "";
        document.getElementById("job-name").value     = b.jobName     || "";
        document.getElementById("job-ups").value      = b.labelUps    || "";
        document.getElementById("rate-per-1k").value  = b.ratePerK    || "";
        document.getElementById("label-master-id-hidden").value = b.labelMasterId || "";
        const printedEl = document.getElementById("printed");
        if (printedEl) printedEl.value = b.jobType === "PLAIN" ? "Plain" : "Printed";
        const costEl = document.getElementById("prod-cost-percentage");
        if (costEl) costEl.value = b.jobType === "PLAIN" ? "1.35" : "1.55";
        const oqEl = document.getElementById("order-quantity");
        if (oqEl) oqEl.value = b.OrderQty || b.minOrderQty || "";
        document.getElementById("block-section").style.display = b.jobType === "PLAIN" ? "none" : "contents";
        getValues();
        loadDieOptions(b.labelWidth || "", b.labelHeight || "");
      }

      function clearSpecsCard() {
        ["d-job-type","d-job-name","d-front-color","d-back-color","d-instructions",
         "d-varnish","d-foil-no","d-paper-type","d-width","d-height","d-gap","d-ups",
         "d-core","d-per-roll-qty","d-first-out","d-rate-per-k","d-rate-per-label","d-per-roll"
        ].forEach(id => txt(id, ""));
        ["d-job-name-wrap","d-front-color-wrap","d-back-color-wrap",
         "d-instructions-wrap","d-first-out-wrap"
        ].forEach(id => show(id, true));
      }

      function clearFormFields() {
        ["label-width","label-height","paper-type","job-name","job-ups","rate-per-1k"]
          .forEach(id => { const el = document.getElementById(id); if (el) el.value = ""; });
        document.getElementById("label-master-id-hidden").value = "";
        const p = document.getElementById("printed"); if (p) p.value = "";
        document.getElementById("block-section").style.display = "contents";
        resetDieSelect();
      }

      /* ══════════════════════════════════════
         WIDTH / HEIGHT → CALC DATA FETCH
      ══════════════════════════════════════ */
      async function getValues() {
        const w = document.getElementById("label-width").value;
        const h = document.getElementById("label-height").value;
        if (!w || !h) return;
        try {
          const res = await fetch(
            `/fairtech/form/prodcalc/data?w=${w}&h=${h}&client=${encodeURIComponent(clientSelect.value)}`
          );
          if (!res.ok) throw new Error("fetch failed");
          const data = await res.json();
          if (data) feedValues(data);
        } catch (err) {
          console.error("Calc data fetch error:", err);
        }
      }

      function feedValues(v) {
        const sv = (id, val) => { const el = document.getElementById(id); if (el) el.value = val || ""; };
        sv("rate-per-1k",           v.perOneK);
        sv("job-ups",               v.jobUps);
        sv("paper-type",            v.paperType);
        sv("printed",               v.printed);
        sv("job-name",              v.jobName);
        sv("order-quantity",        v.orderQuantity);
        sv("prod-cost-percentage",  v.costPercent);
      }

