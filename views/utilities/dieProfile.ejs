<!-- Link to boilerplate.ejs -->
<% layout('/layout/boilerplate') -%>

<style>
  .die-details-shell {
    padding: 18px;
    background: linear-gradient(180deg, #eef5fb 0%, #f7f9fc 100%);
  }

  .die-details-card {
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 18px 42px rgba(4, 74, 120, 0.12);
    border: 1px solid rgba(4, 74, 120, 0.12);
    overflow: hidden;
  }

  .die-details-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-end;
    padding: 24px 24px 22px;
    background:
      radial-gradient(circle at top right, rgba(255,255,255,0.16), transparent 34%),
      linear-gradient(135deg, #044a78 0%, #03365a 100%);
    color: #fff;
  }

  .header-copy h1 {
    margin: 0;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: 0.2px;
  }

  .header-sub {
    margin-top: 6px;
    font-size: 14px;
    opacity: 0.88;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }

  .header-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
  }

  .badge-active   { background: #22c55e; color: #fff; }
  .badge-inactive { background: #ef4444; color: #fff; }

  .header-action-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 16px;
    border-radius: 999px;
    background: rgba(255,255,255,0.14);
    border: 1px solid rgba(255,255,255,0.18);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 13px;
    backdrop-filter: blur(8px);
    transition: background 0.18s ease;
  }

  .header-action-link:hover {
    color: #fff;
    background: rgba(255,255,255,0.22);
  }

  .die-details-body {
    padding: 22px 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .section-title {
    margin: 0 0 12px;
    color: #044a78;
    font-size: 15px;
    font-weight: 700;
    padding-bottom: 8px;
    border-bottom: 2px solid #e6eaf2;
  }

  .kv-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border: 1.5px solid #e6eaf2;
    border-radius: 10px;
    overflow: hidden;
  }

  .kv-table tr:last-child td {
    border-bottom: none;
  }

  .kv-table td {
    padding: 11px 14px;
    border-bottom: 1px solid #e6eaf2;
    font-size: 14px;
    vertical-align: top;
  }

  .kv-table td.kv-label {
    width: 38%;
    color: #5a6586;
    font-weight: 600;
    background: #f8fbff;
    border-right: 1.5px solid #e6eaf2;
  }

  .kv-table td.kv-value {
    color: #1f2a44;
    font-weight: 500;
  }

  .kv-table td.kv-value.muted {
    color: #9ca3af;
    font-weight: 400;
  }

  @media (max-width: 768px) {
    .die-details-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<div class="main-content die-details-shell">
  <div class="die-details-card">

    <!-- Header -->
    <div class="die-details-header">
      <div class="header-copy">
        <h1><%= die.dieDieNo %></h1>
        <div class="header-sub">
          <span><%= Array.isArray(die.dieFamily) ? die.dieFamily.join(" · ") : die.dieFamily %></span>
          <% const isActive = die.dieStatus === "ACTIVE"; %>
          <span class="header-badge <%= isActive ? 'badge-active' : 'badge-inactive' %>">
            <%= die.dieStatus || "N/A" %>
          </span>
          <span class="header-badge" style="background: rgba(255,255,255,0.18);">
            V<%= die.dieVersion || 1 %>
          </span>
        </div>
      </div>
      <div style="display: flex; gap: 10px; align-items: center;">
        <a class="header-action-link" href="/fairtech/die/edit/<%= die._id %>">
          <i class="fa-solid fa-pen-to-square"></i> Edit
        </a>
        <% if (!replacedByDie) { %>
          <a class="header-action-link" href="/fairtech/form/die?replaces=<%= die._id %>">
            <i class="fa-solid fa-code-branch"></i> New Version
          </a>
        <% } %>
        <% if (die.dieJpgFile) { %>
          <a class="header-action-link" href="/fairtech/die/file/<%= die._id %>/jpg" target="_blank" rel="noopener">
            <i class="fa-solid fa-file-image"></i> JPG
          </a>
        <% } %>
        <% if (die.dieDesignFile) { %>
          <a class="header-action-link" href="/fairtech/die/file/<%= die._id %>/design" target="_blank" rel="noopener">
            <i class="fa-solid fa-file-arrow-down"></i> Design
          </a>
        <% } %>
        <% if (die.dieLayoutFile) { %>
          <a class="header-action-link" href="/fairtech/die/file/<%= die._id %>/layout" target="_blank" rel="noopener">
            <i class="fa-solid fa-file-arrow-down"></i> Layout
          </a>
        <% } %>
      </div>
    </div>

    <!-- Body -->
    <div class="die-details-body">

      <% if (replacedDie || replacedByDie) { %>
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <% if (replacedDie) { %>
          <a href="/fairtech/die/profile/<%= replacedDie._id %>" style="display:inline-flex; align-items:center; gap:8px; padding:8px 14px; border-radius:8px; background:#f8fbff; border:1px solid #e6eaf2; color:#044a78; font-weight:600; font-size:13px; text-decoration:none;">
            <i class="fa-solid fa-clock-rotate-left"></i> Replaces <%= replacedDie.dieDieNo %> (V<%= replacedDie.dieVersion || 1 %>)
          </a>
        <% } %>
        <% if (replacedByDie) { %>
          <a href="/fairtech/die/profile/<%= replacedByDie._id %>" style="display:inline-flex; align-items:center; gap:8px; padding:8px 14px; border-radius:8px; background:#fff8e1; border:1px solid #f0c36d; color:#7a5b00; font-weight:600; font-size:13px; text-decoration:none;">
            <i class="fa-solid fa-triangle-exclamation"></i> Replaced by <%= replacedByDie.dieDieNo %> (V<%= replacedByDie.dieVersion || 1 %>)
          </a>
        <% } %>
      </div>
      <% } %>

      <!-- Die Details + Dimensions side by side -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; align-items: start;">
        <div>
          <h3 class="section-title">Die Details</h3>
          <table class="kv-table">
            <tbody>
              <tr><td class="kv-label">Die No</td><td class="kv-value"><%= die.dieDieNo || "N/A" %></td></tr>
              <tr><td class="kv-label">Family</td><td class="kv-value"><%= Array.isArray(die.dieFamily) ? die.dieFamily.join(", ") : (die.dieFamily || "N/A") %></td></tr>
              <tr><td class="kv-label">Die Type</td><td class="kv-value"><%= die.dieType || "N/A" %></td></tr>
              <tr><td class="kv-label">Die Make</td><td class="kv-value"><%= die.dieMake || "N/A" %></td></tr>
              <tr><td class="kv-label">Blade Type</td><td class="kv-value"><%= die.dieBladType || "N/A" %></td></tr>
              <tr><td class="kv-label">Machine No</td><td class="kv-value"><%= Array.isArray(die.dieMachineNo) ? die.dieMachineNo.join(", ") : (die.dieMachineNo || "N/A") %></td></tr>
              <% if (die.dieTeeth) { %>
              <tr><td class="kv-label">Magnetic Teeth</td><td class="kv-value"><%= die.dieTeeth %></td></tr>
              <% } %>
              <tr><td class="kv-label">Status</td><td class="kv-value"><%= die.dieStatus || "N/A" %></td></tr>
            </tbody>
          </table>
        </div>
        <div>
          <h3 class="section-title">Dimensions & Ups</h3>
          <table class="kv-table">
            <tbody>
              <tr><td class="kv-label">Width</td><td class="kv-value"><%= die.dieWidth || "N/A" %></td></tr>
              <tr><td class="kv-label">Height</td><td class="kv-value"><%= die.dieHeight || "N/A" %></td></tr>
              <tr><td class="kv-label">Across Gap</td><td class="kv-value"><%= die.dieFlatAcrossGap || "N/A" %></td></tr>
              <tr><td class="kv-label">Repeat Gap</td><td class="kv-value"><%= die.dieFlatrepGap || "N/A" %></td></tr>
              <tr><td class="kv-label">Across Ups</td><td class="kv-value"><%= die.dieFlatAcross || "N/A" %></td></tr>
              <tr><td class="kv-label">Down Ups</td><td class="kv-value"><%= die.dieFlatDown || "N/A" %></td></tr>
              <tr><td class="kv-label">Total Ups</td><td class="kv-value"><%= die.dieTotalUps || "N/A" %></td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Ownership -->
      <div>
        <h3 class="section-title">Ownership</h3>
        <table class="kv-table">
          <tbody>
            <tr><td class="kv-label">Owned By</td><td class="kv-value"><%= die.dieOwnedBy || "N/A" %></td></tr>
            <% if (die.dieClientName) { %>
            <tr><td class="kv-label">Client Name</td><td class="kv-value"><%= die.dieClientName %></td></tr>
            <% } %>
            <tr><td class="kv-label">Remark</td><td class="kv-value <%= die.dieFlatRemark ? '' : 'muted' %>"><%= die.dieFlatRemark || "—" %></td></tr>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>
