<!-- ============ DELETE CONFIRMATION DIALOG ============ -->
<div class="logout-modal" id="deleteDialog" aria-hidden="true">
  <div class="logout-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteDialogTitle"
    style="width: min(400px, 95vw);">
    <h2 class="logout-title" id="deleteDialogTitle">
      <i class="fa-solid fa-triangle-exclamation" style="color: #ef4444; margin-right: 8px;"></i>Delete SIM Card?
    </h2>
    <p class="logout-text">
      Are you sure you want to remove the SIM card assigned to <strong id="deleteSimName"></strong>? This action cannot be undone.
    </p>
    <div class="logout-actions">
      <button class="logout-btn" type="button" onclick="closeDeleteDialog()">Cancel</button>
      <button class="logout-btn" type="button" id="deleteConfirmBtn" onclick="submitDelete()"
        style="background: #ef4444; color: #fff; border-color: #ef4444;">Yes, Delete</button>
    </div>
  </div>
</div>

<script id="simcards-data" type="application/json"><%- safeJson(jsonData) %></script>
<script id="employees-data" type="application/json"><%- safeJson(employees) %></script>
<script id="departments-data" type="application/json"><%- safeJson(departments) %></script>
<script src="https://unpkg.com/tabulator-tables@5.5.2/dist/js/tabulator.min.js"></script>
<script>
  const employeesData  = JSON.parse(document.getElementById("employees-data").textContent);
  const departmentsData = JSON.parse(document.getElementById("departments-data").textContent);
  const tableData     = JSON.parse(document.getElementById("simcards-data").textContent);

  // Unassigned SIM cards (free to assign) surface first in the list.
  tableData.sort((a, b) => (b.isUnassigned === true) - (a.isUnassigned === true));

  function renderSimCardStats() {
    const totalEl      = document.getElementById("stat-total");
    const unassignedEl = document.getElementById("stat-unassigned");
    const tracemateEl  = document.getElementById("stat-tracemate");
    const ubiEl        = document.getElementById("stat-ubi");
    const providerEl   = document.getElementById("simcard-provider-stats");
    if (!totalEl || !providerEl) return;

    totalEl.textContent      = tableData.length;
    unassignedEl.textContent = tableData.filter(s => s.isUnassigned).length;
    tracemateEl.textContent  = tableData.filter(s => s.tracementService === "YES").length;
    ubiEl.textContent        = tableData.filter(s => s.ubi === "YES").length;

    const providerCounts = {};
    tableData.forEach(s => {
      const provider = String(s.serviceProvider || "").trim().toUpperCase();
      if (!provider) return;
      providerCounts[provider] = (providerCounts[provider] || 0) + 1;
    });
    const providerEntries = Object.entries(providerCounts).sort((a, b) => b[1] - a[1]);

    providerEl.innerHTML = providerEntries
      .map(([provider, count]) => `<span class="simcard-highlight">${provider}: ${count}</span>`)
      .join("");
  }
  renderSimCardStats();

  const withTextFilter = col => ({ headerFilter: "input", headerFilterPlaceholder: "Search", ...col });

  new Tabulator("#master-table", {
    data:             tableData,
    height:           "auto",
    responsiveLayout: false,
    movableColumns:   true,
    placeholder:      "No SIM cards assigned yet.",
    rowFormatter(row) {
      const el = row.getElement();
      if (row.getData().isUnassigned) {
        el.style.backgroundColor = "#d4edda";
      }
    },
    columns: [
      {
        title: "Actions", field: "_id", width: 125, hozAlign: "center", headerSort: false,
        formatter(cell) {
          const s    = cell.getRow().getData();
          const wrap = document.createElement("div");
          wrap.style.cssText = "display:flex;gap:5px;justify-content:center;";

          const viewBtn = document.createElement("button");
          viewBtn.className = "loc-btn";
          viewBtn.style.background = "#044a78";
          viewBtn.title = "View";
          viewBtn.innerHTML = '<i class="fa-solid fa-eye"></i>';
          viewBtn.addEventListener("click", () => {
            window.location.href = `/fairtech/simcard/profile/${s._id}`;
          });

          const editBtn = document.createElement("button");
          editBtn.className = "loc-btn";
          editBtn.style.background = "#e67e22";
          editBtn.title = "Edit";
          editBtn.innerHTML = '<i class="fa-solid fa-pen-to-square"></i>';
          editBtn.addEventListener("click", () => openEditDialog(s));

          const delBtn = document.createElement("button");
          delBtn.className = "loc-btn";
          delBtn.style.background = "#d9534f";
          delBtn.title = "Delete";
          delBtn.innerHTML = '<i class="fa-solid fa-trash"></i>';
          delBtn.addEventListener("click", () => openDeleteDialog(s._id, s.employeeName));

          wrap.appendChild(viewBtn);
          wrap.appendChild(editBtn);
          wrap.appendChild(delBtn);
          return wrap;
        },
      },
      withTextFilter({ title: "Mobile Number", field: "mobileNumber", minWidth: 140, sorter: "string" }),
      withTextFilter({ title: "Department", field: "department", minWidth: 150, sorter: "string", formatter: cell => cell.getValue() || "-" }),
      withTextFilter({ title: "Employee Name", field: "employeeName", minWidth: 180, sorter: "string" }),
      withTextFilter({ title: "Service Provider", field: "serviceProvider", minWidth: 150, sorter: "string" }),
      {
        title: "Tracemate Service", field: "tracementService", width: 150, hozAlign: "center", sorter: "string",
        formatter: cell => cell.getValue() === "YES" ? "Yes" : "No",
        headerFilter: "select",
        headerFilterParams: { values: { "": "All", YES: "Yes", NO: "No" } },
      },
      {
        title: "UBI", field: "ubi", width: 110, hozAlign: "center", sorter: "string",
        formatter: cell => cell.getValue() === "YES" ? "Yes" : cell.getValue() === "NO" ? "No" : "-",
        headerFilter: "select",
        headerFilterParams: { values: { "": "All", YES: "Yes", NO: "No" } },
      },
    ],
  });

  /* ─────────────────────────────────────────
     Dialog helpers
  ───────────────────────────────────────── */
  const EMP_CHOICES_CONFIG   = { searchEnabled: true,  shouldSort: false, itemSelectText: "", searchPlaceholderValue: "Search employee..." };
  const SIMPLE_CHOICES_CONFIG = { searchEnabled: false, shouldSort: false, itemSelectText: "" };
  const OTHERS_VALUE = "OTHERS";
  const UNASSIGNED_VALUE = "UNASSIGNED";
  const PROVIDERS = ["AIRTEL", "JIO", "VI", "BSNL", "MTNL"];

  // Choices.js dropdowns are positioned absolute inside .choices, which sits
  // inside .dialog-body (overflow-y: auto for the scrollbar). That clips any
  // dropdown that opens past the visible scroll area. Pin it to the viewport
  // instead, computed off the wrapper's actual on-screen position, so it
  // always renders in full regardless of dialog scroll.
  function fixChoicesDropdownOverflow(sel) {
    sel.addEventListener("showDropdown", () => {
      const wrapper = sel.closest(".choices");
      const dropdown = wrapper?.querySelector(".choices__list--dropdown");
      if (!wrapper || !dropdown) return;
      // Chromium collapses a position:fixed box with overflow:hidden and an
      // explicit `top` (no `bottom`) to a 0-height auto box instead of sizing
      // to content, so the dropdown items render but are clipped to nothing.
      // Measure the natural height before repositioning and pin it explicitly.
      const naturalHeight = dropdown.getBoundingClientRect().height;
      const rect = wrapper.getBoundingClientRect();
      dropdown.style.position = "fixed";
      dropdown.style.left = `${rect.left}px`;
      dropdown.style.top = `${rect.bottom + 2}px`;
      dropdown.style.width = `${rect.width}px`;
      dropdown.style.height = `${naturalHeight}px`;
      dropdown.style.marginTop = "0";
    });
  }

  function buildEmployeeChoices(selectId, selectedId) {
    const sel = document.getElementById(selectId);
    sel.innerHTML = '<option value="">Select Employee</option>' +
      `<option value="${UNASSIGNED_VALUE}"${selectedId === UNASSIGNED_VALUE ? " selected" : ""}>UNASSIGNED</option>` +
      employeesData.map(emp =>
        `<option value="${emp._id}"${String(emp._id) === String(selectedId) ? " selected" : ""}>${emp.empName}</option>`
      ).join("") +
      `<option value="${OTHERS_VALUE}"${selectedId === OTHERS_VALUE ? " selected" : ""}>Others (Not in Employee List)</option>`;
    fixChoicesDropdownOverflow(sel);
    return new Choices(sel, EMP_CHOICES_CONFIG);
  }

  function buildProviderChoices(selectId, selectedValue) {
    const sel = document.getElementById(selectId);
    sel.innerHTML = '<option value="">Select Provider</option>' +
      PROVIDERS.map(p => `<option value="${p}"${p === selectedValue ? " selected" : ""}>${p}</option>`).join("") +
      `<option value="${OTHERS_VALUE}"${selectedValue === OTHERS_VALUE ? " selected" : ""}>Others (Specify)</option>`;
    fixChoicesDropdownOverflow(sel);
    return new Choices(sel, SIMPLE_CHOICES_CONFIG);
  }

  function buildDepartmentChoices(selectId, selectedValue) {
    const sel = document.getElementById(selectId);
    sel.innerHTML = '<option value="">Select Department</option>' +
      departmentsData.map(d => `<option value="${d}"${d === selectedValue ? " selected" : ""}>${d}</option>`).join("") +
      `<option value="${OTHERS_VALUE}"${selectedValue === OTHERS_VALUE ? " selected" : ""}>Others (Specify)</option>`;
    fixChoicesDropdownOverflow(sel);
    return new Choices(sel, EMP_CHOICES_CONFIG);
  }

  function buildTracementChoices(selectId, selectedValue) {
    const sel = document.getElementById(selectId);
    sel.innerHTML = '<option value="">Select</option>' +
      `<option value="YES"${selectedValue === "YES" ? " selected" : ""}>Yes</option>` +
      `<option value="NO"${selectedValue === "NO" ? " selected" : ""}>No</option>`;
    fixChoicesDropdownOverflow(sel);
    return new Choices(sel, SIMPLE_CHOICES_CONFIG);
  }

  function toggleManualNameField(groupId, inputId, show) {
    const group = document.getElementById(groupId);
    group.classList.toggle("hidden-field", !show);
    if (!show) document.getElementById(inputId).value = "";
  }

  function formatMobileNumber(inputElement) {
    let value = inputElement.value.replace(/\D/g, "");
    value = value.substring(0, 10);
    if (value.length > 5) {
      value = value.substring(0, 5) + " " + value.substring(5);
    }
    inputElement.value = value;
  }

  const MOBILE_ERROR_ID = { addMobileInput: "addSimError", editMobileInput: "editSimError" };

  ["addMobileInput", "editMobileInput"].forEach(id => {
    const input = document.getElementById(id);
    const errorId = MOBILE_ERROR_ID[id];
    input.addEventListener("input", () => {
      const rawDigits = input.value.replace(/\D/g, "");
      formatMobileNumber(input);
      if (rawDigits.length > 10) {
        showError(errorId, "Mobile number can have at most 10 digits — extra digits were removed.");
      } else {
        hideError(errorId);
      }
    });
    input.addEventListener("blur", () => {
      const digits = input.value.replace(/\D/g, "");
      if (digits.length > 0 && digits.length !== 10) {
        showError(errorId, `Mobile number must be exactly 10 digits (currently ${digits.length}).`);
      }
    });
  });

  document.getElementById("addMobileInput").addEventListener("input", () => {
    autoFillEmployeeFromMobile("addMobileInput", addEmpChoices, addDepartmentChoices, "addManualNameGroup", "addManualNameInput", "addDepartmentManualGroup", "addDepartmentManualInput");
  });

  function autoFillDepartment(employeeId, deptChoices, manualGroupId, manualInputId) {
    if (!employeeId || employeeId === OTHERS_VALUE || employeeId === UNASSIGNED_VALUE || !deptChoices) return;
    const emp = employeesData.find(e => String(e._id) === String(employeeId));
    if (!emp || !emp.empDept) return;
    const knownDept = departmentsData.includes(emp.empDept);
    deptChoices.setChoiceByValue(knownDept ? emp.empDept : OTHERS_VALUE);
    toggleManualNameField(manualGroupId, manualInputId, !knownDept);
    document.getElementById(manualInputId).value = knownDept ? "" : emp.empDept;
  }

  // Reverse lookup for the Add dialog: once the typed number matches an
  // employee's office mobile exactly, fill in their name and department so
  // the user doesn't have to pick them from the list too.
  function findEmployeeByOfficeMobile(digits) {
    if (digits.length !== 10) return null;
    return employeesData.find(e => String(e.empOfficeMob || "").replace(/\D/g, "") === digits) || null;
  }

  function autoFillEmployeeFromMobile(mobileInputId, empChoices, deptChoices, manualNameGroupId, manualNameInputId, manualDeptGroupId, manualDeptInputId) {
    if (!empChoices) return;
    const digits = document.getElementById(mobileInputId).value.replace(/\D/g, "");
    const emp = findEmployeeByOfficeMobile(digits);
    if (!emp) return;
    empChoices.setChoiceByValue(String(emp._id));
    toggleManualNameField(manualNameGroupId, manualNameInputId, false);
    autoFillDepartment(String(emp._id), deptChoices, manualDeptGroupId, manualDeptInputId);
  }

  function openModal(id)  { const d = document.getElementById(id); d.classList.add("show");    d.setAttribute("aria-hidden", "false"); }
  function closeModal(id) { const d = document.getElementById(id); d.classList.remove("show"); d.setAttribute("aria-hidden", "true");  }
  function showError(elId, msg) { const el = document.getElementById(elId); el.textContent = msg; el.style.display = "block"; }
  function hideError(elId)      { document.getElementById(elId).style.display = "none"; }
  function setLoading(btnId, loading) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.disabled = loading;
    btn.style.opacity = loading ? "0.7" : "";
  }

  document.addEventListener("keydown", e => {
    if (e.key !== "Escape") return;
    ["addDialog", "editDialog", "deleteDialog"].forEach(id => {
      if (document.getElementById(id).classList.contains("show")) closeModal(id);
    });
  });

  /* ─── ADD ─── */
  let addEmpChoices = null, addTracementChoices = null, addUbiChoices = null, addProviderChoices = null, addDepartmentChoices = null;

  function openAddDialog() {
    if (addEmpChoices)        { addEmpChoices.destroy();        addEmpChoices = null; }
    if (addTracementChoices)  { addTracementChoices.destroy();  addTracementChoices = null; }
    if (addUbiChoices)        { addUbiChoices.destroy();        addUbiChoices = null; }
    if (addProviderChoices)   { addProviderChoices.destroy();   addProviderChoices = null; }
    if (addDepartmentChoices) { addDepartmentChoices.destroy(); addDepartmentChoices = null; }
    addEmpChoices        = buildEmployeeChoices("addEmployeeSelect", "");
    addTracementChoices  = buildTracementChoices("addTracementSelect", "");
    addUbiChoices        = buildTracementChoices("addUbiSelect", "");
    addProviderChoices   = buildProviderChoices("addProviderSelect", "");
    addDepartmentChoices = buildDepartmentChoices("addDepartmentSelect", "");
    toggleManualNameField("addManualNameGroup", "addManualNameInput", false);
    toggleManualNameField("addProviderManualGroup", "addProviderManualInput", false);
    toggleManualNameField("addDepartmentManualGroup", "addDepartmentManualInput", false);
    document.getElementById("addMobileInput").value = "";
    hideError("addSimError");

    document.getElementById("addEmployeeSelect").addEventListener("change", (e) => {
      toggleManualNameField("addManualNameGroup", "addManualNameInput", e.target.value === OTHERS_VALUE);
      // Selecting an employee here is for assigning a (possibly brand-new)
      // number to them, not for looking up their existing one — don't
      // clobber whatever the user has already typed into the mobile field.
      autoFillDepartment(e.target.value, addDepartmentChoices, "addDepartmentManualGroup", "addDepartmentManualInput");
    });
    document.getElementById("addProviderSelect").addEventListener("change", (e) => {
      toggleManualNameField("addProviderManualGroup", "addProviderManualInput", e.target.value === OTHERS_VALUE);
    });
    document.getElementById("addDepartmentSelect").addEventListener("change", (e) => {
      toggleManualNameField("addDepartmentManualGroup", "addDepartmentManualInput", e.target.value === OTHERS_VALUE);
    });

    openModal("addDialog");
  }
  function closeAddDialog() { closeModal("addDialog"); }

  async function submitAdd() {
    const employeeId          = addEmpChoices?.getValue(true)       || "";
    const employeeManualName  = document.getElementById("addManualNameInput").value.trim();
    const departmentSelect    = addDepartmentChoices?.getValue(true) || "";
    const departmentManual    = document.getElementById("addDepartmentManualInput").value.trim();
    const department          = departmentSelect === OTHERS_VALUE ? departmentManual : departmentSelect;
    const mobileNumber        = document.getElementById("addMobileInput").value.trim();
    const providerSelect      = addProviderChoices?.getValue(true) || "";
    const providerManualName  = document.getElementById("addProviderManualInput").value.trim();
    const serviceProvider     = providerSelect === OTHERS_VALUE ? providerManualName : providerSelect;
    const tracementService    = addTracementChoices?.getValue(true) || "";
    const ubi                 = addUbiChoices?.getValue(true) || "";

    if (!employeeId) { showError("addSimError", "Please select an employee."); return; }
    if (employeeId === OTHERS_VALUE && !employeeManualName) { showError("addSimError", "Please enter the employee name."); return; }
    if (departmentSelect === OTHERS_VALUE && !departmentManual) { showError("addSimError", "Please enter the department."); return; }
    if (!mobileNumber) { showError("addSimError", "Mobile number is required."); return; }
    if (mobileNumber.replace(/\D/g, "").length !== 10) { showError("addSimError", "Mobile number must be exactly 10 digits."); return; }
    if (!providerSelect) { showError("addSimError", "Please select a service provider."); return; }
    if (providerSelect === OTHERS_VALUE && !providerManualName) { showError("addSimError", "Please enter the service provider."); return; }
    if (!tracementService) { showError("addSimError", "Please select tracemate service."); return; }
    if (!ubi) { showError("addSimError", "Please select UBI."); return; }

    hideError("addSimError");
    setLoading("addSubmitBtn", true);
    try {
      const res  = await fetch("/fairtech/simcard/create", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ employeeId, employeeManualName, department, mobileNumber, serviceProvider, tracementService, ubi }),
      });
      const data = await res.json();
      if (data.success) { window.location.href = data.redirect || "/fairtech/simcard/view"; }
      else              { showError("addSimError", data.message || "Failed to assign SIM card."); }
    } catch { showError("addSimError", "Server error. Please try again."); }
    finally  { setLoading("addSubmitBtn", false); }
  }

  /* ─── EDIT ─── */
  let editId = null, editEmpChoices = null, editTracementChoices = null, editUbiChoices = null, editProviderChoices = null, editDepartmentChoices = null;

  function openEditDialog(row) {
    editId = row._id;
    if (editEmpChoices)        { editEmpChoices.destroy();        editEmpChoices = null; }
    if (editTracementChoices)  { editTracementChoices.destroy();  editTracementChoices = null; }
    if (editUbiChoices)        { editUbiChoices.destroy();        editUbiChoices = null; }
    if (editProviderChoices)   { editProviderChoices.destroy();   editProviderChoices = null; }
    if (editDepartmentChoices) { editDepartmentChoices.destroy(); editDepartmentChoices = null; }
    editEmpChoices       = buildEmployeeChoices("editEmployeeSelect", row.employeeId);
    editTracementChoices = buildTracementChoices("editTracementSelect", row.tracementService);
    editUbiChoices       = buildTracementChoices("editUbiSelect", row.ubi);

    const knownProvider = PROVIDERS.includes(row.serviceProvider);
    editProviderChoices = buildProviderChoices("editProviderSelect", knownProvider ? row.serviceProvider : OTHERS_VALUE);

    const knownDepartment = !!row.department && departmentsData.includes(row.department);
    const departmentSelectValue = !row.department ? "" : (knownDepartment ? row.department : OTHERS_VALUE);
    editDepartmentChoices = buildDepartmentChoices("editDepartmentSelect", departmentSelectValue);

    toggleManualNameField("editManualNameGroup", "editManualNameInput", row.isOthers);
    if (row.isOthers) document.getElementById("editManualNameInput").value = row.employeeName;

    toggleManualNameField("editProviderManualGroup", "editProviderManualInput", !knownProvider);
    if (!knownProvider) document.getElementById("editProviderManualInput").value = row.serviceProvider;

    toggleManualNameField("editDepartmentManualGroup", "editDepartmentManualInput", !!row.department && !knownDepartment);
    if (row.department && !knownDepartment) document.getElementById("editDepartmentManualInput").value = row.department;

    document.getElementById("editMobileInput").value = row.mobileNumber;
    formatMobileNumber(document.getElementById("editMobileInput"));
    hideError("editSimError");

    document.getElementById("editEmployeeSelect").addEventListener("change", (e) => {
      toggleManualNameField("editManualNameGroup", "editManualNameInput", e.target.value === OTHERS_VALUE);
      // Editing reassigns this SIM card's existing number to a different
      // employee — the number itself must stay put, unlike Add where it's
      // a fresh assignment and prefilling from the employee's office mobile
      // is a helpful default.
      autoFillDepartment(e.target.value, editDepartmentChoices, "editDepartmentManualGroup", "editDepartmentManualInput");
    });
    document.getElementById("editProviderSelect").addEventListener("change", (e) => {
      toggleManualNameField("editProviderManualGroup", "editProviderManualInput", e.target.value === OTHERS_VALUE);
    });
    document.getElementById("editDepartmentSelect").addEventListener("change", (e) => {
      toggleManualNameField("editDepartmentManualGroup", "editDepartmentManualInput", e.target.value === OTHERS_VALUE);
    });

    openModal("editDialog");
  }
  function closeEditDialog() { closeModal("editDialog"); editId = null; }

  async function submitEdit() {
    const employeeId          = editEmpChoices?.getValue(true)       || "";
    const employeeManualName  = document.getElementById("editManualNameInput").value.trim();
    const departmentSelect    = editDepartmentChoices?.getValue(true) || "";
    const departmentManual    = document.getElementById("editDepartmentManualInput").value.trim();
    const department          = departmentSelect === OTHERS_VALUE ? departmentManual : departmentSelect;
    const mobileNumber        = document.getElementById("editMobileInput").value.trim();
    const providerSelect      = editProviderChoices?.getValue(true) || "";
    const providerManualName  = document.getElementById("editProviderManualInput").value.trim();
    const serviceProvider     = providerSelect === OTHERS_VALUE ? providerManualName : providerSelect;
    const tracementService    = editTracementChoices?.getValue(true) || "";
    const ubi                 = editUbiChoices?.getValue(true) || "";

    if (!employeeId) { showError("editSimError", "Please select an employee."); return; }
    if (employeeId === OTHERS_VALUE && !employeeManualName) { showError("editSimError", "Please enter the employee name."); return; }
    if (departmentSelect === OTHERS_VALUE && !departmentManual) { showError("editSimError", "Please enter the department."); return; }
    if (!mobileNumber) { showError("editSimError", "Mobile number is required."); return; }
    if (mobileNumber.replace(/\D/g, "").length !== 10) { showError("editSimError", "Mobile number must be exactly 10 digits."); return; }
    if (!providerSelect) { showError("editSimError", "Please select a service provider."); return; }
    if (providerSelect === OTHERS_VALUE && !providerManualName) { showError("editSimError", "Please enter the service provider."); return; }
    if (!tracementService) { showError("editSimError", "Please select tracemate service."); return; }
    if (!ubi) { showError("editSimError", "Please select UBI."); return; }
    if (!editId) return;

    hideError("editSimError");
    setLoading("editSubmitBtn", true);
    try {
      const res  = await fetch(`/fairtech/simcard/api/${editId}`, {
        method: "PUT", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ employeeId, employeeManualName, department, mobileNumber, serviceProvider, tracementService, ubi }),
      });
      const data = await res.json();
      if (data.success) { window.location.reload(); }
      else              { showError("editSimError", data.message || "Failed to update SIM card."); }
    } catch { showError("editSimError", "Server error. Please try again."); }
    finally  { setLoading("editSubmitBtn", false); }
  }

  /* ─── DELETE ─── */
  let deleteId = null;

  function openDeleteDialog(id, name) {
    deleteId = id;
    document.getElementById("deleteSimName").textContent = name;
    openModal("deleteDialog");
  }
  function closeDeleteDialog() { closeModal("deleteDialog"); deleteId = null; }

  async function submitDelete() {
    if (!deleteId) return;
    setLoading("deleteConfirmBtn", true);
    try {
      const res  = await fetch(`/fairtech/simcard/api/${deleteId}`, { method: "DELETE" });
      const data = await res.json();
      if (data.success) { window.location.reload(); }
      else              { closeDeleteDialog(); alert(data.message || "Failed to delete SIM card."); }
    } catch { closeDeleteDialog(); alert("Error deleting SIM card."); }
    finally  { setLoading("deleteConfirmBtn", false); }
  }
</script>
